в”Ӯ +          if (!isa<VectorType>(NotCond->getType()))                                       в”Ӯ
в”Ӯ +            NotCond = Builder.CreateVectorSplat(VecTy->getElementCount(), NotCond);       в”Ӯ
в”Ӯ +        return BinaryOperator::Create(                                                    в”Ӯ
в”Ӯ +            Pred == ICmpInst::ICMP_EQ ? Instruction::And : Instruction::Or, Cmp,          в”Ӯ
в”Ӯ +            NotCond);                                                                     в”Ӯ
