в”Ӯ The analysis identified a type mismatch in an `instcombine` optimization. The code         в”Ӯ
в”Ӯ attempted to create a binary operation between a vector and a scalar, leading to an        в”Ӯ
в”Ӯ assertion failure. The fix involves splatting the scalar condition of a `select`           в”Ӯ
в”Ӯ instruction into a vector to match the type of the other operands before creating the new  в”Ӯ
в”Ӯ `or` or `and` instruction. This is necessary for two similar optimization patterns. The    в”Ӯ
в”Ӯ changes have been implemented and verified.                                                в”Ӯ
в”Ӯ                                                                                            в”Ӯ
в”Ӯ Here is the final patch:                                                                   в”Ӯ
в”Ӯ                                                                                            в”Ӯ
в”Ӯ ```diff                                                                                    в”Ӯ
в”Ӯ --- a/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp                              в”Ӯ
в”Ӯ +++ b/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp                              в”Ӯ
в”Ӯ @@ -3628,11 +3628,15 @@                                                                    в”Ӯ
в”Ӯ        if (Pred == ICmpInst::ICMP_EQ                                                       в”Ӯ
в”Ӯ                ? (match(TV, m_Zero()) && isKnownNonZero(FV, Q))                            в”Ӯ
в”Ӯ                : (match(FV, m_Zero()) && isKnownNonZero(TV, Q))) {                         в”Ӯ
в”Ӯ -        Value *Cmp = Builder.CreateICmp(                                                  в”Ӯ
в”Ӯ -            Pred, Other, Constant::getNullValue(Other->getType()));                       в”Ӯ
в”Ӯ -        return BinaryOperator::Create(                                                    в”Ӯ
в”Ӯ -            Pred == ICmpInst::ICMP_EQ ? Instruction::And : Instruction::Or, Cmp,          в”Ӯ
в”Ӯ -            Cond);                                                                        в”Ӯ
в”Ӯ +        Value *Cmp =                                                                      в”Ӯ
в”Ӯ +            Builder.CreateICmp(Pred, Other,                                               в”Ӯ
в”Ӯ +                               Constant::getNullValue(Other->getType()));                 в”Ӯ
в”Ӯ +        if (auto *VecTy = dyn_cast<VectorType>(Cmp->getType()))                           в”Ӯ
в”Ӯ +          if (!isa<VectorType>(Cond->getType()))                                          в”Ӯ
в”Ӯ +            Cond = Builder.CreateVectorSplat(VecTy->getElementCount(), Cond);             в”Ӯ
в”Ӯ +        return BinaryOperator::Create(                                                    в”Ӯ
в”Ӯ +            Pred == ICmpInst::ICMP_EQ ? Instruction::And : Instruction::Or, Cmp,          в”Ӯ
в”Ӯ +            Cond);                                                                        в”Ӯ
в”Ӯ        }                                                                                   в”Ӯ
в”Ӯ        // Harder case is if eq/ne matches whether 0 is falseval/trueval. In this           в”Ӯ
в”Ӯ        // case we need to invert the select condition so we need to be careful to          в”Ӯ
в”Ӯ @@ -3651,11 +3655,15 @@                                                                    в”Ӯ
в”Ӯ            (Pred == ICmpInst::ICMP_EQ                                                      в”Ӯ
в”Ӯ                 ? (match(FV, m_Zero()) && isKnownNonZero(TV, Q))                           в”Ӯ
