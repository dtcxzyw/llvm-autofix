в”Ӯ     "old": "      const SimplifyQuery Q = SQ.getWithInstruction(&Cmp);",                   в”Ӯ
в”Ӯ     "new": "      // Do not transform if the select has a scalar condition but vector      в”Ӯ
в”Ӯ values.\n      // This is usually not a performance win and can cause crashes if we try    в”Ӯ
