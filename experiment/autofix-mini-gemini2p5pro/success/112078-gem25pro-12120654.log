│ if (Range->getLower().isStrictlyPositive())\n                │
│ return nullptr;\n    }\n    return                           │
│ Builder.CreateICmpULT(CtPop,                                 │
│ ConstantInt::get(CtPop->getType(), 2));\n  }"                │
