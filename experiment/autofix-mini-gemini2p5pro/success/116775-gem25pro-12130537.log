│ Builder.CreateGEP(\n                  GEP->getSourceElementType(), InnerPtr,\n             │
│ ConstantInt::get(GEPIndexType, MaskedGEPIndex),\n                  GEP->getName(),         │
│ GEP->isInBounds());\n\n              replaceOperand(*I, 0, MaskedGEP);",                   │
