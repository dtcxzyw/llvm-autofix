b/llvm/lib/Transforms/Vectorize/VectorCombine.cpp\n@@ -1037,6 +1037,11 @@ bool
VectorCombine::foldExtractedCmps(Instruction &I) {\n   if (!I.isBinaryOp() ||
!I.getType()->isIntegerTy(1))\n     return false;\n \n+  // The semantics of 'ashr i1' are not
