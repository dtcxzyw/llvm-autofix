Final Patch
-----------
diff --git a/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
b/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
index d824c40c401d..ae00b8d4ddfc 100644
--- a/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
+++ b/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
@@ -9756,7 +9756,8 @@ class BoUpSLP::ShuffleCostEstimator : public BaseShuffleAnalysis {
     // FIXME: this must be moved to TTI for better estimation.
     unsigned EltsPerVector = getPartNumElems(VL.size(), NumParts);
     auto CheckPerRegistersShuffle = [&](MutableArrayRef<int> Mask,
-                                        SmallVectorImpl<unsigned> &Indices)
+                                        SmallVectorImpl<unsigned> &Indices,
+                                        ArrayRef<Value *> VL, unsigned Part)
         -> std::optional<TTI::ShuffleKind> {
       if (NumElts <= EltsPerVector)
         return std::nullopt;
@@ -9777,6 +9778,14 @@ class BoUpSLP::ShuffleCostEstimator : public BaseShuffleAnalysis {
       for (auto [Pos, I] : enumerate(Mask)) {
         if (I == PoisonMaskElem)
           continue;
+        // FIXME: Support different vector sizes.
+        if (auto *EE = dyn_cast<ExtractElementInst>(
+                VL[Part * EltsPerVector + Pos])) {
+          if (auto *VTy = dyn_cast<FixedVectorType>(EE->getVectorOperandType())) {
+            if (VTy->getNumElements() != NumElts)
+              return std::nullopt;
+          }
+        }
         int Idx = I - OffsetReg0;
         int RegId =
             (Idx / NumElts) * NumParts + (Idx % NumElts) / EltsPerVector;
@@ -9824,7 +9833,7 @@ class BoUpSLP::ShuffleCostEstimator : public BaseShuffleAnalysis {
       copy(MaskSlice, SubMask.begin());
       SmallVector<unsigned, 2> Indices;
       std::optional<TTI::ShuffleKind> RegShuffleKind =
-          CheckPerRegistersShuffle(SubMask, Indices);
+          CheckPerRegistersShuffle(SubMask, Indices, VL, Part);
       if (!RegShuffleKind) {
         if (*ShuffleKinds[Part] != TTI::SK_PermuteSingleSrc ||
             !ShuffleVectorInst::isIdentityMask(

