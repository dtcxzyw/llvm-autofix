Final Patch
-----------
diff --git a/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
b/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
index 71aca3be9e5d..f7b963b42c31 100644
--- a/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
+++ b/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
@@ -3320,10 +3320,18 @@ VPFirstOrderRecurrencePHIRecipe::computeCost(ElementCount VF,
   if (VF.isScalable() && VF.getKnownMinValue() == 1)
     return InstructionCost::getInvalid();

+  if (VF.isScalar())
+    return 0;
+
+  Type *ScalarTy = Ctx.Types.inferScalarType(this->getVPSingleValue());
+  // Shuffling non-power-of-2 integer types is not supported.
+  if (auto *IntTy = dyn_cast<IntegerType>(ScalarTy))
+    if (!isPowerOf2_32(IntTy->getBitWidth()))
+      return InstructionCost::getInvalid();
+
   SmallVector<int> Mask(VF.getKnownMinValue());
   std::iota(Mask.begin(), Mask.end(), VF.getKnownMinValue() - 1);
-  Type *VectorTy =
-      ToVectorTy(Ctx.Types.inferScalarType(this->getVPSingleValue()), VF);
+  Type *VectorTy = ToVectorTy(ScalarTy, VF);

   TTI::TargetCostKind CostKind = TTI::TCK_RecipThroughput;
   return Ctx.TTI.getShuffleCost(TargetTransformInfo::SK_Splice,

