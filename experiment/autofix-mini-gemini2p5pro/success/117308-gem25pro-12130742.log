│ #30 0x00007fbb088511ca (/usr/lib/x86_64-linux-gnu/libc.so.6+0x2a1ca)                       │
│ #31 0x00007fbb0885128b __libc_start_main (/usr/lib/x86_64-linux-gnu/libc.so.6+0x2a28b)     │
