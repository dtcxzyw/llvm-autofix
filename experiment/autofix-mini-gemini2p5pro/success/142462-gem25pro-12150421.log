│ 629 /// A simple and fast domtree-based CSE pass.            │
│ 630 ///                                                      │
│ 631 /// This pass does a simple depth-first walk over the    │
│ dominator tree,                                              │
│ 632 /// eliminating trivially redundant instructions and     │
│ using instsimplify to                                        │
│ 633 /// canonicalize things as it goes. It is intended to be │
│ fast and catch obvious                                       │
│ 634 /// cases so that instcombine and other passes are more  │
│ effective. It is                                             │
│ 635 /// expected that a later pass of GVN will catch the     │
│ interesting/hard cases.                                      │
│ 636 class EarlyCSE {                                         │
│ 637 public:                                                  │
│ 638   const TargetLibraryInfo &TLI;                          │
│ 639   const TargetTransformInfo &TTI;                        │
│ 640   DominatorTree &DT;                                     │
│ 641   AssumptionCache &AC;                                   │
│ 642   const SimplifyQuery SQ;                                │
│ 643   MemorySSA *MSSA;                                       │
│ 644   std::unique_ptr<MemorySSAUpdater> MSSAUpdater;         │
│ 645                                                          │
│ 646   using AllocatorTy =                                    │
│ 647       RecyclingAllocator<BumpPtrAllocator,               │
│ 648                          ScopedHashTableVal<SimpleValue, │
│ Value *>>;                                                   │
│ 649   using ScopedHTType =                                   │
│ 650       ScopedHashTable<SimpleValue, Value *,              │
│ DenseMapInfo<SimpleValue>,                                   │
│ 651                       AllocatorTy>;                      │
│ 652                                                          │
│ 653   /// A scoped hash table of the current values of all   │
│ of our simple                                                │
│ 654   /// scalar expressions.                                │
│ 655   ///                                                    │
│ 656   /// As we walk down the domtree, we look to see if     │
│ instructions are in this:                                    │
│ 657   /// if so, we replace them with what we find,          │
│ otherwise we insert them so                                  │
