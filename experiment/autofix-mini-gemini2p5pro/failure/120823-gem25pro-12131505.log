│     "new": "      if (TE->isDiamondMerge(OpIdx) && TE->getAltOp(OpIdx).Ty &&\n             │
│ TE->getAltOp(OpIdx).Ty->getScalarSizeInBits() ==\n                                         │
│ ScalarTy->getScalarSizeInBits()) {"                                                        │
│   }                                                                                        │
