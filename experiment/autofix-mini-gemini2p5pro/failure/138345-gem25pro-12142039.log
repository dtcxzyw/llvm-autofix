│  94 static bool isMemoryInst(const Instruction *I) {         │
│  95   return isa<LoadInst>(I) || isa<StoreInst>(I) ||        │
│  96          (isa<InvokeInst>(I) &&                          │
│ !cast<InvokeInst>(I)->doesNotAccessMemory()) ||              │
