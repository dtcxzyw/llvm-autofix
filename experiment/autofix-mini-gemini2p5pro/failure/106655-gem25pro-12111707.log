│ 8277     SmallVector<int> NewMask(Mask);                                                   │
│ 8278     bool IsIdentity = peekThroughShuffles(V1, NewMask, /*SinglePermute=*/true);       │
│ 8279     assert(V1 && "Expected non-null value after looking through shuffles.");          │
│ 8280                                                                                       │
