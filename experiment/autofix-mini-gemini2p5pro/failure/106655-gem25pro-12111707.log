│                                                 ArrayRef<int> Mask,                        │
│                                                 ShuffleIRBuilder &Builder) {               │
│   // TODO: We can optimize this better.                                                    │
│   if (Mask.empty())                                                                        │
│     return nullptr;                                                                        │
│                                                                                            │
│   // Don't try to optimize non-identity shuffles here.                                     │
│   // The ShuffleInstructionBuilder has more powerful logic for this.                       │
│   if (V1->getType()->getVectorNumElements() != Mask.size() ||                              │
│       !isIdentityMask(Mask, cast<FixedVectorType>(V1->getType()),                          │
│                       /*AllowUndefs*/ true))                                               │
│     return nullptr;                                                                        │
│                                                                                            │
│   SmallVector<int, 16> NewMask;                                                            │
│   Value *NewV = peekThroughShuffles(V1, NewMask);                                          │
│ ```                                                                                        │
│                                                                                            │
