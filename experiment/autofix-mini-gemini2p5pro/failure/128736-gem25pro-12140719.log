│ #22 0x00007fdbe5bcf1ca (/usr/lib/x86_64-linux-gnu/libc.so.6+0x2a1ca)                       │
│ #23 0x00007fdbe5bcf28b __libc_start_main (/usr/lib/x86_64-linux-gnu/libc.so.6+0x2a28b)     │
