│     "old": "    for (unsigned Opc : CastOpcodes) {",                                       │
│     "new": "    for (unsigned Opc : CastOpcodes) {\n      // Do not change the opcode of   │
│ the cast if it is used by a freeze.\n      // Freeze does not allow to change the cast's   │
│ opcode.\n      if (isa<CastInst>(S) &&\n          any_of(S->users(),\n                     │
│ [](const User *U) { return isa<FreezeInst>(U); }))\n        return false;"                 │
│   }                                                                                        │
│ }                                                                                          │
│ </tool_call>                                                                               │
