│             if (Pred == ICmpInst::ICMP_EQ && match(RHS, m_Zero()))                         │
│               return CmpInst::Create(Instruction::ICmp, ICmpInst::ICMP_UGT, X, Y);         │
│             if (Pred == ICmpInst::ICMP_NE && match(RHS, m_Zero()))                         │
│               return CmpInst::Create(Instruction::ICmp, ICmpInst::ICMP_ULE, X, Y);         │
│           }                                                                                │
│         }                                                                                  │
│       }                                                                                    │
│     }                                                                                      │
│   }                                                                                        │
│ ```                                                                                        │
│                                                                                            │
