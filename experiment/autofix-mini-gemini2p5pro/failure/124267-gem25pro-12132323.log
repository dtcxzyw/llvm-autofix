│   if (auto *SI = dyn_cast<ICmpInst>(LHS->getOperand(0))) {                                 │
│     if (SI->getPredicate() == ICmpInst::ICMP_SAMESIGN) {                                   │
│       if (auto *Sub = dyn_cast<BinaryOperator>(SI->getOperand(0))) {                       │
│         if (Sub->getOpcode() == Instruction::Sub) {                                        │
│           Value *X = Sub->getOperand(0);                                                   │
│           Value *Y = Sub->getOperand(1);                                                   │
