│ 198           : iterator_adaptor_base(BaseI), E(E) {                                       │
│ 199         while (I != E && !*I)                                                          │
│ 200           ++I;                                                                         │
│ 201       }                                                                                │
│ 202                                                                                        │
│ 203     public:                                                                            │
│ 204       iterator() = default;                                                            │
│ 205                                                                                        │
│ 206       using iterator_adaptor_base::operator++;                                         │
│ 207       iterator &operator++() {                                                         │
