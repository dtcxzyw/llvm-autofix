│ "new": "BasicBlock *BoUpSLP::getInsertBlock(const PHINode *PN,\n                           │
│ ArrayRef<Value *> Values) const {\n  // The insertion point is the predecessor basic       │
│ block. All values in `Values`\n  // are incoming values for one predecessor of PN. Find    │
│ the predecessor block\n  // and return it.\n  for (Value *V : Values) {\n    if (auto *I = │
│ dyn_cast<Instruction>(V)) {\n      // The incoming block for a PHI may be an edge from a   │
│ switch, which can\n      // be a critical edge. We must insert in the predecessor block,   │
│ not a\n      // common dominator, to ensure the value is available.\n      for (unsigned i │
│ = 0, e = PN->getNumIncomingValues(); i != e; ++i)\n        if (PN->getIncomingValue(i) ==  │
│ V)\n          return PN->getIncomingBlock(i);\n      // The value might be an instruction  │
│ that is not a direct incoming value\n      // but is in the same block as one. This can    │
│ happen with casts.\n      return I->getParent();\n    }\n  }\n\n  // If all values are     │
│ constants, we can insert anywhere that dominates the PHI.\n  // The PHI's parent block is  │
│ a safe and convenient choice.\n  return PN->getParent();\n}"})                             │
