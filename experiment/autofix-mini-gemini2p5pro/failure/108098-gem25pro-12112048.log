│ 236 /// VPIteration represents a single point in the iteration space of the output         │
│ 237 /// (vectorized and/or unrolled) IR loop.                                              │
│ 238 struct VPIteration {                                                                   │
│ 239   /// in [0..UF)                                                                       │
│ 240   unsigned Part;                                                                       │
│ 241                                                                                        │
│ 242   VPLane Lane;                                                                         │
│ 243                                                                                        │
