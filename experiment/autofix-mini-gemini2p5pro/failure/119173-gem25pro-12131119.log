│ 474 ///          ...                                                                       │
│ 475 ///        }                                                                           │
│ 476 ///                                                                                    │
│ 477 ///      An interleaved store group of factor 4:                                       │
│ 478 ///        for (unsigned i = 0; i < 1024; i+=4) {                                      │
