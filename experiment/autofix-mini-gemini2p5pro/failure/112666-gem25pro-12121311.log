│ 511 #endif                                                                                 │
│ 512                                                                                        │
│ 513   // No luck. Try negating it for real.                                                │
│ 514   Value *NegatedV = visitImpl(V, IsNSW, Depth);                                        │
│ 515   // And cache the (real) result for the future.                                       │
│ 516   NegationsCache[V] = NegatedV;                                                        │
│ 517                                                                                        │
│ 518   return NegatedV;                                                                     │
│ 519 }                                                                                      │
│ 520                                                                                        │
│                                                                                            │
│ ```                                                                                        │
