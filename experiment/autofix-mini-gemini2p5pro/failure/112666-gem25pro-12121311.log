│ 140                                 /*HasNSW=*/false);                                     │
│ 141                                                                                        │
│ 142   // If we have a non-instruction, then give up.                                       │
│ 143   if (!isa<Instruction>(V))                                                            │
│ 144     return nullptr;                                                                    │
