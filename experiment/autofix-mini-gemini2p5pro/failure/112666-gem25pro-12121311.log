│ 171   case Instruction::Xor:                                                               │
│ 172     // `not` is always negatible.                                                      │
│ 173     if (match(I, m_Not(m_Value(X))))                                                   │
│ 174       return Builder.CreateAdd(X, ConstantInt::get(X->getType(), 1),                   │
