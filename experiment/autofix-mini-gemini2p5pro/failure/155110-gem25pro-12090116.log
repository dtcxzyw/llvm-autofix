│ 237                                                                                     │
│ 238   Type *ScalarTy = Scalar->getType();                                               │
│ 239   uint64_t ScalarSize = ScalarTy->getPrimitiveSizeInBits();                         │
│ 240   unsigned MinVectorSize = TTI.getMinVectorRegisterBitWidth();                      │
│ 241                                                                                     │
│ 242   // Check safety of replacing the scalar load with a larger vector load.           │
│ 243   // We use minimal alignment (maximum flexibility) because we only care about      │
│ 244   // the dereferenceable region. When calculating cost and creating a new op,       │
