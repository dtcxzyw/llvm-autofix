│ 221   // Match insert into fixed vector of scalar value.                                │
│ 222   // TODO: Handle non-zero insert index.                                            │
│ 223   Value *Scalar;                                                                    │
│ 224   if (!match(&I,                                                                    │
│ 225              m_InsertElt(m_Poison(), m_OneUse(m_Value(Scalar)), m_ZeroInt())))      │
│ 226     return false;                                                                   │
│ 227                                                                                     │
│ 228   // Optionally match an extract from another vector.                               │
│ 229   Value *X;                                                                         │
│ 230   bool HasExtract = match(Scalar, m_ExtractElt(m_Value(X), m_ZeroInt()));           │
│ 231   if (!HasExtract)                                                                  │
│ 232     X = Scalar;                                                                     │
│ 233                                                                                     │
│ 234   auto *Load = dyn_cast<LoadInst>(X);                                               │
