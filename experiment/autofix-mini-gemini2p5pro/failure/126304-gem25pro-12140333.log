│         Order[Idx] = Idx;                                                                  │
│     return;                                                                                │
│   }                                                                                        │
│   SmallBitVector UsedIndices2(Sz);                                                         │
│   for (unsigned Idx : seq<unsigned>(0, Sz)) {                                              │
│     if (SecondaryOrder[Idx] != Sz)                                                         │
│       UsedIndices2.set(SecondaryOrder[Idx]);                                               │
│   }                                                                                        │
│   for (unsigned Idx : seq<unsigned>(0, Sz)) {                                              │
│     if (Order[Idx] == Sz) {                                                                │
