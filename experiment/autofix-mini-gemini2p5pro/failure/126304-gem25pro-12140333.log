│ // We have two orders, where the secondary order might be empty.                           │
│ // The orders are permutations of {0, ..., Sz-1} plus the special value Sz                 │
│ // which marks an undef lane.                                                              │
│ // We want to combine them into a single order, where the values from the                  │
│ // primary order have precedence.                                                          │
│ // For the undef lanes in the primary order, we take the values from the                   │
│ // secondary order. If the secondary order is empty, we fill the undef lanes               │
│ // with the indices of the lanes themselves.                                               │
│ // E.g., Order = {1, Sz, 0}, SecondaryOrder = {Sz, 2, Sz}                                  │
│ // --> {1, 2, 0}                                                                           │
│ // E.g., Order = {1, Sz, 0}, SecondaryOrder = {}                                           │
│ // --> {1, 1, 0} -> WRONG, should be {1, 2, 0} with 2 taken from the identity              │
│ // E.g., Order = {1, Sz, 0}, SecondaryOrder = {}                                           │
│ // --> {1, 2, 0} with 2 taken from the identity, wait, the second lane is undef            │
│ // so it should be {1, 1, 0}. No, the second lane is at index 1, so it should              │
│ // be {1, 1, 0}.                                                                           │
│ // Let's trace:                                                                            │
│ // Order = {1, Sz, 0}, Sz = 3                                                              │
│ // UsedIndices = {T, F, T}                                                                 │
│ // Idx = 1, Order[1] = Sz. UsedIndices.test(1) = F. Order[1] = 1.                          │
│ // Order is now {1, 1, 0}.                                                                 │
│ static void combineOrders(MutableArrayRef<unsigned> Order,                                 │
│                           ArrayRef<unsigned> SecondaryOrder) {                             │
