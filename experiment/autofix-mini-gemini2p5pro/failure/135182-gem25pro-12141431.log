│   "args": {                                                                                │
│     "file": "llvm/lib/Analysis/ScalarEvolution.cpp",                                       │
│     "old": "case scConstant:\n    // If the type of the constant is smaller than the       │
│ pointer size, it may be\n    // that the calculation needs to be done in the pointer-sized │
│ integer type.\n    if (getType()->getScalarSizeInBits() <\n                                │
│ SE.getDataLayout().getPointerSizeInBits(0)) {\n      // The only context in which we can   │
│ currently usefully do this is for\n      // getSCEVAtScope, so restrict this to that for   │
│ now.\n      if (L != this->getLoop()) {\n        const SCEV *V =                           │
│ SE.getConstant(cast<SCEVConstant>(this)->getAPInt(),\n                                     │
