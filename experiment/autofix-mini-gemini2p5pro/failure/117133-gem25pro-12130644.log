│ +// A visitor that looks for a division by a constant zero. Such a division                │
│ +// would produce a poison value, which we want to avoid when creating                     │
│ +// an AddRec expression.                                                                  │
│ +struct PoisonDivVisitor : public SCEVVisitor<PoisonDivVisitor, bool> {                    │
│ +  bool visitUDivExpr(const SCEVUDivExpr *S) {                                             │
│ +    if (S->getRHS()->isZero())                                                            │
│ +      return true;                                                                        │
│ +    return visit(S->getLHS()) || visit(S->getRHS());                                      │
│ +  }                                                                                       │
│ +                                                                                          │
│ +  bool visit(const SCEV *S) {                                                             │
│ +    for (const SCEV *Op : S->operands())                                                  │
│ +      if (visit(Op))                                                                      │
│ +        return true;                                                                      │
│ +    return false;                                                                         │
│ +  }                                                                                       │
│ +};                                                                                        │
