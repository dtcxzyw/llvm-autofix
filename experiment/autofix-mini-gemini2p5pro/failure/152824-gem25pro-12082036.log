│ This is an interesting bug. The root cause analysis correctly identifies that an        │
│ incorrect assumption is being made when looking through an `fabs` in a floating-point   │
│ comparison. Specifically, `fcmp ogt (fabs %x), 0.0` is true for any non-zero `%x`,      │
│ regardless of its sign. The optimizer was incorrectly concluding that `%x` must be      │
│ positive.                                                                               │
│                                                                                         │
│ The faulty logic was located in a templated helper function `fcmpImpliesClass`. This    │
│ function had a parameter `LookThroughSrc` which controlled whether to look through      │
│ `fabs` and `fneg`. By removing this parameter and the associated logic, we can prevent  │
│ the incorrect deduction. The fix involves:                                              │
│                                                                                         │
│ 1.  Removing the `LookThroughSrc` boolean parameter and the logic that uses it from the │
│ two overloads of `fcmpImpliesClass`.                                                    │
│ 2.  Updating the call sites of `fcmpImpliesClass` to remove the now-deleted argument.   │
│                                                                                         │
│ This ensures that comparisons involving `fabs` are handled more conservatively,         │
│ preventing the optimizer from making invalid assumptions about the sign of the operand. │
│                                                                                         │
│ Here is the patch that fixes the issue:                                                 │
│                                                                                         │
│ ```patch                                                                                │
│ --- a/llvm/lib/Analysis/ValueTracking.cpp                                               │
│ +++ b/llvm/lib/Analysis/ValueTracking.cpp                                               │
│ @@ -413,14 +413,12 @@                                                                   │
│                                                                                         │
│  template <typename ValueRefT, typename FunctionT>                                      │
│  static std::tuple<ValueRefT, FPClassTest, FPClassTest> fcmpImpliesClass(               │
│ -    CmpInst::Predicate Pred, const FunctionT &F, ValueRefT LHS,                        │
│ -    const APFloat &ConstRHS, bool LookThroughSrc) {                                    │
│ +    CmpInst::Predicate Pred, const FunctionT &F, ValueRefT LHS, const APFloat          │
│ &ConstRHS) {                                                                            │
│    // We can refine checks against smallest normal / largest denormal to an             │
│    // exact class test.                                                                 │
│    if (!ConstRHS.isNegative() && ConstRHS.isSmallestNormalized()) {                     │
│ -    ValueRefT Src = LHS;                                                               │
│ -    const bool IsFabs = LookThroughSrc && lookThroughFAbs(F, LHS, Src);                │
│ -                                                                                       │
│      FPClassTest Mask;                                                                  │
│      // Match pattern that's used in __builtin_isnormal.                                │
│      switch (Pred) {                                                                    │
│ @@ -431,38 +429,29 @@                                                                   │
│        // fcNan|fcPosNormal|fcPosInf fcmp uge fabs(x), smallest_normal ->               │
│        // ~(fcSubnormal|fcZero)                                                         │
│        Mask = fcZero | fcSubnormal;                                                     │
│ -      if (!IsFabs)                                                                     │
│ -        Mask |= fcNegNormal | fcNegInf;                                                │
│ -                                                                                       │
│ +      Mask |= fcNegNormal | fcNegInf;                                                  │
│        break;                                                                           │
│      }                                                                                  │
│      case FCmpInst::FCMP_OGE:                                                           │
│      case FCmpInst::FCMP_ULT: {                                                         │
│        // fcmp oge x, smallest_normal -> fcPosNormal | fcPosInf                         │
│ -      // fcmp oge fabs(x), smallest_normal -> fcInf | fcNormal                         │
│        // fcmp ult x, smallest_normal -> ~(fcPosNormal | fcPosInf)                      │
│ -      // fcmp ult fabs(x), smallest_normal -> ~(fcInf | fcNormal)                      │
│        Mask = fcPosInf | fcPosNormal;                                                   │
│ -      if (IsFabs)                                                                      │
│ -        Mask |= fcNegInf | fcNegNormal;                                                │
│        break;                                                                           │
│      }                                                                                  │
│      default:                                                                           │
│ -      return fcmpImpliesClass(Pred, F, LHS, ConstRHS.classify(),                       │
│ -                              LookThroughSrc);                                         │
