│ 127                                                bool      │
│ ForceHardwareLoopPHI) {                                      │
│ 128   SmallVector<BasicBlock *, 4> ExitingBlocks;            │
│ 129   L->getExitingBlocks(ExitingBlocks);                    │
│ 130                                                          │
│ 131   for (BasicBlock *BB : ExitingBlocks) {                 │
