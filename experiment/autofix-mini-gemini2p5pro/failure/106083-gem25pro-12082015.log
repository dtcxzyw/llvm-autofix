│ 377     ExitVal = V->getValue();                                                                                                                                                   │
│ 378     IsExitValSet = true;                                                                                                                                                       │
│ 379   }                                                                                                                                                                            │
│ 380   bool isExitValueSet() const { return IsExitValSet; }                                                                                                                         │
│ 381                                                                                                                                                                                │
