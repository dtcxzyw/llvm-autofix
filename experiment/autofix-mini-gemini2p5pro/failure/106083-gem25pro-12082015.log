│ 202   assert(SI->hasOneUse());                                                                                                                                                     │
│ 203                                                                                                                                                                                │
│ 204   if (StartBlockTerm->isUnconditional()) {                                                                                                                                     │
│ 205     // Arbitrarily choose the 'false' side for a new input value to the PHI.                                                                                                   │
