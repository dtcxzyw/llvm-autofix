│ 10878         assert(SubVectorsMask.size() == CommonMask.size() &&                         │
│ 10879                "Expected same size of masks for subvectors and common mask.");       │
│ 10880         SmallVector<int> SVMask(SubVectorsMask.begin(), SubVectorsMask.end());       │
