│ 10871       else                                                                           │
│ 10872         Cost += createShuffle(Vec, nullptr, CommonMask);                             │
│ 10873       for (unsigned Idx = 0, Sz = CommonMask.size(); Idx < Sz; ++Idx)                │
│ 10874         if (CommonMask[Idx] != PoisonMaskElem)                                       │
