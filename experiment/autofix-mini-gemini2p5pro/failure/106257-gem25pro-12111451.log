│ 201   /// lane can only be calculated at runtime.                               │
│ 202   unsigned getKnownLane() const {                                           │
│ 203     assert(LaneKind == Kind::First);                                        │
│ 204     return Lane;                                                            │
│ 205   }                                                                         │
