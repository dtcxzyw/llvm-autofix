│ The tests passed. The patch fixes the bug and does not introduce any regressions. I will   │
│ now provide the final patch.                                                               │
│                                                                                            │
│ ```diff                                                                                    │
│ --- a/llvm/lib/Transforms/InstCombine/InstCombineMulDivRem.cpp                             │
│ +++ b/llvm/lib/Transforms/InstCombine/InstCombineMulDivRem.cpp                             │
│ @@ -2125,9 +2125,11 @@                                                                     │
│    if (IsSRem) {                                                                           │
│      // srem (X * C), (X * (C-1)) -> srem (X, X * (C-1))                                   │
│      // srem (X * C), (X * (C+1)) -> srem (-X, X * (C+1))                                  │
│ -    // srem (X * -128), (X * 127) -> -X                                                   │
│ -    if (CY.isMinSignedValue() && CZ == CY + 1)                                            │
│ -      return Builder.CreateNeg(X);                                                        │
│ +    // srem (X * C1), (X * C2) -> X if C1 is min-signed-val and C2 is C1+1.               │
│ +    // Ex: srem (X * -128), (X * 127) -> X                                                │
│ +    if (CY.isMinSignedValue() && CZ == CY + 1)                                            │
│ +      return BinaryOperator::Create(Instruction::Add, X,                                  │
│ +                                    ConstantInt::get(X->getType(), 0));                   │
│      if (CY == CZ - 1)                                                                     │
│        return BinaryOperator::CreateSRem(X, Op1);                                          │
│      if (CY == CZ + 1)                                                                     │
│                                                                                            │
