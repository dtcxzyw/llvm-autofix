│ 134 // Get the top-most entry block of \p Start. This is the │
│ entry block of the                                           │
│ 135 // containing VPlan. This function is templated to       │
│ support both const and non-const blocks                      │
│ 136 template <typename T> static T *getPlanEntry(T *Start) { │
│ 137   T *Next = Start;                                       │
│ 138   T *Current = Start;                                    │
│ 139   while ((Next = Next->getParent()))                     │
│ 140     Current = Next;                                      │
│ 141                                                          │
│ 142   SmallSetVector<T *, 8> WorkList;                       │
│ 143   WorkList.insert(Current);                              │
│ 144                                                          │
│ 145   for (unsigned i = 0; i < WorkList.size(); i++) {       │
│ 146     T *Current = WorkList[i];                            │
│ 147     if (Current->getNumPredecessors() == 0)              │
│ 148       return Current;                                    │
│ 149     auto &Predecessors = Current->getPredecessors();     │
│ 150     WorkList.insert(Predecessors.begin(),                │
│ Predecessors.end());                                         │
│ 151   }                                                      │
│ 152                                                          │
│ 153   llvm_unreachable("VPlan without any entry node without │
│ predecessors");                                              │
│ 154 }                                                        │
