│ -    } else if (auto Widen = dyn_cast<VPWidenRecipe>(RedPhiOp1R))                          │
│ -      HandleWiden(Widen);                                                                 │
│ +    if (RedPhiOp1R) {                                                                     │
│ +      if (auto *Widen = dyn_cast<VPWidenCastRecipe>(RedPhiOp1R)) {                        │
