│ 345     InputTypeA = Ctx.Types.inferScalarType(OpR->getOperand(0));                        │
│ 346     ExtAType = GetExtendKind(OpR);                                                     │
│ 347   } else if (isa<VPReductionPHIRecipe>(OpR)) {                                         │
│ 348     auto RedPhiOp1R = getOperand(1)->getDefiningRecipe();                              │
│ 349     if (isa<VPWidenCastRecipe>(RedPhiOp1R)) {                                          │
│ 350       InputTypeA = Ctx.Types.inferScalarType(RedPhiOp1R->getOperand(0));               │
│ 351       ExtAType = GetExtendKind(RedPhiOp1R);                                            │
│ 352     } else if (auto Widen = dyn_cast<VPWidenRecipe>(RedPhiOp1R))                       │
│ 353       HandleWiden(Widen);                                                              │
│ 354   } else if (auto Widen = dyn_cast<VPWidenRecipe>(OpR)) {                              │
│ 355     HandleWiden(Widen);                                                                │
│ 356   } else if (auto Reduction = dyn_cast<VPPartialReductionRecipe>(OpR)) {               │
│ 357     return Reduction->computeCost(VF, Ctx);                                            │
│ 358   }                                                                                    │
│                                                                                            │
│ ```                                                                                        │
