│ +      if (CI->getOpcode() == Instruction::SExt)                                           │
│ +        ExtAType = TTI::CastContextHint::CCH_SignExtend;                                  │
│ +      else if (CI->getOpcode() == Instruction::ZExt)                                      │
│ +        ExtAType = TTI::CastContextHint::CCH_ZeroExtend;                                  │
│ +    }                                                                                     │
