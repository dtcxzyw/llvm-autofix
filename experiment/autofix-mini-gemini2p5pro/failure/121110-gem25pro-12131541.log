│ 127         const auto *CA = dyn_cast<ConstantAggregate>(Op);                              │
│ 128         if (!CA)                                                                       │
│ 129           return false;                                                                │
│ 130         if (Seen.insert(CA).second)                                                    │
│ 131           Worklist.emplace_back(CA);                                                   │
│ 132       }                                                                                │
│ 133                                                                                        │
│ 134       return true;                                                                     │
│ 135     };                                                                                 │
│ 136                                                                                        │
│ 137     if (!CheckValue(CA))                                                               │
│ 138       return false;                                                                    │
│ 139                                                                                        │
