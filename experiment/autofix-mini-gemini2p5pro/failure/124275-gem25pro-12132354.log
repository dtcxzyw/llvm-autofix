│ 268       if (A->isEntryBlock() && DT->isReachableFromEntry(B))                            │
│ 269         return true;                                                                   │
│ 270       if (B->isEntryBlock() && DT->isReachableFromEntry(A))                            │
│ 271         return false;                                                                  │
