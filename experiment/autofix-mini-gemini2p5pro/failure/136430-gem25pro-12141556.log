│ *Add = dyn_cast<Instruction>(SI.getTrueValue())) {\n      if │
│ (Add->getOpcode() == Instruction::FAdd) {\n        Value     │
│ *Op0 = Add->getOperand(0);\n        Value *Op1 =             │
│ Add->getOperand(1);\n        Constant *K =                   │
│ dyn_cast<Constant>(SI.getFalseValue());\n        Value *X =  │
│ nullptr;\n        if (Op0 == K)\n          X = Op1;\n        │
│ else if (Op1 == K)\n          X = Op0;\n\n        if (X) {\n │
│ // This is unsafe if the add has any fast-math-flags.\n      │
│ // For example, if X is -inf, and K is 1.0, and the add has  │
