│ ```cpp                                                       │
│ auto *CtPop = cast<CallInst>(Cmp0->getOperand(0));           │
│ if (match(Cmp1, m_ICmp(Pred, m_Value(X), m_Zero())) &&       │
│     match(Cmp0, m_ICmp(ICmpInst::ICMP_ULT,                   │
│                        m_Specific(CtPop),                    │
│                        m_ConstantInt<2>())) &&               │
│     CtPop->getArgOperand(0) == X &&                          │
│     isCtpopFast(CtPop) &&                                    │
│ CtPop->hasRetAttr(Attribute::NoUndef)) {                     │
│ ```                                                          │
