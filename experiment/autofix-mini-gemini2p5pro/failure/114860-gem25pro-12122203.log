│ -    // model.                                                                             │
│ -    InstructionCost Cost = 0;                                                             │
│ +    // instruction executed VF times. The cost of the scalarized instruction              │
│ +    // should be included in the cost model.                                              │
│ +    InstructionCost Cost = getInstructionCost(I, VF);                                     │
