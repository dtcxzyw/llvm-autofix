│ +  if (auto *I = dyn_cast<Instruction>(V))                                                 │
│ +    if (!Inserted.count(I))                                                               │
│ +      return I;                                                                           │
│                                                                                            │
│    Instruction *I = cast<Instruction>(V);                                                  │
│    // If we are using a cleaner, add the instruction to the list of generated              │
│                                                                                            │
│ ```                                                                                        │
│                                                                                            │
│ ### 5. Conclusion                                                                          │
│                                                                                            │
│ This edit correctly distinguishes between newly generated instructions and reused          │
│ pre-existing ones. By returning early for reused instructions, we avoid incorrectly adding │
│ them to the cleanup list, thus preventing the `SCEVExpanderCleaner` from attempting to     │
│ delete an instruction that is still live. This resolves the assertion failure and allows   │
│ vectorization to proceed correctly.                                                        │
