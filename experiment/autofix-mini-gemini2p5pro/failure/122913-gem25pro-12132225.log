│ *ScalarEvolution::getPredecessorWithUniqueSuccessorForBB(\n    const BasicBlock *BB) const │
│ {\n  // If the block has no predecessors, then we can't forward any predicates\n  // from  │
│ it.\n  if (pred_empty(BB))\n    return nullptr;\n\n  // If the block has a single          │
│ predecessor, then that predecessor is the\n  // block that is branching to BB.\n  if       │
│ (BB->getSinglePredecessor())\n    return BB->getSinglePredecessor();\n\n  // If the block  │
│ has multiple predecessors, then it must be a join.\n  // In this case, we can't forward    │
│ any predicates from the predecessors.\n  return nullptr;\n}"})                             │
