│ 419 static const Loop *PickMostRelevantLoop(const Loop *A, const Loop *B,                  │
│ 420                                         DominatorTree &DT) {                           │
│ 421   if (!A) return B;                                                                    │
│ 422   if (!B) return A;                                                                    │
