│ 580   const PointerInfo &PointerI = Pointers[I];                                        │
│ 581   const PointerInfo &PointerJ = Pointers[J];                                        │
│ 582                                                                                     │
│ 583   // No need to check if two readonly pointers intersect.                           │
│ 584   if (!PointerI.IsWritePtr && !PointerJ.IsWritePtr)                                 │
│ 585     return false;                                                                   │
│ 586                                                                                     │
│ 587   // Only need to check pointers between two different dependency sets.             │
│ 588   if (PointerI.DependencySetId == PointerJ.DependencySetId)                         │
