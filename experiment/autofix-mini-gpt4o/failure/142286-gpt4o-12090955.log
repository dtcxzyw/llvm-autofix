│ 405         break;                                                                      │
│ 406       }                                                                             │
│ 407                                                                                     │
│ 408       // Increment the case iterator since we didn't delete it.                     │
│ 409       ++CI;                                                                         │
│ 410       ++ReachableCaseCount;                                                         │
