│ 387                                                                                     │
│ 388         // The condition can be modified by removePredecessor's PHI simplification  │
│ 389         // logic.                                                                   │
│ 390         Cond = SI->getCondition();                                                  │
│ 391                                                                                     │
│ 392         ++NumDeadCases;                                                             │
│ 393         Changed = true;                                                             │
│ 394         if (--SuccessorsCount[Succ] == 0)                                           │
│ 395           DTU.applyUpdatesPermissive({{DominatorTree::Delete, BB, Succ}});          │
│ 396         continue;                                                                   │
