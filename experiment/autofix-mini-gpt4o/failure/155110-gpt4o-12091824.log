│ 199 static bool canWidenLoad(LoadInst *Load, const TargetTransformInfo &TTI) {                                               │
│ 200   // Do not widen load if atomic/volatile or under asan/hwasan/memtag/tsan.                                              │
│ 201   // The widened load may load data from dirty regions or create data races                                              │
│ 202   // non-existent in the source.                                                                                         │
│ 203   if (!Load || !Load->isSimple() || !Load->hasOneUse() ||                                                                │
│ 204       Load->getFunction()->hasFnAttribute(Attribute::SanitizeMemTag) ||                                                  │
│ 205       mustSuppressSpeculation(*Load))                                                                                    │
│ 206     return false;                                                                                                        │
│ 207                                                                                                                          │
│ 208   // We are potentially transforming byte-sized (8-bit) memory accesses, so make                                         │
│ 209   // sure we have all of our type-based constraints in place for this target.                                            │
│ 210   Type *ScalarTy = Load->getType()->getScalarType();                                                                     │
│ 211   uint64_t ScalarSize = ScalarTy->getPrimitiveSizeInBits();                                                              │
│ 212   unsigned MinVectorSize = TTI.getMinVectorRegisterBitWidth();                                                           │
│ 213   if (!ScalarSize || !MinVectorSize || MinVectorSize % ScalarSize != 0 ||                                                │
│ 214       ScalarSize % 8 != 0)                                                                                               │
│ 215     return false;                                                                                                        │
│ 216                                                                                                                          │
│ 217   return true;                                                                                                           │
│ 218 }                                                                                                                        │
