│ 527     switch (R->getVPDefID()) {                                                                     │
│ 528     case VPRecipeBase::VPDerivedIVSC:                                                              │
│ 529     case VPRecipeBase::VPEVLBasedIVPHISC:                                                          │
│ 530     case VPRecipeBase::VPExpandSCEVSC:                                                             │
│ 531     case VPRecipeBase::VPInstructionSC:                                                            │
