│ 233                                                                                        │
│ 234   static AvailableValue getLoad(LoadInst *Load, unsigned Offset = 0) {                 │
│ 235     AvailableValue Res;                                                                │
│ 236     Res.Val = Load;                                                                    │
│ 237     Res.Kind = ValType::LoadVal;                                                       │
