│ 239     return Res;                                                                        │
│ 240   }                                                                                    │
│ 241                                                                                        │
│ 242   static AvailableValue getUndef() {                                                   │
│ 243     AvailableValue Res;                                                                │
│ 244     Res.Val = nullptr;                                                                 │
│ 245     Res.Kind = ValType::UndefVal;                                                      │
│ 246     Res.Offset = 0;                                                                    │
