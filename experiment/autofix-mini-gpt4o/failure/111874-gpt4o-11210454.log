│ 397 /// A helper function that returns true if the given type is irregular. The         │
│ 398 /// type is irregular if its allocated size doesn't equal the store size of an      │
│ 399 /// element of the corresponding vector type.                                       │
│ 400 static bool hasIrregularType(Type *Ty, const DataLayout &DL) {                      │
│ 401   // Determine if an array of N elements of type Ty is "bitcast compatible"         │
