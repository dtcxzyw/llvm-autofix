│ 412 ///   4) Returns std::nullopt if all of the above failed.                           │
│ 413 static std::optional<unsigned>                                                      │
│ 414 getSmallBestKnownTC(PredicatedScalarEvolution &PSE, Loop *L,                        │
│ 415                     bool CanUseConstantMax = true) {                                │
