│ 407 /// Returns "best known" trip count for the specified loop \p L as defined by       │
│ 408 /// the following procedure:                                                        │
│ 409 ///   1) Returns exact trip count if it is known.                                   │
│ 410 ///   2) Returns expected trip count according to profile data if any.              │
│ 411 ///   3) Returns upper bound estimate if known, and if \p CanUseConstantMax.        │
│ 412 ///   4) Returns std::nullopt if all of the above failed.                           │
│ 413 static std::optional<unsigned>                                                      │
│ 414 getSmallBestKnownTC(PredicatedScalarEvolution &PSE, Loop *L,                        │
│ 415                     bool CanUseConstantMax = true) {                                │
│ 416   // Check if exact trip count is known.                                            │
│ 417   if (unsigned ExpectedTC = PSE.getSE()->getSmallConstantTripCount(L))              │
│ 418     return ExpectedTC;                                                              │
│ 419                                                                                     │
│ 420   // Check if there is an expected trip count available from profile data.          │
│ 421   if (LoopVectorizeWithBlockFrequency)                                              │
│ 422     if (auto EstimatedTC = getLoopEstimatedTripCount(L))                            │
