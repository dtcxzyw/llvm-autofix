│ 441     assert(PredBB && "Predecessor basic-block not found building successor.");      │
│ 442     auto *PredBBTerminator = PredBB->getTerminator();                               │
│ 443     LLVM_DEBUG(dbgs() << "LV: draw edge from" << PredBB->getName() << '\n');        │
│ 444                                                                                     │
│ 445     auto *TermBr = dyn_cast<BranchInst>(PredBBTerminator);                          │
│ 446     if (isa<UnreachableInst>(PredBBTerminator)) {                                   │
│ 447       assert(PredVPSuccessors.size() == 1 &&                                        │
│ 448              "Predecessor ending w/o branch must have single successor.");          │
│ 449       DebugLoc DL = PredBBTerminator->getDebugLoc();                                │
