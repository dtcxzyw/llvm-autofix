│ 446     CmpPredicate CurrentPred;                                                          │
│ 447     return Cmp_match<Op0_t, Op1_t, Opcodes...>(CurrentPred, Op0, Op1)                  │
│ 448                .match(V) &&                                                            │
│ 449            CmpPredicate::getMatching(CurrentPred, Predicate);                          │
│ 450   }                                                                                    │
│ 451 };                                                                                     │
