│ 1726   if (!NewFV)                                                            │
│ 1727     NewFV = foldOperationIntoSelectOperand(Op, SI, FV, *this);           │
│ 1728   return SelectInst::Create(SI->getCondition(), NewTV, NewFV, "",        │
│ nullptr, SI);                                                                 │
