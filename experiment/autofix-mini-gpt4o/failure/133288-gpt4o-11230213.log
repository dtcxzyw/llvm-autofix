│ $ bin/opt -S                                   │
│ --passes=print<scalar-evolution>,slp-vectorize │
│ r -mtriple=x86_64-unknown-linux-gnu            │
│ -slp-threshold=-99999 -mattr=+sse4.1           │
│ --debug-only=SLP /tmp/reprod_wjrdnhfg.ll       │
