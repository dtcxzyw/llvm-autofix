│ 372     SwitchInstProfUpdateWrapper SI(*I);                                             │
│ 373     unsigned ReachableCaseCount = 0;                                                │
│ 374                                                                                     │
│ 375     for (auto CI = SI->case_begin(), CE = SI->case_end(); CI != CE;) {              │
