│  940 /// First we normalize calls to strncmp/strcmp to the form of                                                                                                                                                │
│  941 /// compare(s1, s2, N), which means comparing first N bytes of s1 and s2                                                                                                                                     │
│  942 /// (without considering '\0').                                                                                                                                                                              │
│  943 ///                                                                                                                                                                                                          │
│  944 /// Examples:                                                                                                                                                                                                │
│  945 ///                                                                                                                                                                                                          │
│  946 /// \code                                                                                                                                                                                                    │
│  947 ///   strncmp(s, "a", 3) -> compare(s, "a", 2)                                                                                                                                                               │
│  948 ///   strncmp(s, "abc", 3) -> compare(s, "abc", 3)                                                                                                                                                           │
│  949 ///   strncmp(s, "a\0b", 3) -> compare(s, "a\0b", 2)                                                                                                                                                         │
│  950 ///   strcmp(s, "a") -> compare(s, "a", 2)                                                                                                                                                                   │
│  951 ///                                                                                                                                                                                                          │
│  952 ///   char s2[] = {'a'}                                                                                                                                                                                      │
│  953 ///   strncmp(s, s2, 3) -> compare(s, s2, 3)                                                                                                                                                                 │
│  954 ///                                                                                                                                                                                                          │
│  955 ///   char s2[] = {'a', 'b', 'c', 'd'}                                                                                                                                                                       │
│  956 ///   strncmp(s, s2, 3) -> compare(s, s2, 3)                                                                                                                                                                 │
│  957 /// \endcode                                                                                                                                                                                                 │
│  958 ///                                                                                                                                                                                                          │
│  959 /// We only handle cases where N and exactly one of s1 and s2 are constant.                                                                                                                                  │
│  960 /// Cases that s1 and s2 are both constant are already handled by the                                                                                                                                        │
