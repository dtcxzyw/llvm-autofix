│  948 ///   strncmp(s, "abc", 3) -> compare(s, "abc", 3)                                                                                                                                                           │
│  949 ///   strncmp(s, "a\0b", 3) -> compare(s, "a\0b", 2)                                                                                                                                                         │
│  950 ///   strcmp(s, "a") -> compare(s, "a", 2)                                                                                                                                                                   │
│  951 ///                                                                                                                                                                                                          │
│  952 ///   char s2[] = {'a'}                                                                                                                                                                                      │
│  953 ///   strncmp(s, s2, 3) -> compare(s, s2, 3)                                                                                                                                                                 │
│  954 ///                                                                                                                                                                                                          │
│  955 ///   char s2[] = {'a', 'b', 'c', 'd'}                                                                                                                                                                       │
│  956 ///   strncmp(s, s2, 3) -> compare(s, s2, 3)                                                                                                                                                                 │
