│ {                                                                                                      │
│   "name": <tool_name>,                                                                                 │
│   "args": <tool_args>                                                                                  │
│ }                                                                                                      │
│ </tool_call>                                                                                           │
│                                                                                                        │
│ For example:                                                                                           │
│                                                                                                        │
│ <tool_call>                                                                                            │
│ {                                                                                                      │
