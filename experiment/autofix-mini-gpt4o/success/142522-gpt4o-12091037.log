Final Patch
-----------
diff --git a/llvm/lib/Transforms/Utils/SimplifyCFG.cpp
b/llvm/lib/Transforms/Utils/SimplifyCFG.cpp
index 245d0c4f073d..fd7968718ebf 100644
--- a/llvm/lib/Transforms/Utils/SimplifyCFG.cpp
+++ b/llvm/lib/Transforms/Utils/SimplifyCFG.cpp
@@ -8223,9 +8223,22 @@ static bool passingValueIsAlwaysUndefined(Value *V, Instruction *I,
bool PtrValu
       if (CB->isArgOperand(&Use)) {
         unsigned ArgIdx = CB->getArgOperandNo(&Use);
         // Passing null to a nonnnull+noundef argument is undefined.
-        if (isa<ConstantPointerNull>(C) &&
-            CB->paramHasNonNullAttr(ArgIdx, /*AllowUndefOrPoison=*/false))
-          return !PtrValueMayBeModified;
+        if (isa<ConstantPointerNull>(C)) {
+          if (CB->getArgOperand(ArgIdx)->getType()->isVectorTy()) {
+            auto *VecTy = cast<VectorType>(CB->getArgOperand(ArgIdx)->getType());
+            if (VecTy->getElementType()->isPointerTy()) {
+              for (unsigned i = 0; i < VecTy->getElementCount().getFixedValue(); ++i) {
+                if (CB->getArgOperand(ArgIdx)->getType()->isPointerTy() &&
CB->paramHasNonNullAttr(ArgIdx, /*AllowUndefOrPoison=*/false)) {
+                  return !PtrValueMayBeModified;
+                }
+              }
+            }
+          } else {
+            if (CB->getArgOperand(ArgIdx)->getType()->isPointerTy() &&
CB->paramHasNonNullAttr(ArgIdx, /*AllowUndefOrPoison=*/false)) {
+              return !PtrValueMayBeModified;
+            }
+          }
+        }
         // Passing undef to a noundef argument is undefined.
         if (isa<UndefValue>(C) && CB->isPassingUndefUB(ArgIdx))
           return true;

Reference Patch
