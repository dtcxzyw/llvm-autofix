│ 220 void UnrollState::unrollHeaderPHIByUF(VPHeaderPHIRecipe *R,                                                                                                                                                   │
│ 221                                       VPBasicBlock::iterator InsertPtForPhi) {                                                                                                                                │
│ 222   // First-order recurrences pass a single vector or scalar through their header                                                                                                                              │
