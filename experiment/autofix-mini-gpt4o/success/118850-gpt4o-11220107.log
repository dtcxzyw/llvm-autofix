│ 240     Copy->insertBefore(*R->getParent(), InsertPt);                                                                                                                                                            │
│ 241     addRecipeForPart(R, Copy, Part);                                                                                                                                                                          │
│ 242     if (isa<VPWidenPointerInductionRecipe>(R)) {                                                                                                                                                              │
│ 243       Copy->addOperand(R);                                                                                                                                                                                    │
│ 244       Copy->addOperand(getConstantVPV(Part));                                                                                                                                                                 │
