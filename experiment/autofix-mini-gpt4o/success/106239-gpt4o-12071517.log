diff --git
a/llvm/lib/Transforms/Utils/ScalarEvolutionExpander.cpp
b/llvm/lib/Transforms/Utils/ScalarEvolutionExpander.cpp
index c7d758aa575e..6d71d7286074 100644
--- a/llvm/lib/Transforms/Utils/ScalarEvolutionExpander.cpp
+++ b/llvm/lib/Transforms/Utils/ScalarEvolutionExpander.cpp
@@ -825,9 +825,11 @@ bool
SCEVExpander::canReuseFlagsFromOriginalIVInc(PHINode *OrigPhi,
                                                   PHINode
*WidePhi,
                                                   Instruction
*OrigInc,
                                                   Instruction
*WideInc) {
-  return match(OrigInc, m_c_BinOp(m_Specific(OrigPhi),
m_Value())) &&
-         match(WideInc, m_c_BinOp(m_Specific(WidePhi),
m_Value())) &&
-         OrigInc->getOpcode() == WideInc->getOpcode();
+  if (!WideInc)
+  return false;
+return match(OrigInc, m_c_BinOp(m_Specific(OrigPhi),
m_Value())) &&
+       match(WideInc, m_c_BinOp(m_Specific(WidePhi),
m_Value())) &&
+       OrigInc->getOpcode() == WideInc->getOpcode();
 }

