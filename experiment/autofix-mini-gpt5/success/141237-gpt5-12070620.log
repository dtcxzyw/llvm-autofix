dyn_cast<LoadInst>(&I)) {\n+          Value *Ptr =
LI->getPointerOperand();\n+          if (TheLoop->isLoopInvariant(Ptr))\n+
return true;\n+        }\n+        // Also consider other instructions whose
operands are all\n+        // loop-invariant, which VPlan may treat as
uniform and simplify.\n+        if (all_of(I.operands(), [TheLoop](Value
*Op) {\n+              return TheLoop->isLoopInvariant(Op);\n+
}))\n+          return true;\n+      }\n+      return false;\n     });\n
});\n }\n",
