diff --git a/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
b/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
index 4a68e0ee5989..6a69dd6c3eb2 100644
--- a/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
+++ b/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
@@ -3448,9 +3448,9 @@ private:
     Instruction *getAltOp() const { return S.getAltOp(); }

     /// The main/alternate opcodes for the list of instructions.
-    unsigned getOpcode() const { return S.getOpcode(); }
+    unsigned getOpcode() const { return hasState() ? S.getOpcode() : 0; }

-    unsigned getAltOpcode() const { return S.getAltOpcode(); }
+    unsigned getAltOpcode() const { return hasState() ? S.getAltOpcode() : 0; }

     bool hasState() const { return S.valid(); }

@@ -3652,6 +3652,8 @@ private:
       Last->Scalars.assign(VL.begin(), VL.end());
       if (S)
         Last->setOperations(S);
+      else
+        Last->State = TreeEntry::NeedToGather;
     } else {
       // Reorder scalars and build final mask.
       Last->Scalars.assign(VL.size(), nullptr);
@@ -3664,8 +3666,20 @@ private:
       InstructionsState S = getSameOpcode(Last->Scalars, *TLI);
       if (S)
         Last->setOperations(S);
+      else
+        Last->State = TreeEntry::NeedToGather;
       Last->ReorderIndices.append(ReorderIndices.begin(), ReorderIndices.end());
     }
+    // Ensure non-gather entries always have a valid InstructionsState.
+    if (!Last->hasState()) {
+      InstructionsState NewS = S;
+      if (!NewS)
+        NewS = getSameOpcode(Last->Scalars, *TLI);
+      if (NewS)
+        Last->setOperations(NewS);
+      else
+        Last->State = TreeEntry::NeedToGather;
+    }
     if (!Last->isGather()) {
       SmallPtrSet<Value *, 4> Processed;
       for (Value *V : VL) {
@@ -11339,7 +11353,11 @@ BoUpSLP::getEntryCost(const TreeEntry *E, ArrayRef<Value
*> VectorizedVals,
   unsigned EntryVF = E->getVectorFactor();
   auto *FinalVecTy = getWidenedType(ScalarTy, EntryVF);

-  if (E->isGather()) {
+  if (E->isGather() || !E->hasState()) {
+    // If a non-gather node has no valid state, conservatively treat it as a
+    // gather during cost estimation.
+    if (!E->isGather())
+      const_cast<TreeEntry *>(E)->State = TreeEntry::NeedToGather;
     if (allConstant(VL))
       return 0;
     if (isa<InsertElementInst>(VL[0]))
@@ -11354,7 +11372,7 @@ BoUpSLP::getEntryCost(const TreeEntry *E, ArrayRef<Value
*> VectorizedVals,
   if (!E->ReorderIndices.empty() && (E->State != TreeEntry::StridedVectorize ||
                                      !isReverseOrder(E->ReorderIndices))) {
     SmallVector<int> NewMask;
-    if (E->getOpcode() == Instruction::Store) {
+    if (E->hasState() && E->getOpcode() == Instruction::Store) {
       // For stores the order is actually a mask.
       NewMask.resize(E->ReorderIndices.size());
       copy(E->ReorderIndices, NewMask.begin());
@@ -11368,6 +11386,9 @@ BoUpSLP::getEntryCost(const TreeEntry *E, ArrayRef<Value
*> VectorizedVals,
   if (!Mask.empty() && !ShuffleVectorInst::isIdentityMask(Mask, Mask.size()))
     CommonCost =
         ::getShuffleCost(*TTI, TTI::SK_PermuteSingleSrc, FinalVecTy, Mask);
+  // If state became invalid for any reason, bail out gracefully.
+  if (!E->hasState())
+    return InstructionCost::getInvalid();
   assert((E->State == TreeEntry::Vectorize ||
           E->State == TreeEntry::ScatterVectorize ||
           E->State == TreeEntry::StridedVectorize) &&
@@ -11425,8 +11446,8 @@ BoUpSLP::getEntryCost(const TreeEntry *E, ArrayRef<Value
*> VectorizedVals,
             E->Idx != 0 &&
             (E->getOpcode() != Instruction::Load || E->UserTreeIndex)) {
           const EdgeInfo &EI = E->UserTreeIndex;
-          if (EI.UserTE->getOpcode() != Instruction::Select ||
-              EI.EdgeIdx != 0) {
+          if (EI.UserTE->hasState() &&
+              (EI.UserTE->getOpcode() != Instruction::Select || EI.EdgeIdx !=
0)) {
             auto UserBWIt = MinBWs.find(EI.UserTE);
             Type *UserScalarTy =
                 EI.UserTE->getOperand(EI.EdgeIdx).front()->getType();
@@ -12726,6 +12747,14 @@ InstructionCost BoUpSLP::getTreeCost(ArrayRef<Value *>
VectorizedVals) {

   unsigned BundleWidth = VectorizableTree[0]->Scalars.size();

+  // Ensure invariants: any non-gather node must have a valid instruction state.
+  // If not, conservatively downgrade it to a gather to avoid relying on an
+  // invalid main/alt opcode during costing.
+  for (std::unique_ptr<TreeEntry> &TEPtr : VectorizableTree) {
+    if (!TEPtr->isGather() && !TEPtr->hasState())
+      TEPtr->State = TreeEntry::NeedToGather;
+  }
+
   SmallPtrSet<Value *, 4> CheckedExtracts;
   for (unsigned I = 0, E = VectorizableTree.size(); I < E; ++I) {
     TreeEntry &TE = *VectorizableTree[I];
@@ -12756,6 +12785,11 @@ InstructionCost BoUpSLP::getTreeCost(ArrayRef<Value *>
VectorizedVals) {
     assert((!TE.isGather() || TE.Idx == 0 || TE.UserTreeIndex) &&
            "Expected gather nodes with users only.");

+    // Be conservative: if a non-gather entry has no valid state, downgrade it
