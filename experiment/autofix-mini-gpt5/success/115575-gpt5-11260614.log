Final Patch
-----------
diff --git a/llvm/lib/Transforms/Vectorize/VectorCombine.cpp
b/llvm/lib/Transforms/Vectorize/VectorCombine.cpp
index 04ea12ef0f12..db0a6ea293c9 100644
--- a/llvm/lib/Transforms/Vectorize/VectorCombine.cpp
+++ b/llvm/lib/Transforms/Vectorize/VectorCombine.cpp
@@ -969,6 +969,17 @@ bool VectorCombine::scalarizeBinopOrCmp(Instruction &I) {
           ScalarTy->isPointerTy()) &&
          "Unexpected types for insert element into binop or cmp");

+  // If the insertelement index is out-of-range, the original vector operand
+  // is entirely poison and the vector operation yields poison without
+  // risking undefined behavior (e.g. division by zero). Scalarizing would
+  // attempt to extract that out-of-range element from a constant vector,
+  // producing a poison operand to a potentially UB-sensitive scalar op.
+  // Bail out to preserve correctness (PR115575).
+  if (auto *FVT = dyn_cast<FixedVectorType>(VecTy)) {
+    if (Index >= FVT->getNumElements())
+      return false;
+  }
+
   unsigned Opcode = I.getOpcode();
   InstructionCost ScalarOpCost, VectorOpCost;
   if (IsCmp) {

