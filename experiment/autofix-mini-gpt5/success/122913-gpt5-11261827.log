│ 213 /// be checked at run-time.                                               │
│ 214 class SCEVPredicate : public FoldingSetNode {                             │
│ 215   friend struct FoldingSetTrait<SCEVPredicate>;                           │
│ 216                                                                           │
│ 217   /// A reference to an Interned FoldingSetNodeID for this node.  The     │
