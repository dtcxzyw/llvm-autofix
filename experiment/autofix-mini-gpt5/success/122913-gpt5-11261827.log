│ 220                                                                           │
│ 221 public:                                                                   │
│ 222   enum SCEVPredicateKind { P_Union, P_Compare, P_Wrap };                  │
│ 223                                                                           │
│ 224 protected:                                                                │
│ 225   SCEVPredicateKind Kind;                                                 │
│ 226   ~SCEVPredicate() = default;                                             │
