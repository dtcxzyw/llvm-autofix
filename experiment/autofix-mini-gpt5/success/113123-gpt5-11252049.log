Final Patch
-----------
diff --git a/llvm/lib/Transforms/InstCombine/InstCombineAndOrXor.cpp
b/llvm/lib/Transforms/InstCombine/InstCombineAndOrXor.cpp
index d72013ba223d..7829b88d3f04 100644
--- a/llvm/lib/Transforms/InstCombine/InstCombineAndOrXor.cpp
+++ b/llvm/lib/Transforms/InstCombine/InstCombineAndOrXor.cpp
@@ -1531,8 +1531,13 @@ Value *InstCombinerImpl::foldLogicOfFCmps(FCmpInst *LHS,
FCmpInst *RHS,
     }
     if (IsLessThanOrLessEqual(IsAnd ? PredL : PredR)) {
       BuilderTy::FastMathFlagGuard Guard(Builder);
-      Builder.setFastMathFlags(LHS->getFastMathFlags() |
-                               RHS->getFastMathFlags());
+      // For logic formed from a select, intersect FMF to avoid introducing
+      // new assumptions (e.g. ninf) that could create observable poison.
+      // Otherwise, we can safely union the flags.
+      FastMathFlags FMFL = LHS->getFastMathFlags();
+      FastMathFlags FMFR = RHS->getFastMathFlags();
+      FastMathFlags NewFMF = IsLogicalSelect ? (FMFL & FMFR) : (FMFL | FMFR);
+      Builder.setFastMathFlags(NewFMF);

       Value *FAbs = Builder.CreateUnaryIntrinsic(Intrinsic::fabs, LHS0);
       return Builder.CreateFCmp(PredL, FAbs,

