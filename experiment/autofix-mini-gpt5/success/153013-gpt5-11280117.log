│ !wouldInstructionBeTriviallyDead(CB)) ||                                      │
│  71                                                                           │
│ CB->getOperandBundle(LLVMContext::OB_clang_arc_attachedcall))) {              │
│  72     Function *F = CB->getCalledFunction();                                │
│  73                                                                           │
│  74     // Don't zap returns of the callee                                    │
│  75     if (F)                                                                │
│  76       addToMustPreserveReturnsInFunctions(F);                             │
│  77                                                                           │
│  78     LLVM_DEBUG(dbgs() << "  Can\'t treat the result of call " << *CB      │
│  79                       << " as a constant\n");                             │
│  80     return false;                                                         │
│  81   }                                                                       │
│  82                                                                           │
│  83   LLVM_DEBUG(dbgs() << "  Constant: " << *Const << " = " << *V << '\n');  │
│  84                                                                           │
