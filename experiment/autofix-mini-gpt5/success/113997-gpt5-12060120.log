    "diff --git a/llvm/lib/Transforms/Utils/Local.cpp
b/llvm/lib/Transforms/Utils/Local.cpp\nindex 65c1669f92b4..9c157e777825
100644\n--- a/llvm/lib/Transforms/Utils/Local.cpp\n+++
b/llvm/lib/Transforms/Utils/Local.cpp\n@@ -3518,6 +3518,58 @@ void
llvm::patchReplacementInstruction(Instruction *I, Value *Repl) {\n   // regions,
and so we need a conservative combination of the noalias\n   // scopes.\n
combineMetadataForCSE(ReplInst, I, false);\n+\n+  // If the replacement has
result !range metadata that is different from the\n+  // original, conservatively
drop it to avoid making the replacement more\n+  // poisonous at new use sites.
Result !range can turn otherwise well-defined\n+  // values into poison when the
actual runtime value falls outside the stated\n+  // range; propagating a
stricter range into uses that were not proven to\n+  // satisfy it is not
correct.\n+  if (MDNode *ReplRange =
ReplInst->getMetadata(LLVMContext::MD_range)) {\n+    MDNode *OrigRange =
I->getMetadata(LLVMContext::MD_range);\n+    if (OrigRange && OrigRange !=
ReplRange)\n+      // Prefer the original (usually wider) range to avoid making
the\n+      // replacement more poisonous at new use sites.\n+
ReplInst->setMetadata(LLVMContext::MD_range, OrigRange);\n+    else if
(!OrigRange)\n+      // If the original did not have a range, drop the
replacement's range\n+      // to avoid strengthening semantics.\n+
ReplInst->setMetadata(LLVMContext::MD_range, nullptr);\n+  }\n+  // Additionally,
if the replacement is a call with a return value range\n+  // attribute, and the
original being replaced does not have an equivalent\n+  // return range, align
the replacement's return range to the original (if any)\n+  // or drop it to
avoid introducing poison at new use sites.\n+  if (auto *ReplCB =
dyn_cast<CallBase>(ReplInst)) {\n+    AttributeList ReplAL =
ReplCB->getAttributes();\n+    if (ReplAL.hasRetAttr(Attribute::Range)) {\n+
bool KeepSame = false;\n+      AttributeList NewAL = ReplAL;\n+      if (auto
*OrigCB = dyn_cast<CallBase>(I)) {\n+        AttributeList OrigAL =
OrigCB->getAttributes();\n+        if (OrigAL.hasRetAttr(Attribute::Range)) {\n+
// If both have range and it's identical, keep it. Otherwise, replace\n+
// replacement's return range with the original's.\n+          Attribute ReplRA =
ReplAL.getRetAttr(Attribute::Range);\n+          Attribute OrigRA =
OrigAL.getRetAttr(Attribute::Range);\n+          if (ReplRA == OrigRA) {\n+
KeepSame = true;\n+          } else {\n+            // Remove and then add the
original's range attribute.\n+            NewAL =
NewAL.removeRetAttribute(ReplCB->getContext(), Attribute::Range)\n+
.addRetAttribute(ReplCB->getContext(), OrigRA);\n+          }\n+        }\n+
}\n+      if (!KeepSame) {\n+        // If original didn't have a range, drop the
replacement's range.\n+        if (!NewAL.hasRetAttr(Attribute::Range))\n+
NewAL = NewAL.removeRetAttribute(ReplCB->getContext(), Attribute::Range);\n+
ReplCB->setAttributes(NewAL);\n+      }\n+    }\n+  }\n+\n }\n \n template
<typename RootType, typename ShouldReplaceFn>\n",
