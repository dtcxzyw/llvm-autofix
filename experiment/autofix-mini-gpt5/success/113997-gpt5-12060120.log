(!OrigRange)\n+        // If the original did not have a range, drop the
replacement's range\n+        // to avoid strengthening semantics across
blocks.\n+        ReplInst->setMetadata(LLVMContext::MD_range, nullptr);\n+
}\n+  }\n+\n }\n \n template <typename RootType, typename ShouldReplaceFn>\n",
