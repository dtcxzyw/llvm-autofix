diff --git a/llvm/lib/Transforms/InstCombine/InstCombineAndOrXor.cpp b/llvm/lib/Transforms/InstCombine/InstCombineAndOrXor.cpp
index dff9304be64d..15c24f264551 100644
--- a/llvm/lib/Transforms/InstCombine/InstCombineAndOrXor.cpp
+++ b/llvm/lib/Transforms/InstCombine/InstCombineAndOrXor.cpp
@@ -3356,17 +3356,49 @@ Value *InstCombinerImpl::foldAndOrOfICmps(ICmpInst *LHS, ICmpInst *RHS,
   // handle (roughly):
   // (icmp ne (A & B), C) | (icmp ne (A & D), E)
   // (icmp eq (A & B), C) & (icmp eq (A & D), E)
-  if (Value *V = foldLogOpOfMaskedICmps(LHS, RHS, IsAnd, IsLogical, Builder))
+  if (Value *V = foldLogOpOfMaskedICmps(LHS, RHS, IsAnd, IsLogical, Builder)) {
+    // If we collapse to one of the original compares under logical semantics,
+    // drop samesign to preserve poison-safety.
+    if (IsLogical) {
+      if (V == LHS && LHS->hasSameSign()) {
+        LHS->setSameSign(false);
+        addToWorklist(LHS);
+      } else if (V == RHS && RHS->hasSameSign()) {
+        RHS->setSameSign(false);
+        addToWorklist(RHS);
+      }
+    }
     return V;
+  }

   if (Value *V =
-          foldAndOrOfICmpEqConstantAndICmp(LHS, RHS, IsAnd, IsLogical, Builder))
+          foldAndOrOfICmpEqConstantAndICmp(LHS, RHS, IsAnd, IsLogical, Builder)) {
+    if (IsLogical) {
+      if (V == LHS && LHS->hasSameSign()) {
+        LHS->setSameSign(false);
+        addToWorklist(LHS);
+      } else if (V == RHS && RHS->hasSameSign()) {
+        RHS->setSameSign(false);
+        addToWorklist(RHS);
+      }
+    }
     return V;
+  }
   // We can treat logical like bitwise here, because both operands are used on
   // the LHS, and as such poison from both will propagate.
   if (Value *V = foldAndOrOfICmpEqConstantAndICmp(RHS, LHS, IsAnd,
-                                                  /*IsLogical*/ false, Builder))
+                                                  /*IsLogical*/ false, Builder)) {
+    if (IsLogical) {
+      if (V == RHS && RHS->hasSameSign()) {
+        RHS->setSameSign(false);
+        addToWorklist(RHS);
+      } else if (V == LHS && LHS->hasSameSign()) {
+        LHS->setSameSign(false);
+        addToWorklist(LHS);
+      }
+    }
     return V;
+  }

   if (Value *V =
           foldAndOrOfICmpsWithConstEq(LHS, RHS, IsAnd, IsLogical, Builder, Q))
diff --git a/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp b/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp
index 5eebfdb774d2..dd26828bde2c 100644
--- a/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp
+++ b/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp
@@ -3364,8 +3364,22 @@ Instruction *InstCombinerImpl::foldSelectOfBools(SelectInst &SI) {
     }

     if (auto *V = foldBooleanAndOr(CondVal, Op1, SI, IsAnd,
-                                   /*IsLogical=*/true))
+                                   /*IsLogical=*/true)) {
+      // If folding the logical op reduces to the RHS itself, be careful:
+      // dropping the condition may expose a poison-producing RHS (e.g. icmp
+      // samesign) that was previously short-circuited by CondVal. If that is
+      // the case and the condition does not guarantee poison-safety, drop the
+      // samesign flag to make the compare non-poison.
+      if (V == Op1)
+        if (auto *Cmp = dyn_cast<ICmpInst>(Op1); Cmp && Cmp->hasSameSign()) {
+          bool Expected = IsAnd; // and: Cond must be true; or: Cond must be false
+          if (!impliesPoisonOrCond(Op1, CondVal, Expected)) {
+            Cmp->setSameSign(false);
+            addToWorklist(Cmp);
+          }
+        }
       return replaceInstUsesWith(SI, V);
+    }
   }

   // select (a || b), c, false -> select a, c, false

