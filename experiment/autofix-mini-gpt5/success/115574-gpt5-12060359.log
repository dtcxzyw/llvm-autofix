if (match(CmpLHS, m_And(m_Value(X), m_Value(Y))) &&\n+          match(CmpRHS,
m_AllOnes())) {\n+        // (X & Y) == -1 implies X == -1 and Y == -1.\n+
if (Value *V = simplifySelectWithEquivalence(\n+                {{X, CmpRHS}, {Y,
CmpRHS}}, TrueVal, FalseVal, Q, MaxRecurse))\n+          return V;\n+      }\n
}\n   }\n \n"
  ]
}
