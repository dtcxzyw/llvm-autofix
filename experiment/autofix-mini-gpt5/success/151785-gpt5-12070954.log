Final Patch
-----------
diff --git a/llvm/lib/Analysis/Loads.cpp b/llvm/lib/Analysis/Loads.cpp
index 6fc81d787c22..b7a23c1c20bc 100644
--- a/llvm/lib/Analysis/Loads.cpp
+++ b/llvm/lib/Analysis/Loads.cpp
@@ -833,6 +833,18 @@ bool llvm::canReplacePointersInUseIfEqual(const Use &U,
const Value *To,
   if (!To->getType()->isPointerTy())
     return true;

+  // Do not replace operands of lifetime intrinsics: their pointer operand
must
+  // be an alloca or poison. Replacing with null or other values breaks IR
rules.
+  if (auto *II = dyn_cast<IntrinsicInst>(U.getUser())) {
+    switch (II->getIntrinsicID()) {
+    case Intrinsic::lifetime_start:
+    case Intrinsic::lifetime_end:
+      return false;
+    default:
+      break;
+    }
+  }
+
   if (isPointerAlwaysReplaceable(&*U, To, DL))
     return true;
   return isPointerUseReplacable(U);
diff --git a/llvm/lib/Transforms/Scalar/GVN.cpp
b/llvm/lib/Transforms/Scalar/GVN.cpp
index f6bf09d09433..1243f12886a6 100644
--- a/llvm/lib/Transforms/Scalar/GVN.cpp
+++ b/llvm/lib/Transforms/Scalar/GVN.cpp
@@ -2497,6 +2497,19 @@ void GVNPass::assignBlockRPONumber(Function &F) {
 }

 bool GVNPass::replaceOperandsForInBlockEquality(Instruction *Instr) const {
+  // Avoid operand replacement for lifetime intrinsics. Their pointer
operand
+  // must be an alloca or poison, and substituting based on equality (e.g.,
to
+  // null) can break IR invariants and trip the verifier.
+  if (auto *II = dyn_cast<IntrinsicInst>(Instr)) {
+    switch (II->getIntrinsicID()) {
+    case Intrinsic::lifetime_start:
+    case Intrinsic::lifetime_end:
+      return false;
+    default:
+      break;
+    }
+  }
+
   bool Changed = false;
   for (unsigned OpNum = 0; OpNum < Instr->getNumOperands(); ++OpNum) {
     Value *Operand = Instr->getOperand(OpNum);

Reference Patch
---------------
commit 4b5b36e5c4b887a86fc7164d6899caaa2e2f5aed
Author: Nikita Popov <npopov@redhat.com>
Date:   Mon Aug 4 12:05:37 2025 +0200

    [GVN] Avoid creating lifetime of non-alloca

    There is a larger problem here in that we should not be performing
    arbitrary pointer replacements for assumes. This is handled for
    branches, but assume goes through a different code path.

    Fixes https://github.com/llvm/llvm-project/issues/151785.

diff --git a/llvm/lib/Analysis/Loads.cpp b/llvm/lib/Analysis/Loads.cpp
index 6fc81d787c22..da76f5b3d498 100644
--- a/llvm/lib/Analysis/Loads.cpp
+++ b/llvm/lib/Analysis/Loads.cpp
@@ -833,6 +833,10 @@ bool llvm::canReplacePointersInUseIfEqual(const Use &U,
const Value *To,
   if (!To->getType()->isPointerTy())
     return true;

+  // Do not perform replacements in lifetime intrinsic arguments.
+  if (isa<LifetimeIntrinsic>(U.getUser()))
+    return false;
+
   if (isPointerAlwaysReplaceable(&*U, To, DL))
     return true;
   return isPointerUseReplacable(U);
diff --git a/llvm/lib/Transforms/Scalar/GVN.cpp
b/llvm/lib/Transforms/Scalar/GVN.cpp
index f6bf09d09433..fa6ee95d33d1 100644
--- a/llvm/lib/Transforms/Scalar/GVN.cpp
+++ b/llvm/lib/Transforms/Scalar/GVN.cpp
@@ -2502,6 +2502,10 @@ bool
GVNPass::replaceOperandsForInBlockEquality(Instruction *Instr) const {
     Value *Operand = Instr->getOperand(OpNum);
     auto It = ReplaceOperandsWithMap.find(Operand);
     if (It != ReplaceOperandsWithMap.end()) {
+      // Do not replace lifetime alloca argument with something else.
+      if (Instr->isLifetimeStartOrEnd())
+        continue;
+
       LLVM_DEBUG(dbgs() << "GVN replacing: " << *Operand << " with "
                         << *It->second << " in instruction " << *Instr <<
'\n');
       Instr->setOperand(OpNum, It->second);

