Final Patch
-----------
diff --git a/llvm/lib/Transforms/InstCombine/InstCombinePHI.cpp
b/llvm/lib/Transforms/InstCombine/InstCombinePHI.cpp
index cb5c44730512..66e1dbc72e7a 100644
--- a/llvm/lib/Transforms/InstCombine/InstCombinePHI.cpp
+++ b/llvm/lib/Transforms/InstCombine/InstCombinePHI.cpp
@@ -545,7 +545,9 @@ Instruction *InstCombinerImpl::foldPHIArgGEPIntoPHI(PHINode
&PN) {
   // especially bad when the PHIs are in the header of a loop.
   bool NeededPhi = false;

-  GEPNoWrapFlags NW = GEPNoWrapFlags::all();
+  // Initialize NW with the first incoming GEP's flags so we form the
+  // intersection across all incoming GEPs, including the first.
+  GEPNoWrapFlags NW = FirstInst->getNoWrapFlags();

   // Scan to see if all operands are the same opcode, and all have one user.
   for (Value *V : drop_begin(PN.incoming_values())) {

