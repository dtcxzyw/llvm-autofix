│    // If ctlz/cttz is only used as a shift amount, set is_zero_poison to      │
│ true.                                                                         │
│ +  // This is safe because shifting by the bitwidth is poison anyway.         │
│ However,                                                                      │
│ +  // do not apply this fold if the intrinsic's return value is marked        │
│ 'noundef'                                                                     │
│ +  // because flipping the flag would allow the intrinsic to produce poison   │
│ for                                                                           │
│ +  // a zero input (when is_zero_poison=true) where previously it was         │
│ guaranteed                                                                    │
│ +  // to return a defined integer equal to the bitwidth. That would violate   │
│ the                                                                           │
│ +  // NoUndef contract and make the program less defined. If we can later     │
│ prove                                                                         │
│ +  // the input is non-zero, the fold below guarded by known-nonzero logic    │
│ will                                                                          │
│ +  // still canonicalize the flag safely.                                     │
│    if (II.hasOneUse() && match(Op1, m_Zero()) &&                              │
│ -      match(II.user_back(), m_Shift(m_Value(), m_Specific(&II))))            │
│ +      match(II.user_back(), m_Shift(m_Value(), m_Specific(&II))) &&          │
│ +      !II.hasRetAttr(Attribute::NoUndef))                                    │
│      return IC.replaceOperand(II, 1, IC.Builder.getTrue());                   │
