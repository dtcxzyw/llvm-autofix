│ 448 void RuntimePointerChecking::groupChecks(                                 │
│ 449     MemoryDepChecker::DepCandidates &DepCands, bool UseDependencies) {    │
│ 450   // We build the groups from dependency candidates equivalence classes   │
│ 451   // because:                                                             │
│ 452   //    - We know that pointers in the same equivalence class share       │
