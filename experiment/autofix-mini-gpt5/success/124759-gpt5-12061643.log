│ 492   // for correctness, because in this case we can have checking between   │
│ 493   // pointers to the same underlying object.                              │
│ 494   if (!UseDependencies) {                                                 │
│ 495     for (unsigned I = 0; I < Pointers.size(); ++I)                        │
│ 496       CheckingGroups.emplace_back(I, *this);                              │
