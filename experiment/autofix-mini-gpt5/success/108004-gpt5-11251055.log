the new predecessor (or have their single incoming edge's block\n+    // updated)
to preserve IR validity.\n+    if (LoopExitBlock) {\n+
SmallVector<BasicBlock *, 4> Preds(predecessors(LoopExitBlock));\n+      for
(PHINode &PN : LoopExitBlock->phis()) {\n+        // Fast path: single incoming
edge which is no longer a predecessor and\n+        // there is exactly one
current predecessor (the middle block). Redirect.\n+        if
(PN.getNumIncomingValues() == 1) {\n+          BasicBlock *IncBB =
PN.getIncomingBlock(0);\n+          if (!llvm::is_contained(Preds, IncBB) &&
Preds.size() == 1) {\n+            PN.setIncomingBlock(0, Preds[0]);\n+
continue;\n+          }\n+        }\n+        // Ensure PHI has incoming for
every predecessor.\n+        for (BasicBlock *PredBB : Preds) {\n+          if
(PN.getBasicBlockIndex(PredBB) != -1)\n+            continue; // Already has
incoming.\n+          // Reuse an existing loop-invariant incoming value if
possible.\n+          Value *IncomingV = nullptr;\n+          for (unsigned I =
0, E = PN.getNumIncomingValues(); I < E; ++I) {\n+            Value *Cand =
PN.getIncomingValue(I);\n+            if (OrigLoop->isLoopInvariant(Cand)) {
IncomingV = Cand; break; }\n+          }\n+          if (!IncomingV &&
PN.getNumIncomingValues() > 0)\n+            IncomingV =
PN.getIncomingValue(0);\n+          if (!IncomingV)\n+            continue; //
Defensive: shouldn't happen.\n+          PN.addIncoming(IncomingV, PredBB);\n+
}\n+        // Remove incoming edges from blocks that are no longer
predecessors.\n+        for (unsigned I = 0; I < PN.getNumIncomingValues(); ++I)
{\n+          BasicBlock *IncBB = PN.getIncomingBlock(I);\n+          if
(!llvm::is_contained(Preds, IncBB)) {\n+            PN.removeIncomingValue(I,
/*DeletePHIIfEmpty=*/false);\n+            --I; // Re-check current index after
removal.\n+          }\n+        }\n+      }\n+    }\n   }\n \n   // Fix live-out
phis not already fixed earlier.\n"
