│ edit({"file": "llvm/lib/Transforms/Scalar/CorrelatedValuePropagation.cpp",    │
│ "old": "static bool processTrunc(TruncInst *TI, LazyValueInfo *LVI) {\n  //   │
│ Do not deduce NUW/NSW for trunc here. Adding no-wrap flags to trunc\n  //     │
│ introduces poison-on-out-of-range semantics, and the current deduction\n  //  │
│ based on LVI ranges can be unsound in the presence of path-sensitive\n  //    │
│ conditions. Be conservative and avoid changing trunc flags.\n  (void)LVI;\n   │
│ return false;\n}", "new": "static bool processTrunc(TruncInst *TI,            │
│ LazyValueInfo *LVI) {\n  // Only deduce NUW/NSW for trunc in cases that are   │
│ provably safe.\n  // Specifically, when truncating from a zext/sext of the    │
│ destination type,\n  // the value is guaranteed to fit and we can infer       │
│ no-wrap flags without\n  // relying on potentially unsound LVI deductions.\n  │
│ (void)LVI;\n\n  if (TI->hasNoSignedWrap() && TI->hasNoUnsignedWrap())\n       │
│ return false;\n\n  Value *Op = TI->getOperand(0);\n  Type *DestTy =           │
│ TI->getDestTy();\n  bool Changed = false;\n\n  // zext X to W; trunc to       │
│ original type -> exact roundtrip, imply nuw+nsw.\n  if (auto *ZI =            │
│ dyn_cast<ZExtInst>(Op)) {\n    if (ZI->getSrcTy() == DestTy) {\n      if      │
│ (!TI->hasNoUnsignedWrap()) {\n        TI->setHasNoUnsignedWrap(true);\n       │
│ ++NumNUW;\n        Changed = true;\n      }\n      if                         │
│ (!TI->hasNoSignedWrap()) {\n        TI->setHasNoSignedWrap(true);\n           │
│ ++NumNSW;\n        Changed = true;\n      }\n      return Changed;\n    }\n   │
│ }\n\n  // sext X to W; trunc to original type -> exact roundtrip, imply       │
│ nsw.\n  if (auto *SI = dyn_cast<SExtInst>(Op)) {\n    if (SI->getSrcTy() ==   │
│ DestTy) {\n      if (!TI->hasNoSignedWrap()) {\n                              │
│ TI->setHasNoSignedWrap(true);\n        ++NumNSW;\n        Changed = true;\n   │
│ }\n      return Changed;\n    }\n  }\n\n  // Otherwise, be conservative and   │
│ do not set flags.\n  return false;\n}"})                                      │
