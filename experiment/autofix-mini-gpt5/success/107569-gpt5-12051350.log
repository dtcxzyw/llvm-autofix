│ 237   // at it, remove the dead arguments from the DeadArguments list.                 │
│ 238   for (Function::arg_iterator I = F.arg_begin(), E = F.arg_end(),                  │
│ 239                               I2 = NF->arg_begin();                                │
│ 240        I != E; ++I, ++I2) {                                                        │
│ 241     // Move the name and users over to the new version.                            │
│ 242     I->replaceAllUsesWith(&*I2);                                                   │
│ 243     I2->takeName(&*I);                                                             │
│ 244   }                                                                                │
│ 245                                                                                    │
