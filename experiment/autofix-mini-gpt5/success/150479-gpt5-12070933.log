Final Patch
-----------
diff --git a/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
b/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
index 0adad5a90d31..53217dd9d6b0 100644
--- a/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
+++ b/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
@@ -10637,7 +10637,17 @@ void BoUpSLP::buildTreeRec(ArrayRef<Value *> VLRef,
unsigned Depth,
   };
   if (AreOnlyConstsWithPHIs(VL)) {
     LLVM_DEBUG(dbgs() << "SLP: Gathering due to all constants and
PHIs.\n");
-    newGatherTreeEntry(VL, InstructionsState::invalid(), UserTreeIdx);
+    // If there is an instruction among VL (e.g., a PHI), provide a valid
+    // InstructionsState to help downstream scheduling heuristics.
Otherwise,
+    // keep an invalid state and make sure users guard against it.
+    Instruction *MainAlt = nullptr;
+    for (Value *V : VL) {
+      if (auto *I = dyn_cast<Instruction>(V)) { MainAlt = I; break; }
+    }
+    if (MainAlt)
+      newGatherTreeEntry(VL, InstructionsState(MainAlt, MainAlt),
UserTreeIdx);
+    else
+      newGatherTreeEntry(VL, InstructionsState::invalid(), UserTreeIdx);
     return;
   }

@@ -15703,12 +15713,17 @@ BoUpSLP::isGatherShuffledSingleRegisterEntry(
   const Instruction *TEInsertPt =
&getLastInstructionInBundle(TEUseEI.UserTE);
   const BasicBlock *TEInsertBlock = nullptr;
   // Main node of PHI entries keeps the correct order of operands/incoming
-  // blocks.
-  if (auto *PHI = dyn_cast<PHINode>(TEUseEI.UserTE->getMainOp());
-      PHI && TEUseEI.UserTE->State != TreeEntry::SplitVectorize) {
-    TEInsertBlock = PHI->getIncomingBlock(TEUseEI.EdgeIdx);
-    TEInsertPt = TEInsertBlock->getTerminator();
+  // blocks. Only attempt to query main op if the entry has a valid state.
+  if (TEUseEI.UserTE->hasState()) {
+    if (auto *PHI = dyn_cast<PHINode>(TEUseEI.UserTE->getMainOp());
+        PHI && TEUseEI.UserTE->State != TreeEntry::SplitVectorize) {
+      TEInsertBlock = PHI->getIncomingBlock(TEUseEI.EdgeIdx);
+      TEInsertPt = TEInsertBlock->getTerminator();
+    } else {
+      TEInsertBlock = TEInsertPt->getParent();
+    }
   } else {
+    // No valid state; fall back to using the parent of the insertion
point.
     TEInsertBlock = TEInsertPt->getParent();
   }
   if (!DT->isReachableFromEntry(TEInsertBlock))
@@ -16438,8 +16453,52 @@ Instruction
&BoUpSLP::getLastInstructionInBundle(const TreeEntry *E) {
   // Get the basic block this bundle is in. All instructions in the bundle
   // should be in this block (except for extractelement-like instructions
with
   // constant indices or gathered loads or copyables).
-  auto *Front = E->getMainOp();
+  // Use a representative instruction from the bundle without relying on
+  // InstructionsState::getMainOp(), which may be invalid for some gather
+  // entries (e.g., constants/PHIs).
+  Instruction *Front = nullptr;
+  for (Value *V : E->Scalars) {
+    if (auto *I = dyn_cast<Instruction>(V)) { Front = I; break; }
+  }
+  assert(Front && "Expected at least one instruction in the bundle to
determine insertion point.");
   auto *BB = Front->getParent();
+
+  // If the entry has no valid state (e.g., constants/PHIs gather), avoid
using
+  // opcode/state-dependent queries and just find the last instruction in
the
+  // bundle.
+  if (!E->hasState()) {
+    Res = Front;
+    auto FindLastInstNoState = [&]() {
+      Instruction *LastInst = Front;
+      for (Value *V : E->Scalars) {
+        auto *I = dyn_cast<Instruction>(V);
+        if (!I)
+          continue;
+        if (LastInst->getParent() == I->getParent()) {
+          if (LastInst->comesBefore(I))
+            LastInst = I;
+          continue;
+        }
+        if (!DT->isReachableFromEntry(LastInst->getParent())) {
+          LastInst = I;
+          continue;
+        }
+        if (!DT->isReachableFromEntry(I->getParent()))
+          continue;
+        auto *NodeA = DT->getNode(LastInst->getParent());
+        auto *NodeB = DT->getNode(I->getParent());
+        assert(NodeA && "Should only process reachable instructions");
+        assert(NodeB && "Should only process reachable instructions");
+        if (NodeA->getDFSNumIn() < NodeB->getDFSNumIn())
+          LastInst = I;
+      }
+      return LastInst;
+    };
+    Res = FindLastInstNoState();
+    EntryToLastInstruction.try_emplace(E, Res);
+    return *Res;
+  }
+
   assert(((GatheredLoadsEntriesFirst.has_value() &&
            E->getOpcode() == Instruction::Load && E->isGather() &&
            E->Idx < *GatheredLoadsEntriesFirst) ||

Reference Patch
