Final Patch
-----------
diff --git a/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp
b/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp
index 4bba2f406b4c..1f6bf5abd526 100644
--- a/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp
+++ b/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp
@@ -2794,6 +2794,21 @@ static Instruction *foldSelectWithFCmpToFabs(SelectInst
&SI,
     // fold (X <= +/-0.0) ? (0.0 - X) : X to fabs(X), when 'Swap' is false
     // fold (X >  +/-0.0) ? X : (0.0 - X) to fabs(X), when 'Swap' is true
     if (match(TrueVal, m_FSub(m_PosZeroFP(), m_Specific(X)))) {
+      // Require nnan to ensure NaN sign/canonicalization behavior is preserved.
+      // Allow if the select already has nnan, the fcmp condition has nnan,
+      // or the operand X is known to not be NaN via nofpclass(nan).
+      bool AllowNaNFold = false;
+      FastMathFlags CFMF = cast<FPMathOperator>(CondVal)->getFastMathFlags();
+      if (SI.hasNoNaNs() || CFMF.noNaNs()) {
+        AllowNaNFold = true;
+      } else if (auto *Arg = dyn_cast<Argument>(X)) {
+        FPClassTest NFT = Arg->getNoFPClass();
+        // If NaNs are excluded for X, then it's safe to fold.
+        if (NFT & fcNan)
+          AllowNaNFold = true;
+      }
+      if (!AllowNaNFold)
+        continue;
       if (!Swap && (Pred == FCmpInst::FCMP_OLE || Pred == FCmpInst::FCMP_ULE)) {
         Value *Fabs = IC.Builder.CreateUnaryIntrinsic(Intrinsic::fabs, X, &SI);
         return IC.replaceInstUsesWith(SI, Fabs);

Reference Patch
---------------
commit 3e1e4062e1e95031c32c0ed9786647ef1a4141aa
Author: Yingwei Zheng <dtcxzyw2333@gmail.com>
Date:   Sat Apr 26 14:03:12 2025 +0800

    [InstCombine] Preserve signbit semantics of NaN with fold to fabs (#136648)

    As per the LangRef and IEEE 754-2008 standard, the sign bit of NaN is
    preserved if there is no floating-point operation being performed.
    See also
    https://github.com/llvm/llvm-project/commit/862e35e25a68502433da0a8d0819448ff
5745339
    for reference.

    Alive2: https://alive2.llvm.org/ce/z/QYtEGj
    Closes https://github.com/llvm/llvm-project/issues/136646

diff --git a/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp
b/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp
index 4bba2f406b4c..5a42a5c996da 100644
--- a/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp
+++ b/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp
@@ -2793,7 +2793,14 @@ static Instruction *foldSelectWithFCmpToFabs(SelectInst
&SI,

     // fold (X <= +/-0.0) ? (0.0 - X) : X to fabs(X), when 'Swap' is false
     // fold (X >  +/-0.0) ? X : (0.0 - X) to fabs(X), when 'Swap' is true
-    if (match(TrueVal, m_FSub(m_PosZeroFP(), m_Specific(X)))) {
+    // Note: We require "nnan" for this fold because fcmp ignores the signbit
+    //       of NAN, but IEEE-754 specifies the signbit of NAN values with
+    //       fneg/fabs operations.
+    if (match(TrueVal, m_FSub(m_PosZeroFP(), m_Specific(X))) &&
+        (cast<FPMathOperator>(CondVal)->hasNoNaNs() || SI.hasNoNaNs() ||
+         isKnownNeverNaN(X, /*Depth=*/0,
+                         IC.getSimplifyQuery().getWithInstruction(
+                             cast<Instruction>(CondVal))))) {
       if (!Swap && (Pred == FCmpInst::FCMP_OLE || Pred == FCmpInst::FCMP_ULE)) {
         Value *Fabs = IC.Builder.CreateUnaryIntrinsic(Intrinsic::fabs, X, &SI);
         return IC.replaceInstUsesWith(SI, Fabs);

