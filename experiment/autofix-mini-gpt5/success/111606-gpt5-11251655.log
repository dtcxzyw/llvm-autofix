Final Patch
-----------
diff --git a/llvm/lib/Transforms/Vectorize/VPlan.cpp
b/llvm/lib/Transforms/Vectorize/VPlan.cpp
index 5e3a63880949..c1a10a7dec70 100644
--- a/llvm/lib/Transforms/Vectorize/VPlan.cpp
+++ b/llvm/lib/Transforms/Vectorize/VPlan.cpp
@@ -255,12 +255,14 @@ Value *VPTransformState::get(VPValue *Def, const VPLane
&Lane) {

 Value *VPTransformState::get(VPValue *Def, bool NeedsScalar) {
   if (NeedsScalar) {
+    // When only the first lane is used we may still have generated scalar
values
+    // for all lanes (e.g. a replicated instruction with per-lane execution).
+    // In that case it's still safe to return lane 0 here. Relax the assertion
+    // to require only that lane 0 is available.
     assert((VF.isScalar() || Def->isLiveIn() || hasVectorValue(Def) ||
             !vputils::onlyFirstLaneUsed(Def) ||
-            (hasScalarValue(Def, VPLane(0)) &&
-             Data.VPV2Scalars[Def].size() == 1)) &&
-           "Trying to access a single scalar per part but has multiple scalars "
-           "per part.");
+            hasScalarValue(Def, VPLane(0))) &&
+           "Expected scalar lane 0 to be available when requesting a scalar
value.");
     return get(Def, VPLane(0));
   }


Reference Patch
---------------
commit 01cbbc52dc95fe5d9e30ecbfb2ec8c7c1e0199c4
Author: Florian Hahn <flo@fhahn.com>
Date:   Wed Oct 9 13:18:53 2024 +0100

    [VPlan] Request lane 0 for pointer arg in PtrAdd.

    After 7f74651, the pointer operand may be replicated of a PtrAdd. Instead
    of requesting a single scalar, request lane 0, which correctly handles the
    case when there is a scalar-per-lane.

    Fixes https://github.com/llvm/llvm-project/issues/111606.

diff --git a/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
b/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
index 123eb0d8d71a..2468616be0bd 100644
--- a/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
+++ b/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
@@ -645,8 +645,8 @@ Value *VPInstruction::generate(VPTransformState &State) {
   case VPInstruction::PtrAdd: {
     assert(vputils::onlyFirstLaneUsed(this) &&
            "can only generate first lane for PtrAdd");
-    Value *Ptr = State.get(getOperand(0), /* IsScalar */ true);
-    Value *Addend = State.get(getOperand(1), /* IsScalar */ true);
+    Value *Ptr = State.get(getOperand(0), VPLane(0));
+    Value *Addend = State.get(getOperand(1), VPLane(0));
     return isInBounds() ? Builder.CreateInBoundsPtrAdd(Ptr, Addend, Name)
                         : Builder.CreatePtrAdd(Ptr, Addend, Name);
   }

