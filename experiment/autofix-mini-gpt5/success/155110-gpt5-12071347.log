│ 213   if (!ScalarSize || !MinVectorSize || MinVectorSize % ScalarSize != │
│ 0 ||                                                                     │
│ 214       ScalarSize % 8 != 0)                                           │
│ 215     return false;                                                    │
│ 216                                                                      │
