│ 155 /// Try to replace signed instructions with their unsigned equivalent.    │
│ 156 static bool replaceSignedInst(SCCPSolver &Solver,                         │
│ 157                               SmallPtrSetImpl<Value *> &InsertedValues,   │
│ 158                               Instruction &Inst) {                        │
│ 159   // Determine if a signed value is known to be >= 0.                     │
│ 160   auto isNonNegative = [&Solver](Value *V) {                              │
│ 161     // If this value was constant-folded, it may not have a solver entry. │
│ 162     // Handle integers. Otherwise, return false.                          │
│ 163     if (auto *C = dyn_cast<Constant>(V)) {                                │
│ 164       auto *CInt = dyn_cast<ConstantInt>(C);                              │
│ 165       return CInt && !CInt->isNegative();                                 │
│ 166     }                                                                     │
│ 167     const ValueLatticeElement &IV = Solver.getLatticeValueFor(V);         │
│ 168     return IV.isConstantRange(/*UndefAllowed=*/false) &&                  │
│ 169            IV.getConstantRange().isAllNonNegative();                      │
│ 170   };                                                                      │
│ 171                                                                           │
│ 172   Instruction *NewInst = nullptr;                                         │
│ 173   switch (Inst.getOpcode()) {                                             │
│ 174   case Instruction::SIToFP:                                               │
│ 175   case Instruction::SExt: {                                               │
│ 176     // If the source value is not negative, this is a zext/uitofp.        │
│ 177     Value *Op0 = Inst.getOperand(0);                                      │
│ 178     if (InsertedValues.count(Op0) || !isNonNegative(Op0))                 │
│ 179       return false;                                                       │
│ 180     NewInst = CastInst::Create(Inst.getOpcode() == Instruction::SExt      │
│ 181                                    ? Instruction::ZExt                    │
│ 182                                    : Instruction::UIToFP,                 │
│ 183                                Op0, Inst.getType(), "",                   │
│ Inst.getIterator());                                                          │
│ 184     NewInst->setNonNeg();                                                 │
│ 185     break;                                                                │
│ 186   }                                                                       │
│ 187   case Instruction::AShr: {                                               │
│ 188     // If the shifted value is not negative, this is a logical shift      │
│ right.                                                                        │
│ 189     Value *Op0 = Inst.getOperand(0);                                      │
│ 190     if (InsertedValues.count(Op0) || !isNonNegative(Op0))                 │
│ 191       return false;                                                       │
│ 192     NewInst = BinaryOperator::CreateLShr(Op0, Inst.getOperand(1), "",     │
│ Inst.getIterator());                                                          │
│ 193     NewInst->setIsExact(Inst.isExact());                                  │
│ 194     break;                                                                │
│ 195   }                                                                       │
│ 196   case Instruction::SDiv:                                                 │
│ 197   case Instruction::SRem: {                                               │
│ 198     // If both operands are not negative, this is the same as udiv/urem.  │
│ 199     Value *Op0 = Inst.getOperand(0), *Op1 = Inst.getOperand(1);           │
│ 200     if (InsertedValues.count(Op0) || InsertedValues.count(Op1) ||         │
│ 201         !isNonNegative(Op0) || !isNonNegative(Op1))                       │
│ 202       return false;                                                       │
│ 203     auto NewOpcode = Inst.getOpcode() == Instruction::SDiv ?              │
│ Instruction::UDiv                                                             │
│ 204                                                            :              │
│ Instruction::URem;                                                            │
│ 205     NewInst = BinaryOperator::Create(NewOpcode, Op0, Op1, "",             │
│ Inst.getIterator());                                                          │
│ 206     if (Inst.getOpcode() == Instruction::SDiv)                            │
│ 207       NewInst->setIsExact(Inst.isExact());                                │
│ 208     break;                                                                │
│ 209   }                                                                       │
│ 210   default:                                                                │
│ 211     return false;                                                         │
│ 212   }                                                                       │
│ 213                                                                           │
│ 214   // Wire up the new instruction and update state.                        │
│ 215   assert(NewInst && "Expected replacement instruction");                  │
│ 216   NewInst->takeName(&Inst);                                               │
│ 217   InsertedValues.insert(NewInst);                                         │
│ 218   Inst.replaceAllUsesWith(NewInst);                                       │
│ 219   NewInst->setDebugLoc(Inst.getDebugLoc());                               │
│ 220   Solver.removeLatticeValueFor(&Inst);                                    │
│ 221   Inst.eraseFromParent();                                                 │
│ 222   return true;                                                            │
│ 223 }                                                                         │
