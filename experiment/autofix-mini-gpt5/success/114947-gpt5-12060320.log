│ 563 //     define internal void @RecursiveFn(i32* arg1) {                     │
│ 564 //       %temp = alloca i32, align 4                                      │
│ 565 //       store i32 2 i32* %temp, align 4                                  │
│ 566 //       call void @RecursiveFn.1(i32* nonnull %temp)                     │
│ 567 //       ret void                                                         │
│ 568 //     }                                                                  │
│ 569 //                                                                        │
