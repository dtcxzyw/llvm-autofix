diff --git a/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
b/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
index 4c0a1c4c094b..b3cbabea8f3b 100644
--- a/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
+++ b/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
@@ -13466,6 +13466,13 @@ Value *BoUpSLP::vectorizeTree(TreeEntry *E, bool PostponedPHIs) {
           assert(BWSz > SrcBWSz && "Invalid cast!");
           VecOpcode =
               SrcIt->second.second ? Instruction::SExt : Instruction::ZExt;
+        } else {
+          // Fallback for widening when MinBWs has no info: use zero-extend.
+          // This can happen if the source operand got demoted (e.g., to i1)
+          // but there is no MinBWs entry for either the destination or source.
+          // Trunc/BitCast would be invalid in such cases; default to ZExt.
+          assert(BWSz > SrcBWSz && "Invalid cast!");
+          VecOpcode = Instruction::ZExt;
         }
       } else if (VecOpcode == Instruction::SIToFP && SrcIt != MinBWs.end() &&
                  !SrcIt->second.second) {

