│ 13580 /// Merges shuffle masks and emits final shuffle instruction, if        │
│ required. It                                                                  │
│ 13581 /// supports shuffling of 2 input vectors. It implements lazy shuffles  │
│ emission,                                                                     │
│ 13582 /// when the actual shuffle instruction is generated only if this is    │
│ actually                                                                      │
│ 13583 /// required. Otherwise, the shuffle instruction emission is delayed    │
│ till the                                                                      │
│ 13584 /// end of the process, to reduce the number of emitted instructions    │
│ and further                                                                   │
│ 13585 /// analysis/transformations.                                           │
│ 13586 /// The class also will look through the previously emitted shuffle     │
│ instructions                                                                  │
│ 13587 /// and properly mark indices in mask as undef.                         │
│ 13588 /// For example, given the code                                         │
│ 13589 /// \code                                                               │
│ 13590 /// %s1 = shufflevector <2 x ty> %0, poison, <1, 0>                     │
│ 13591 /// %s2 = shufflevector <2 x ty> %1, poison, <1, 0>                     │
│ 13592 /// \endcode                                                            │
│ 13593 /// and if need to emit shuffle of %s1 and %s2 with mask <1, 0, 3, 2>,  │
│ it will                                                                       │
│ 13594 /// look through %s1 and %s2 and emit                                   │
│ 13595 /// \code                                                               │
│ 13596 /// %res = shufflevector <2 x ty> %0, %1, <0, 1, 2, 3>                  │
│ 13597 /// \endcode                                                            │
│ 13598 /// instead.                                                            │
│ 13599 /// If 2 operands are of different size, the smallest one will be       │
│ resized and                                                                   │
│ 13600 /// the mask recalculated properly.                                     │
│ 13601 /// For example, given the code                                         │
│ 13602 /// \code                                                               │
│ 13603 /// %s1 = shufflevector <2 x ty> %0, poison, <1, 0, 1, 0>               │
