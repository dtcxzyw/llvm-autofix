Final Patch
-----------
diff --git a/llvm/lib/Transforms/Utils/ScalarEvolutionExpander.cpp
b/llvm/lib/Transforms/Utils/ScalarEvolutionExpander.cpp
index c7d758aa575e..bc3b8f8287f1 100644
--- a/llvm/lib/Transforms/Utils/ScalarEvolutionExpander.cpp
+++ b/llvm/lib/Transforms/Utils/ScalarEvolutionExpander.cpp
@@ -825,9 +825,15 @@ bool SCEVExpander::canReuseFlagsFromOriginalIVInc(PHINode *OrigPhi,
                                                   PHINode *WidePhi,
                                                   Instruction *OrigInc,
                                                   Instruction *WideInc) {
-  return match(OrigInc, m_c_BinOp(m_Specific(OrigPhi), m_Value())) &&
-         match(WideInc, m_c_BinOp(m_Specific(WidePhi), m_Value())) &&
-         OrigInc->getOpcode() == WideInc->getOpcode();
+  if (!OrigInc || !WideInc)
+    return false;
+  auto *OB = dyn_cast<BinaryOperator>(OrigInc);
+  auto *WB = dyn_cast<BinaryOperator>(WideInc);
+  if (!OB || !WB)
+    return false;
+  return match(OB, m_c_BinOp(m_Specific(OrigPhi), m_Value())) &&
+         match(WB, m_c_BinOp(m_Specific(WidePhi), m_Value())) &&
+         OB->getOpcode() == WB->getOpcode();
 }

