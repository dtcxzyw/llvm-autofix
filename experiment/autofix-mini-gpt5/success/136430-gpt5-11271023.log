│ 189     BB = nullptr;                                                         │
│ 190     InsertPt = BasicBlock::iterator();                                    │
│ 191   }                                                                       │
│ 192                                                                           │
│ 193   BasicBlock *GetInsertBlock() const { return BB; }                       │
