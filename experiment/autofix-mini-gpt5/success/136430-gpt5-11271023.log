│ 195   LLVMContext &getContext() const { return Context; }                     │
│ 196                                                                           │
│ 197   /// This specifies that created instructions should be appended to the  │
│ 198   /// end of the specified block.                                         │
│ 199   void SetInsertPoint(BasicBlock *TheBB) {                                │
│ 200     BB = TheBB;                                                           │
│ 201     InsertPt = BB->end();                                                 │
│ 202   }                                                                       │
