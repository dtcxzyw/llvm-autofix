│ *LI,                                                                          │
│ 444                      ScalarEvolution *SE) {                               │
│ 445   LoopExitBlocksTy LoopExitBlocks;                                        │
│ 446                                                                           │
│ 447   return formLCSSAImpl(L, DT, LI, SE, LoopExitBlocks);                    │
