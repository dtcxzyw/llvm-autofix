│ =//                                                                           │
│ 626                                                                           │
│ 627 namespace {                                                               │
│ 628                                                                           │
│ 629 /// A simple and fast domtree-based CSE pass.                             │
│ 630 ///                                                                       │
│ 631 /// This pass does a simple depth-first walk over the dominator tree,     │
│ 632 /// eliminating trivially redundant instructions and using instsimplify   │
│ to                                                                            │
│ 633 /// canonicalize things as it goes. It is intended to be fast and catch   │
│ obvious                                                                       │
│ 634 /// cases so that instcombine and other passes are more effective. It is  │
│ 635 /// expected that a later pass of GVN will catch the interesting/hard     │
│ cases.                                                                        │
│ 636 class EarlyCSE {                                                          │
│ 637 public:                                                                   │
│ 638   const TargetLibraryInfo &TLI;                                           │
│ 639   const TargetTransformInfo &TTI;                                         │
│ 640   DominatorTree &DT;                                                      │
│ 641   AssumptionCache &AC;                                                    │
│ 642   const SimplifyQuery SQ;                                                 │
│ 643   MemorySSA *MSSA;                                                        │
│ 644   std::unique_ptr<MemorySSAUpdater> MSSAUpdater;                          │
│ 645                                                                           │
│ 646   using AllocatorTy =                                                     │
│ 647       RecyclingAllocator<BumpPtrAllocator,                                │
│ 648                          ScopedHashTableVal<SimpleValue, Value *>>;       │
│ 649   using ScopedHTType =                                                    │
│ 650       ScopedHashTable<SimpleValue, Value *, DenseMapInfo<SimpleValue>,    │
│ 651                       AllocatorTy>;                                       │
│ 652                                                                           │
│ 653   /// A scoped hash table of the current values of all of our simple      │
│ 654   /// scalar expressions.                                                 │
│ 655   ///                                                                     │
│ 656   /// As we walk down the domtree, we look to see if instructions are in  │
│ this:                                                                         │
│ 657   /// if so, we replace them with what we find, otherwise we insert them  │
│ so                                                                            │
│ 658   /// that dominated values can succeed in their lookup.                  │
│ 659   ScopedHTType AvailableValues;                                           │
│ 660                                                                           │
│ 661   /// A scoped hash table of the current values of previously encountered │
│ 662   /// memory locations.                                                   │
│ 663   ///                                                                     │
│ 664   /// This allows us to get efficient access to dominating loads or       │
│ stores when                                                                   │
│ 665   /// we have a fully redundant load.  In addition to the most recent     │
│ load, we                                                                      │
│ 666   /// keep track of a generation count of the read, which is compared     │
│ against                                                                       │
│ 667   /// the current generation count.  The current generation count is      │
│ incremented                                                                   │
│ 668   /// after every possibly writing memory operation, which ensures that   │
│ we only                                                                       │
│ 669   /// CSE loads with other loads that have no intervening store.          │
│ Ordering                                                                      │
│ 670   /// events (such as fences or atomic instructions) increment the        │
│ generation                                                                    │
│ 671   /// count as well; essentially, we model these as writes to all         │
│ possible                                                                      │
│ 672   /// locations.  Note that atomic and/or volatile loads and stores can   │
│ be                                                                            │
│ 673   /// present the table; it is the responsibility of the consumer to      │
│ inspect                                                                       │
│ 674   /// the atomicity/volatility if needed.                                 │
│ 675   struct LoadValue {                                                      │
│ 676     Instruction *DefInst = nullptr;                                       │
│ 677     unsigned Generation = 0;                                              │
│ 678     int MatchingId = -1;                                                  │
│ 679     bool IsAtomic = false;                                                │
│ 680     bool IsLoad = false;                                                  │
