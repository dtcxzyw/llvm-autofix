│ 315   auto *II = dyn_cast<IntrinsicInst>(Inst);                               │
│ 316   if (II && II->isCommutative() && II->arg_size() >= 2) {                 │
│ 317     Value *LHS = II->getArgOperand(0), *RHS = II->getArgOperand(1);       │
│ 318     if (LHS > RHS)                                                        │
