│ 335     return hashCallInst(CI);                                              │
│ 336                                                                           │
│ 337   // Mix in the opcode.                                                   │
│ 338   return hash_combine(Inst->getOpcode(),                                  │
│ 339                       hash_combine_range(Inst->operand_values()));        │
