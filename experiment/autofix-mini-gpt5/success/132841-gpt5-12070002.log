Final Patch
-----------
diff --git a/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
b/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
index 4dc398f716b3..aff2f1625c57 100644
--- a/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
+++ b/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
@@ -15111,6 +15111,12 @@ Instruction &BoUpSLP::getLastInstructionInBundle(const
TreeEntry *E) {
       Res = (*It)->getBundle().back()->getInst();
       return *Res;
     }
+    // If no bundles were found for V, but we have a block schedule and this is
+    // not a PHI, fall back to brute-force to find the last instruction.
+    if (E->getOpcode() != Instruction::PHI) {
+      Res = FindLastInst();
+      return *Res;
+    }
     assert(E->getOpcode() == Instruction::PHI && "Expected PHI");
   }


