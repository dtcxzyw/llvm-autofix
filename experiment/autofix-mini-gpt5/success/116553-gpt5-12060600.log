Final Patch
-----------
diff --git a/llvm/lib/Transforms/Scalar/ConstraintElimination.cpp
b/llvm/lib/Transforms/Scalar/ConstraintElimination.cpp
index d2e532d29d07..b602140d499f 100644
--- a/llvm/lib/Transforms/Scalar/ConstraintElimination.cpp
+++ b/llvm/lib/Transforms/Scalar/ConstraintElimination.cpp
@@ -1763,9 +1763,30 @@ static bool eliminateConstraints(Function &F,
DominatorTree &DT, LoopInfo &LI,
       if (auto *II = dyn_cast<WithOverflowInst>(Inst)) {
         Changed |= tryToSimplifyOverflowMath(II, Info, ToRemove);
       } else if (auto *Cmp = dyn_cast<ICmpInst>(Inst)) {
-        bool Simplified = checkAndReplaceCondition(
-            Cmp, Info, CB.NumIn, CB.NumOut, CB.getContextInst(),
-            ReproducerModule.get(), ReproducerCondStack, S.DT, ToRemove);
+        bool Simplified = false;
+        // Avoid path-dependent simplifications on non-dedicated loop exits.
+        // If the context block is outside of any loop, but has predecessors
+        // both from inside some loop and from outside any loop, constraints
+        // learned along the loop path may not hold along the non-loop path.
+        BasicBlock *CtxBB = CB.getContextInst()->getParent();
+        Loop *CtxLoop = LI.getLoopFor(CtxBB);
+        bool HasLoopPred = false, HasNonLoopPred = false;
+        if (!pred_empty(CtxBB)) {
+          for (BasicBlock *Pred : predecessors(CtxBB)) {
+            if (LI.getLoopFor(Pred))
+              HasLoopPred = true;
+            else
+              HasNonLoopPred = true;
+            if (HasLoopPred && HasNonLoopPred)
+              break;
+          }
+        }
+        bool IsNonDedicatedExit = (CtxLoop == nullptr) && HasLoopPred &&
HasNonLoopPred;
+        if (!IsNonDedicatedExit) {
+          Simplified = checkAndReplaceCondition(
+              Cmp, Info, CB.NumIn, CB.NumOut, CB.getContextInst(),
+              ReproducerModule.get(), ReproducerCondStack, S.DT, ToRemove);
+        }
         if (!Simplified &&
             match(CB.getContextInst(), m_LogicalOp(m_Value(), m_Value()))) {
           Simplified =

