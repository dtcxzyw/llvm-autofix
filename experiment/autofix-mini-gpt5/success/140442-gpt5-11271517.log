b/llvm/lib/Transforms/Utils/LoopPeel.cpp\n@@ -1213,8 +1213,15 @@ bool
llvm::peelLoop(Loop *L, unsigned PeelCount, bool PeelLast, LoopInfo *LI,\n   if
(PeelLast) {\n     // Now adjust users of the original exit values by replacing
