│       Instruction *After = (I1->comesBefore(I2) ? I2 : I1);                   │
│       Builder.SetInsertPoint(After->getNextNonDebugInstruction());            │
│     } else {                                                                  │
│       // Different blocks: set IP right after I1 by default; if V2 is null    │
│ use I1; otherwise prefer I2 if V2 exists.                                     │
│       Builder.SetInsertPoint(I2->getNextNonDebugInstruction());               │
│     }                                                                         │
│   } else if (I1) {                                                            │
│     Builder.SetInsertPoint(I1->getNextNonDebugInstruction());                 │
│   } else if (I2) {                                                            │
│     Builder.SetInsertPoint(I2->getNextNonDebugInstruction());                 │
│   }                                                                           │
│   // Then perform type adjustment/casting and CreateShuffleVector.            │
│                                                                               │
│ - Edit 2 (lines 15114–15129 in SLPVectorizer.cpp): Similarly adjust           │
│ ShuffleIRBuilder::createShuffleVector(Value *V1, ArrayRef<int> Mask) to set   │
│ the insertion point after V1’s definition if V1 is an Instruction before      │
│ emitting the shuffle.                                                         │
│                                                                               │
│ These local, conservative insertion point adjustments reduce the chance that  │
│ the shuffle is placed before its operands.                                    │
│                                                                               │
