│ edit({"file": "llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp", "old": "  //    │
│ select Cond, !X, X -> xor Cond, X\n  // Do not speculatively execute the value used by │
│ xor if it may produce poison.\n  if (CondVal->getType() == SI.getType() &&             │
│ isKnownInversion(FalseVal, TrueVal)) {\n    if (auto *FI =                             │
│ dyn_cast<Instruction>(FalseVal))\n      if (canCreatePoison(cast<Operator>(FI)))\n     │
│ return nullptr;\n    return BinaryOperator::CreateXor(CondVal, FalseVal);\n  }",       │
│ "new": "  // select Cond, !X, X -> xor Cond, X\n  // Do not speculatively execute the  │
│ value used by xor if it may produce poison.\n  // Additionally, avoid the transform if │
│ exactly one arm is a samesign icmp.\n  // The select guards potential poison from the  │
│ samesign arm, while the xor\n  // would unconditionally consume one operand.\n  if     │
│ (CondVal->getType() == SI.getType() && isKnownInversion(FalseVal, TrueVal)) {\n    if  │
│ (auto *FI = dyn_cast<Instruction>(FalseVal))\n      if                                 │
│ (canCreatePoison(cast<Operator>(FI)))\n        return nullptr;\n    if (auto *FIC =    │
│ dyn_cast<ICmpInst>(FalseVal)) {\n      if (auto *TIC = dyn_cast<ICmpInst>(TrueVal))    │
│ {\n        bool FS = FIC->isSameSign();\n        bool TS = TIC->isSameSign();\n        │
│ // If exactly one side is samesign, keep select to avoid changing poison behavior.\n   │
│ if (FS != TS)\n          return nullptr;\n      }\n    }\n    return                   │
│ BinaryOperator::CreateXor(CondVal, FalseVal);\n  }"})                                  │
