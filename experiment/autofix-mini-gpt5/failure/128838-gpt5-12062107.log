│ 442 void VPBasicBlock::connectToPredecessors(VPTransformState &State) {       │
│ 443   auto &CFG = State.CFG;                                                  │
│ 444   BasicBlock *NewBB = CFG.VPBB2IRBB[this];                                │
│ 445   // Hook up the new basic block to its predecessors.                     │
│ 446   for (VPBlockBase *PredVPBlock : getHierarchicalPredecessors()) {        │
│ 447     VPBasicBlock *PredVPBB = PredVPBlock->getExitingBasicBlock();         │
│ 448     auto &PredVPSuccessors = PredVPBB->getHierarchicalSuccessors();       │
│ 449     BasicBlock *PredBB = CFG.VPBB2IRBB[PredVPBB];                         │
│ 450                                                                           │
│ 451     assert(PredBB && "Predecessor basic-block not found building          │
│ successor.");                                                                 │
│ 452     auto *PredBBTerminator = PredBB->getTerminator();                     │
│ 453     LLVM_DEBUG(dbgs() << "LV: draw edge from" << PredBB->getName() <<     │
│ '\n');                                                                        │
│ 454                                                                           │
│ 455     auto *TermBr = dyn_cast<BranchInst>(PredBBTerminator);                │
│ 456     if (isa<UnreachableInst>(PredBBTerminator)) {                         │
│ 457       assert(PredVPSuccessors.size() == 1 &&                              │
│ 458              "Predecessor ending w/o branch must have single              │
│ successor.");                                                                 │
│ 459       DebugLoc DL = PredBBTerminator->getDebugLoc();                      │
│ 460       PredBBTerminator->eraseFromParent();                                │
│ 461       auto *Br = BranchInst::Create(NewBB, PredBB);                       │
│ 462       Br->setDebugLoc(DL);                                                │
│ 463     } else if (TermBr && !TermBr->isConditional()) {                      │
│ 464       TermBr->setSuccessor(0, NewBB);                                     │
│ 465     } else {                                                              │
│ 466       // Set each forward successor here when it is created, excluding    │
│ 467       // backedges. A backward successor is set when the branch is        │
│ created.                                                                      │
│ 468       unsigned idx = PredVPSuccessors.front() == this ? 0 : 1;            │
│ 469       assert((TermBr && (!TermBr->getSuccessor(idx) ||                    │
│ 470                          (isa<VPIRBasicBlock>(this) &&                    │
│ 471                           TermBr->getSuccessor(idx) == NewBB))) &&        │
│ 472              "Trying to reset an existing successor block.");             │
│ 473       TermBr->setSuccessor(idx, NewBB);                                   │
│ 474     }                                                                     │
│ 475     CFG.DTU.applyUpdates({{DominatorTree::Insert, PredBB, NewBB}});       │
│ 476   }                                                                       │
