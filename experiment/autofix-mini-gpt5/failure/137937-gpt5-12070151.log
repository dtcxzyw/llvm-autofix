│ NumOut(DTN->getDFSNumOut()),                                                  │
│ 131         Ty(Ty) {}                                                         │
│ 132                                                                           │
│ 133   FactOrCheck(DomTreeNode *DTN, Use *U)                                   │
│ 134       : U(U), NumIn(DTN->getDFSNumIn()), NumOut(DTN->getDFSNumOut()),     │
│ 135         Ty(EntryTy::UseCheck) {}                                          │
