│ (auto *Br = dyn_cast<BranchInst>(MovedTerm)) {\n                              │
│ BranchInst::Create(Br->getSuccessor(0), MovedTerm);\n                         │
│ MovedTerm->eraseFromParent();\n      }\n      new                             │
│ UnreachableInst(Preheader->getContext(), MemCheckBlock);\n                    │
│ Preheader->getTerminator()->eraseFromParent();\n    }\n", "new": "    //      │
│ Unhook the temporary block(s) with the checks without moving any\n    //      │
│ existing terminators. This avoids introducing non-inserted users of\n    //   │
│ the expanded SCEV values (which would break SCEVExpanderCleaner\n    //       │
│ invariants). We redirect the preheader directly to the original loop\n    //  │
│ header and turn the check blocks into unreachable islands.\n    if            │
│ (SCEVCheckBlock || MemCheckBlock) {\n      BasicBlock *FinalCheckBlock =      │
│ MemCheckBlock ? MemCheckBlock : SCEVCheckBlock;\n      BranchInst *PreBr =    │
│ cast<BranchInst>(Preheader->getTerminator());\n      BranchInst *FinalBr =    │
│ cast<BranchInst>(FinalCheckBlock->getTerminator());\n      // The original    │
│ successor of the chain of split blocks is the successor\n      // of the      │
│ final check block's branch.\n      PreBr->setSuccessor(0,                     │
│ FinalBr->getSuccessor(0));\n    }\n    if (SCEVCheckBlock) {\n                │
│ ReplaceInstWithInst(SCEVCheckBlock->getTerminator(),\n                        │
│ new UnreachableInst(Preheader->getContext(), SCEVCheckBlock));\n    }\n    if │
│ (MemCheckBlock) {\n                                                           │
│ ReplaceInstWithInst(MemCheckBlock->getTerminator(),\n                         │
│ new UnreachableInst(Preheader->getContext(), MemCheckBlock));\n    }\n"})     │
