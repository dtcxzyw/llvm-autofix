│ 371 /// ThreadingPath is a path in the control flow of a loop that can be threaded          │
│ 372 /// by cloning necessary basic blocks and replacing conditional branches with           │
│ 373 /// unconditional ones. A threading path includes a list of basic blocks, the           │
│ 374 /// exit state, and the block that determines the next state.                           │
│ 375 struct ThreadingPath {                                                                  │
│ 376   /// Exit value is DFA's exit state for the given path.                                │
│ 377   APInt getExitValue() const { return ExitVal; }                                        │
│ 378   void setExitValue(const ConstantInt *V) {                                             │
│ 379     ExitVal = V->getValue();                                                            │
│ 380     IsExitValSet = true;                                                                │
│ 381   }                                                                                     │
│ 382   bool isExitValueSet() const { return IsExitValSet; }                                  │
│ 383                                                                                         │
│ 384   /// Determinator is the basic block that determines the next state of the DFA.        │
│ 385   const BasicBlock *getDeterminatorBB() const { return DBB; }                           │
│ 386   void setDeterminator(const BasicBlock *BB) { DBB = BB; }                              │
│ 387                                                                                         │
│ 388   /// Path is a list of basic blocks.                                                   │
│ 389   const PathType &getPath() const { return Path; }                                      │
│ 390   void setPath(const PathType &NewPath) { Path = NewPath; }                             │
│ 391   void push_back(BasicBlock *BB) { Path.push_back(BB); }                                │
│ 392   void push_front(BasicBlock *BB) { Path.push_front(BB); }                              │
│ 393   void appendExcludingFirst(const PathType &OtherPath) {                                │
│ 394     Path.insert(Path.end(), OtherPath.begin() + 1, OtherPath.end());                    │
│ 395   }                                                                                     │
│ 396                                                                                         │
│ 397   void print(raw_ostream &OS) const {                                                   │
│ 398     OS << Path << " [ " << ExitVal << ", " << DBB->getName() << " ]";                   │
│ 399   }                                                                                     │
│ 400                                                                                         │
│ 401 private:                                                                                │
│ 402   PathType Path;                                                                        │
