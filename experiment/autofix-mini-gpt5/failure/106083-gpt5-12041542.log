│ 370 /// ThreadingPath is a path in the control flow of a loop that can be threaded          │
│ 371 /// by cloning necessary basic blocks and replacing conditional branches with           │
│ 372 /// unconditional ones. A threading path includes a list of basic blocks, the           │
│ 373 /// exit state, and the block that determines the next state.                           │
│ 374 struct ThreadingPath {                                                                  │
│ 375   /// Exit value is DFA's exit state for the given path.                                │
│ 376   APInt getExitValue() const { return ExitVal; }                                        │
│ 377   void setExitValue(const ConstantInt *V) {                                             │
│ 378     ExitVal = V->getValue();                                                            │
│ 379     IsExitValSet = true;                                                                │
│ 380   }                                                                                     │
│ 381   bool isExitValueSet() const { return IsExitValSet; }                                  │
│ 382                                                                                         │
│ 383   /// Determinator is the basic block that determines the next state of the DFA.        │
│ 384   const BasicBlock *getDeterminatorBB() const { return DBB; }                           │
│ 385   void setDeterminator(const BasicBlock *BB) { DBB = BB; }                              │
│ 386                                                                                         │
│ 387   /// Path is a list of basic blocks.                                                   │
│ 388   const PathType &getPath() const { return Path; }                                      │
│ 389   void setPath(const PathType &NewPath) { Path = NewPath; }                             │
│ 390   void push_back(BasicBlock *BB) { Path.push_back(BB); }                                │
│ 391   void push_front(BasicBlock *BB) { Path.push_front(BB); }                              │
│ 392   void appendExcludingFirst(const PathType &OtherPath) {                                │
│ 393     Path.insert(Path.end(), OtherPath.begin() + 1, OtherPath.end());                    │
│ 394   }                                                                                     │
│ 395                                                                                         │
│ 396   void print(raw_ostream &OS) const {                                                   │
│ 397     OS << Path << " [ " << ExitVal << ", " << DBB->getName() << " ]";                   │
│ 398   }                                                                                     │
│ 399                                                                                         │
│ 400 private:                                                                                │
│ 401   PathType Path;                                                                        │
│ 402   APInt ExitVal;                                                                        │
│ 403   const BasicBlock *DBB = nullptr;                                                      │
│ 404   bool IsExitValSet = false;                                                            │
│ 405 };                                                                                      │
