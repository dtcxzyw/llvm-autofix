│ 389   const PathType &getPath() const { return Path; }                                      │
│ 390   void setPath(const PathType &NewPath) { Path = NewPath; }                             │
│ 391   void push_back(BasicBlock *BB) { Path.push_back(BB); }                                │
│ 392   void push_front(BasicBlock *BB) { Path.push_front(BB); }                              │
│ 393   void appendExcludingFirst(const PathType &OtherPath) {                                │
