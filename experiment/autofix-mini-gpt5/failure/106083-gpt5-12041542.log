│ 372 /// exit state, and the block that determines the next state.                   │
│ 373 struct ThreadingPath {                                                          │
│ 374   /// Exit value is DFA's exit state for the given path.                        │
│ 375   APInt getExitValue() const { return ExitVal; }                                │
