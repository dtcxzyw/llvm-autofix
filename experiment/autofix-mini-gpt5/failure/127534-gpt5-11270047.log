│ 510 bool LoopPredication::isLoopInvariantValue(const SCEV* S) {               │
│ 511   // Handling expressions which produce invariant results, but *haven't*  │
│ yet                                                                           │
│ 512   // been removed from the loop serves two important purposes.            │
│ 513   // 1) Most importantly, it resolves a pass ordering cycle which would   │
│ 514   // otherwise need us to iteration licm, loop-predication, and either    │
│ 515   // loop-unswitch or loop-peeling to make progress on examples with lots │
│ of                                                                            │
│ 516   // predicable range checks in a row.  (Since, in the general case,  we  │
│ can't                                                                         │
│ 517   // hoist the length checks until the dominating checks have been        │
│ discharged                                                                    │
│ 518   // as we can't prove doing so is safe.)                                 │
│ 519   // 2) As a nice side effect, this exposes the value of peeling or       │
│ unswitching                                                                   │
│ 520   // much more obviously in the IR.  Otherwise, the cost modeling for     │
│ other                                                                         │
│ 521   // transforms would end up needing to duplicate all of this logic to    │
│ model a                                                                       │
│ 522   // check which becomes predictable based on a modeled peel or unswitch. │
│ 523   //                                                                      │
│ 524   // The cost of doing so in the worst case is an extra fill from the     │
│ stack  in                                                                     │
│ 525   // the loop to materialize the loop invariant test value instead of     │
│ checking                                                                      │
│ 526   // against the original IV which is presumable in a register inside the │
│ loop.                                                                         │
│ 527   // Such cases are presumably rare, and hint at missing oppurtunities    │
│ for                                                                           │
│ 528   // other passes.                                                        │
│ 529                                                                           │
│ 530   if (SE->isLoopInvariant(S, L))                                          │
│ 531     // Note: This the SCEV variant, so the original Value* may be within  │
│ the                                                                           │
│ 532     // loop even though SCEV has proven it is loop invariant.             │
│ 533     return true;                                                          │
│ 534                                                                           │
│ 535   // Handle a particular important case which SCEV doesn't yet know about │
│ which                                                                         │
│ 536   // shows up in range checks on arrays with immutable lengths.           │
│ 537   // TODO: This should be sunk inside SCEV.                               │
│ 538   if (const SCEVUnknown *U = dyn_cast<SCEVUnknown>(S))                    │
│ 539     if (const auto *LI = dyn_cast<LoadInst>(U->getValue()))               │
│ 540       if (LI->isUnordered() && L->hasLoopInvariantOperands(LI))           │
│ 541         if (!isModSet(AA->getModRefInfoMask(LI->getOperand(0))) ||        │
│ 542             LI->hasMetadata(LLVMContext::MD_invariant_load))              │
│ 543           return true;                                                    │
│ 544   return false;                                                           │
│ 545 }                                                                         │
