│ if (SLPReVec && isa<FixedVectorType>(Ty))\n    Ty = Ty->getScalarType();\n    │
│ // Avoid creating vectors of pointers which may be placed at an insertion\n   │
│ // point that does not dominate all uses in complex CFGs. While LLVM IR\n  // │
│ technically allows vector-of-pointer types, SLP currently does not\n  //      │
│ reliably ensure dominance when building such vectors (e.g. via\n  //          │
│ insertelement + shufflevector splats). Conservatively reject pointer\n  //    │
│ element types to prevent verifier failures.\n  if (Ty->isPointerTy())\n       │
│ return false;\n  return VectorType::isValidElementType(Ty) &&                 │
│ !Ty->isX86_FP80Ty() &&\n         !Ty->isPPC_FP128Ty();\n}"})                  │
