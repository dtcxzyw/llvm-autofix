│ dyn_cast<LoadInst>(&I)) {\n      Value *PtrOp = LI->getPointerOperand();\n    │
│ bool NeedsMask = !SafePtrs.count(PtrOp);\n      // Apply poison-safety        │
│ heuristic only when the pointer is computed in a\n      // conditionally      │
