│ speculated if safe to do so.)\n    // The existing \"SafePtrs\" set only      │
│ reasons about dereferenceability /\n    // faulting. When predicating a block │
│ we may still generate poison values\n    // for instructions in inactive      │
│ lanes. If the pointer operand of a load is\n    // defined in a predicated    │
│ block, and we speculate the load, the widened\n    // (unmasked) load would   │
│ use a poison pointer and immediately trigger UB.\n    // Conservatively       │
│ require masking (or scalar predication) for such loads.\n    if (auto *LI =   │
│ dyn_cast<LoadInst>(&I)) {\n      Value *PtrOp = LI->getPointerOperand();\n    │
│ bool NeedsMask = !SafePtrs.count(PtrOp);\n      if (!NeedsMask &&             │
│ blockNeedsPredication(BB)) {\n        if (auto *PtrInst =                     │
│ dyn_cast<Instruction>(PtrOp)) {\n          // If the pointer is produced in   │
│ this predicated block and is not\n          // loop invariant, its value for  │
│ inactive lanes may become poison\n          // after if-conversion. Do not    │
│ speculate the load.\n          if (PtrInst->getParent() == BB &&              │
│ !TheLoop->isLoopInvariant(PtrOp))\n            NeedsMask = true;\n        }\n │
│ }\n      if (NeedsMask)\n        MaskedOp.insert(LI);\n      continue;\n      │
│ }\n"})                                                                        │
