│ "old": "    // Loads are handled via masking (or speculated if safe to do     │
│ so.)\n    // However, dereferenceability alone is insufficient if the         │
│ pointer\n    // computation itself may become poison after predication. This  │
│ happens\n    // when we widen a conditional block and replace results of      │
│ inactive lanes\n    // (e.g. from divisions) with poison, and then speculate  │
│ the load.\n    // Conservatively require masking if the pointer operand       │
│ depends (through\n    // instructions in this block) on a predicated          │
│ division/remainder op.\n    if (auto *LI = dyn_cast<LoadInst>(&I)) {\n        │
│ auto DependsOnPredicatedUnsafeOp = [&](Value *V) {\n        SmallPtrSet<Value │
│ *, 8> Visited;\n        SmallVector<Value *, 8> Worklist;\n                   │
│ Worklist.push_back(V);\n        while (!Worklist.empty()) {\n          Value  │
│ *Cur = Worklist.pop_back_val();\n          if (!Visited.insert(Cur).second)\n │
│ continue;\n          auto *CurI = dyn_cast<Instruction>(Cur);\n          if   │
│ (!CurI || CurI->getParent() != BB)\n            continue; // Stop at values   │
│ from other blocks or non-instructions.\n          // Division / remainder ops │
│ are used in if-conversion via widening\n          // and replaced by poison   │
│ in inactive lanes. If the pointer depends\n          // on such an op inside  │
│ a predicated block, we must not speculate.\n          if (CurI->getOpcode()   │
│ == Instruction::SDiv ||\n              CurI->getOpcode() == Instruction::UDiv │
│ ||\n              CurI->getOpcode() == Instruction::SRem ||\n                 │
│ CurI->getOpcode() == Instruction::URem)\n            return true;\n           │
│ for (Value *Op : CurI->operands())\n            Worklist.push_back(Op);\n     │
│ }\n        return false;\n      };\n\n      Value *PtrOp =                    │
│ LI->getPointerOperand();\n      bool NeedsMask = !SafePtrs.count(PtrOp);\n    │
│ if (!NeedsMask && blockNeedsPredication(BB) &&                                │
│ DependsOnPredicatedUnsafeOp(PtrOp))\n        NeedsMask = true;\n      if      │
│ (NeedsMask)\n        MaskedOp.insert(LI);\n      continue;\n    }", "new": "  │
│ // Loads are handled via masking (or speculated if safe to do so.)\n    //    │
│ Add a narrow poison-safety heuristic: if the load's pointer operand is\n      │
│ // computed inside a predicated block and depends on a division/remainder\n   │
│ // instruction in that same block, require masking. This prevents\n    //     │
│ vectorizing a predicated division into a lane that becomes poison and\n    // │
│ then using that poison pointer in an unmasked wide load (UB). Only\n    //    │
│ trigger in the specific risky pattern to avoid perturbing other tests.\n      │
│ if (auto *LI = dyn_cast<LoadInst>(&I)) {\n      Value *PtrOp =                │
│ LI->getPointerOperand();\n      bool NeedsMask = !SafePtrs.count(PtrOp);\n    │
│ if (!NeedsMask && blockNeedsPredication(BB)) {\n        if (auto *PtrInst =   │
│ dyn_cast<Instruction>(PtrOp)) {\n          if (PtrInst->getParent() == BB)    │
│ {\n            SmallPtrSet<Value *, 8> Visited;\n                             │
│ SmallVector<Value *, 8> Worklist{PtrOp};\n            bool DivDep = false;\n  │
│ while (!Worklist.empty() && !DivDep) {\n              Value *Cur =            │
│ Worklist.pop_back_val();\n              if (!Visited.insert(Cur).second)\n    │
│ continue;\n              auto *CurI = dyn_cast<Instruction>(Cur);\n           │
│ if (!CurI || CurI->getParent() != BB)\n                continue;\n            │
│ switch (CurI->getOpcode()) {\n              case Instruction::SDiv:\n         │
│ case Instruction::UDiv:\n              case Instruction::SRem:\n              │
│ case Instruction::URem:\n                DivDep = true; break;\n              │
│ default:\n                for (Value *Op : CurI->operands())\n                │
│ Worklist.push_back(Op);\n              }\n            }\n            if       │
│ (DivDep)\n              NeedsMask = true;\n          }\n        }\n      }\n  │
│ if (NeedsMask)\n        MaskedOp.insert(LI);\n      continue;\n    }"})       │
