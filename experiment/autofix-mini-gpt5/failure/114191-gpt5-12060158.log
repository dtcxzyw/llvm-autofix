│ isKnownNonZero(Op1, Q);\n      }\n    }\n    if (AllowThread) {\n      if     │
│ (Value *V = threadBinOpOverSelect(Opcode, Op0, Op1, Q, MaxRecurse))\n         │
│ return V;\n    }\n  }", "new": "  // If the operation is with the result of a │
│ select instruction, check whether\n  // operating on either branch of the     │
│ select always yields the same value.\n  // For division and remainder,        │
│ threading over a select that may yield zero\n  // in the divisor can be       │
│ unsafe unless we know the divisor is non-zero across\n  // all paths. If the  │
│ divisor is a select-of-constants, only allow threading\n  // if both arms are │
│ provably non-zero (per-element for vectors).\n  if (isa<SelectInst>(Op0) ||   │
│ isa<SelectInst>(Op1)) {\n    bool IsDivRem = (Opcode == Instruction::SDiv ||  │
│ Opcode == Instruction::UDiv ||\n                     Opcode ==                │
│ Instruction::SRem || Opcode == Instruction::URem);\n    bool AllowThread =    │
│ true;\n    if (IsDivRem) {\n      auto IsConstNonZero = [&](Constant *C) {\n  │
│ if (!C)\n          return false;\n        if (C->isZeroValue() ||             │
│ Q.isUndefValue(C))\n          return false;\n        if (auto *VTy =          │
│ dyn_cast<FixedVectorType>(C->getType())) {\n          unsigned NumElts =      │
│ VTy->getNumElements();\n          for (unsigned i = 0; i != NumElts; ++i) {\n │
│ Constant *Elt = C->getAggregateElement(i);\n            if (!Elt ||           │
│ Elt->isZeroValue() || Q.isUndefValue(Elt))\n              return false;\n     │
│ }\n        }\n        return true;\n      };\n      if (auto *Sel =           │
│ dyn_cast<SelectInst>(Op1)) {\n        Constant *T =                           │
│ dyn_cast<Constant>(Sel->getTrueValue());\n        Constant *F =               │
│ dyn_cast<Constant>(Sel->getFalseValue());\n        AllowThread =              │
│ IsConstNonZero(T) && IsConstNonZero(F);\n      } else {\n        AllowThread  │
│ = isKnownNonZero(Op1, Q);\n      }\n    }\n    if (AllowThread) {\n      if   │
│ (Value *V = threadBinOpOverSelect(Opcode, Op0, Op1, Q, MaxRecurse))\n         │
│ return V;\n    }\n  }"})                                                      │
