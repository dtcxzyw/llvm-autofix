│ threadBinOpOverSelect(Opcode, Op0, Op1, Q, MaxRecurse))\n      return V;",    │
│ "new": "  // If the operation is with the result of a select instruction,     │
│ check whether\n  // operating on either branch of the select always yields    │
│ the same value.\n  // For division and remainder, threading over a select     │
│ that may yield zero\n  // in the divisor can be unsafe unless we are dealing  │
│ with a select-of-constants\n  // (which can be folded safely into a select of │
│ computed results) or we can\n  // prove the divisor is non-zero.\n  if        │
│ (isa<SelectInst>(Op0) || isa<SelectInst>(Op1)) {\n    bool IsDivRem = (Opcode │
│ == Instruction::SDiv || Opcode == Instruction::UDiv ||\n                      │
│ Opcode == Instruction::SRem || Opcode == Instruction::URem);\n    bool        │
│ AllowThread = true;\n    if (IsDivRem) {\n      if (auto *Sel =               │
│ dyn_cast<SelectInst>(Op1)) {\n        // Allow threading if the divisor is a  │
│ select-of-constants; poison-per-arm\n        // folding is handled by         │
│ downstream logic.\n        AllowThread = isa<Constant>(Sel->getTrueValue())   │
│ && isa<Constant>(Sel->getFalseValue());\n      } else {\n        //           │
│ Otherwise, only thread if the divisor is known non-zero.\n        AllowThread │
│ = isKnownNonZero(Op1, Q);\n      }\n    }\n    if (AllowThread) {\n      if   │
│ (Value *V = threadBinOpOverSelect(Opcode, Op0, Op1, Q, MaxRecurse))\n         │
│ return V;\n    }\n  }"})                                                      │
