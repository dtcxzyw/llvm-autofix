│ backedge).\n  DenseMap<Value *, Value *> ReverseLVMap;\n  for (auto &KV :     │
│ LVMap)\n    if (KV.second)\n      ReverseLVMap[KV.second] = const_cast<Value  │
│ *>(KV.first);\n\n  for (auto &Edge : ExitEdges) {\n    BasicBlock *ExitFrom = │
│ Edge.first;\n    BasicBlock *ExitTo = Edge.second;\n    for (PHINode &PN :    │
