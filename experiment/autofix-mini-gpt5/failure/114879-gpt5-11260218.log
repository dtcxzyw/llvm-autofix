│ edit({"file": "llvm/lib/Transforms/Utils/LoopPeel.cpp", "old": "  for (const  │
│ auto &[Term, Info] : Weights) {\n    setBranchWeights(*Term, Info.Weights,    │
│ /*IsExpected=*/false);\n  }", "new": "  // Fix exit-block PHIs to ensure the  │
│ value coming from the original\n  // in-loop predecessor (ExitFrom)           │
│ corresponds to the value observed when the\n  // remaining loop exits on its  │
│ first iteration. In that case, ExitFrom is\n  // reached from the loop        │
│ header, not via the latch/backedge. If the incoming\n  // value is a PHI in   │
│ ExitFrom, select the non-latch incoming.\n  for (auto &Edge : ExitEdges) {\n  │
│ BasicBlock *ExitFrom = Edge.first;\n    BasicBlock *ExitTo = Edge.second;\n   │
│ for (PHINode &PHI : ExitTo->phis()) {\n      Value *Incoming =                │
│ PHI.getIncomingValueForBlock(ExitFrom);\n      if (auto *IncomingPHI =        │
│ dyn_cast<PHINode>(Incoming)) {\n        if (IncomingPHI->getParent() ==       │
│ ExitFrom) {\n          BasicBlock *Chosen = nullptr;\n          // Prefer the │
│ header incoming if available, otherwise any non-latch.\n          for         │
│ (unsigned i = 0, e = IncomingPHI->getNumIncomingValues(); i != e; ++i) {\n    │
│ BasicBlock *Pred = IncomingPHI->getIncomingBlock(i);\n            if (Pred == │
│ Latch)\n              continue;\n            if (!Chosen)\n                   │
│ Chosen = Pred;\n            if (Pred == Header) {\n              Chosen =     │
│ Pred;\n              break;\n            }\n          }\n          if         │
│ (Chosen)\n            Incoming =                                              │
│ IncomingPHI->getIncomingValueForBlock(Chosen);\n        }\n      }\n      //  │
│ Update only if ExitFrom is indeed a predecessor.\n      int Idx =             │
│ PHI.getBasicBlockIndex(ExitFrom);\n      if (Idx >= 0) {\n                    │
│ PHI.setIncomingValue(Idx, Incoming);\n                                        │
│ SE->forgetLcssaPhiWithNewPredecessor(L, &PHI);\n      }\n    }\n  }\n\n  for  │
│ (const auto &[Term, Info] : Weights) {\n    setBranchWeights(*Term,           │
│ Info.Weights, /*IsExpected=*/false);\n  }"})                                  │
