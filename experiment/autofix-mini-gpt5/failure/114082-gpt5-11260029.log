│ 13592 /// Merges shuffle masks and emits final shuffle instruction, if        │
│ required. It                                                                  │
│ 13593 /// supports shuffling of 2 input vectors. It implements lazy shuffles  │
│ emission,                                                                     │
│ 13594 /// when the actual shuffle instruction is generated only if this is    │
│ actually                                                                      │
│ 13595 /// required. Otherwise, the shuffle instruction emission is delayed    │
│ till the                                                                      │
│ 13596 /// end of the process, to reduce the number of emitted instructions    │
│ and further                                                                   │
│ 13597 /// analysis/transformations.                                           │
│ 13598 /// The class also will look through the previously emitted shuffle     │
│ instructions                                                                  │
│ 13599 /// and properly mark indices in mask as undef.                         │
│ 13600 /// For example, given the code                                         │
│ 13601 /// \code                                                               │
│ 13602 /// %s1 = shufflevector <2 x ty> %0, poison, <1, 0>                     │
│ 13603 /// %s2 = shufflevector <2 x ty> %1, poison, <1, 0>                     │
│ 13604 /// \endcode                                                            │
│ 13605 /// and if need to emit shuffle of %s1 and %s2 with mask <1, 0, 3, 2>,  │
│ it will                                                                       │
│ 13606 /// look through %s1 and %s2 and emit                                   │
│ 13607 /// \code                                                               │
│ 13608 /// %res = shufflevector <2 x ty> %0, %1, <0, 1, 2, 3>                  │
│ 13609 /// \endcode                                                            │
│ 13610 /// instead.                                                            │
│ 13611 /// If 2 operands are of different size, the smallest one will be       │
│ resized and                                                                   │
│ 13612 /// the mask recalculated properly.                                     │
│ 13613 /// For example, given the code                                         │
│ 13614 /// \code                                                               │
│ 13615 /// %s1 = shufflevector <2 x ty> %0, poison, <1, 0, 1, 0>               │
│ 13616 /// %s2 = shufflevector <2 x ty> %1, poison, <1, 0, 1, 0>               │
│ 13617 /// \endcode                                                            │
│ 13618 /// and if need to emit shuffle of %s1 and %s2 with mask <1, 0, 5, 4>,  │
│ it will                                                                       │
│ 13619 /// look through %s1 and %s2 and emit                                   │
│ 13620 /// \code                                                               │
│ 13621 /// %res = shufflevector <2 x ty> %0, %1, <0, 1, 2, 3>                  │
│ 13622 /// \endcode                                                            │
│ 13623 /// instead.                                                            │
