│ Replace:                                                                      │
│   Vec = InsElt = Builder.CreateInsertVector(                                  │
│       Vec->getType(), Vec, Scalar,                                            │
│       Builder.getInt64(Pos * VecTy->getNumElements()));                       │
│                                                                               │
│ With:                                                                         │
│   // Ensure dominance: place the insert after the Scalar definition if        │
│ possible.                                                                     │
│   Instruction *SavedIP = nullptr;                                             │
│   BasicBlock::iterator SavedIt;                                               │
│   BasicBlock *SavedBB = nullptr;                                              │
│   if (auto *SI = dyn_cast<Instruction>(Scalar)) {                             │
│     if (SI->getParent()) {                                                    │
│       SavedBB = Builder.GetInsertBlock();                                     │
│       if (SavedBB) {                                                          │
│         SavedIP = Builder.GetInsertPoint() != SavedBB->end() ?                │
│ &*Builder.GetInsertPoint() : nullptr;                                         │
│       }                                                                       │
│       auto NextIt = std::next(SI->getIterator());                             │
│       Builder.SetInsertPoint(SI->getParent(), NextIt);                        │
│     }                                                                         │
│   }                                                                           │
│   Vec = InsElt = Builder.CreateInsertVector(                                  │
│       Vec->getType(), Vec, Scalar,                                            │
│       Builder.getInt64(Pos * VecTy->getNumElements()));                       │
│   // Restore original insertion point.                                        │
│   if (SavedBB) {                                                              │
│     if (SavedIP)                                                              │
│       Builder.SetInsertPoint(SavedBB, SavedIP->getIterator());                │
│     else                                                                      │
│       Builder.SetInsertPoint(SavedBB);                                        │
│   }                                                                           │
│                                                                               │
│ This ensures the newly created intrinsic is placed after its operand          │
│ definition, satisfying dominance.                                             │
│                                                                               │
│ Optionally, a similar guard can be added in the else branch for               │
│ CreateInsertElement, but the reported verifier error is specifically about    │
│ vector.insert, so we keep the change minimal.                                 │
│                                                                               │
│ 5. Conclusion:                                                                │
│ The crash is caused by emitting a vector.insert intrinsic at an insertion     │
│ point where its operand doesn't dominate, breaking IR immediately. By         │
│ adjusting the IRBuilder's insertion point to be immediately after the         │
│ operand's defining instruction (when the operand is an Instruction), we       │
│ ensure correct dominance and prevent the verifier failure. This localized fix │
│ in BoUpSLP::CreateInsertElement stabilizes the SLPReVec insertion path and    │
│ should resolve the reported SIGABRT.                                          │
