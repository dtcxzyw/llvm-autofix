│ 504 bool SimplifyIndvar::eliminateTrunc(TruncInst *TI) {                      │
│ 505   // It is always legal to replace                                        │
│ 506   //   icmp <pred> i32 trunc(iv), n                                       │
│ 507   // with                                                                 │
│ 508   //   icmp <pred> i64 sext(trunc(iv)), sext(n), if pred is signed        │
│ predicate.                                                                    │
│ 509   // Or with                                                              │
│ 510   //   icmp <pred> i64 zext(trunc(iv)), zext(n), if pred is unsigned      │
│ predicate.                                                                    │
│ 511   // Or with either of these if pred is an equality predicate.            │
│ 512   //                                                                      │
│ 513   // If we can prove that iv == sext(trunc(iv)) or iv == zext(trunc(iv))  │
│ for                                                                           │
│ 514   // every comparison which uses trunc, it means that we can replace each │
│ of                                                                            │
│ 515   // them with comparison of iv against sext/zext(n). We no longer need   │
│ trunc                                                                         │
│ 516   // after that.                                                          │
│ 517   //                                                                      │
│ 518   // TODO: Should we do this if we can widen *some* comparisons, but not  │
│ all                                                                           │
│ 519   // of them? Sometimes it is enough to enable other optimizations, but   │
│ the                                                                           │
│ 520   // trunc instruction will stay in the loop.                             │
│ 521   Value *IV = TI->getOperand(0);                                          │
│ 522   Type *IVTy = IV->getType();                                             │
│ 523   const SCEV *IVSCEV = SE->getSCEV(IV);                                   │
│ 524   const SCEV *TISCEV = SE->getSCEV(TI);                                   │
│ 525                                                                           │
│ 526   // Check if iv == zext(trunc(iv)) and if iv == sext(trunc(iv)). If so,  │
│ we can                                                                        │
│ 527   // get rid of trunc                                                     │
│ 528   bool DoesSExtCollapse = false;                                          │
│ 529   bool DoesZExtCollapse = false;                                          │
│ 530   if (IVSCEV == SE->getSignExtendExpr(TISCEV, IVTy))                      │
│ 531     DoesSExtCollapse = true;                                              │
│ 532   if (IVSCEV == SE->getZeroExtendExpr(TISCEV, IVTy))                      │
│ 533     DoesZExtCollapse = true;                                              │
│ 534                                                                           │
│ 535   // If neither sext nor zext does collapse, it is not profitable to do   │
│ any                                                                           │
│ 536   // transform. Bail.                                                     │
│ 537   if (!DoesSExtCollapse && !DoesZExtCollapse)                             │
│ 538     return false;                                                         │
│ 539                                                                           │
│ 540   // Collect users of the trunc that look like comparisons against        │
│ invariants.                                                                   │
│ 541   // Bail if we find something different.                                 │
│ 542   SmallVector<ICmpInst *, 4> ICmpUsers;                                   │
│ 543   for (auto *U : TI->users()) {                                           │
│ 544     // We don't care about users in unreachable blocks.                   │
│ 545     if (isa<Instruction>(U) &&                                            │
│ 546         !DT->isReachableFromEntry(cast<Instruction>(U)->getParent()))     │
│ 547       continue;                                                           │
│ 548     ICmpInst *ICI = dyn_cast<ICmpInst>(U);                                │
│ 549     if (!ICI) return false;                                               │
│ 550     assert(L->contains(ICI->getParent()) && "LCSSA form broken?");        │
│ 551     if (!(ICI->getOperand(0) == TI &&                                     │
│ L->isLoopInvariant(ICI->getOperand(1))) &&                                    │
│ 552         !(ICI->getOperand(1) == TI &&                                     │
│ L->isLoopInvariant(ICI->getOperand(0))))                                      │
│ 553       return false;                                                       │
│ 554     // If we cannot get rid of trunc, bail.                               │
│ 555     if (ICI->isSigned() && !DoesSExtCollapse)                             │
│ 556       return false;                                                       │
│ 557     if (ICI->isUnsigned() && !DoesZExtCollapse)                           │
│ 558       return false;                                                       │
│ 559     // For equality, either signed or unsigned works.                     │
│ 560     ICmpUsers.push_back(ICI);                                             │
│ 561   }                                                                       │
│ 562                                                                           │
│ 563   auto CanUseZExt = [&](ICmpInst *ICI) {                                  │
│ 564     // Unsigned comparison can be widened as unsigned.                    │
│ 565     if (ICI->isUnsigned())                                                │
│ 566       return true;                                                        │
│ 567     // Is it profitable to do zext?                                       │
│ 568     if (!DoesZExtCollapse)                                                │
│ 569       return false;                                                       │
│ 570     // For equality, we can safely zext both parts.                       │
│ 571     if (ICI->isEquality())                                                │
│ 572       return true;                                                        │
│ 573     // Otherwise we can only use zext when comparing two non-negative or  │
│ two                                                                           │
│ 574     // negative values. But in practice, we will never pass               │
│ DoesZExtCollapse                                                              │
│ 575     // check for a negative value, because zext(trunc(x)) is              │
│ non-negative. So                                                              │
│ 576     // it only make sense to check for non-negativity here.               │
│ 577     const SCEV *SCEVOP1 = SE->getSCEV(ICI->getOperand(0));                │
│ 578     const SCEV *SCEVOP2 = SE->getSCEV(ICI->getOperand(1));                │
│ 579     return SE->isKnownNonNegative(SCEVOP1) &&                             │
│ SE->isKnownNonNegative(SCEVOP2);                                              │
│ 580   };                                                                      │
│ 581   // Replace all comparisons against trunc with comparisons against IV.   │
│ 582   for (auto *ICI : ICmpUsers) {                                           │
│ 583     bool IsSwapped = L->isLoopInvariant(ICI->getOperand(0));              │
│ 584     auto *Op1 = IsSwapped ? ICI->getOperand(0) : ICI->getOperand(1);      │
│ 585     IRBuilder<> Builder(ICI);                                             │
│ 586     Value *Ext = nullptr;                                                 │
│ 587     // For signed/unsigned predicate, replace the old comparison with     │
│ comparison                                                                    │
│ 588     // of immediate IV against sext/zext of the invariant argument. If we │
│ can                                                                           │
│ 589     // use either sext or zext (i.e. we are dealing with equality         │
│ predicate),                                                                   │
│ 590     // then prefer zext as a more canonical form.                         │
│ 591     // TODO: If we see a signed comparison which can be turned into       │
│ unsigned,                                                                     │
│ 592     // we can do it here for canonicalization purposes.                   │
│ 593     ICmpInst::Predicate Pred = ICI->getPredicate();                       │
│ 594     if (IsSwapped) Pred = ICmpInst::getSwappedPredicate(Pred);            │
│ 595     if (CanUseZExt(ICI)) {                                                │
│ 596       assert(DoesZExtCollapse && "Unprofitable zext?");                   │
│ 597       Ext = Builder.CreateZExt(Op1, IVTy, "zext");                        │
│ 598       Pred = ICmpInst::getUnsignedPredicate(Pred);                        │
│ 599     } else {                                                              │
│ 600       assert(DoesSExtCollapse && "Unprofitable sext?");                   │
│ 601       Ext = Builder.CreateSExt(Op1, IVTy, "sext");                        │
│ 602       assert(Pred == ICmpInst::getSignedPredicate(Pred) && "Must be       │
│ signed!");                                                                    │
│ 603     }                                                                     │
│ 604     bool Changed;                                                         │
│ 605     L->makeLoopInvariant(Ext, Changed);                                   │
│ 606     (void)Changed;                                                        │
│ 607     auto *NewCmp = Builder.CreateICmp(Pred, IV, Ext);                     │
│ 608     ICI->replaceAllUsesWith(NewCmp);                                      │
│ 609     DeadInsts.emplace_back(ICI);                                          │
