│ // non-negativity for loop-varying values and model srem like urem.\n  if     │
│ (auto *BO = dyn_cast<BinaryOperator>(I)) {\n    if (BO->getOpcode() ==        │
│ Instruction::SRem) {\n      const DataLayout &DL =                            │
│ I->getModule()->getDataLayout();\n      SimplifyQuery SQ(DL, DT,              │
│ /*AC=*/nullptr, /*CxtI=*/I);\n      if                                        │
│ (!isKnownNonNegative(BO->getOperand(1), SQ))\n        return false;\n    }\n  │
│ }\n\n  // Get the symbolic expression for this instruction.\n  const SCEV *S  │
│ = SE->getSCEV(I);\n"})                                                        │
