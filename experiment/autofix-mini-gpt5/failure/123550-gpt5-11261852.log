│ 220   const SCEV *X = SE->getSCEVAtScope(ICmp->getOperand(1 - IVOperIdx),     │
│ ICmpLoop);                                                                    │
│ 221   auto LIP = SE->getLoopInvariantPredicate(Pred, S, X, L, ICmp);          │
│ 222   if (!LIP)                                                               │
