│ 127 /// Fold an IV operand into its use.  This removes increments of an       │
│ 128 /// aligned IV when used by a instruction that ignores the low bits.      │
│ 129 ///                                                                       │
│ 130 /// IVOperand is guaranteed SCEVable, but UseInst may not be.             │
│ 131 ///                                                                       │
│ 132 /// Return the operand of IVOperand for this induction variable if        │
│ IVOperand can                                                                 │
│ 133 /// be folded (in case more folding opportunities have been exposed).     │
│ 134 /// Otherwise return null.                                                │
│ 135 Value *SimplifyIndvar::foldIVUser(Instruction *UseInst, Instruction       │
│ *IVOperand) {                                                                 │
│ 136   Value *IVSrc = nullptr;                                                 │
│ 137   const unsigned OperIdx = 0;                                             │
│ 138   const SCEV *FoldedExpr = nullptr;                                       │
│ 139   bool MustDropExactFlag = false;                                         │
│ 140   switch (UseInst->getOpcode()) {                                         │
│ 141   default:                                                                │
│ 142     return nullptr;                                                       │
│ 143   case Instruction::UDiv:                                                 │
│ 144   case Instruction::LShr:                                                 │
│ 145     // We're only interested in the case where we know something about    │
│ 146     // the numerator and have a constant denominator.                     │
│ 147     if (IVOperand != UseInst->getOperand(OperIdx) ||                      │
│ 148         !isa<ConstantInt>(UseInst->getOperand(1)))                        │
│ 149       return nullptr;                                                     │
│ 150                                                                           │
│ 151     // Attempt to fold a binary operator with constant operand.           │
│ 152     // e.g. ((I + 1) >> 2) => I >> 2                                      │
│ 153     if (!isa<BinaryOperator>(IVOperand)                                   │
│ 154         || !isa<ConstantInt>(IVOperand->getOperand(1)))                   │
│ 155       return nullptr;                                                     │
│ 156                                                                           │
│ 157     IVSrc = IVOperand->getOperand(0);                                     │
│ 158     // IVSrc must be the (SCEVable) IV, since the other operand is const. │
│ 159     assert(SE->isSCEVable(IVSrc->getType()) && "Expect SCEVable IV        │
│ operand");                                                                    │
│ 160                                                                           │
│ 161     ConstantInt *D = cast<ConstantInt>(UseInst->getOperand(1));           │
│ 162     if (UseInst->getOpcode() == Instruction::LShr) {                      │
│ 163       // Get a constant for the divisor. See createSCEV.                  │
│ 164       uint32_t BitWidth =                                                 │
│ cast<IntegerType>(UseInst->getType())->getBitWidth();                         │
│ 165       if (D->getValue().uge(BitWidth))                                    │
│ 166         return nullptr;                                                   │
│ 167                                                                           │
│ 168       D = ConstantInt::get(UseInst->getContext(),                         │
│ 169                            APInt::getOneBitSet(BitWidth,                  │
│ D->getZExtValue()));                                                          │
│ 170     }                                                                     │
│ 171     const SCEV *LHS = SE->getSCEV(IVSrc);                                 │
│ 172     const SCEV *RHS = SE->getSCEV(D);                                     │
│ 173     FoldedExpr = SE->getUDivExpr(LHS, RHS);                               │
│ 174     // We might have 'exact' flag set at this point which will no longer  │
│ be                                                                            │
│ 175     // correct after we make the replacement.                             │
│ 176     if (UseInst->isExact() && LHS != SE->getMulExpr(FoldedExpr, RHS))     │
│ 177       MustDropExactFlag = true;                                           │
│ 178   }                                                                       │
│ 179   // We have something that might fold it's operand. Compare SCEVs.       │
│ 180   if (!SE->isSCEVable(UseInst->getType()))                                │
│ 181     return nullptr;                                                       │
│ 182                                                                           │
│ 183   // Bypass the operand if SCEV can prove it has no effect.               │
│ 184   if (SE->getSCEV(UseInst) != FoldedExpr)                                 │
│ 185     return nullptr;                                                       │
│ 186                                                                           │
│ 187   LLVM_DEBUG(dbgs() << "INDVARS: Eliminated IV operand: " << *IVOperand   │
│ 188                     << " -> " << *UseInst << '\n');                       │
│ 189                                                                           │
│ 190   UseInst->setOperand(OperIdx, IVSrc);                                    │
│ 191   assert(SE->getSCEV(UseInst) == FoldedExpr && "bad SCEV with folded      │
│ oper");                                                                       │
│ 192                                                                           │
│ 193   if (MustDropExactFlag)                                                  │
│ 194     UseInst->dropPoisonGeneratingFlags();                                 │
│ 195                                                                           │
│ 196   ++NumElimOperand;                                                       │
│ 197   Changed = true;                                                         │
│ 198   if (IVOperand->use_empty())                                             │
