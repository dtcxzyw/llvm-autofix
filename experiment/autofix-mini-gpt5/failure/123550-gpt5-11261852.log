│ 442 bool SimplifyIndvar::eliminateOverflowIntrinsic(WithOverflowInst *WO) {   │
│ 443   const SCEV *LHS = SE->getSCEV(WO->getLHS());                            │
│ 444   const SCEV *RHS = SE->getSCEV(WO->getRHS());                            │
│ 445   if (!SE->willNotOverflow(WO->getBinaryOp(), WO->isSigned(), LHS, RHS))  │
│ 446     return false;                                                         │
│ 447                                                                           │
