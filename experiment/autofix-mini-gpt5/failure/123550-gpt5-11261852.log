│ 114 /// Find a point in code which dominates all given instructions. We can   │
│ safely                                                                        │
│ 115 /// assume that, whatever fact we can prove at the found point, this fact │
│ is                                                                            │
│ 116 /// also true for each of the given instructions.                         │
│ 117 static Instruction *findCommonDominator(ArrayRef<Instruction *>           │
│ Instructions,                                                                 │
│ 118                                         DominatorTree &DT) {              │
│ 119   Instruction *CommonDom = nullptr;                                       │
│ 120   for (auto *Insn : Instructions)                                         │
│ 121     CommonDom =                                                           │
│ 122         CommonDom ? DT.findNearestCommonDominator(CommonDom, Insn) :      │
│ Insn;                                                                         │
│ 123   assert(CommonDom && "Common dominator not found?");                     │
│ 124   return CommonDom;                                                       │
│ 125 }                                                                         │
