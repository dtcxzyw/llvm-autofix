│ overflow                                                                      │
│ 449   // intrinsic as well.                                                   │
│ 450                                                                           │
│ 451   BinaryOperator *NewResult = BinaryOperator::Create(                     │
│ 452       WO->getBinaryOp(), WO->getLHS(), WO->getRHS(), "",                  │
│ WO->getIterator());                                                           │
│ 453                                                                           │
│ 454   if (WO->isSigned())                                                     │
│ 455     NewResult->setHasNoSignedWrap(true);                                  │
│ 456   else                                                                    │
│ 457     NewResult->setHasNoUnsignedWrap(true);                                │
│ 458                                                                           │
│ 459   SmallVector<ExtractValueInst *, 4> ToDelete;                            │
│ 460                                                                           │
│ 461   for (auto *U : WO->users()) {                                           │
│ 462     if (auto *EVI = dyn_cast<ExtractValueInst>(U)) {                      │
│ 463       if (EVI->getIndices()[0] == 1)                                      │
│ 464         EVI->replaceAllUsesWith(ConstantInt::getFalse(WO->getContext())); │
│ 465       else {                                                              │
│ 466         assert(EVI->getIndices()[0] == 0 && "Only two possibilities!");   │
│ 467         EVI->replaceAllUsesWith(NewResult);                               │
│ 468         NewResult->setDebugLoc(EVI->getDebugLoc());                       │
│ 469       }                                                                   │
│ 470       ToDelete.push_back(EVI);                                            │
│ 471     }                                                                     │
│ 472   }                                                                       │
│ 473                                                                           │
│ 474   for (auto *EVI : ToDelete)                                              │
│ 475     EVI->eraseFromParent();                                               │
│ 476                                                                           │
│ 477   if (WO->use_empty())                                                    │
│ 478     WO->eraseFromParent();                                                │
