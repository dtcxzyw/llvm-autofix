│ edit({"file": "llvm/lib/Transforms/Utils/LoopUnrollRuntime.cpp", "old": "///  │
│ Connect the unrolling prolog code to the original loop.", "new": "// Helper   │
│ to conservatively reject runtime unrolling if expanding the SCEV\n// for trip │
│ or backedge count could introduce a potential unsigned division by\n// zero.  │
│ SCEV can represent a udiv where the divisor is not provably non-zero.\n//     │
│ Expanding such an expression would materialize a 'udiv' instruction and\n//   │
│ introduce undefined behavior not present in the original program.\nstatic     │
│ bool hasUnsafeUDiv(const SCEV *S, ScalarEvolution &SE) {\n  if (const auto    │
│ *UD = dyn_cast<SCEVUDivExpr>(S))\n    if (!SE.isKnownNonZero(UD->getRHS()))\n │
│ return true;\n  for (const SCEV *Op : S->operands())\n    if                  │
│ (hasUnsafeUDiv(Op, SE))\n      return true;\n  return false;\n}\n/// Connect  │
│ the unrolling prolog code to the original loop."})                            │
