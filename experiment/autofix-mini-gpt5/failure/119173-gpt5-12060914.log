│ 450 /// Process a loop nest depth first.                                      │
│ 451 static bool formLCSSARecursivelyImpl(Loop &L, const DominatorTree &DT,    │
│ 452                                      const LoopInfo *LI, ScalarEvolution  │
│ *SE,                                                                          │
│ 453                                      LoopExitBlocksTy &LoopExitBlocks) {  │
│ 454   bool Changed = false;                                                   │
│ 455                                                                           │
│ 456   // Recurse depth-first through inner loops.                             │
│ 457   for (Loop *SubLoop : L.getSubLoops())                                   │
│ 458     Changed |= formLCSSARecursivelyImpl(*SubLoop, DT, LI, SE,             │
│ LoopExitBlocks);                                                              │
│ 459                                                                           │
│ 460   Changed |= formLCSSAImpl(L, DT, LI, SE, LoopExitBlocks);                │
│ 461   return Changed;                                                         │
│ 462 }                                                                         │
