│ Res.push_back(ResElem);\n  }\nwith:\n  IRBuilder<> Builder(&EVI);\n           │
│ assert(!EVI.getIndices().empty() && \"Make sure an index exists\");\n         │
│ unsigned Index = EVI.getIndices()[0];\n  // First extract the selected vector │
│ component from the struct.\n  Value *Vec = Builder.CreateExtractValue(Op,     │
│ Index, EVI.getName() + \".elem\" + Twine(Index));\n  // Now scatter the       │
│ extracted vector into its fragments.\n  Scatterer Op0 = scatter(&EVI, Vec,    │
