│ 539 /// Create a conditional branch using \p Cond branching to the       │
│ successors of \p                                                         │
│ 540 /// VPBB. Note that the first successor is always forward (i.e. not  │
│ created yet)                                                             │
│ 541 /// while the second successor may already have been created (if it  │
│ is a header                                                              │
│ 542 /// block and VPBB is a latch).                                      │
│ 543 static BranchInst *createCondBranch(Value *Cond, VPBasicBlock *VPBB, │
│ 544                                     VPTransformState &State) {       │
│ 545   // Replace the temporary unreachable terminator with a new         │
│ conditional                                                              │
│ 546   // branch, hooking it up to backward destination (header) for      │
│ latch blocks                                                             │
│ 547   // now, and to forward destination(s) later when they are created. │
│ 548   // Second successor may be backwards - iff it is already in        │
│ VPBB2IRBB.                                                               │
│ 549   VPBasicBlock *SecondVPSucc =                                       │
│ cast<VPBasicBlock>(VPBB->getSuccessors()[1]);                            │
│ 550   BasicBlock *SecondIRSucc =                                         │
│ State.CFG.VPBB2IRBB.lookup(SecondVPSucc);                                │
│ 551   BasicBlock *IRBB = State.CFG.VPBB2IRBB[VPBB];                      │
│ 552   BranchInst *CondBr = State.Builder.CreateCondBr(Cond, IRBB,        │
│ SecondIRSucc);                                                           │
│ 553   // First successor is always forward, reset it to nullptr          │
│ 554   CondBr->setSuccessor(0, nullptr);                                  │
│ 555   IRBB->getTerminator()->eraseFromParent();                          │
│ 556   return CondBr;                                                     │
│ 557 }                                                                    │
