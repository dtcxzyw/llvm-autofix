│ extraction through trunc. A conservative and targeted fix is to make splitGEP bail out early when any           │
│ sequential index operand is a trunc with nsw, avoiding both extraction and accumulation for such cases. This    │
│ prevents miscompilation for the reproducer without broadly affecting other transformations.                     │
│                                                                                                                 │
│ ```bash                                                                                                         │
│ sed -n '1070,1120p' llvm/lib/Transforms/Scalar/SeparateConstOffsetFromGEP.cpp | awk '1' && sed -i '1078a\  //   │
│ Conservatively bail out if any sequential index is a trunc with NSW, to avoid strengthening poison when         │
│ distributing additions across trunc.\ngep_type_iterator PreGTI = gep_type_begin(*GEP);\nfor (unsigned PI = 1,   │
│ PE = GEP->getNumOperands(); PI != PE; ++PI, ++PreGTI) {\n  if (!PreGTI.isSequential()) continue;\n  if (auto    │
│ *TI = dyn_cast<TruncInst>(GEP->getOperand(PI))) {\n    if (TI->hasNoSignedWrap()) return Changed; // Do not     │
│ transform\n  }\n}\n' llvm/lib/Transforms/Scalar/SeparateConstOffsetFromGEP.cpp && sed -n '1070,1130p'           │
│ llvm/lib/Transforms/Scalar/SeparateConstOffsetFromGEP.cpp && submit-patch                                       │
