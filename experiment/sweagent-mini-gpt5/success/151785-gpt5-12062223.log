│ THOUGHT: The verifier still sees lifetime.start/end on null, which means the replacement is happening via the   │
│ leader table path that doesn’t use the per-use callback. We must modify canReplacePointersIfEqual (used to gate │
│ LeaderTable.insert) to disallow pointer replacement when equalities would cause illegal substitution into       │
│ lifetime intrinsics. I will patch GVN.cpp to wrap the canReplacePointersIfEqual check with an additional filter │
│ that scans uses of LHS and skips leader-table insertion if any use is operand 1 of a lifetime intrinsic. This   │
│ prevents the global canonicalization that was bypassing our previous guards.                                    │
│                                                                                                                 │
│ ```bash                                                                                                         │
│ python3 - << 'PY'                                                                                               │
│ import pathlib, re, sys, subprocess, textwrap                                                                   │
│ p = pathlib.Path("llvm/lib/Transforms/Scalar/GVN.cpp")                                                          │
│ s = p.read_text()                                                                                               │
│ # Locate the spot where LeaderTable.insert is guarded by canReplacePointersIfEqual                              │
│ pat =                                                                                                           │
│ r'if\s*\(\s*RootDominatesEnd\s*&&\s*!\s*isa<Instruction>\(RHS\)\s*&&\s*canReplacePointersIfEqual\s*\(\s*LHS\s*, │
│ \s*RHS\s*,\s*DL\s*\)\s*\)\s*\n\s*LeaderTable\.insert\(LVN,\s*RHS,\s*Root\.getEnd\(\)\);'                        │
│ m = re.search(pat, s)                                                                                           │
│ if not m:                                                                                                       │
│     print("Failed to locate LeaderTable insertion guard", file=sys.stderr)                                      │
│     sys.exit(1)                                                                                                 │
│ start = m.start()                                                                                               │
│ end = m.end()                                                                                                   │
│ # Replace with extended guard that checks lifetime uses on LHS                                                  │
│ replacement = textwrap.dedent('''                                                                               │
│     if (RootDominatesEnd && !isa<Instruction>(RHS) &&                                                           │
│         canReplacePointersIfEqual(LHS, RHS, DL)) {                                                              │
│       bool SafeForLifetime = true;                                                                              │
│       // Scan uses of LHS and avoid leader-table insertion if it would replace                                  │
│       // operand 1 (pointer) of a lifetime.start/end intrinsic.                                                 │
│       if (LHS->hasOneUse() || LHS->hasNUsesOrMore(1)) {                                                         │
│         for (const Use &U : LHS->uses()) {                                                                      │
│           if (const Instruction *UserI = dyn_cast<Instruction>(U.getUser())) {                                  │
│             if (const IntrinsicInst *II = dyn_cast<IntrinsicInst>(UserI)) {                                     │
│               Intrinsic::ID ID = II->getIntrinsicID();                                                          │
│               if ((ID == Intrinsic::lifetime_start || ID == Intrinsic::lifetime_end) &&                         │
│                   U.getOperandNo() == 1) {                                                                      │
│                 SafeForLifetime = false;                                                                        │
│                 break;                                                                                          │
│               }                                                                                                 │
│             }                                                                                                   │
│           }                                                                                                     │
│         }                                                                                                       │
│       }                                                                                                         │
│       if (SafeForLifetime)                                                                                      │
│         LeaderTable.insert(LVN, RHS, Root.getEnd());                                                            │
│     }                                                                                                           │
│ ''').strip()                                                                                                    │
│ s = s[:start] + replacement + s[end:]                                                                           │
│ p.write_text(s)                                                                                                 │
│ subprocess.run(["submit-patch"], check=False)                                                                   │
│ PY                                                                                                              │
│ ```                                                                                                             │
