diff --git a/llvm/lib/Transforms/Scalar/GVN.cpp b/llvm/lib/Transforms/Scalar/GVN.cpp
index f6bf09d09433..1e6fb6795ea1 100644
--- a/llvm/lib/Transforms/Scalar/GVN.cpp
+++ b/llvm/lib/Transforms/Scalar/GVN.cpp
@@ -2504,7 +2504,16 @@ bool GVNPass::replaceOperandsForInBlockEquality(Instruction *Instr) const {
     if (It != ReplaceOperandsWithMap.end()) {
       LLVM_DEBUG(dbgs() << "GVN replacing: " << *Operand << " with "
                         << *It->second << " in instruction " << *Instr << '\n');
-      Instr->setOperand(OpNum, It->second);
+
+// Avoid replacing the pointer operand of lifetime intrinsics.
+// The verifier requires llvm.lifetime.start/end to operate on an alloca or poison.
+if (auto *II = dyn_cast<IntrinsicInst>(Instr)) {
+  Intrinsic::ID ID = II->getIntrinsicID();
+  if ((ID == Intrinsic::lifetime_start || ID == Intrinsic::lifetime_end) &&
+      OpNum == 1)
+    continue;
+}
+Instr->setOperand(OpNum, It->second);
       Changed = true;
     }
   }
@@ -2533,11 +2542,11 @@ bool GVNPass::propagateEquality(Value *LHS, Value *RHS,
     if (LHS == RHS)
       continue;
     assert(LHS->getType() == RHS->getType() && "Equality but unequal types!");
-
     // Don't try to propagate equalities between constants.
     if (isa<Constant>(LHS) && isa<Constant>(RHS))
       continue;

+
     // Prefer a constant on the right-hand side, or an Argument if no constants.
     if (isa<Constant>(LHS) || (isa<Argument>(LHS) && !isa<Constant>(RHS)))
       std::swap(LHS, RHS);
@@ -2576,29 +2585,52 @@ bool GVNPass::propagateEquality(Value *LHS, Value *RHS,
