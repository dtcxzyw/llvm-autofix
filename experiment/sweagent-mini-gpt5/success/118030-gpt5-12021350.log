│ ```                                                                                                                                                                                      │
│                                                                                                                                                                                          │
│ ### Submit your patch:                                                                                                                                                                   │
│                                                                                                                                                                                          │
│ ```bash                                                                                                                                                                                  │
│ # This command has no arguments                                                                                                                                                          │
│ submit-patch                                                                                                                                                                             │
│ ```                                                                                                                                                                                      │
│                                                                                                                                                                                          │
