diff --git a/llvm/lib/Transforms/Scalar/ConstraintElimination.cpp
b/llvm/lib/Transforms/Scalar/ConstraintElimination.cpp
index da5be383df15..cfca37692602 100644
--- a/llvm/lib/Transforms/Scalar/ConstraintElimination.cpp
+++ b/llvm/lib/Transforms/Scalar/ConstraintElimination.cpp
@@ -792,7 +792,30 @@ ConstraintTy ConstraintInfo::getConstraintForSolving(CmpInst::Predicate Pred,
     return ConstraintTy(SmallVector<int64_t, 8>(Value2Index.size(), 0), false,
                         false, false);
   }
-
+  // Conservatively bail out if operands involve NSW multiplication by a large constant.
+  // Decomposition does not soundly handle signed-wrapping muls with large factors, which can
+  // lead to incorrect reasoning (e.g., chains of mul nsw by +/-5001000 under assumptions).
+  // Keep reasoning for small constants (<=255) to preserve existing i8 simplifications.
+  // Place this early in the function to avoid adding variables unnecessarily.
+  do {
+    auto hasBadNSWMulByLargeConst = [](Value *V) {
+      Value *X; ConstantInt *CI;
+      if (match(V, m_NSWMul(m_Value(X), m_ConstantInt(CI))) ||
+          match(V, m_NSWMul(m_ConstantInt(CI), m_Value(X)))) {
+        if (CI->getBitWidth() <= 64) {
+          int64_t K = CI->getSExtValue();
+          if (K < -255 || K > 255)
+            return true;
+        } else {
+          return true;
+        }
+      }
+      return false;
+    };
+    if (hasBadNSWMulByLargeConst(Op0) || hasBadNSWMulByLargeConst(Op1))
+      return ConstraintTy();
+  } while (false);
+  SmallVector<Value *> NewVariables;
   // If both operands are known to be non-negative, change signed predicates to
   // unsigned ones. This increases the reasoning effectiveness in combination
   // with the signed <-> unsigned transfer logic.
@@ -800,14 +823,12 @@ ConstraintTy ConstraintInfo::getConstraintForSolving(CmpInst::Predicate Pred,
       isKnownNonNegative(Op0, DL, /*Depth=*/MaxAnalysisRecursionDepth - 1) &&
       isKnownNonNegative(Op1, DL, /*Depth=*/MaxAnalysisRecursionDepth - 1))
     Pred = ICmpInst::getUnsignedPredicate(Pred);
-
-  SmallVector<Value *> NewVariables;
   ConstraintTy R = getConstraint(Pred, Op0, Op1, NewVariables);
   if (!NewVariables.empty())
     return {};
   return R;
-}

+}
 bool ConstraintTy::isValid(const ConstraintInfo &Info) const {
   return Coefficients.size() > 0 &&
          all_of(Preconditions, [&Info](const ConditionTy &C) {

Reference Patch
---------------
commit 287294d54d7a806e70b0061cf5ccc1fc2bd03eea
Author: Yingwei Zheng <dtcxzyw2333@gmail.com>
Date:   Thu May 22 11:31:04 2025 +0800

    [ConstraintElim] Do not allow overflows in `Decomposition` (#140541)

    Consider the following case:
    ```
    define i1 @pr140481(i32 %x) {
      %cond = icmp slt i32 %x, 0
      call void @llvm.assume(i1 %cond)
      %add = add nsw i32 %x, 5001000
      %mul1 = mul nsw i32 %add, -5001000
      %mul2 = mul nsw i32 %mul1, 5001000
      %cmp2 = icmp sgt i32 %mul2, 0
      ret i1 %cmp2
    }
    ```
    Before this patch, `decompose(%mul2)` returns `-25010001000000 * %x +
    4052193514966861312`.
    Therefore, `%cmp2` will be simplified into true because `%x s< 0 &&
    -25010001000000 * %x + 4052193514966861312 s<= 0` is unsat.

    It is incorrect since the offset `-25010001000000 * 5001000 ->
    4052193514966861312` signed wraps.
    This patch treats a decomposition as invalid if overflows occur when
    computing coefficients.

    Closes https://github.com/llvm/llvm-project/issues/140481.

diff --git a/llvm/lib/Transforms/Scalar/ConstraintElimination.cpp
b/llvm/lib/Transforms/Scalar/ConstraintElimination.cpp
index da5be383df15..cbad5dd35768 100644
