Final Patch
-----------
diff --git a/llvm/lib/Transforms/IPO/FunctionAttrs.cpp b/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
index bbfed2ac2c09..9d2d5fe83879 100644
--- a/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
+++ b/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
@@ -656,25 +656,28 @@ ArgumentAccessInfo getArgumentAccessInfo(const Instruction *I,
                                          const ArgumentUse &ArgUse,
                                          const DataLayout &DL) {
   auto GetTypeAccessRange =
-      [&DL](Type *Ty,
-            std::optional<int64_t> Offset) -> std::optional<ConstantRange> {
+      [&](Type *Ty, std::optional<int64_t> Offset) -> std::optional<ConstantRange> {
     auto TypeSize = DL.getTypeStoreSize(Ty);
     if (!TypeSize.isScalable() && Offset) {
-      int64_t Size = TypeSize.getFixedValue();
-      return ConstantRange(APInt(64, *Offset, true),
-                           APInt(64, *Offset + Size, true));
+      APInt Lower(64, *Offset, true);
+      APInt SizeAP(64, TypeSize.getFixedValue(), true);
+      APInt Upper = Lower + SizeAP;
+      if (Lower.slt(Upper))
+        return ConstantRange(Lower, Upper);
+      return std::nullopt;
     }
     return std::nullopt;
   };
   auto GetConstantIntRange =
-      [](Value *Length,
-         std::optional<int64_t> Offset) -> std::optional<ConstantRange> {
+      [](Value *Length, std::optional<int64_t> Offset) -> std::optional<ConstantRange> {
     auto *ConstantLength = dyn_cast<ConstantInt>(Length);
-    if (ConstantLength && Offset &&
-        ConstantLength->getValue().isStrictlyPositive()) {
-      return ConstantRange(
-          APInt(64, *Offset, true),
-          APInt(64, *Offset + ConstantLength->getSExtValue(), true));
+    if (ConstantLength && Offset && ConstantLength->getValue().isStrictlyPositive()) {
+      APInt Lower(64, *Offset, true);
+      APInt LenAP(64, ConstantLength->getSExtValue(), true);
+      APInt Upper = Lower + LenAP;
+      if (Lower.slt(Upper))
+        return ConstantRange(Lower, Upper);
+      return std::nullopt;
     }
     return std::nullopt;
   };

Reference Patch
---------------
commit 0547e84181ff10b24d6363bbfc97f168fe245397
Author: Arthur Eubanks <aeubanks@google.com>
Date:   Wed Apr 23 15:56:24 2025 -0700

    [FunctionAttrs] Bail if initializes range overflows 64-bit signed int (#137053)

    Otherwise the range doesn't make sense since we interpret it as signed.

    Fixes #134115

diff --git a/llvm/lib/Transforms/IPO/FunctionAttrs.cpp b/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
index bbfed2ac2c09..74e8a849803d 100644
--- a/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
+++ b/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
@@ -661,8 +661,13 @@ ArgumentAccessInfo getArgumentAccessInfo(const Instruction *I,
     auto TypeSize = DL.getTypeStoreSize(Ty);
     if (!TypeSize.isScalable() && Offset) {
       int64_t Size = TypeSize.getFixedValue();
-      return ConstantRange(APInt(64, *Offset, true),
-                           APInt(64, *Offset + Size, true));
+      APInt Low(64, *Offset, true);
+      bool Overflow;
+      APInt High = Low.sadd_ov(APInt(64, Size, true), Overflow);
+      // Bail if the range overflows signed 64-bit int.
+      if (Overflow)
+        return std::nullopt;
+      return ConstantRange(Low, High);
     }
     return std::nullopt;
   };

