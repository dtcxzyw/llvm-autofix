│ THOUGHT: The SLP vectorizer is incorrectly narrowing a 64-bit abs/mul sequence followed by truncation into 32-bit vector ops and calling llvm.abs.v2i32, which changes semantics. │
│ The safest fix is to prevent the truncation-sinking/narrowing across the llvm.abs intrinsic. I will modify SLPVectorizer.cpp's canTruncate() to bail out if either the top        │
│ instruction or the trunc operand is an llvm.abs intrinsic, thereby preserving the original wide type and avoiding miscompilation. Then I'll submit the patch.                     │
│                                                                                                                                                                                   │
│ ```bash                                                                                                                                                                           │
│ LFILE=llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp && grep -n "canTruncate(const Instruction \*I, const TruncInst \*Trunc" -n $LFILE && LN=$(awk '/static bool                 │
│ canTruncate\(const Instruction \*I, const TruncInst \*Trunc/{flag=1} flag&&/\{/{print NR; exit}' $LFILE) && echo "Insert after line $LN" && sed -i "$((LN+1))a\  // Avoid         │
│ narrowing across llvm.abs intrinsic to preserve semantics of wide abs before truncation.\n  if (const auto *CB = dyn_cast<CallBase>(I)) {\n    if (const Function *F =            │
│ CB->getCalledFunction()) {\n      if (F->isIntrinsic() && F->getIntrinsicID() == Intrinsic::abs)\n        return false;\n    }\n  }\n  if (const auto *OpI =                      │
│ dyn_cast<Instruction>(Trunc->getOperand(0))) {\n    if (const auto *CB2 = dyn_cast<CallBase>(OpI)) {\n      if (const Function *F2 = CB2->getCalledFunction()) {\n        if      │
│ (F2->isIntrinsic() && F2->getIntrinsicID() == Intrinsic::abs)\n          return false;\n      }\n    }\n  }" $LFILE && sed -n "$((LN-3)),$((LN+30))p" $LFILE && submit-patch      │
│ ```                                                                                                                                                                               │
