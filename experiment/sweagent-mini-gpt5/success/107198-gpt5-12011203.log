index 19b95cf473e9..bb22de335332 100644
--- a/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
+++ b/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
@@ -7781,13 +7781,20 @@ unsigned BoUpSLP::canMapToVector(Type *T) const {

   while (isa<StructType, ArrayType, FixedVectorType>(EltTy)) {
     if (auto *ST = dyn_cast<StructType>(EltTy)) {
+      // Empty structs cannot be mapped to a vector.
+      if (ST->getNumElements() == 0)
+        return 0;
+      Type *FirstElt = *ST->element_begin();
       // Check that struct is homogeneous.
       for (const auto *Ty : ST->elements())
-        if (Ty != *ST->element_begin())
+        if (Ty != FirstElt)
           return 0;
       N *= ST->getNumElements();
-      EltTy = *ST->element_begin();
+      EltTy = FirstElt;
     } else if (auto *AT = dyn_cast<ArrayType>(EltTy)) {
+      // Zero-length arrays cannot be mapped to a vector.
+      if (AT->getNumElements() == 0)
+        return 0;
       N *= AT->getNumElements();
       EltTy = AT->getElementType();
     } else {
@@ -19706,4 +19713,4 @@ bool SLPVectorizerPass::vectorizeStoreChains(BoUpSLP &R) {
         /*MaxVFOnly=*/false, R);
   }
   return Changed;
-}
+}
