│   mapfile -t FILES < <(find "$ROOT" -type f | sort)                                                                                                                                              │
│   if [ "${#FILES[@]}" -eq 0 ]; then                                                                                                                                                              │
│     exec "$REAL" -j 16 "${ARGS[@]}"                                                                                                                                                              │
│   fi                                                                                                                                                                                             │
│   CHUNK=150                                                                                                                                                                                      │
│   START=0                                                                                                                                                                                        │
