│ # Remove any -j N from args and enforce -j 16                                                                                                                                                    │
│ ARGS=()                                                                                                                                                                                          │
│ SKIP=0                                                                                                                                                                                           │
│ for ARG in "$@"; do                                                                                                                                                                              │
│   if [ "$SKIP" = 1 ]; then SKIP=0; continue; fi                                                                                                                                                  │
│   if [ "$ARG" = "-j" ]; then SKIP=1; continue; fi                                                                                                                                                │
│   ARGS+=("$ARG")                                                                                                                                                                                 │
