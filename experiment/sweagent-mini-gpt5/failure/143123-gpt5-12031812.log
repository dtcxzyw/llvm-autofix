│ THOUGHT: The miscompile happens because when InstCombine rebuilds a select after flipping a floating-point compare, it drops the original select’s fast-math flags (especially nnan),    │
│ which changes semantics for signaling NaNs. A safe, centralized fix is to have IRBuilder::CreateSelect preserve only the essential FMF (NoNaNs/NoInfs) when the insertion point (MDFrom) │
│ is an FPMathOperator. This keeps nnan (fixes the miscompile) but avoids copying NoSignedZeros, preventing an unintended canonicalization to minnum that was breaking tests. I will:      │
│ - Patch IRBuilderBase::CreateSelect in llvm/lib/IR/IRBuilder.cpp to set only NoNaNs/NoInfs when MDFrom is an FPMathOperator.                                                             │
│ - Revert the two tests’ checks (both in-repo and deps) back to their original fcmp/select expectations to align with upstream.                                                           │
│ - Run the patch pipeline.                                                                                                                                                                │
│                                                                                                                                                                                          │
│ ```bash                                                                                                                                                                                  │
│ python3 - << 'PY'                                                                                                                                                                        │
│ import re, subprocess, sys                                                                                                                                                               │
│ from pathlib import Path                                                                                                                                                                 │
│                                                                                                                                                                                          │
│ # 1) Patch IRBuilderBase::CreateSelect to preserve only NoNaNs/NoInfs when MDFrom is FPMathOperator                                                                                      │
│ irb_cpp = Path("llvm/lib/IR/IRBuilder.cpp")                                                                                                                                              │
│ txt = irb_cpp.read_text()                                                                                                                                                                │
│                                                                                                                                                                                          │
│ fn_pat = re.compile(                                                                                                                                                                     │
│     r'(Value\s*\*\s*IRBuilderBase::CreateSelect\s*\(\s*Value\s*\*\s*C\s*,\s*Value\s*\*\s*True\s*,\s*Value\s*\*\s*False\s*,\s*'                                                           │
│     r'const\s+Twine\s*&\s*Name\s*,\s*Instruction\s*\*\s*MDFrom\s*\)\s*\{)([\s\S]*?)(\n\})',                                                                                              │
│     re.M)                                                                                                                                                                                │
│ m = fn_pat.search(txt)                                                                                                                                                                   │
│ if not m:                                                                                                                                                                                │
│     print("ERROR: Could not locate IRBuilderBase::CreateSelect definition", file=sys.stderr); sys.exit(1)                                                                                │
│                                                                                                                                                                                          │
│ new_body = """                                                                                                                                                                           │
│   if (auto *V = Folder.FoldSelect(C, True, False))                                                                                                                                       │
│     return V;                                                                                                                                                                            │
│                                                                                                                                                                                          │
│   SelectInst *Sel = SelectInst::Create(C, True, False);                                                                                                                                  │
│   if (MDFrom) {                                                                                                                                                                          │
│     MDNode *Prof = MDFrom->getMetadata(LLVMContext::MD_prof);                                                                                                                            │
│     MDNode *Unpred = MDFrom->getMetadata(LLVMContext::MD_unpredictable);                                                                                                                 │
│     Sel = addBranchMetadata(Sel, Prof, Unpred);                                                                                                                                          │
│   }                                                                                                                                                                                      │
│                                                                                                                                                                                          │
│   // Preserve only essential fast-math flags (nnan/ninf) from the insertion point                                                                                                        │
│   // if it is an FP math operator. Avoid copying NSZ to prevent unexpected canonicalizations.                                                                                            │
│   if (isa<FPMathOperator>(Sel)) {                                                                                                                                                        │
│     if (auto *FPO = dyn_cast<FPMathOperator>(MDFrom)) {                                                                                                                                  │
│       FastMathFlags FMF;                                                                                                                                                                 │
│       if (FPO->hasNoNaNs())                                                                                                                                                              │
│         FMF.setNoNaNs(true);                                                                                                                                                             │
│       if (FPO->hasNoInfs())                                                                                                                                                              │
│         FMF.setNoInfs(true);                                                                                                                                                             │
│       Sel->setFastMathFlags(FMF);                                                                                                                                                        │
│     }                                                                                                                                                                                    │
│   }                                                                                                                                                                                      │
│                                                                                                                                                                                          │
│   return Insert(Sel, Name);                                                                                                                                                              │
│ """                                                                                                                                                                                      │
│ patched = txt[:m.start(2)] + new_body + txt[m.end(2):]                                                                                                                                   │
│ irb_cpp.write_text(patched)                                                                                                                                                              │
