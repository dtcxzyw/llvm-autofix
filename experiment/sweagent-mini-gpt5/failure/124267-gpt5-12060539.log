│ THOUGHT: The failing tests indicate that my earlier heavy edits to ValueTracking.cpp broke implied-condition    │
│ functionality. To minimally fix the miscompilation without disrupting other logic, I will insert a conservative │
│ guard at the beginning of isImpliedCondICmps: if the RHS is "icmp ult ... , -1" and its LHS is "sub nsw L0, L1" │
│ matching the LHS compare operands, then bail out by returning std::nullopt. This should prevent the incorrect   │
│ fold in the reproducer while preserving other implications.                                                     │
│                                                                                                                 │
│ ```bash                                                                                                         │
│ python3 - << 'PY'                                                                                               │
│ import re                                                                                                       │
│ path = "llvm/lib/Analysis/ValueTracking.cpp"                                                                    │
│ with open(path,'r',encoding='utf-8') as f:                                                                      │
│     s = f.read()                                                                                                │
│ # Find the isImpliedCondICmps function opening brace                                                            │
│ sig = re.search(r'std::optional<bool>\s*isImpliedCondICmps\s*\(\s*const\s+ICmpInst\s*\*LHSCmp,.*?\)\s*\{', s,   │
│ re.DOTALL)                                                                                                      │
│ if not sig:                                                                                                     │
│     print("Function signature not found")                                                                       │
│     raise SystemExit(1)                                                                                         │
│ insert_pos = sig.end()                                                                                          │
│ guard = '''                                                                                                     │
│   // Guard against incorrect implication: a dominating samesign compare does not                                │
│   // imply that (x -nsw y) ult -1 is false. Be conservative for this pattern.                                   │
│   if (RHSPred == ICmpInst::ICMP_ULT && match(RHSOp1, m_AllOnes()) &&                                            │
│       match(RHSOp0, m_NSWSub(m_Specific(LHSCmp->getOperand(0)),                                                 │
│                               m_Specific(LHSCmp->getOperand(1)))))                                              │
│     return std::nullopt;                                                                                        │
│ '''                                                                                                             │
│ # Insert guard if not already present                                                                           │
│ if 'Guard against incorrect implication' not in s:                                                              │
│     s = s[:insert_pos] + guard + s[insert_pos:]                                                                 │
