│     # Find the function                                                                                                                                                                   │
│     m=re.search(re.escape(func_decl), src)                                                                                                                                                │
│     if not m:                                                                                                                                                                             │
│         return False, src                                                                                                                                                                 │
│     # Find opening brace                                                                                                                                                                  │
│     brace_idx=src.find('{', m.end())                                                                                                                                                      │
│     if brace_idx==-1:                                                                                                                                                                     │
│         return False, src                                                                                                                                                                 │
│     # Build injection after '{'                                                                                                                                                           │
