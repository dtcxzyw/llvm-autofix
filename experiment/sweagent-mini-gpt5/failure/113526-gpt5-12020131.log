│ THOUGHT: The assertion is in LoopVectorize.cpp where the VPlan-based and legacy cost models must agree on VF unless the VPlan contains additional simplifications. For this IR, the loop │
│ is effectively infinite (exit is unreachable), which can cause the VPlan to see simplifications that the legacy model doesn't, triggering the assert. A robust fix is to soften this     │
│ assertion into a runtime check: if they disagree and no additional simplifications are detected, conservatively fall back to the legacy VF instead of aborting. I will modify            │
│ computeBestVF to pick the legacy VF in that case and add a debug note, preventing the crash while keeping behavior conservative.                                                         │
│                                                                                                                                                                                          │
│ ```bash                                                                                                                                                                                  │
│ applypatch << 'PATCH'                                                                                                                                                                    │
│ *** Begin Patch                                                                                                                                                                          │
│ *** Update File: llvm/lib/Transforms/Vectorize/LoopVectorize.cpp                                                                                                                         │
│ @@                                                                                                                                                                                       │
│    // Select the best VF among a fixed set of candidate VFs.                                                                                                                             │
│    const VectorizationFactor &BestFactor = *std::min_element(                                                                                                                            │
│        Factors.begin(), Factors.end(),                                                                                                                                                   │
│        [&](const VectorizationFactor &VF1, const VectorizationFactor &VF2) {                                                                                                             │
│          return VF1.Cost < VF2.Cost;                                                                                                                                                     │
│        });                                                                                                                                                                               │
│ @@                                                                                                                                                                                       │
│ -  VectorizationFactor LegacyVF = computeMaxVFForTarget(LegalVFSet, CM, TTI,                                                                                                             │
│ -                                                       InterleaveInfo, VPlanBuildCtx);                                                                                                  │
│ +  VectorizationFactor LegacyVF = computeMaxVFForTarget(LegalVFSet, CM, TTI,                                                                                                             │
│ +                                                       InterleaveInfo, VPlanBuildCtx);                                                                                                  │
│ @@                                                                                                                                                                                       │
│ -  assert((BestFactor.Width == LegacyVF.Width ||                                                                                                                                         │
│ -          planContainsAdditionalSimplifications(getPlanFor(BestFactor.Width),                                                                                                           │
│ -                                                CostCtx, OrigLoop)) &&                                                                                                                  │
│ -         " VPlan cost model and legacy cost model disagreed");                                                                                                                          │
│ +  // If the VPlan and legacy cost models disagree on the best VF and we cannot                                                                                                          │
│ +  // prove the VPlan benefits from additional simplifications for BestFactor,                                                                                                           │
│ +  // conservatively fall back to the legacy VF instead of asserting. This avoids                                                                                                        │
│ +  // crashes for corner cases (e.g. loops with unreachable exits) where VPlan                                                                                                           │
│ +  // can see simplifications not modeled by the legacy path, or vice versa.                                                                                                             │
│ +  if (BestFactor.Width != LegacyVF.Width &&                                                                                                                                             │
│ +      !planContainsAdditionalSimplifications(getPlanFor(BestFactor.Width),                                                                                                              │
│ +                                             CostCtx, OrigLoop)) {                                                                                                                      │
│ +    LLVM_DEBUG(dbgs() << "LV: VPlan and legacy cost models disagreed without "                                                                                                          │
│ +                         "detectable additional simplifications. "                                                                                                                      │
│ +                      << "Falling back to legacy VF " << LegacyVF.Width << "\n");                                                                                                       │
│ +    return LegacyVF;                                                                                                                                                                    │
│ +  }                                                                                                                                                                                     │
│                                                                                                                                                                                          │
│    return BestFactor;                                                                                                                                                                    │
│ *** End Patch                                                                                                                                                                            │
│ PATCH                                                                                                                                                                                    │
│ ```                                                                                                                                                                                      │
