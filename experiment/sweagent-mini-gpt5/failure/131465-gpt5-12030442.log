│ THOUGHT: The miscompile happens because the runtime unroller emits a udiv by a possibly-zero value when computing the unroll iteration count. A robust fix is to bail out of runtime     │
│ unrolling if the pass would emit an unsigned or signed division whose denominator isn't provably nonzero. The easiest way to implement this without fully understanding SCEV structure   │
│ is to detect the spots where IRBuilder creates divisions (CreateUDiv/CreateSDiv) in LoopUnrollRuntime.cpp and add a guard to return false before generating such code when the           │
│ denominator may be zero. I will patch the file to wrap any CreateUDiv/CreateSDiv with a check using ScalarEvolution::isKnownNonZero on the denominator and bail out if not.              │
│                                                                                                                                                                                          │
│ ```bash                                                                                                                                                                                  │
│ python3 - << 'PY'                                                                                                                                                                        │
│ import pathlib, re                                                                                                                                                                       │
│ p = pathlib.Path("llvm/lib/Transforms/Utils/LoopUnrollRuntime.cpp")                                                                                                                      │
│ s = p.read_text()                                                                                                                                                                        │
│ # Ensure helper exists after includes                                                                                                                                                    │
│ if 'isProvablyNonZero' not in s:                                                                                                                                                         │
│     inc_end = 0                                                                                                                                                                          │
│     for m in re.finditer(r'^\s*#include\s+["<].*[">]\s*$', s, re.M):                                                                                                                     │
│         inc_end = m.end()                                                                                                                                                                │
│     helper = '''                                                                                                                                                                         │
│ static bool isProvablyNonZero(const llvm::SCEV *S, llvm::ScalarEvolution &SE, llvm::Loop *L) {                                                                                           │
│   if (const auto *SC = llvm::dyn_cast<llvm::SCEVConstant>(S))                                                                                                                            │
│     return !SC->getAPInt().isZero();                                                                                                                                                     │
│   return SE.isKnownNonZero(S);                                                                                                                                                           │
│ }                                                                                                                                                                                        │
│ '''.strip('\n')                                                                                                                                                                          │
│     s = s[:inc_end] + '\n\n' + helper + '\n' + s[inc_end:]                                                                                                                               │
│ # Add guards around IRBuilder::CreateUDiv/CreateSDiv patterns used for runtime count.                                                                                                    │
│ # We'll look for lines with CreateUDiv( ... , Den ) and insert a check before they execute.                                                                                              │
│ def add_guard_for_div(s):                                                                                                                                                                │
│     lines = s.splitlines()                                                                                                                                                               │
│     new = []                                                                                                                                                                             │
│     for i, line in enumerate(lines):                                                                                                                                                     │
│         new.append(line)                                                                                                                                                                 │
│         m = re.search(r'CreateU?Div\s*\(\s*([^\),]+)\s*,\s*([^\),]+)\s*(?:,|\))', line)                                                                                                  │
│         if m:                                                                                                                                                                            │
│             num = m.group(1).strip()                                                                                                                                                     │
│             den = m.group(2).strip()                                                                                                                                                     │
│             # Insert a conservative bail-out comment and runtime check if SE and L are available.                                                                                        │
│             guard = [                                                                                                                                                                    │
│                 '  // Guard against division by zero in runtime unroll computation.',                                                                                                    │
│                 '  if (SE && L) {',                                                                                                                                                      │
│                 f'    if (!SE->isKnownNonZero(SE->getSCEV({den}))) {{',                                                                                                                  │
│                 '      LLVM_DEBUG(llvm::dbgs() << "Runtime unroll disabled: denominator may be zero\\n");',                                                                              │
│                 '      return false;',                                                                                                                                                   │
│                 '    }',                                                                                                                                                                 │
│                 '  }'                                                                                                                                                                    │
│             ]                                                                                                                                                                            │
│             # Insert guard before the division line                                                                                                                                      │
│             new[-1] = '\n'.join(guard) + '\n' + new[-1]                                                                                                                                  │
