│     if (inDtor && $0 ~ /I->insertBefore\(F->getEntryBlock\(\)\.getTerminator\(\)->getIterator\(\)\);/) {        │
│       # Peek next line; if it is a lone "continue;", drop it so we process the instruction further.             │
