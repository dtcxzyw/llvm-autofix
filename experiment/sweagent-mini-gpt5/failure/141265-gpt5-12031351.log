│ THOUGHT: The verifier shows vector loads/gathers are inserted after their uses (vector_insert). My previous change to setInsertPointAfter/BeforeBundle didn’t ensure the loads/gathers dominate those inserts. A robust fix is to set the         │
│ IRBuilder insertion point to the beginning of the current basic block (before any non-PHI instructions) right before creating vp.strided.load and masked.gather, ensuring they dominate subsequent vector_insert uses.                            │
│                                                                                                                                                                                                                                                   │
│ ```bash                                                                                                                                                                                                                                           │
│ python3 - << 'PY'                                                                                                                                                                                                                                 │
│ import re                                                                                                                                                                                                                                         │
│ path = "/llvm-autofix-deps/llvm/llvm/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp"                                                                                                                                                             │
│ with open(path, 'r') as f:                                                                                                                                                                                                                        │
│     s = f.read()                                                                                                                                                                                                                                  │
│ # Insert setting insertion point before vp_strided_load creation                                                                                                                                                                                  │
│ s = re.sub(                                                                                                                                                                                                                                       │
│     r'(\n\s*auto \*Inst = Builder\.CreateIntrinsic\(\s*Intrinsic::experimental_vp_strided_load,)',                                                                                                                                                │
│     r'\n          {\n            auto *IP = &*Builder.GetInsertPoint();\n            auto *BB = IP->getParent();\n            Builder.SetInsertPoint(&*BB->getFirstInsertionPt());\n          }\n\\1',                                            │
│     s                                                                                                                                                                                                                                             │
│ )                                                                                                                                                                                                                                                 │
│ # Insert setting insertion point before masked gather creation                                                                                                                                                                                    │
│ s = re.sub(                                                                                                                                                                                                                                       │
│     r'(\n\s*NewLI = Builder\.CreateMaskedGather\(VecTy, VecPtr, CommonAlignment\);)',                                                                                                                                                             │
│     r'\n          {\n            auto *IP = &*Builder.GetInsertPoint();\n            auto *BB = IP->getParent();\n            Builder.SetInsertPoint(&*BB->getFirstInsertionPt());\n          }\n\\1',                                            │
│     s                                                                                                                                                                                                                                             │
│ )                                                                                                                                                                                                                                                 │
│ with open(path, 'w') as f:                                                                                                                                                                                                                        │
│     f.write(s)                                                                                                                                                                                                                                    │
│ print("Patched insertion points for loads/gathers to start of block.")                                                                                                                                                                            │
│ PY                                                                                                                                                                                                                                                │
│ ```                                                                                                                                                                                                                                               │
