│    192    // mechanism that may remove flags to increase the likelihood of CSE.                                                                                                          │
│    193                                                                                                                                                                                   │
│    194    Flavor = SPF_UNKNOWN;                                                                                                                                                          │
│    195    CmpPredicate Pred;                                                                                                                                                             │
│    196                                                                                                                                                                                   │
│    197    if (!match(Cond, m_ICmp(Pred, m_Specific(A), m_Specific(B)))) {                                                                                                                │
