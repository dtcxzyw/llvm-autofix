│   // Don't blow up on huge arrays.                                                                                                                                          │
│   if (ArrayElementCount > MaxArraySizeForCombine)                                                                                                                           │
│                                                                                                                                                                             │
│   // There are many forms of this optimization we can handle, for now, just do                                                                                              │
│   // the simple index into a single-dimensional array.                                                                                                                      │
│   //                                                                                                                                                                        │
