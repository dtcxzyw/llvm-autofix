│ iterator after computing NewIP from the last scalar instruction. If LastInst is the last non-PHI in the block,  │
│ std::next yields the end sentinel, and dereferencing it asserts. The fix is to avoid dereferencing the end      │
│ iterator: check if NewIP equals the block’s end and use SetInsertPoint(BB) for insertion at the end; otherwise  │
│ use SetInsertPoint(&*NewIP). I will patch llvm/lib/Transforms/Vectorize/VPlan.cpp accordingly and submit the    │
│ patch.                                                                                                          │
│                                                                                                                 │
│ ```bash                                                                                                         │
│ applypatch << 'PATCH'                                                                                           │
│ *** Begin Patch                                                                                                 │
│ *** Update File: llvm/lib/Transforms/Vectorize/VPlan.cpp                                                        │
│ @@                                                                                                              │
│ -  auto NewIP = isa<PHINode>(LastInst)                                                                          │
│ -                   ? LastInst->getParent()->getFirstNonPHIIt()                                                 │
│ -                   : std::next(BasicBlock::iterator(LastInst));                                                │
│ -  Builder.SetInsertPoint(&*NewIP);                                                                             │
│ +  auto *BB = LastInst->getParent();                                                                            │
