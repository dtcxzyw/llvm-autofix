│ THOUGHT: The crash happens because a shufflevector is emitted before the insertelement that feeds it, so the    │
│ insertelement does not dominate its use. A targeted, low-risk fix is to ensure that when we create an           │
│ insertelement for a non-instruction pointer scalar (like a function arg), we emit it in a dominating location.  │
│ I’ll adjust SLPVectorizer’s CreateInsertElement lambda to temporarily set the IRBuilder insertion point to the  │
│ start of the function entry block (after allocas) for pointer-typed, non-instruction scalars before creating    │
│ the insertelement. This ensures dominance for broadcasts of pointer vectors without broadly reordering other    │
│ instructions.                                                                                                   │
│                                                                                                                 │
│ ```bash                                                                                                         │
│ python3 - << 'PY' && /llvm-autofix/build/llvm-build/128770/bin/opt -S --passes=slp-vectorizer                   │
│ -mtriple=x86_64-unknown-linux-gnu -mcpu=skylake /tmp/test.ll >/dev/null && submit-patch                         │
│ from pathlib import Path, re                                                                                    │
│ p = Path("llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp")                                                     │
│ s = p.read_text()                                                                                               │
│                                                                                                                 │
│ # Insert a guarded insertion point hoist to the function entry (after allocas)                                  │
│ # specifically for pointer-typed, non-instruction scalars before creating the insertelement.                    │
│ target = 'Vec = Builder.CreateInsertElement(Vec, Scalar, Builder.getInt32(Pos));'                               │
│ insert_block = r'''IRBuilderBase::InsertPointGuard Guard(Builder);                                              │
│       if (Ty->isPointerTy() && !isa<Instruction>(Scalar)) {                                                     │
│         if (BasicBlock *InsertBB = Builder.GetInsertBlock()) {                                                  │
│           if (Function *F = InsertBB->getParent()) {                                                            │
│             BasicBlock &EB = F->getEntryBlock();                                                                │
│             auto It = EB.begin();                                                                               │
│             while (It != EB.end() && isa<AllocaInst>(&*It))                                                     │
│               ++It;                                                                                             │
│             if (It != EB.end())                                                                                 │
│               Builder.SetInsertPoint(&*It);                                                                     │
│           }                                                                                                     │
│         }                                                                                                       │
│       }                                                                                                         │
│       '''                                                                                                       │
│                                                                                                                 │
│ # Only add if not already present to avoid duplication.                                                         │
│ if insert_block.strip() not in s:                                                                               │
│     s = s.replace(target, insert_block + target, 1)                                                             │
│                                                                                                                 │
│ Path(p).write_text(s)                                                                                           │
│ PY                                                                                                              │
│ ```                                                                                                             │
