│ p = Path("llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp")                                                     │
│ s = p.read_text()                                                                                               │
│                                                                                                                 │
│ # Insert intra-block move in two-operand createShuffleVector before creating the shuffle.                       │
│ two_pat = r'(Value \*createShuffleVector\(Value \*V1, Value \*V2, ArrayRef<int> Mask\) \{\s*)([^}]*?)(\s*Value  │
│ \*Vec = Builder\.CreateShuffleVector\(V1, V2, Mask\);)'                                                         │
│ def repl_two(m):                                                                                                │
│     prefix, mid, create = m.groups()                                                                            │
│     move = '''                                                                                                  │
│       // Ensure operands dominate the insertion point intra-block: if an InsertElement                          │
│       // is located after the current insertion point in the same block, move it before.                        │
│       if (Instruction *IP = (Builder.GetInsertBlock() && Builder.GetInsertPoint() !=                            │
│ Builder.GetInsertBlock()->end())                                                                                │
│                                  ? &*Builder.GetInsertPoint() : nullptr) {                                      │
│         if (auto *I1 = dyn_cast<InsertElementInst>(V1))                                                         │
│           if (I1->getParent() == IP->getParent() && !I1->comesBefore(IP))                                       │
