│ THOUGHT: The crash stems from a shufflevector using an insertelement that’s emitted later or in a               │
│ non-dominating block. Broad hoisting/cloning caused test regressions. A minimal, safe fix is to adjust          │
│ dominance only for the simple, common case: when the insertelement builds from a poison (or undef) base and is  │
│ located in a different block than the current builder insertion point. In that case, rebuild the insertelement  │
│ at the current insertion point (just before where the shuffle will be emitted), so it dominates the use. I’ll   │
│ inject this targeted rebuild right after the existing intra-block move code in CreateInsertElement.             │
│                                                                                                                 │
│ ```bash                                                                                                         │
│ python3 - << 'PY' && /llvm-autofix/build/llvm-build/128770/bin/opt -S --passes=slp-vectorizer                   │
│ -mtriple=x86_64-unknown-linux-gnu -mcpu=skylake /tmp/test.ll && submit-patch                                    │
│ from pathlib import Path                                                                                        │
│ import re                                                                                                       │
│                                                                                                                 │
│ p = Path("llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp")                                                     │
│ s = p.read_text()                                                                                               │
│                                                                                                                 │
│ anchor_comment = "Ensure intra-block dominance: if the insertelement is after the current"                      │
│ idx = s.find(anchor_comment)                                                                                    │
│ insert_code = '''                                                                                               │
│       // If insertelement is from a different block and built from poison/undef base,                           │
│       // rebuild it at the current insertion point to ensure dominance.                                         │
│       if (Builder.GetInsertBlock()) {                                                                           │
│         BasicBlock *UseBB = Builder.GetInsertBlock();                                                           │
│         if (InsElt->getParent() != UseBB) {                                                                     │
│           if (auto *IdxC = dyn_cast<Constant>(InsElt->getOperand(2)))                                           │
│             if (isa<PoisonValue>(InsElt->getOperand(0)) || isa<UndefValue>(InsElt->getOperand(0))) {            │
│               auto ItIP = Builder.GetInsertPoint();                                                             │
│               if (ItIP != UseBB->end()) {                                                                       │
│                 IRBuilderBase::InsertPointGuard G(Builder);                                                     │
│                 Instruction *IP = &*ItIP;                                                                       │
│                 Builder.SetInsertPoint(IP);                                                                     │
│                 Value *Base = PoisonValue::get(InsElt->getType());                                              │
│                 Vec = Builder.CreateInsertElement(Base, Scalar, IdxC);                                          │
│                 InsElt = dyn_cast<InsertElementInst>(Vec);                                                      │
│               }                                                                                                 │
│             }                                                                                                   │
│         }                                                                                                       │
│       }                                                                                                         │
│ '''                                                                                                             │
│ if idx != -1:                                                                                                   │
│     # Insert after the intra-block move block by finding the end of that if statement (the next newline after   │
│ our comment block).                                                                                             │
│     # To keep it simple and robust, inject right after the intra-block move code's closing brace which we       │
│ placed just above.                                                                                              │
│     # Find the pattern of the move block end before the GatherShuffleExtractSeq insertion.                      │
│     pat = re.compile(r'(InsElt->moveBefore\(IP\);\s*\n\s*\}\s*\n\s*\}\s*\n\s*\}\s*\n)', re.S)                   │
│     s, n = pat.subn(r'\1' + insert_code, s, count=1)                                                            │
│     if n == 0:                                                                                                  │
│         # Fallback: insert right after the anchor comment line.                                                 │
│         line_start = s.rfind('\n', 0, idx) + 1                                                                  │
│         line_end = s.find('\n', idx) + 1                                                                        │
│         s = s[:line_end] + insert_code + s[line_end:]                                                           │
│     Path(p).write_text(s)                                                                                       │
