│ THOUGHT: The crash happens because an insertelement used to build a pointer vector does not dominate a          │
│ subsequent shufflevector that uses it. A minimal and robust fix is to relocate the freshly created              │
│ insertelement to a block that dominates its uses when needed. Specifically, right after creating the            │
│ InsertElementInst, if its parent block does not dominate the current IRBuilder insertion block, and the         │
│ inserted scalar is not an instruction (e.g., function argument/constant), move the insertelement to the         │
│ beginning of the current insertion block (skipping allocas in the entry block). This preserves correctness and  │
│ minimizes ordering changes elsewhere.                                                                           │
│                                                                                                                 │
│ ```bash                                                                                                         │
│ python3 - << 'PY' && /llvm-autofix/build/llvm-build/128770/bin/opt -S --passes=slp-vectorizer                   │
│ -mtriple=x86_64-unknown-linux-gnu -mcpu=skylake /tmp/test.ll >/dev/null && submit-patch                         │
│ from pathlib import Path                                                                                        │
│ import re                                                                                                       │
│ p = Path("llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp")                                                     │
│ s = p.read_text()                                                                                               │
│                                                                                                                 │
│ # Insert dominance-fix move right after insertelement creation.                                                 │
│ pattern = re.compile(                                                                                           │
│     r'(InsElt\s*=\s*dyn_cast<InsertElementInst>\(Vec\);\s*\n\s*if\s*\(!InsElt\)\s*return\s*Vec;\s*)',           │
│     re.S                                                                                                        │
│ )                                                                                                               │
│ insertion = r"""\1                                                                                              │
│       // Ensure the insertelement dominates all subsequent uses created by this builder.                        │
│       // If the scalar is not an instruction (e.g., argument/constant) and the newly                            │
│       // created insertelement does not dominate the current insertion block, move it.                          │
│       if (!isa<Instruction>(Scalar)) {                                                                          │
│         if (BasicBlock *UseBB = Builder.GetInsertBlock()) {                                                     │
│           BasicBlock *DefBB = InsElt->getParent();                                                              │
│           if (DefBB != UseBB && (!DT || !DT->dominates(DefBB, UseBB))) {                                        │
│             // Move to the first valid insertion point of the use block.                                        │
│             auto FI = UseBB->getFirstInsertionPt();                                                             │
│             if (UseBB == &UseBB->getParent()->getEntryBlock()) {                                                │
│               // Skip allocas in the entry block.                                                               │
│               auto It = UseBB->begin();                                                                         │
│               while (It != UseBB->end() && isa<AllocaInst>(&*It))                                               │
│                 ++It;                                                                                           │
│               if (It != UseBB->end())                                                                           │
│                 InsElt->moveBefore(&*It);                                                                       │
│               else if (FI != UseBB->end())                                                                      │
│                 InsElt->moveBefore(&*FI);                                                                       │
│             } else if (FI != UseBB->end()) {                                                                    │
│               InsElt->moveBefore(&*FI);                                                                         │
│             }                                                                                                   │
│           }                                                                                                     │
│         }                                                                                                       │
│       }                                                                                                         │
│ """                                                                                                             │
│ ns, n = pattern.subn(insertion, s, count=1)                                                                     │
│ if n == 0:                                                                                                      │
│     raise SystemExit("Failed to locate insertelement site for dominance fix.")                                  │
│ p.write_text(ns)                                                                                                │
│ PY                                                                                                              │
│ ```                                                                                                             │
