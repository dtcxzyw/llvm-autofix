│ needle = "Vec = Builder.CreateInsertElement(Vec, Scalar, Builder.getInt32(Pos));"                               │
│ guard_block = """IRBuilderBase::InsertPointGuard Guard(Builder);                                                │
│       if (Ty->isPointerTy() && !isa<Instruction>(Scalar)) {                                                     │
│         if (BasicBlock *IBB = Builder.GetInsertBlock()) {                                                       │
