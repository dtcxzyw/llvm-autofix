╭─ assistant [MainThread@2549908] ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────╮
│ THOUGHT: The header branch becoming constant false is due to PeelLast replacing all uses of original exit values with values from the peeled iteration, which inadvertently updates in-loop users like the header condition. The correct behavior │
│ is to only replace uses outside the loop. I will modify the PeelLast post-processing to replace uses selectively: only for users not within the loop.                                                                                             │
│                                                                                                                                                                                                                                                   │
│ ```bash                                                                                                                                                                                                                                           │
│ sed -i '1214,1218c\                                                                                                                                                                                                                               │
│     // Now adjust users of the original exit values by replacing them with the\                                                                                                                                                                   │
│     // exit value from the peeled iteration, but only for users outside the loop.\                                                                                                                                                                │
│     for (const auto &[P, E] : ExitValues) {\                                                                                                                                                                                                      │
│       Value *Replacement = isa<Constant>(E) ? E : &*VMap.lookup(E);\                                                                                                                                                                              │
│       for (Use &U : P->uses()) {\                                                                                                                                                                                                                 │
│         if (auto *UserI = dyn_cast<Instruction>(U.getUser())) {\                                                                                                                                                                                  │
│           if (!L->contains(UserI->getParent()))\                                                                                                                                                                                                  │
│             U.set(Replacement);\                                                                                                                                                                                                                  │
│         }\                                                                                                                                                                                                                                        │
│       }\                                                                                                                                                                                                                                          │
│     }' llvm/lib/Transforms/Utils/LoopPeel.cpp && submit-patch                                                                                                                                                                                     │
│ ```                                                                                                                                                                                                                                               │
