│ && sed -n '1,260p' /llvm-autofix/llvm-project/llvm/lib/Transforms/InstCombine/InstructionCombining.cpp && awk 'NR==1,NR==240{print NR": "$0}'                                             │
│ /llvm-autofix/llvm-project/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp && echo "Editing to guard transform on FMF NoInfs" && sed -i 's/if (match(SI, m_Select(m_Value(C),       │
│ m_Value(T), m_Value(F))) && .*FMul)/if (match(SI, m_Select(m_Value(C), m_Value(T), m_Value(F))) && /* existing conditions */ FMul &&                                                      │
│ !cast<FPMathOperator>(FMul)->getFastMathFlags().noInfs())/' /llvm-autofix/llvm-project/llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp && submit-patch                              │
