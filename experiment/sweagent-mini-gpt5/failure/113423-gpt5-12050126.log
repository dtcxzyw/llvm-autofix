│ THOUGHT: The miscompile occurs because foldSelectBinOpIdentity replaces a select arm containing an FMul with its identity, which then allows hoisting the FMul unconditionally. This is   │
│ unsafe when the FMul has the NoInfs (ninf) flag because executing FMul can produce poison. To fix this, I will add a guard in foldSelectBinOpIdentity to bail out when the binop is FMul  │
│ with FastMathFlags.noInfs set, right before performing the replacement.                                                                                                                   │
│                                                                                                                                                                                           │
│ ```bash                                                                                                                                                                                   │
│ # Insert a guard in foldSelectBinOpIdentity to bail out on FMul with NoInfs before the final replacement                                                                                  │
│ awk 'BEGIN{infunc=0}                                                                                                                                                                      │
│ {                                                                                                                                                                                         │
│   print                                                                                                                                                                                   │
│   if ($0 ~ /^static Instruction \*foldSelectBinOpIdentity\(SelectInst &Sel,/){infunc=1}                                                                                                   │
│   if (infunc && $0 ~ /return IC\.replaceOperand\(Sel, IsEq \? 1 : 2, Y\);/){                                                                                                              │
│     print "  // Avoid unsafe folding for FMul when NoInfs is set: hoisting would introduce poison.";                                                                                      │
│     print "  if (BO->getOpcode() == Instruction::FMul) {";                                                                                                                                │
│     print "    if (auto *FPO = dyn_cast<FPMathOperator>(BO)) {";                                                                                                                          │
│     print "      if (FPO->getFastMathFlags().noInfs())";                                                                                                                                  │
│     print "        return nullptr;";                                                                                                                                                      │
│     print "    }";                                                                                                                                                                        │
│     print "  }";                                                                                                                                                                          │
│     infunc=0                                                                                                                                                                              │
│   }                                                                                                                                                                                       │
│ }' llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp > /tmp/InstCombineSelect.cpp && mv /tmp/InstCombineSelect.cpp llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp &&           │
│ submit-patch                                                                                                                                                                              │
│ ```                                                                                                                                                                                       │
