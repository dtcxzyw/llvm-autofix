│ THOUGHT: The replacement is happening on the local pointer value (such as an alloca) inside simplifyInstsInBlock, not just on function arguments. A robust fix is to avoid replacing any │
│ pointer-typed instruction with a constant if it is used by a call to llvm.lifetime.start/end. I will insert a guard in SCCPSolver::simplifyInstsInBlock right after we start iterating   │
│ instructions: if the current instruction is pointer-typed and any user is a call to a function whose name starts with llvm.lifetime.start or llvm.lifetime.end, skip replacement for     │
│ that instruction.                                                                                                                                                                        │
│                                                                                                                                                                                          │
│ ```bash                                                                                                                                                                                  │
│ sed -i '/for (Instruction &Inst : make_early_inc_range(BB)) {/a \                                                                                                                        │
│       if (Inst.getType()->isPointerTy()) {\                                                                                                                                              │
│         bool UsedByLifetime = false;\                                                                                                                                                    │
│         for (llvm::User *U : Inst.users()) {\                                                                                                                                            │
│           if (auto *CB = llvm::dyn_cast<llvm::CallBase>(U)) {\                                                                                                                           │
│             if (llvm::Function *CF = CB->getCalledFunction()) {\                                                                                                                         │
│               llvm::StringRef N = CF->getName();\                                                                                                                                        │
│               if (N.starts_with("llvm.lifetime.start") || N.starts_with("llvm.lifetime.end")) {\                                                                                         │
│                 UsedByLifetime = true; break;\                                                                                                                                           │
│               }\                                                                                                                                                                         │
│             }\                                                                                                                                                                           │
│           }\                                                                                                                                                                             │
│         }\                                                                                                                                                                               │
│         if (UsedByLifetime) continue;\                                                                                                                                                   │
│       }' llvm/lib/Transforms/Utils/SCCPSolver.cpp && submit-patch                                                                                                                        │
│ ```                                                                                                                                                                                      │
