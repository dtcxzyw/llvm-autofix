│ THOUGHT: The verifier abort occurs because IPSCCP replaces a pointer value that is used as the operand of llvm.lifetime.start/end. A minimal and safe fix is to prevent SCCP from        │
│ replacing any pointer-typed value if it is used by a call to lifetime intrinsics. I will add a small guard in SCCPSolver::tryToReplaceWithConstant right after we determine there is a   │
│ constant: if the value is a pointer and any user is a CallBase to a function whose name starts with "llvm.lifetime.start" or "llvm.lifetime.end", then skip the replacement. This is a   │
│ conservative, well-formed change that avoids generating invalid IR.                                                                                                                      │
│                                                                                                                                                                                          │
│ ```bash                                                                                                                                                                                  │
│ sed -i '64a \                                                                                                                                                                            │
│   /* Do not replace pointer values feeding lifetime intrinsics. */\                                                                                                                      │
│   if (V->getType()->isPointerTy()) {\                                                                                                                                                    │
│     for (llvm::User *U : V->users()) {\                                                                                                                                                  │
│       if (auto *CB = llvm::dyn_cast<llvm::CallBase>(U)) {\                                                                                                                               │
│         if (llvm::Function *CF = CB->getCalledFunction()) {\                                                                                                                             │
│           llvm::StringRef N = CF->getName();\                                                                                                                                            │
│           if (N.startswith("llvm.lifetime.start") || N.startswith("llvm.lifetime.end"))\                                                                                                 │
│             return false;\                                                                                                                                                               │
│         }\                                                                                                                                                                               │
│       }\                                                                                                                                                                                 │
│     }\                                                                                                                                                                                   │
│   }' llvm/lib/Transforms/Utils/SCCPSolver.cpp && submit-patch                                                                                                                            │
│ ```                                                                                                                                                                                      │
