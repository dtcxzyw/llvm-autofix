│ THOUGHT: The crash occurs because IPSCCP replaces the alloca pointer %a with a non-alloca constant (inttoptr(-1)) and that constant becomes the operand of llvm.lifetime.start, which    │
│ violates the verifier rule that lifetime intrinsics must reference only alloca or poison. The safest fix is to add a guard in SCCPSolver::tryToReplaceWithConstant: if we're about to    │
│ replace a pointer value that is used by llvm.lifetime.start/end, then only allow replacement if the constant is poison; otherwise, skip the replacement. This preserves correctness and  │
│ prevents introducing invalid IR.                                                                                                                                                         │
│                                                                                                                                                                                          │
│ ```bash                                                                                                                                                                                  │
│ sed -i '68a \                                                                                                                                                                            │
│   /* Avoid replacing pointer operands used by lifetime intrinsics with non-alloca constants. */\                                                                                         │
│   if (V->getType()->isPointerTy()) {\                                                                                                                                                    │
│     if (!isa<PoisonValue>(Const)) {\                                                                                                                                                     │
│       for (User *U : V->users()) {\                                                                                                                                                      │
│         if (auto *II = dyn_cast<IntrinsicInst>(U)) {\                                                                                                                                    │
│           Intrinsic::ID IID = II->getIntrinsicID();\                                                                                                                                     │
│           if (IID == Intrinsic::lifetime_start || IID == Intrinsic::lifetime_end) {\                                                                                                     │
│             LLVM_DEBUG(dbgs() << "  Skipping replacement: pointer used by lifetime intrinsic\\n");\                                                                                      │
│             return false;\                                                                                                                                                               │
│           }\                                                                                                                                                                             │
│         }\                                                                                                                                                                               │
│       }\                                                                                                                                                                                 │
│     }\                                                                                                                                                                                   │
│   }' llvm/lib/Transforms/Utils/SCCPSolver.cpp && submit-patch                                                                                                                            │
│ ```                                                                                                                                                                                      │
