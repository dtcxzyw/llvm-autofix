│ does not fire, explicitly detect a select fed by an FCmp where the compare operands match the select arms and   │
│ the predicate is a max/min case, and then create the corresponding maxnum/minnum intrinsic while propagating    │
│ FMF (including nsz). This should restore the expected transforms without affecting other logic.                 │
│                                                                                                                 │
│ ```bash                                                                                                         │
│ sed -i '3956a\ \n    // Fallback: explicitly detect simple clamp patterns if matcher failed.\n    if (FCmp) {\n │
│ Value *Cmp0 = FCmp->getOperand(0), *Cmp1 = FCmp->getOperand(1);\n      if ((Cmp0 == TrueVal && Cmp1 ==          │
│ FalseVal) || (Cmp0 == FalseVal && Cmp1 == TrueVal)) {\n        auto Pred = FCmp->getPredicate();\n        Value │
│ *X = Cmp0, *Y = Cmp1;\n        bool SwapArms = (Cmp0 == FalseVal && Cmp1 == TrueVal);\n        if (SwapArms) {  │
│ X = Cmp1; Y = Cmp0; }\n        if (CmpInst::isRelational(Pred)) {\n          if (Pred == CmpInst::FCMP_OGT ||   │
│ Pred == CmpInst::FCMP_UGT || Pred == CmpInst::FCMP_OGE || Pred == CmpInst::FCMP_UGE) {\n            Value       │
│ *BinIntr = Builder.CreateBinaryIntrinsic(Intrinsic::maxnum, X, Y, &SI);\n            if (auto *BinIntrInst =    │
│ dyn_cast<Instruction>(BinIntr)) {\n              BinIntrInst->setHasNoNaNs(FCmp->hasNoNaNs());\n                │
│ BinIntrInst->setHasNoInfs(FCmp->hasNoInfs());\n                                                                 │
│ BinIntrInst->setHasNoSignedZeros(SIFPOp->hasNoSignedZeros());\n            }\n            return                │
│ replaceInstUsesWith(SI, BinIntr);\n          }\n          if (Pred == CmpInst::FCMP_OLT || Pred ==              │
│ CmpInst::FCMP_ULT || Pred == CmpInst::FCMP_OLE || Pred == CmpInst::FCMP_ULE) {\n            Value *BinIntr =    │
│ Builder.CreateBinaryIntrinsic(Intrinsic::minnum, X, Y, &SI);\n            if (auto *BinIntrInst =               │
│ dyn_cast<Instruction>(BinIntr)) {\n              BinIntrInst->setHasNoNaNs(FCmp->hasNoNaNs());\n                │
│ BinIntrInst->setHasNoInfs(FCmp->hasNoInfs());\n                                                                 │
