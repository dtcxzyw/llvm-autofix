│ sed -i '3932,3936s/SIFPOp->hasNoNaNs() &&\n        (SIFPOp->hasNoSignedZeros() ||\n                             │
│ (SIFPOp->hasOneUse() &&\n          canIgnoreSignBitOfZero(*SIFPOp->use_begin())))/SIFPOp->hasNoNaNs() &&\n      │
