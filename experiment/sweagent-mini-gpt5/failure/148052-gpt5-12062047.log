│ nl -ba llvm/lib/Transforms/Utils/SimplifyCFG.cpp | sed -n '5440,5560p' && sed -n '2830,2870p'                   │
│ llvm/lib/Transforms/Utils/Local.cpp && sed -n '4430,4460p' llvm/include/llvm/IR/Instructions.h && python3 - <<  │
