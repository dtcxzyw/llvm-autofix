│ THOUGHT: The miscompilation is caused by SLP vectorizing a cast group where lanes have different cast kinds (sext vs zext), applying a single cast kind across all lanes    │
│ and producing poison. A safe fix is to bail out of vectorizing such cast groups. I will insert a guard in buildTree_rec’s cast handling: before creating the vectorized     │
│ cast TreeEntry, detect if any lane’s CastInst opcode differs from the group’s ShuffleOrOp. If mixed, create a NeedToGather TreeEntry, recurse on its operands, and return.  │
│ This avoids merging mixed cast kinds while preserving pass behavior elsewhere.                                                                                              │
│                                                                                                                                                                             │
│ ```bash                                                                                                                                                                     │
│ awk 'BEGIN{ins=0} {if($0 ~ /TreeEntry \*TE = newTreeEntry\(VL, Bundle \/\*vectorized\*\/, S, UserTreeIdx,/ && ins==0){print "      {"; print "        // Bail out if lanes  │
│ have different cast opcodes (e.g., mixing ZExt and SExt)."; print "        bool HasMixedCastOpcodes = false;"; print "        for (Value *V : VL) {"; print "          if   │
│ (auto *CI = dyn_cast<CastInst>(V)) {"; print "            if (CI->getOpcode() != ShuffleOrOp) { HasMixedCastOpcodes = true; break; }"; print "          }"; print "         │
│ }"; print "        if (HasMixedCastOpcodes) {"; print "          TreeEntry *TE = newTreeEntry(VL, TreeEntry::NeedToGather, Bundle, S, UserTreeIdx, ReuseShuffleIndices);";  │
│ print "          LLVM_DEBUG(dbgs() << \"SLP: keep mixed cast ops as scalars.\\n\");"; print "          TE->setOperandsInOrder();"; print "          for (unsigned I :       │
│ seq<unsigned>(0, VL0->getNumOperands()))"; print "            buildTree_rec(TE->getOperand(I), Depth + 1, {TE, I});"; print "          return;"; print "        }"; print " │
│ }"; ins=1} print }' llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp > /tmp/SLPVectorizer.cpp.new && mv /tmp/SLPVectorizer.cpp.new                                           │
│ llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp && submit-patch                                                                                                             │
│ ```                                                                                                                                                                         │
