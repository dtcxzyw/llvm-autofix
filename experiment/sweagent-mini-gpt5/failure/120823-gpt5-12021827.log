│ THOUGHT: The miscompilation comes from SLP emitting a vector icmp on <N x i1> after truncation, which can yield poison. A targeted and minimally invasive fix is to widen operands to i8 │
│ only when the compare would be performed on a vector of i1 elements. I will modify the ICmp emission in SLPVectorizer.cpp to zext L and R to a vector of i8 when the element type is i1, │
│ right before Builder.CreateCmp, and then run the focused X86 test to validate the change.                                                                                                │
│                                                                                                                                                                                          │
│ ```bash                                                                                                                                                                                  │
│ sed -i '15488i \                                                                                                                                                                         │
│         if (auto *VTElTy = dyn_cast<VectorType>(L->getType())) {\                                                                                                                        │
│           if (VTElTy->getElementType()->isIntegerTy(1)) {\                                                                                                                               │
│             auto *I8TyFix = IntegerType::get(F->getContext(), 8);\                                                                                                                       │
│             auto *WideTyFix = FixedVectorType::get(I8TyFix, cast<FixedVectorType>(VTElTy)->getNumElements());\                                                                           │
│             L = Builder.CreateZExt(L, WideTyFix);\                                                                                                                                       │
│             R = Builder.CreateZExt(R, WideTyFix);\                                                                                                                                       │
│           }\                                                                                                                                                                             │
│         }' llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp && /llvm-autofix/build/llvm-build/120823/bin/llvm-lit --no-progress-bar -j 1 --max-failures 1 --order lexical -sv             │
│ /llvm-autofix-deps/llvm/llvm/llvm/test/Transforms/SLPVectorizer/X86/buildvector-schedule-for-subvector.ll                                                                                │
│ ```                                                                                                                                                                                      │
