│ Here are some thoughts about why I want to perform the action. The miscompilation stems from GVN propagating equalities and performing replacements without considering     │
│ differences in MD_range metadata between LHS and RHS, which can introduce poison. I will add a guard in the equality propagation loop to skip leader-table insertion and    │
│ dominated use replacements when both LHS and RHS are instructions and their MD_range metadata differ. This should prevent unsafe forwarding leading to the observed         │
│ miscompile.                                                                                                                                                                 │
│                                                                                                                                                                             │
│ ```bash                                                                                                                                                                     │
│ python3 - << 'PY'                                                                                                                                                           │
│ import re                                                                                                                                                                   │
│ path = 'llvm/lib/Transforms/Scalar/GVN.cpp'                                                                                                                                 │
│ s = open(path).read()                                                                                                                                                       │
│                                                                                                                                                                             │
│ # Insert a guard after the block deciding LVN/RVN ordering, before any leader insertion or replacements.                                                                    │
│ insertion_point = s.find('    if ((isa<Argument>(LHS) && isa<Argument>(RHS)) ||\n        (isa<Instruction>(LHS) && isa<Instruction>(RHS))) {', s.find('while                │
│ (!Worklist.empty())'))                                                                                                                                                      │
│ if insertion_point == -1:                                                                                                                                                   │
│     print("Failed to find insertion anchor.")                                                                                                                               │
│     raise SystemExit(0)                                                                                                                                                     │
│                                                                                                                                                                             │
│ # Find end of that conditional block to insert after it.                                                                                                                    │
│ block_end = s.find('\n    }\n', insertion_point)                                                                                                                            │
│ if block_end == -1:                                                                                                                                                         │
│     print("Failed to find end of LVN/RVN block.")                                                                                                                           │
│     raise SystemExit(0)                                                                                                                                                     │
│                                                                                                                                                                             │
│ guard_code = '''                                                                                                                                                            │
│     // Prevent unsafe forwarding when MD_range metadata differs between LHS and RHS.                                                                                        │
│     if (isa<Instruction>(LHS) && isa<Instruction>(RHS)) {                                                                                                                   │
│       auto *LHSI = cast<Instruction>(LHS);                                                                                                                                  │
│       auto *RHSI = cast<Instruction>(RHS);                                                                                                                                  │
│       MDNode *LHSRange = LHSI->getMetadata(LLVMContext::MD_range);                                                                                                          │
│       MDNode *RHSRange = RHSI->getMetadata(LLVMContext::MD_range);                                                                                                          │
