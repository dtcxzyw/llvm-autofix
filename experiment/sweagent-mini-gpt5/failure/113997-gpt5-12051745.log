│ Here are some thoughts about why I want to perform the action. The build failed because Value::getMetadata is protected; only Instruction exposes metadata publicly.        │
│ Replacements in GVN can be non-instruction Values (e.g., constants). I will update the previously inserted guards to retrieve MD_range from the replacement value only if   │
│ it’s an Instruction, otherwise treat NewMD as null. This preserves safety without violating access rules.                                                                   │
│                                                                                                                                                                             │
│ ```bash                                                                                                                                                                     │
│ python3 - << 'PY'                                                                                                                                                           │
│ import re, sys                                                                                                                                                              │
│ path = 'llvm/lib/Transforms/Scalar/GVN.cpp'                                                                                                                                 │
│ s = open(path).read()                                                                                                                                                       │
│                                                                                                                                                                             │
│ def fix_newmd(text):                                                                                                                                                        │
│     # Replace patterns like: auto *NewMD = V->getMetadata(LLVMContext::MD_range);                                                                                           │
│     # or for other variables: Repl, AvailableValue                                                                                                                          │
│     vars = ['V', 'Repl', 'AvailableValue']                                                                                                                                  │
│     for var in vars:                                                                                                                                                        │
│         pat = re.compile(rf'auto\s*\*\s*NewMD\s*=\s*{var}\s*->\s*getMetadata\s*\(\s*LLVMContext::MD_range\s*\)\s*;')                                                        │
│         def repl(m):                                                                                                                                                        │
│             return (                                                                                                                                                        │
│                 f'auto *NewMD = nullptr;\n'                                                                                                                                 │
│                 f'if (auto *IV = dyn_cast<Instruction>({var}))\n'                                                                                                           │
│                 f'  NewMD = IV->getMetadata(LLVMContext::MD_range);'                                                                                                        │
│             )                                                                                                                                                               │
│         text = pat.sub(repl, text)                                                                                                                                          │
│     return text                                                                                                                                                             │
│                                                                                                                                                                             │
│ patched = fix_newmd(s)                                                                                                                                                      │
│ if patched == s:                                                                                                                                                            │
