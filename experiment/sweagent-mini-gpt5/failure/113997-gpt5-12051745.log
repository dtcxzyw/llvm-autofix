│ Here are some thoughts about why I want to perform the action. The replacement still occurs because GVN’s value numbering treats instructions as equivalent regardless of   │
│ MD_range, allowing ctpop calls with different range metadata to be considered the same and forwarded. A robust fix is to incorporate MD_range presence/content into the GVN │
│ expression hashing/equality, so instructions with differing MD_range are not considered equivalent and won’t be forwarded. I will patch GVN.cpp to add MD_range awareness   │
│ to expression construction by appending a discriminator to the varargs when an instruction has MD_range, then submit the patch.                                             │
│                                                                                                                                                                             │
│ ```bash                                                                                                                                                                     │
│ python3 - << 'PY'                                                                                                                                                           │
│ import re                                                                                                                                                                   │
│ path = 'llvm/lib/Transforms/Scalar/GVN.cpp'                                                                                                                                 │
│ s = open(path).read()                                                                                                                                                       │
│                                                                                                                                                                             │
│ # Heuristic patch: when building expressions from instructions, include MD_range discriminator.                                                                             │
│ # Find a function/method that constructs Expression from Instruction operands, and tack on MD_range info.                                                                   │
│ # We'll add a helper near the Expression struct usage: after Expression creation for an Instruction I,                                                                      │
│ # append a tag to varargs if I has MD_range metadata.                                                                                                                       │
│                                                                                                                                                                             │
│ # Insert a small utility function to query MD_range and incorporate into expression building.                                                                               │
│ insertion_point = s.find('struct llvm::GVNPass::Expression {')                                                                                                              │
│ if insertion_point != -1:                                                                                                                                                   │
│     # Add a forward utility after the struct to tag expressions with MD_range presence.                                                                                     │
│     add_after_struct = '\nstatic inline void GVNAddRangeMDDiscriminator(llvm::GVNPass::Expression &E, const llvm::Instruction *I) {\n  if (!I) return;\n  if                │
│ (I->getMetadata(llvm::LLVMContext::MD_range)) {\n    // Push a fixed discriminator to distinguish expressions with MD_range.\n    E.varargs.push_back(0xRANG); // arbitrary │
│ tag to differentiate\n  }\n}\n'                                                                                                                                             │
│     # Use a safer tag: push back opcode-sized discriminator twice to avoid collision; replace placeholder                                                                   │
│     add_after_struct = add_after_struct.replace('0xRANG', '0xBEEF')                                                                                                         │
│     # Insert after struct definition end (find closing brace followed by semicolon).                                                                                        │
│     end_struct = s.find('};', insertion_point)                                                                                                                              │
│     if end_struct != -1:                                                                                                                                                    │
│         s = s[:end_struct+2] + add_after_struct + s[end_struct+2:]                                                                                                          │
│                                                                                                                                                                             │
│ # Now find spots where Expressions are created from Instructions and call our discriminator.                                                                                │
│ # Common pattern: Expression e; e.opcode = I->getOpcode(); etc. We will add calls after such creations.                                                                     │
│ # Patch occurrences where an Expression variable is initialized and we have an Instruction pointer named I or CurInst.                                                      │
│ patterns = [                                                                                                                                                                │
│     (r'(Expression\s+[A-Za-z_][A-Za-z0-9_]*\s*=\s*.*;)', 'I'),                                                                                                              │
│     (r'(Expression\s+[A-Za-z_][A-Za-z0-9_]*;)', 'I'),                                                                                                                       │
│ ]                                                                                                                                                                           │
│ def add_call(text):                                                                                                                                                         │
│     # Insert a call GVNAddRangeMDDiscriminator(expr, I);                                                                                                                    │
│     # We will search for lines where we set e.opcode = I->getOpcode() to identify the expr variable name.                                                                   │
│     lines = text.splitlines(True)                                                                                                                                           │
│     for i in range(len(lines)):                                                                                                                                             │
│         if 'getOpcode()' in lines[i] and 'I->getOpcode()' in lines[i]:                                                                                                      │
│             # find the closest previous declaration of Expression var                                                                                                       │
│             varname = None                                                                                                                                                  │
│             for j in range(i, -1, -1):                                                                                                                                      │
│                 m = re.search(r'Expression\s+([A-Za-z_][A-Za-z0-9_]*)', lines[j])                                                                                           │
│                 if m:                                                                                                                                                       │
