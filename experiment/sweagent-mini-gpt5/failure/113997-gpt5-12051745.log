│                     break                                                                                                                                                   │
│             if varname:                                                                                                                                                     │
│                 # insert call after current line                                                                                                                            │
│                 lines[i] = lines[i] + f'  GVNAddRangeMDDiscriminator({varname}, I);\n'                                                                                      │
│     return ''.join(lines)                                                                                                                                                   │
