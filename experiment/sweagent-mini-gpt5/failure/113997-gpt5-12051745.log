│ Here are some thoughts about why I want to perform the action. The miscompilation persists because GVN still performs dominated-use replacements in the equality            │
│ propagation loop without considering MD_range differences between LHS and RHS. I will insert a guard right before replaceDominatedUsesWithIf calls to skip replacements     │
│ when both LHS and RHS are Instructions and their MD_range metadata differs. This will prevent turning a well-defined value into poison in cases like differing ctpop range  │
│ metadata.                                                                                                                                                                   │
│                                                                                                                                                                             │
│ ```bash                                                                                                                                                                     │
│ python3 - << 'PY'                                                                                                                                                           │
│ import re                                                                                                                                                                   │
│ path = 'llvm/lib/Transforms/Scalar/GVN.cpp'                                                                                                                                 │
│ s = open(path).read()                                                                                                                                                       │
│                                                                                                                                                                             │
│ anchor = 'unsigned NumReplacements =\n          DominatesByEdge\n              ? replaceDominatedUsesWithIf(LHS, RHS, *DT, Root,\n                                          │
│ canReplacePointersCallBack)\n              : replaceDominatedUsesWithIf(LHS, RHS, *DT, Root.getStart(),\n                                                                   │
│ canReplacePointersCallBack);'                                                                                                                                               │
│ guard = '''unsigned NumReplacements = 0;                                                                                                                                    │
│       // Guard against unsafe replacements when MD_range differs.                                                                                                           │
│       if (isa<Instruction>(LHS) && isa<Instruction>(RHS)) {                                                                                                                 │
│         auto *LHSI = cast<Instruction>(LHS);                                                                                                                                │
│         auto *RHSI = cast<Instruction>(RHS);                                                                                                                                │
│         MDNode *LHSRange = LHSI->getMetadata(LLVMContext::MD_range);                                                                                                        │
│         MDNode *RHSRange = RHSI->getMetadata(LLVMContext::MD_range);                                                                                                        │
│         if (LHSRange && LHSRange != RHSRange) {                                                                                                                             │
│           // Skip replacements to avoid introducing poison via mismatched range MD.                                                                                         │
│           NumReplacements = 0;                                                                                                                                              │
│         } else {                                                                                                                                                            │
│           NumReplacements =                                                                                                                                                 │
│               DominatesByEdge                                                                                                                                               │
│                   ? replaceDominatedUsesWithIf(LHS, RHS, *DT, Root,                                                                                                         │
│                                                canReplacePointersCallBack)                                                                                                  │
│                   : replaceDominatedUsesWithIf(LHS, RHS, *DT, Root.getStart(),                                                                                              │
│                                                canReplacePointersCallBack);                                                                                                 │
│         }                                                                                                                                                                   │
│       } else {                                                                                                                                                              │
│         NumReplacements =                                                                                                                                                   │
│             DominatesByEdge                                                                                                                                                 │
│                 ? replaceDominatedUsesWithIf(LHS, RHS, *DT, Root,                                                                                                           │
│                                              canReplacePointersCallBack)                                                                                                    │
│                 : replaceDominatedUsesWithIf(LHS, RHS, *DT, Root.getStart(),                                                                                                │
│                                              canReplacePointersCallBack);                                                                                                   │
│       }'''                                                                                                                                                                  │
│ if anchor in s:                                                                                                                                                             │
│     s = s.replace(anchor, guard)                                                                                                                                            │
│     open(path,'w').write(s)                                                                                                                                                 │
│     print("Inserted MD_range guard before replaceDominatedUsesWithIf in GVN equality propagation.")                                                                         │
│ else:                                                                                                                                                                       │
│     print("Anchor not found; no changes made.")                                                                                                                             │
│ PY                                                                                                                                                                          │
│ ```                                                                                                                                                                         │
