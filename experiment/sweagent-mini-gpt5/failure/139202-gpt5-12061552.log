│ THOUGHT: The miscompilation is due to SLP grouping non-inbounds pointer arithmetic that appears consecutive     │
│ after wraparound. A conservative, targeted fix is to only consider stores for grouping when both pointer        │
│ operands are from inbounds GEPs (or exactly the same base pointer). This avoids merging widely separated or     │
│ wrapping addresses without broadly disabling store vectorization.                                               │
│                                                                                                                 │
│ ```bash                                                                                                         │
│ python3 - << 'PY'                                                                                               │
│ import re,sys                                                                                                   │
│ p='llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp'                                                             │
│ s=open(p).read()                                                                                                │
│ # Inject conservative inbounds GEP guard into RelatedStoreInsts::getPointerDiff.                                │
│ pat =                                                                                                           │
│ r'(std::optional<int>\s+getPointerDiff\s*\(\s*StoreInst\s*&SI,\s*const\s*DataLayout\s*&DL,\s*ScalarEvolution\s* │
│ &SE\s*\)\s*const\s*\{\s*StoreInst\s*&BaseStore\s*=\s*\*AllStores\[BaseInstrIdx\];\s*)'                          │
│ def repl(m):                                                                                                    │
│     head = m.group(1)                                                                                           │
│     guard = (                                                                                                   │
│         '  Value *BasePtr = BaseStore.getPointerOperand();\n'                                                   │
│         '  Value *SIPtr = SI.getPointerOperand();\n'                                                            │
│         '  auto *BaseGEP = dyn_cast<GetElementPtrInst>(BasePtr);\n'                                             │
│         '  auto *SIGEP = dyn_cast<GetElementPtrInst>(SIPtr);\n'                                                 │
│         '  if (!(BasePtr == SIPtr) && (!(BaseGEP && BaseGEP->isInBounds()) || !(SIGEP &&                        │
│ SIGEP->isInBounds())))\n'                                                                                       │
│         '    return std::nullopt;\n'                                                                            │
│     )                                                                                                           │
│     return head + guard                                                                                         │
│ s2, n = re.subn(pat, repl, s, flags=re.S)                                                                       │
