│ register.\n      if (!StoreSeq.empty()) {\n        long long FirstDist = StoreSeq.begin()->first;\n        long │
│ long LastDist = std::prev(StoreSeq.end())->first;\n        if (LastDist - FirstDist > (long long)MaxElts)\n     │
│ return false;\n      }' llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp && submit-patch                         │
