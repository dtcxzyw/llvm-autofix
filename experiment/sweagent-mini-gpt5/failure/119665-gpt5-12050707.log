│                                                                                                                                                                                           │
│ # Guard plain (unqualified) calls to isLoopEntryGuardedByCond(L, Pred, X, Y)                                                                                                              │
│ # with availability checks. Skip already guarded or SE-> qualified calls.                                                                                                                 │
│ def guard_plain_calls(src):                                                                                                                                                               │
│     pattern = re.compile(r'(?P<prefix>[^S])isLoopEntryGuardedByCond\(\s*(?P<L>[A-Za-z0-9_]+)\s*,\s*(?P<P>[A-Za-z0-9_]+)\s*,\s*(?P<X>[A-Za-z0-9_]+)\s*,\s*(?P<Y>[A-Za-z0-9_]+)\s*\)')      │
│     def repl(m):                                                                                                                                                                          │
