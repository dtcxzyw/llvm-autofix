│         if 'isAvailableAtLoopEntry' in full:                                                                                                                                              │
│             return full                                                                                                                                                                   │
│         # Reinsert the non-'S' prefix character captured to avoid breaking code.                                                                                                          │
│         pref = m.group('prefix')                                                                                                                                                          │
│         L,P,X,Y = m.group('L'),m.group('P'),m.group('X'),m.group('Y')                                                                                                                     │
