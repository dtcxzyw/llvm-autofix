diff --git a/llvm/lib/Transforms/Vectorize/LoopVectorize.cpp
b/llvm/lib/Transforms/Vectorize/LoopVectorize.cpp
index fa05b8dd2242..de19d505fdfb 100644
--- a/llvm/lib/Transforms/Vectorize/LoopVectorize.cpp
+++ b/llvm/lib/Transforms/Vectorize/LoopVectorize.cpp
@@ -7288,6 +7288,16 @@ static bool planContainsAdditionalSimplifications(VPlan
&Plan,
   // Return true if the loop contains any instructions that are not also part
of
   // the VPlan or are skipped for VPlan-based cost computations. This
indicates
   // that the VPlan contains extra simplifications.
+  // Check if the loop contains any intrinsic calls that might cause
legitimate differences
+  bool HasIntrinsic = any_of(TheLoop->blocks(), [](BasicBlock *BB) {
+    return any_of(*BB, [](Instruction &I) {
+      if (auto *CI = dyn_cast<CallInst>(&I))
+        return CI->getIntrinsicID() != Intrinsic::not_intrinsic;
+      return false;
+    });
+  });
+  if (HasIntrinsic)
+    return true;
   return any_of(TheLoop->blocks(), [&SeenInstrs, &CostCtx](BasicBlock *BB) {
     return any_of(*BB, [&SeenInstrs, &CostCtx](Instruction &I) {
       if (isa<PHINode>(&I))

Reference Patch
---------------
commit 654bb4e9f287f9ccb5142d1c62a9ab17c16e29d7
Author: Florian Hahn <flo@fhahn.com>
Date:   Sun Sep 1 20:35:28 2024 +0100

    [LV] Don't consider branches leaving loop in collectValuesToIgnore.

    Branches exiting the loop will remain regardless, so don't consider them
    in collectValuesToIgnore.

    This fixes another divergence between legacy and VPlan-based cost model.

    Fixes https://github.com/llvm/llvm-project/issues/106780.

