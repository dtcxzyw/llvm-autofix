diff --git a/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
b/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
index 58137cd6f543..2084b11c31a8 100644
--- a/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
+++ b/llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp
@@ -16064,7 +16064,7 @@ void BoUpSLP::computeMinimumValueSizes() {
                     // considered.
                     if (TE->getOpcode() == Instruction::ICmp)
                       return true;
-                    return DL->getTypeSizeInBits(U->getType()) > UserTESz;
+                    return !U->getType()->isSized() ||
DL->getTypeSizeInBits(U->getType()) > UserTESz;
                   }));
