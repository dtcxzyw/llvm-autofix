index dc3829d7f28e..e46a23e1aa33 100644
--- a/llvm/lib/Transforms/Coroutines/CoroSplit.cpp
+++ b/llvm/lib/Transforms/Coroutines/CoroSplit.cpp
@@ -2111,7 +2111,6 @@ static void updateCallGraphAfterCoroutineSplit(
