b/llvm/lib/Transforms/Scalar/GVN.cpp
index 7704e49c499d..0e03e82ec1fb 100644
--- a/llvm/lib/Transforms/Scalar/GVN.cpp
+++ b/llvm/lib/Transforms/Scalar/GVN.cpp
@@ -3169,6 +3169,8 @@ bool GVNPass::performPRE(Function &F) {
 /// Split the critical edge connecting the given two blocks, and return
 /// the block inserted to the critical edge.
 BasicBlock *GVNPass::splitCriticalEdges(BasicBlock *Pred, BasicBlock *Succ) {
+if (isa<IndirectBrInst>(Pred->getTerminator()))
+    return nullptr;
   // GVN does not require loop-simplify, do not try to preserve it if it is
not
