+        Cmp->getPredicate() == ICmpInst::ICMP_SGT &&
+        Cmp->getType()->isIntegerTy(1) &&
+        Cmp->getOperand(1) == ConstantInt::get(Cmp->getOperand(0)->getType(),
0)) {
+      return false;
+    }
+  }
