specific pattern\n+    // select (icmp eq ptr %a, %b), %a, %b when both %a and
%b are non-constant\n+    // and don't have the same underlying object, as it
may not be safe\n+    // due to potential differences in provenance.\n+    if
(CmpLHS->getType()->isPointerTy() &&\n+        !isa<Constant>(CmpLHS) &&
!isa<Constant>(CmpRHS) &&\n+        ((TrueVal == CmpLHS && FalseVal == CmpRHS)
||\n+         (TrueVal == CmpRHS && FalseVal == CmpLHS))) {\n+      Value
*UnderlyingLHS = getUnderlyingObject(CmpLHS);\n+      Value *UnderlyingRHS =
getUnderlyingObject(CmpRHS);\n+      if (UnderlyingLHS != UnderlyingRHS)\n+
return nullptr;\n+    }\n     if (Value *V =
simplifySelectWithEquivalence({{CmpLHS, CmpRHS}}, TrueVal,\n
FalseVal, Q, MaxRecurse))\n       return V;\n"
  ]
}
