│ unsigned VecWidth = cast<FixedVectorType>(VecTy)->getNumElements();         │
│ if (Index >= VecWidth)                                                      │
│   return false;                                                             │
│ ```                                                                         │
│                                                                             │
│ This prevents the transformation when the index is out of bounds,           │
│ preserving the original behavior and avoiding undefined behavior.           │
│                                                                             │
