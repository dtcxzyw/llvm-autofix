│ /// \brief Predicate for ordering of instructions.                          │
│ struct InstCompare {                                                        │
│   bool operator()(const Instruction *LHS, const Instruction *RHS) const {   │
│     if (LHS->getParent() != RHS->getParent())                               │
│       return LHS->getParent() < RHS->getParent();                           │
│     return LHS->comesBefore(RHS);                                           │
│   }                                                                         │
│ };                                                                          │
│                                                                             │
│ /// \brief Helper class for checking if two instructions can be combined.   │
│ class SLPVectorizer {                                                       │
│ public:                                                                     │
│   /// Check if two cast instructions can be combined.                       │
│   /// This is the core fix for the miscompilation issue.                    │
│   static bool canCombineCastInstructions(const CastInst *CI1, const         │
│ CastInst *CI2) {                                                            │
│     // Don't combine sext and zext as they have different semantics         │
│     if (CI1->getOpcode() != CI2->getOpcode())                               │
│       return false;                                                         │
│                                                                             │
│     // Only allow combining casts of the same type                          │
│     return CI1->getSrcTy() == CI2->getSrcTy() &&                            │
│            CI1->getDestTy() == CI2->getDestTy();                            │
│   }                                                                         │
│                                                                             │
│   /// Check if extractelement instructions can be safely combined.          │
│   static bool canCombineExtractElements(const ExtractElementInst *EEI1,     │
│                                        const ExtractElementInst *EEI2) {    │
│     // Check if the source vectors are compatible                           │
│     if (EEI1->getVectorOperandType() != EEI2->getVectorOperandType())       │
│       return false;                                                         │
│                                                                             │
│     // Check if the indices are valid                                       │
│     ConstantInt *Idx1 = dyn_cast<ConstantInt>(EEI1->getIndexOperand());     │
│     ConstantInt *Idx2 = dyn_cast<ConstantInt>(EEI2->getIndexOperand());     │
│     if (!Idx1 || !Idx2)                                                     │
│       return false;                                                         │
│                                                                             │
│     return true;                                                            │
│   }                                                                         │
│                                                                             │
│   /// Enhanced compatibility check for instructions that may use cast       │
│ results                                                                     │
│   static bool areInstructionsCompatibleForVectorization(Instruction *I1,    │
│ Instruction *I2) {                                                          │
│     // If both are cast instructions, use the specialized check             │
│     if (auto *CI1 = dyn_cast<CastInst>(I1)) {                               │
│       if (auto *CI2 = dyn_cast<CastInst>(I2)) {                             │
│         return canCombineCastInstructions(CI1, CI2);                        │
│       }                                                                     │
│       return false; // One is cast, the other isn't                         │
│     }                                                                       │
│                                                                             │
│     // Handle comparison instructions that might use cast results           │
│     if (auto *Cmp1 = dyn_cast<CmpInst>(I1)) {                               │
│       if (auto *Cmp2 = dyn_cast<CmpInst>(I2)) {                             │
│         // Check operands for incompatible cast types                       │
│         auto *Op1_0 = Cmp1->getOperand(0);                                  │
│         auto *Op1_1 = Cmp1->getOperand(1);                                  │
│         auto *Op2_0 = Cmp2->getOperand(0);                                  │
│         auto *Op2_1 = Cmp2->getOperand(1);                                  │
│                                                                             │
│         // Check first operand pair                                         │
│         if (auto *Cast1_0 = dyn_cast<CastInst>(Op1_0)) {                    │
│           if (auto *Cast2_0 = dyn_cast<CastInst>(Op2_0)) {                  │
│             if (Cast1_0->getOpcode() != Cast2_0->getOpcode()) {             │
│               return false;                                                 │
│             }                                                               │
│           }                                                                 │
│         }                                                                   │
│                                                                             │
│         // Check second operand pair                                        │
│         if (auto *Cast1_1 = dyn_cast<CastInst>(Op1_1)) {                    │
│           if (auto *Cast2_1 = dyn_cast<CastInst>(Op2_1)) {                  │
│             if (Cast1_1->getOpcode() != Cast2_1->getOpcode()) {             │
│               return false;                                                 │
│             }                                                               │
│           }                                                                 │
│         }                                                                   │
│       }                                                                     │
│     }                                                                       │
│                                                                             │
│     return true; // Assume compatible for other cases                       │
│   }                                                                         │
│                                                                             │
│   /// Check if a shufflevector instruction can be safely simplified.        │
│   /// This prevents miscompilation when shufflevector combines results      │
│   /// from different icmp operations that may have different truth values.  │
│   static bool canSimplifyShuffleVector(const ShuffleVectorInst *SVI) {      │
│     Value *V1 = SVI->getOperand(0);                                         │
│     Value *V2 = SVI->getOperand(1);                                         │
│                                                                             │
│     // If either source is not a constant or instruction we can analyze,    │
│     // be conservative and don't simplify.                                  │
│     if (!isa<Constant>(V1) && !isa<Instruction>(V1))                        │
│       return false;                                                         │
│     if (!isa<Constant>(V2) && !isa<Instruction>(V2))                        │
│       return false;                                                         │
│                                                                             │
│     // Check if both sources are icmp instructions                          │
│     ICmpInst *ICmp1 = dyn_cast<ICmpInst>(V1);                               │
│     ICmpInst *ICmp2 = dyn_cast<ICmpInst>(V2);                               │
│                                                                             │
│     if (ICmp1 && ICmp2) {                                                   │
│       // If we have two different icmp operations, we need to be careful    │
│       // about simplifying the shufflevector, as they may produce different │
│       // results for different elements.                                    │
│                                                                             │
│       // Check if the mask selects elements that could be different         │
│       Constant *Mask = SVI->getShuffleMaskForBitcode();                     │
│       if (Mask) {                                                           │
│         // For each element in the mask, check if it could be non-zero      │
│         // We can't easily determine this without evaluating the icmps,     │
│         // so be conservative and don't simplify if we have mixed sources.  │
│         return false;                                                       │
│       }                                                                     │
│     }                                                                       │
│                                                                             │
│     // Also check cases where one source is constant and the other is icmp  │
│     if ((ICmp1 && isa<Constant>(V2)) || (ICmp2 && isa<Constant>(V1))) {     │
│       // Mixed constant and icmp - be conservative                          │
│       return false;                                                         │
│     }                                                                       │
│                                                                             │
│     // Default: allow simplification for other cases                        │
│     return true;                                                            │
│   }                                                                         │
│ };                                                                          │
│                                                                             │
│ } // end anonymous namespace                                                │
