│ assume the select will definitely choose one of the operands.               │
│                                                                             │
│ The safest fix is to disable InstCombine optimizations for scalar selects   │
│ of vectors when the condition could be poison.                              │
│                                                                             │
│ Let me add this check at the beginning of the `visitSelectInst` function.   │
│                                                                             │
│ ```bash                                                                     │
│ # Add a safety check at the beginning of visitSelectInst to prevent         │
│ optimizations                                                               │
│ # for scalar selects of vectors when the condition could be poison          │
│ sed -i '/Instruction \*InstCombinerImpl::visitSelectInst(SelectInst \&SI)   │
│ {/a \                                                                       │
│   Value *CondVal = SI.getCondition();\                                      │
│   Type *SelType = SI.getType();\                                            │
│   \                                                                         │
│   // Prevent unsafe transformations for scalar selects of vectors when      │
│ condition could be poison\                                                  │
│   if (CondVal->getType()->isIntOrIntVectorTy(1) &&                          │
│ !CondVal->getType()->isVectorTy() && SelType->isVectorTy()) {\              │
│     if (!isGuaranteedNotToBePoison(CondVal, SQ.AC)) {\                      │
│       return nullptr;\                                                      │
│     }\                                                                      │
│   }'                                                                        │
│ /llvm-autofix-deps/llvm/llvm/llvm/lib/Transforms/InstCombine/InstCombineSel │
│ ect.cpp                                                                     │
│ ```                                                                         │
