│ +      LastValid = Mask[i];                                                 │
│ +      break;                                                               │
│ +    }                                                                      │
│ +  }                                                                        │
│ +                                                                           │
│ +  if (LastValid != -1) {                                                   │
│ +    for (int i = 0; i < (int)NumElements; ++i) {                           │
│ +      if (Mask[i] == -1) {                                                 │
│ +        Mask[i] = LastValid; // Use last valid index instead of poison     │
│ +      }                                                                    │
│ +    }                                                                      │
│ +  }                                                                        │
│ +                                                                           │
│ +  return Mask;                                                             │
│ +}                                                                          │
│ +                                                                           │
│ +// The vector-combine pass should use these utilities to avoid poison      │
│ introduction                                                                │
