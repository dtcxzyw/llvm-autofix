│ lanes                                                                       │
│ +// Instead, use safe indices or duplicate existing valid indices           │
│ +SmallVector<int, 8> createSafeShuffleMask(unsigned NumElements,            │
│ +                                          const SmallVectorImpl<unsigned>  │
│ &ValidIndices) {                                                            │
│ +  SmallVector<int, 8> Mask(NumElements, -1); // Initialize with poison     │
│ (-1)                                                                        │
│ +                                                                           │
│ +  // Fill valid positions with actual indices                              │
│ +  for (unsigned i = 0; i < ValidIndices.size() && i < NumElements; ++i) {  │
│ +    if (ValidIndices[i] < NumElements) {                                   │
│ +      Mask[i] = ValidIndices[i];                                           │
│ +    }                                                                      │
│ +  }                                                                        │
│ +                                                                           │
│ +  // Replace remaining poison indices with safe values (e.g., 0 or         │
│ duplicate last valid)                                                       │
│ +  int LastValid = -1;                                                      │
│ +  for (int i = NumElements - 1; i >= 0; --i) {                             │
