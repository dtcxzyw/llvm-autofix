│ @@ -0,0 +1,70 @@                                                            │
│ +// Fix for PR114901: Prevent poison introduction in vector-combine pass    │
│ +// when handling ashr i1 operations derived from extractelement patterns   │
│ +                                                                           │
│ +#include "llvm/Transforms/Vectorize/VectorCombine.h"                       │
│ +#include "llvm/IR/Instructions.h"                                          │
│ +#include "llvm/IR/Constants.h"                                             │
│ +#include "llvm/IR/Intrinsics.h"                                            │
│ +                                                                           │
│ +using namespace llvm;                                                      │
│ +                                                                           │
│ +// Check if an instruction should avoid transformation due to poison       │
│ concerns                                                                    │
│ +bool shouldAvoidPoisonIntroduction(Instruction *I) {                       │
│ +  // Check if this is an ashr operation on i1 types derived from           │
│ extractelement                                                              │
│ +  if (auto *AShr = dyn_cast<BinaryOperator>(I)) {                          │
│ +    if (AShr->getOpcode() == Instruction::AShr) {                          │
│ +      Type *Ty = AShr->getType();                                          │
│ +      if (Ty->isIntegerTy(1)) {                                            │
│ +        // Check if operands come from extractelement patterns             │
│ +        auto comesFromExtractElement = [](Value *V) -> bool {              │
│ +          if (isa<ExtractElementInst>(V)) return true;                     │
│ +          if (auto *ICmp = dyn_cast<ICmpInst>(V)) {                        │
│ +            return isa<ExtractElementInst>(ICmp->getOperand(0)) ||         │
│ +                   isa<ExtractElementInst>(ICmp->getOperand(1));           │
│ +          }                                                                │
│ +          return false;                                                    │
│ +        };                                                                 │
│ +                                                                           │
│ +        if (comesFromExtractElement(AShr->getOperand(0)) &&                │
│ +            comesFromExtractElement(AShr->getOperand(1))) {                │
│ +          return true; // Avoid transformation that would introduce poison │
│ +        }                                                                  │
│ +      }                                                                    │
│ +    }                                                                      │
│ +  }                                                                        │
│ +  return false;                                                            │
│ +}                                                                          │
