│ if (I->isTerminator())                                                                                                                                                                                         │
│   return false;                                                                                                                                                                                                │
│ ```                                                                                                                                                                                                            │
│                                                                                                                                                                                                                │
│ This should be placed right after the instruction cast assertion in the `extendSchedulingRegion` function.                                                                                                     │
