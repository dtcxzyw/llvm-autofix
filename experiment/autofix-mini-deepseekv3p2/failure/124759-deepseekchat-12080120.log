│ 448 void RuntimePointerChecking::groupChecks(                               │
│ 449     MemoryDepChecker::DepCandidates &DepCands, bool UseDependencies) {  │
│ 450   // We build the groups from dependency candidates equivalence classes │
│ 451   // because:                                                           │
│ 452   //    - We know that pointers in the same equivalence class share     │
│ 453   //      the same underlying object and therefore there is a chance    │
│ 454   //      that we can compare pointers                                  │
│ 455   //    - We wouldn't be able to merge two pointers for which we need   │
│ 456   //      to emit a memcheck. The classes in DepCands are already       │
│ 457   //      conveniently built such that no two pointers in the same      │
│ 458   //      class need checking against each other.                       │
│ 459                                                                         │
│ 460   // We use the following (greedy) algorithm to construct the groups    │
│ 461   // For every pointer in the equivalence class:                        │
│ 462   //   For each existing group:                                         │
│ 463   //   - if the difference between this pointer and the min/max bounds  │
│ 464   //     of the group is a constant, then make the pointer part of the  │
│ 465   //     group and update the min/max bounds of that group as required. │
│ 466                                                                         │
│ 467   CheckingGroups.clear();                                               │
│ 468                                                                         │
│ 469   // If we need to check two pointers to the same underlying object     │
│ 470   // with a non-constant difference, we shouldn't perform any pointer   │
│ 471   // grouping with those pointers. This is because we can easily get    │
│ 472   // into cases where the resulting check would return false, even when │
│ 473   // the accesses are safe.                                             │
│ 474   //                                                                    │
│ 475   // The following example shows this:                                  │
│ 476   // for (i = 0; i < 1000; ++i)                                         │
│ 477   //   a[5000 + i * m] = a[i] + a[i + 9000]                             │
│ 478   //                                                                    │
│ 479   // Here grouping gives a check of (5000, 5000 + 1000 * m) against     │
│ 480   // (0, 10000) which is always false. However, if m is 1, there is no  │
│ 481   // dependence. Not grouping the checks for a[i] and a[i + 9000]       │
│ allows                                                                      │
│ 482   // us to perform an accurate check in this case.                      │
│ 483   //                                                                    │
│ 484   // The above case requires that we have an UnknownDependence between  │
│ 485   // accesses to the same underlying object. This cannot happen unless  │
│ 486   // FoundNonConstantDistanceDependence is set, and therefore           │
│ UseDependencies                                                             │
│ 487   // is also false. In this case we will use the fallback path and      │
│ create                                                                      │
│ 488   // separate checking groups for all pointers.                         │
│ 489                                                                         │
│ 490   // If we don't have the dependency partitions, construct a new        │
│ 491   // checking pointer group for each pointer. This is also required     │
│ 492   // for correctness, because in this case we can have checking between │
│ 493   // pointers to the same underlying object.                            │
│ 494   if (!UseDependencies) {                                               │
│ 495     for (unsigned I = 0; I < Pointers.size(); ++I)                      │
│ 496       CheckingGroups.emplace_back(I, *this);                            │
│ 497     return;                                                             │
│ 498   }                                                                     │
│ 499                                                                         │
│ 500   unsigned TotalComparisons = 0;                                        │
│ 501                                                                         │
│ 502   DenseMap<Value *, SmallVector<unsigned>> PositionMap;                 │
│ 503   for (unsigned Index = 0; Index < Pointers.size(); ++Index)            │
│ 504     PositionMap[Pointers[Index].PointerValue].push_back(Index);         │
│ 505                                                                         │
│ 506   // We need to keep track of what pointers we've already seen so we    │
│ 507   // don't process them twice.                                          │
│ 508   SmallSet<unsigned, 2> Seen;                                           │
│ 509                                                                         │
│ 510   // Go through all equivalence classes, get the "pointer check groups" │
│ 511   // and add them to the overall solution. We use the order in which    │
│ accesses                                                                    │
│ 512   // appear in 'Pointers' to enforce determinism.                       │
│ 513   for (unsigned I = 0; I < Pointers.size(); ++I) {                      │
│ 514     // We've seen this pointer before, and therefore already processed  │
│ 515     // its equivalence class.                                           │
│ 516     if (Seen.count(I))                                                  │
│ 517       continue;                                                         │
│ 518                                                                         │
│ 519     MemoryDepChecker::MemAccessInfo Access(Pointers[I].PointerValue,    │
│ 520                                            Pointers[I].IsWritePtr);     │
│ 521                                                                         │
│ 522     SmallVector<RuntimeCheckingPtrGroup, 2> Groups;                     │
│ 523     auto LeaderI = DepCands.findValue(DepCands.getLeaderValue(Access)); │
│ 524                                                                         │
│ 525     // Because DepCands is constructed by visiting accesses in the      │
│ order in                                                                    │
│ 526     // which they appear in alias sets (which is deterministic) and the │
│ 527     // iteration order within an equivalence class member is only       │
│ dependent on                                                                │
│ 528     // the order in which unions and insertions are performed on the    │
│ 529     // equivalence class, the iteration order is deterministic.         │
│ 530     for (auto MI = DepCands.member_begin(LeaderI), ME =                 │
│ DepCands.member_end();                                                      │
│ 531          MI != ME; ++MI) {                                              │
│ 532       auto PointerI = PositionMap.find(MI->getPointer());               │
│ 533       assert(PointerI != PositionMap.end() &&                           │
│ 534              "pointer in equivalence class not found in PositionMap");  │
│ 535       for (unsigned Pointer : PointerI->second) {                       │
│ 536         bool Merged = false;                                            │
│ 537         // Mark this pointer as seen.                                   │
│ 538         Seen.insert(Pointer);                                           │
│ 539                                                                         │
│ 540         // Go through all the existing sets and see if we can find one  │
│ 541         // which can include this pointer.                              │
│ 542         for (RuntimeCheckingPtrGroup &Group : Groups) {                 │
│ 543           // Don't perform more than a certain amount of comparisons.   │
