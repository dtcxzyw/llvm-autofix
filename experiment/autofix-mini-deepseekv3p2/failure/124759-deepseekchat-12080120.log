│ something                                                                   │
│ 545           // reasonable.  If we do end up hitting this threshold, the   │
│ algorithm                                                                   │
│ 546           // will create separate groups for all remaining pointers.    │
│ 547           if (TotalComparisons > MemoryCheckMergeThreshold)             │
│ 548             break;                                                      │
│ 549                                                                         │
│ 550           TotalComparisons++;                                           │
│ 551                                                                         │
│ 552           if (Group.addPointer(Pointer, *this)) {                       │
│ 553             Merged = true;                                              │
│ 554             break;                                                      │
│ 555           }                                                             │
│ 556         }                                                               │
│ 557                                                                         │
│ 558         if (!Merged)                                                    │
│ 559           // We couldn't add this pointer to any existing set or the    │
│ threshold                                                                   │
│ 560           // for the number of comparisons has been reached. Create a   │
│ new group                                                                   │
│ 561           // to hold the current pointer.                               │
│ 562           Groups.emplace_back(Pointer, *this);                          │
│ 563       }                                                                 │
│ 564     }                                                                   │
│ 565                                                                         │
│ 566     // We've computed the grouped checks for this partition.            │
│ 567     // Save the results and continue with the next one.                 │
│ 568     llvm::copy(Groups, std::back_inserter(CheckingGroups));             │
│ 569   }                                                                     │
│ 570 }                                                                       │
