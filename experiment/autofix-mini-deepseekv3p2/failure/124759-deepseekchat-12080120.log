│  98   /// the elements is important and has to be from most permissive to   │
│ least                                                                       │
│  99   /// permissive.                                                       │
│ 100   enum class VectorizationSafetyStatus {                                │
│ 101     // Can vectorize safely without RT checks. All dependences are      │
│ known to be                                                                 │
│ 102     // safe.                                                            │
│ 103     Safe,                                                               │
│ 104     // Can possibly vectorize with RT checks to overcome unknown        │
│ dependencies.                                                               │
│ 105     PossiblySafeWithRtChecks,                                           │
│ 106     // Cannot vectorize due to known unsafe dependencies.               │
│ 107     Unsafe,                                                             │
│ 108   };                                                                    │
