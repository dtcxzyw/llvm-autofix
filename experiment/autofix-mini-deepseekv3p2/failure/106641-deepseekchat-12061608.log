│                                                                                                                                                                                                                │
│ ```stack                                                                                                                                                                                                       │
│ (frame 1) llvm/lib/Transforms/Vectorize/LoopVectorize.cpp:7365 in llvm::LoopVectorizationPlanner::computeBestVF                                                                                                │
│ (frame 2) llvm/lib/Transforms/Vectorize/LoopVectorize.cpp:9921 in llvm::LoopVectorizePass::processLoop                                                                                                         │
