│ 401         // value.                                                       │
│ 402         SI->setCondition(Case);                                         │
│ 403         NumDeadCases += SI->getNumCases();                              │
│ 404         Changed = true;                                                 │
│ 405         break;                                                          │
│ 406       }                                                                 │
│ 407                                                                         │
│ 408       // Increment the case iterator since we didn't delete it.         │
│ 409       ++CI;                                                             │
│ 410       ++ReachableCaseCount;                                             │
│ 411     }                                                                   │
│ 412                                                                         │
│ 413     if (ReachableCaseCount > 1 && !SI->defaultDestUnreachable()) {      │
│ 414       BasicBlock *DefaultDest = SI->getDefaultDest();                   │
│ 415       ConstantRange CR =                                                │
