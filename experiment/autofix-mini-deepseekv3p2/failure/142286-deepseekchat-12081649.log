│ 371     // ConstantFoldTerminator() as the underlying SwitchInst can be changed.                                                                                                                               │
│ 372     SwitchInstProfUpdateWrapper SI(*I);                                                                                                                                                                    │
│ 373     unsigned ReachableCaseCount = 0;                                                                                                                                                                       │
│ 374                                                                                                                                                                                                            │
