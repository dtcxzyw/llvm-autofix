│ 378           LVI->getPredicateAt(CmpInst::ICMP_EQ, Cond, Case, I,                                                                                                                                             │
│ 379                               /* UseBlockValue */ true));                                                                                                                                                  │
│ 380                                                                                                                                                                                                            │
│ 381       if (Res && Res->isZero()) {                                                                                                                                                                          │
│ 382         // This case never fires - remove it.                                                                                                                                                              │
