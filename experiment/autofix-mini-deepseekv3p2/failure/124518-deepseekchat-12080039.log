│ /// Utility that implements appending of loops onto a worklist.             │
│ /// Loops are added in preorder (analogous for reverse postorder for        │
│ trees),                                                                     │
│ /// and the worklist is processed LIFO.                                     │
│ 1792 void llvm::appendReversedLoopsToWorklist(                              │
│ 1793     RangeT &&Loops, SmallPriorityWorklist<Loop *, 4> &Worklist) {      │
│ 1794   // We use an internal worklist to build up the preorder traversal    │
│ without                                                                     │
│ 1795   // recursion.                                                        │
│ 1796   SmallVector<Loop *, 4> PreOrderLoops, PreOrderWorklist;              │
│ 1797                                                                        │
│ 1798   // We walk the initial sequence of loops in reverse because we       │
│ generally want                                                              │
│ 1799   // to visit defs before uses and the worklist is LIFO.               │
│ 1800   for (Loop *RootL : Loops) {                                          │
│ 1801     assert(PreOrderLoops.empty() && "Must start with an empty preorder │
│ walk.");                                                                    │
│ 1802     assert(PreOrderWorklist.empty() &&                                 │
│ 1803            "Must start with an empty preorder walk worklist.");        │
│ 1804     PreOrderWorklist.push_back(RootL);                                 │
│ 1805     do {                                                               │
│ 1806       Loop *L = PreOrderWorklist.pop_back_val();                       │
│ 1807       PreOrderWorklist.append(L->begin(), L->end());                   │
│ 1808       PreOrderLoops.push_back(L);                                      │
│ 1809     } while (!PreOrderWorklist.empty());                               │
│ 1810                                                                        │
│ 1811     Worklist.insert(std::move(PreOrderLoops));                         │
│ 1812     PreOrderLoops.clear();                                             │
│ 1813   }                                                                    │
│ 1814 }                                                                      │
