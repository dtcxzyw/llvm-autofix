│ PN->getIncomingBlock(U),                                                    │
│ 125                                  I->getParent(), I);                    │
│ 126     else                                                                │
│ 127       C = getConstantAt(S->getCondition(), I, LVI);                     │
│ 128                                                                         │
│ 129     auto *CI = dyn_cast_or_null<ConstantInt>(C);                        │
│ 130     if (!CI)                                                            │
│ 131       continue;                                                         │
│ 132                                                                         │
│ 133     U.set(CI->isOne() ? S->getTrueValue() : S->getFalseValue());        │
