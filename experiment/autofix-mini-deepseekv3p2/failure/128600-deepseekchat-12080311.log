│ 853   // requires an iterator).                                             │
│ 854   DbgMarker *LastMarker = Src->createMarker(Last);                      │
│ 855   LastMarker->absorbDebugValues(*MoreDanglingDbgRecords, true);         │
│ 856   MoreDanglingDbgRecords->eraseFromParent();                            │
