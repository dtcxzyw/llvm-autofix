│ 826       //            Dest                                                │
│ 827       //              |                                                 │
│ 828       // this-block:                                                    │
│ 829       // Src-block: ~~~~~~~~++++B---B---B---B:::C                       │
│ 830       //                        |               |                       │
│ 831       //                       First           Last                     │
│ 832       First->adoptDbgRecords(this, end(), true);                        │
│ 833     } else {                                                            │
