│ 400 void VPTransformState::packScalarIntoVectorizedValue(const VPValue      │
│ *Def,                                                                       │
│ 401                                                      const VPLane       │
│ &Lane) {                                                                    │
│ 402   Value *ScalarInst = get(Def, Lane);                                   │
│ 403   Value *WideValue = get(Def);                                          │
│ 404   Value *LaneExpr = Lane.getAsRuntimeExpr(Builder, VF);                 │
│ 405   if (auto *StructTy = dyn_cast<StructType>(WideValue->getType())) {    │
│ 406     // We must handle each element of a vectorized struct type.         │
│ 407     for (unsigned I = 0, E = StructTy->getNumElements(); I != E; I++) { │
│ 408       Value *ScalarValue = Builder.CreateExtractValue(ScalarInst, I);   │
│ 409       Value *VectorValue = Builder.CreateExtractValue(WideValue, I);    │
│ 410       VectorValue =                                                     │
│ 411           Builder.CreateInsertElement(VectorValue, ScalarValue,         │
│ LaneExpr);                                                                  │
│ 412       WideValue = Builder.CreateInsertValue(WideValue, VectorValue, I); │
│ 413     }                                                                   │
│ 414   } else {                                                              │
│ 415     WideValue = Builder.CreateInsertElement(WideValue, ScalarInst,      │
│ LaneExpr);                                                                  │
│ 416   }                                                                     │
│ 417   set(Def, WideValue);                                                  │
│ 418 }                                                                       │
