│ 432 void VPBasicBlock::connectToPredecessors(VPTransformState &State) {     │
│ 433   auto &CFG = State.CFG;                                                │
│ 434   BasicBlock *NewBB = CFG.VPBB2IRBB[this];                              │
│ 435   // Hook up the new basic block to its predecessors.                   │
│ 436   for (VPBlockBase *PredVPBlock : getHierarchicalPredecessors()) {      │
│ 437     VPBasicBlock *PredVPBB = PredVPBlock->getExitingBasicBlock();       │
│ 438     auto &PredVPSuccessors = PredVPBB->getHierarchicalSuccessors();     │
│ 439     BasicBlock *PredBB = CFG.VPBB2IRBB[PredVPBB];                       │
│ 440                                                                         │
│ 441     assert(PredBB && "Predecessor basic-block not found building        │
│ successor.");                                                               │
│ 442     auto *PredBBTerminator = PredBB->getTerminator();                   │
│ 443     LLVM_DEBUG(dbgs() << "LV: draw edge from" << PredBB->getName() <<   │
│ '\n');                                                                      │
│ 444                                                                         │
│ 445     auto *TermBr = dyn_cast<BranchInst>(PredBBTerminator);              │
│ 446     if (isa<UnreachableInst>(PredBBTerminator)) {                       │
│ 447       assert(PredVPSuccessors.size() == 1 &&                            │
│ 448              "Predecessor ending w/o branch must have single            │
│ successor.");                                                               │
│ 449       DebugLoc DL = PredBBTerminator->getDebugLoc();                    │
│ 450       PredBBTerminator->eraseFromParent();                              │
│ 451       auto *Br = BranchInst::Create(NewBB, PredBB);                     │
│ 452       Br->setDebugLoc(DL);                                              │
│ 453     } else if (TermBr && !TermBr->isConditional()) {                    │
│ 454       TermBr->setSuccessor(0, NewBB);                                   │
│ 455     } else {                                                            │
│ 456       // Set each forward successor here when it is created, excluding  │
│ 457       // backedges. A backward successor is set when the branch is      │
│ created.                                                                    │
│ 458       unsigned idx = PredVPSuccessors.front() == this ? 0 : 1;          │
│ 459       assert((TermBr && (!TermBr->getSuccessor(idx) ||                  │
│ 460                          (isa<VPIRBasicBlock>(this) &&                  │
│ 461                           TermBr->getSuccessor(idx) == NewBB))) &&      │
│ 462              "Trying to reset an existing successor block.");           │
│ 463       TermBr->setSuccessor(idx, NewBB);                                 │
│ 464     }                                                                   │
│ 465     CFG.DTU.applyUpdates({{DominatorTree::Insert, PredBB, NewBB}});     │
│ 466   }                                                                     │
│ 467 }                                                                       │
