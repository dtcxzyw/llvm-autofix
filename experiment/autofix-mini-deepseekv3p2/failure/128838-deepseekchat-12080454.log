│ 469 void VPIRBasicBlock::execute(VPTransformState *State) {                 │
│ 470   assert(getHierarchicalSuccessors().size() <= 2 &&                     │
│ 471          "VPIRBasicBlock can have at most two successors at the         │
│ moment!");                                                                  │
│ 472   State->Builder.SetInsertPoint(IRBB->getTerminator());                 │
│ 473   State->CFG.PrevBB = IRBB;                                             │
│ 474   State->CFG.VPBB2IRBB[this] = IRBB;                                    │
│ 475   executeRecipes(State, IRBB);                                          │
│ 476   // Create a branch instruction to terminate IRBB if one was not       │
│ created yet                                                                 │
│ 477   // and is needed.                                                     │
│ 478   if (getSingleSuccessor() &&                                           │
│ isa<UnreachableInst>(IRBB->getTerminator())) {                              │
│ 479     auto *Br = State->Builder.CreateBr(IRBB);                           │
│ 480     Br->setOperand(0, nullptr);                                         │
│ 481     IRBB->getTerminator()->eraseFromParent();                           │
│ 482   } else {                                                              │
│ 483     assert(                                                             │
│ 484         (getNumSuccessors() == 0 ||                                     │
│ isa<BranchInst>(IRBB->getTerminator())) &&                                  │
│ 485         "other blocks must be terminated by a branch");                 │
│ 486   }                                                                     │
│ 487                                                                         │
│ 488   connectToPredecessors(*State);                                        │
│ 489 }                                                                       │
