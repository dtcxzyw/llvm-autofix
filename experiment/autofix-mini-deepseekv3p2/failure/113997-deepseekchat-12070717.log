│ 327 GVNPass::Expression GVNPass::ValueTable::createExpr(Instruction *I) {                                                                                                                                      │
│ 328   Expression e;                                                                                                                                                                                            │
│ 329   e.type = I->getType();                                                                                                                                                                                   │
