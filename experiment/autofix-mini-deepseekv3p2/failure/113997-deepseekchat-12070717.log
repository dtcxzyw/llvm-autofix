│ 408                                                                                                                                                                                                            │
│ 409   // Not a recognised intrinsic. Fall back to producing an extract value                                                                                                                                   │
│ 410   // expression.                                                                                                                                                                                           │
│ 411   e.opcode = EI->getOpcode();                                                                                                                                                                              │
│ 412   for (Use &Op : EI->operands())                                                                                                                                                                           │
│ 413     e.varargs.push_back(lookupOrAdd(Op));                                                                                                                                                                  │
│ 414                                                                                                                                                                                                            │
