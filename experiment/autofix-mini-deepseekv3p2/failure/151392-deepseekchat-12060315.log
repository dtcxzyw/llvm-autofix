│ 404       (!isa<VPInstruction>(R) || cast<VPInstruction>(R)->getOpcode() !=                                                                                                                                    │
│ 405                                      VPInstruction::ReductionStartVector) &&                                                                                                                               │
│ 406       "getting scaling factor of reduction-start-vector not implemented yet");                                                                                                                             │
