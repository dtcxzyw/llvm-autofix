│ 356 bool VPDominatorTree::properlyDominates(const VPRecipeBase *A,                                                                                                                                             │
│ 357                                         const VPRecipeBase *B) {                                                                                                                                           │
│ 358   if (A == B)                                                                                                                                                                                              │
│ 359     return false;                                                                                                                                                                                          │
│ 360                                                                                                                                                                                                            │
│ 361   auto LocalComesBefore = [](const VPRecipeBase *A, const VPRecipeBase *B) {                                                                                                                               │
│ 362     for (auto &R : *A->getParent()) {                                                                                                                                                                      │
│ 363       if (&R == A)                                                                                                                                                                                         │
│ 364         return true;                                                                                                                                                                                       │
│ 365       if (&R == B)                                                                                                                                                                                         │
│ 366         return false;                                                                                                                                                                                      │
│ 367     }                                                                                                                                                                                                      │
│ 368     llvm_unreachable("recipe not found");                                                                                                                                                                  │
│ 369   };                                                                                                                                                                                                       │
│ 370   const VPBlockBase *ParentA = A->getParent();                                                                                                                                                             │
│ 371   const VPBlockBase *ParentB = B->getParent();                                                                                                                                                             │
│ 372   if (ParentA == ParentB)                                                                                                                                                                                  │
│ 373     return LocalComesBefore(A, B);                                                                                                                                                                         │
│ 374                                                                                                                                                                                                            │
│ 375 #ifndef NDEBUG                                                                                                                                                                                             │
│ 376   auto GetReplicateRegion = [](VPRecipeBase *R) -> VPRegionBlock * {                                                                                                                                       │
│ 377     auto *Region = dyn_cast_or_null<VPRegionBlock>(R->getParent()->getParent());                                                                                                                           │
│ 378     if (Region && Region->isReplicator()) {                                                                                                                                                                │
│ 379       assert(Region->getNumSuccessors() == 1 &&                                                                                                                                                            │
│ 380              Region->getNumPredecessors() == 1 && "Expected SESE region!");                                                                                                                                │
│ 381       assert(R->getParent()->size() == 1 &&                                                                                                                                                                │
│ 382              "A recipe in an original replicator region must be the only "                                                                                                                                 │
│ 383              "recipe in its block");                                                                                                                                                                       │
│ 384       return Region;                                                                                                                                                                                       │
│ 385     }                                                                                                                                                                                                      │
│ 386     return nullptr;                                                                                                                                                                                        │
│ 387   };                                                                                                                                                                                                       │
│ 388   assert(!GetReplicateRegion(const_cast<VPRecipeBase *>(A)) &&                                                                                                                                             │
│ 389          "No replicate regions expected at this point");                                                                                                                                                   │
│ 390   assert(!GetReplicateRegion(const_cast<VPRecipeBase *>(B)) &&                                                                                                                                             │
│ 391          "No replicate regions expected at this point");                                                                                                                                                   │
│ 392 #endif                                                                                                                                                                                                     │
│ 393   return Base::properlyDominates(ParentA, ParentB);                                                                                                                                                        │
│ 394 }                                                                                                                                                                                                          │
