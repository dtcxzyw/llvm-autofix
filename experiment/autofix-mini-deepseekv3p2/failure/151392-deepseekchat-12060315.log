│ 397 /// one.                                                                                                                                                                                                   │
│ 398 static unsigned getVFScaleFactor(VPRecipeBase *R) {                                                                                                                                                        │
│ 399   if (auto *RR = dyn_cast<VPReductionPHIRecipe>(R))                                                                                                                                                        │
