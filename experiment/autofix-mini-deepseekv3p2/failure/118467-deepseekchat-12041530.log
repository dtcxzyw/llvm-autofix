│  84     if (match(V, m_OneUse(m_c_Or(                                       │
│  85                      m_Shl(m_Value(ShVal0), m_Value(ShAmt)),            │
│  86                      m_LShr(m_Value(ShVal1),                            │
│  87                             m_Sub(m_SpecificInt(Width),                 │
│ m_Deferred(ShAmt))))))) {                                                   │
│  88       return Intrinsic::fshl;                                           │
