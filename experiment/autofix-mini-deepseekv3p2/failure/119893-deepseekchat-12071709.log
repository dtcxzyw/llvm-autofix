│ 206   switch (Pred) {                                                       │
│ 207   case CmpInst::ICMP_UGT: Flavor = SPF_UMAX; break;                     │
│ 208   case CmpInst::ICMP_ULT: Flavor = SPF_UMIN; break;                     │
