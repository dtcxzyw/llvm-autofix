│ 393                                                                                                                                                                                                            │
│ 394   OffsetResult(GEPOperator &GEP, const DataLayout &DL)                                                                                                                                                     │
│ 395       : BasePtr(GEP.getPointerOperand()), AllInbounds(GEP.isInBounds()) {                                                                                                                                  │
│ 396     ConstantOffset = APInt(DL.getIndexTypeSizeInBits(BasePtr->getType()), 0);                                                                                                                              │
