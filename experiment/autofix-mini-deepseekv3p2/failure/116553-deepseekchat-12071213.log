│ 386 struct OffsetResult {                                                                                                                                                                                      │
│ 387   Value *BasePtr;                                                                                                                                                                                          │
│ 388   APInt ConstantOffset;                                                                                                                                                                                    │
│ 389   SmallMapVector<Value *, APInt, 4> VariableOffsets;                                                                                                                                                       │
│ 390   bool AllInbounds;                                                                                                                                                                                        │
│ 391                                                                                                                                                                                                            │
