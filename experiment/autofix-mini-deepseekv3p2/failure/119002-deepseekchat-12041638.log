│ 246     return CI->getOperand(0)->getType();                                │
│ 247   if (auto *IE = dyn_cast<InsertElementInst>(V))                        │
│ 248     return IE->getOperand(1)->getType();                                │
│ 249   return V->getType();                                                  │
│ 250 }                                                                       │
