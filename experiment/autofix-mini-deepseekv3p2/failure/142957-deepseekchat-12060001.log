│ 387                                                                                                                                                                                                            │
│ 388   unsigned BBNum = 0;                                                                                                                                                                                      │
│ 389   for (VPReplicateRecipe *RepR : WorkList) {                                                                                                                                                               │
│ 390     VPBasicBlock *CurrentBlock = RepR->getParent();                                                                                                                                                        │
