│ 397     VPRegionBlock *Region = createReplicateRegion(RepR, Plan);                                                                                                                                             │
│ 398     Region->setParent(CurrentBlock->getParent());                                                                                                                                                          │
│ 399     VPBlockUtils::insertOnEdge(CurrentBlock, SplitBlock, Region);                                                                                                                                          │
