│ 462   for (auto &Phi : Plan.getVectorLoopRegion()->getEntryBasicBlock()->phis()) {                                                                                                                             │
│ 463     auto *IV = dyn_cast<VPWidenIntOrFpInductionRecipe>(&Phi);                                                                                                                                              │
