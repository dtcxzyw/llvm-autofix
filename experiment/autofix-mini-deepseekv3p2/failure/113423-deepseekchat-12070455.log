│ 126       !match(Sel.getFalseValue(), m_APInt(SelFC)))                      │
│ 127     return nullptr;                                                     │
│ 128                                                                         │
│ 129   // If this is a vector select, we need a vector compare.              │
│ 130   Type *SelType = Sel.getType();                                        │
│ 131   if (SelType->isVectorTy() != Cmp->getType()->isVectorTy())            │
│ 132     return nullptr;                                                     │
│ 133                                                                         │
│ 134   Value *V;                                                             │
