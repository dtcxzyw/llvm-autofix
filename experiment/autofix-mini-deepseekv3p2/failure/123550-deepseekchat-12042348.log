│ 189   UseInst->setOperand(OperIdx, IVSrc);                                  │
│ 190   assert(SE->getSCEV(UseInst) == FoldedExpr && "bad SCEV with folded    │
│ oper");                                                                     │
│ 191                                                                         │
│ 192   if (MustDropExactFlag)                                                │
│ 193     UseInst->dropPoisonGeneratingFlags();                               │
│ 194                                                                         │
│ 195   ++NumElimOperand;                                                     │
│ 196   Changed = true;                                                       │
│ 197   if (IVOperand->use_empty())                                           │
