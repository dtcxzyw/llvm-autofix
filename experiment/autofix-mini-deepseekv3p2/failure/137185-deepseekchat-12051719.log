│  90                                                                                                                                                                                                            │
│  91   /// List of predecessor blocks.                                                                                                                                                                          │
│  92   SmallVector<VPBlockBase *, 1> Predecessors;                                                                                                                                                              │
│  93                                                                                                                                                                                                            │
│  94   /// List of successor blocks.                                                                                                                                                                            │
│  95   SmallVector<VPBlockBase *, 1> Successors;                                                                                                                                                                │
│  96                                                                                                                                                                                                            │
│  97   /// VPlan containing the block. Can only be set on the entry block of the                                                                                                                                │
│  98   /// plan.                                                                                                                                                                                                │
│  99   VPlan *Plan = nullptr;                                                                                                                                                                                   │
│ 100                                                                                                                                                                                                            │
│ 101   /// Add \p Successor as the last successor to this block.                                                                                                                                                │
│ 102   void appendSuccessor(VPBlockBase *Successor) {                                                                                                                                                           │
│ 103     assert(Successor && "Cannot add nullptr successor!");                                                                                                                                                  │
│ 104     Successors.push_back(Successor);                                                                                                                                                                       │
│ 105   }                                                                                                                                                                                                        │
│ 106                                                                                                                                                                                                            │
│ 107   /// Add \p Predecessor as the last predecessor to this block.                                                                                                                                            │
│ 108   void appendPredecessor(VPBlockBase *Predecessor) {                                                                                                                                                       │
│ 109     assert(Predecessor && "Cannot add nullptr predecessor!");                                                                                                                                              │
│ 110     Predecessors.push_back(Predecessor);                                                                                                                                                                   │
│ 111   }                                                                                                                                                                                                        │
│ 112                                                                                                                                                                                                            │
│ 113   /// Remove \p Predecessor from the predecessors of this block.                                                                                                                                           │
│ 114   void removePredecessor(VPBlockBase *Predecessor) {                                                                                                                                                       │
│ 115     auto Pos = find(Predecessors, Predecessor);                                                                                                                                                            │
│ 116     assert(Pos && "Predecessor does not exist");                                                                                                                                                           │
│ 117     Predecessors.erase(Pos);                                                                                                                                                                               │
│ 118   }                                                                                                                                                                                                        │
│ 119                                                                                                                                                                                                            │
│ 120   /// Remove \p Successor from the successors of this block.                                                                                                                                               │
│ 121   void removeSuccessor(VPBlockBase *Successor) {                                                                                                                                                           │
│ 122     auto Pos = find(Successors, Successor);                                                                                                                                                                │
│ 123     assert(Pos && "Successor does not exist");                                                                                                                                                             │
│ 124     Successors.erase(Pos);                                                                                                                                                                                 │
│ 125   }                                                                                                                                                                                                        │
│ 126                                                                                                                                                                                                            │
│ 127   /// This function replaces one predecessor with another, useful when                                                                                                                                     │
