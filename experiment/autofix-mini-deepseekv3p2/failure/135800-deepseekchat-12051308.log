│ 16140 /// Merges shuffle masks and emits final shuffle instruction, if      │
│ required. It                                                                │
│ 16141 /// supports shuffling of 2 input vectors. It implements lazy         │
│ shuffles emission,                                                          │
│ 16142 /// when the actual shuffle instruction is generated only if this is  │
│ actually                                                                    │
│ 16143 /// required. Otherwise, the shuffle instruction emission is delayed  │
│ till the                                                                    │
│ 16144 /// end of the process, to reduce the number of emitted instructions  │
│ and further                                                                 │
│ 16145 /// analysis/transformations.                                         │
│ 16146 /// The class also will look through the previously emitted shuffle   │
│ instructions                                                                │
│ 16147 /// and properly mark indices in mask as undef.                       │
│ 16148 /// For example, given the code                                       │
│ 16149 /// \code                                                             │
│ 16150 /// %s1 = shufflevector <2 x ty> %0, poison, <1, 0>                   │
│ 16151 /// %s2 = shufflevector <2 x ty> %1, poison, <1, 0>                   │
│ 16152 /// \endcode                                                          │
│ 16153 /// and if need to emit shuffle of %s1 and %s2 with mask <1, 0, 3,    │
│ 2>, it will                                                                 │
│ 16154 /// look through %s1 and %s2 and emit                                 │
│ 16155 /// \code                                                             │
│ 16156 /// %res = shufflevector <2 x ty> %0, %1, <0, 1, 2, 3>                │
│ 16157 /// \endcode                                                          │
│ 16158 /// instead.                                                          │
│ 16159 /// If 2 operands are of different size, the smallest one will be     │
│ resized and                                                                 │
│ 16160 /// the mask recalculated properly.                                   │
│ 16161 /// For example, given the code                                       │
│ 16162 /// \code                                                             │
│ 16163 /// %s1 = shufflevector <2 x ty> %0, poison, <1, 0, 1, 0>             │
│ 16164 /// %s2 = shufflevector <2 x ty> %1, poison, <1, 0, 1, 0>             │
│ 16165 /// \endcode                                                          │
│ 16166 /// and if need to emit shuffle of %s1 and %s2 with mask <1, 0, 5,    │
│ 4>, it will                                                                 │
