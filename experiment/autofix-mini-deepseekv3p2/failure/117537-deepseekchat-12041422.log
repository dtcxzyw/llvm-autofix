│ 589 static int CompareValueComplexity(const LoopInfo *const LI, Value *LV,  │
│ 590                                   Value *RV, unsigned Depth) {          │
│ 591   if (Depth > MaxValueCompareDepth)                                     │
│ 592     return 0;                                                           │
