│                                                                                                                                                                                                                │
│ ```stack                                                                                                                                                                                                       │
│ (frame 1) llvm/lib/Transforms/Vectorize/LoopVectorize.cpp:7378 in llvm::LoopVectorizationPlanner::computeBestVF                                                                                                │
│ (frame 2) llvm/lib/Transforms/Vectorize/LoopVectorize.cpp:9939 in llvm::LoopVectorizePass::processLoop                                                                                                         │
│ (frame 3) llvm/lib/Transforms/Vectorize/LoopVectorize.cpp:10285 in llvm::LoopVectorizePass::runImpl                                                                                                            │
