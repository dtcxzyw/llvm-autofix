│ edit({"file": "llvm/lib/Transforms/InstCombine/InstCombineCalls.cpp",       │
│ "old": "    // Propagate sign argument through nested calls:\n    //        │
│ copysign Mag, (copysign ?, X) --> copysign Mag, X\n    Value *X;\n    if    │
│ (match(Sign, m_Intrinsic<Intrinsic::copysign>(m_Value(), m_Value(X)))) {\n  │
│ // We can propagate X only if the outer copysign does not have nnan or\n    │
│ // the inner copysign has nnan. Otherwise, if the inner copysign can\n      │
│ // produce a non-NaN from a NaN sign operand, the outer copysign with       │
│ nnan\n      // would become poison when X is NaN.\n      // Similarly, we   │
│ must consider ninf: if the outer copysign has ninf and\n      // the inner  │
│ copysign does not, the inner copysign could produce a non-Inf\n      //     │
│ from an Inf sign operand, and the outer copysign with ninf would become\n   │
│ // poison when X is Inf.\n      auto *InnerCall = cast<CallInst>(Sign);\n   │
│ if ((!II->hasNoNaNs() || InnerCall->hasNoNaNs()) &&\n                       │
│ (!II->hasNoInfs() || InnerCall->hasNoInfs()))\n        return               │
│ replaceOperand(*II, 1, X);\n    }", "new": "    // Propagate sign argument  │
│ through nested calls:\n    // copysign Mag, (copysign ?, X) --> copysign    │
│ Mag, X\n    Value *X;\n    if (match(Sign,                                  │
│ m_Intrinsic<Intrinsic::copysign>(m_Value(), m_Value(X)))) {\n      // We    │
│ can propagate X only if the outer copysign does not have nnan or\n      //  │
│ the inner copysign has nnan. Otherwise, if the inner copysign can\n      // │
│ produce a non-NaN from a NaN sign operand, the outer copysign with nnan\n   │
│ // would become poison when X is NaN.\n      // Similarly, we must consider │
│ ninf: if the outer copysign has ninf and\n      // the inner copysign does  │
│ not, the inner copysign could produce a non-Inf\n      // from an Inf sign  │
│ operand, and the outer copysign with ninf would become\n      // poison     │
│ when X is Inf.\n      auto *InnerCall = cast<CallInst>(Sign);\n      if     │
│ ((!II->hasNoNaNs() || InnerCall->hasNoNaNs()) &&\n                          │
│ (!II->hasNoInfs() || InnerCall->hasNoInfs()))\n        return               │
│ replaceOperand(*II, 1, X);\n    }"})                                        │
