│ 128     ME |= MemoryEffects::argMemOnly(MR);                                │
│ 129     return;                                                             │
│ 130   }                                                                     │
│ 131                                                                         │
│ 132   // If it's not an identified object, it might be an argument.         │
│ 133   if (!isIdentifiedObject(UO))                                          │
│ 134     ME |= MemoryEffects::argMemOnly(MR);                                │
│ 135   ME |= MemoryEffects(IRMemLocation::Other, MR);                        │
