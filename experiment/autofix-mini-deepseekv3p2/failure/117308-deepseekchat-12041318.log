│ 255 MemoryEffects llvm::computeFunctionBodyMemoryAccess(Function &F,        │
│ 256                                                     AAResults &AAR) {   │
│ 257   return checkFunctionMemoryAccess(F, /*ThisBody=*/true, AAR,           │
│ {}).first;                                                                  │
│ 258 }                                                                       │
