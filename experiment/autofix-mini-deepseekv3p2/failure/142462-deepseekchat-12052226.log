│ 410              GCR1->getBasePtr() == GCR2->getBasePtr() &&                                                                                                                                                   │
│ 411              GCR1->getDerivedPtr() == GCR2->getDerivedPtr();                                                                                                                                               │
│ 412                                                                                                                                                                                                            │
│ 413   // Min/max can occur with commuted operands, non-canonical predicates,                                                                                                                                   │
│ 414   // and/or non-canonical operands.                                                                                                                                                                        │
│ 415   // Selects can be non-trivially equivalent via inverted conditions and swaps.                                                                                                                            │
│ 416   SelectPatternFlavor LSPF, RSPF;                                                                                                                                                                          │
│ 417   Value *CondL, *CondR, *LHSA, *RHSA, *LHSB, *RHSB;                                                                                                                                                        │
│ 418   if (matchSelectWithOptionalNotCond(LHSI, CondL, LHSA, LHSB, LSPF) &&                                                                                                                                     │
│ 419       matchSelectWithOptionalNotCond(RHSI, CondR, RHSA, RHSB, RSPF)) {                                                                                                                                     │
│ 420     if (LSPF == RSPF) {                                                                                                                                                                                    │
│ 421       // TODO: We should also detect FP min/max.                                                                                                                                                           │
│ 422       if (LSPF == SPF_SMIN || LSPF == SPF_SMAX ||                                                                                                                                                          │
│ 423           LSPF == SPF_UMIN || LSPF == SPF_UMAX)                                                                                                                                                            │
│ 424         return ((LHSA == RHSA && LHSB == RHSB) ||                                                                                                                                                          │
│ 425                 (LHSA == RHSB && LHSB == RHSA));                                                                                                                                                           │
│ 426                                                                                                                                                                                                            │
│ 427       // select Cond, A, B <--> select not(Cond), B, A                                                                                                                                                     │
│ 428       if (CondL == CondR && LHSA == RHSA && LHSB == RHSB)                                                                                                                                                  │
│ 429         return true;                                                                                                                                                                                       │
│ 430     }                                                                                                                                                                                                      │
│ 431                                                                                                                                                                                                            │
│ 432     // If the true/false operands are swapped and the conditions are compares                                                                                                                              │
│ 433     // with inverted predicates, the selects are equal:                                                                                                                                                    │
│ 434     // select (icmp Pred, X, Y), A, B <--> select (icmp InvPred, X, Y), B, A                                                                                                                               │
│ 435     //                                                                                                                                                                                                     │
│ 436     // This also handles patterns with a double-negation in the sense of not +                                                                                                                             │
│ 437     // inverse, because we looked through a 'not' in the matching function and                                                                                                                             │
│ 438     // swapped A/B:                                                                                                                                                                                        │
│ 439     // select (cmp Pred, X, Y), A, B <--> select (not (cmp InvPred, X, Y)), B, A                                                                                                                           │
│ 440     //                                                                                                                                                                                                     │
│ 441     // This intentionally does NOT handle patterns with a double-negation in                                                                                                                               │
│ 442     // the sense of not + not, because doing so could result in values                                                                                                                                     │
│ 443     // comparing                                                                                                                                                                                           │
│ 444     // as equal that hash differently in the min/max cases like:                                                                                                                                           │
│ 445     // select (cmp slt, X, Y), X, Y <--> select (not (not (cmp slt, X, Y))), X, Y                                                                                                                          │
│ 446     //   ^ hashes as min                  ^ would not hash as min                                                                                                                                          │
│ 447     // In the context of the EarlyCSE pass, however, such cases never reach                                                                                                                                │
│ 448     // this code, as we simplify the double-negation before hashing the second                                                                                                                             │
│ 449     // select (and so still succeed at CSEing them).                                                                                                                                                       │
│ 450     if (LHSA == RHSB && LHSB == RHSA) {                                                                                                                                                                    │
│ 451       CmpPredicate PredL, PredR;                                                                                                                                                                           │
│ 452       Value *X, *Y;                                                                                                                                                                                        │
│ 453       if (match(CondL, m_Cmp(PredL, m_Value(X), m_Value(Y))) &&                                                                                                                                            │
│ 454           match(CondR, m_Cmp(PredR, m_Specific(X), m_Specific(Y))) &&                                                                                                                                      │
│ 455           CmpInst::getInversePredicate(PredL) == PredR)                                                                                                                                                    │
│ 456         return true;                                                                                                                                                                                       │
│ 457     }                                                                                                                                                                                                      │
│ 458   }                                                                                                                                                                                                        │
│ 459                                                                                                                                                                                                            │
│ 460   return false;                                                                                                                                                                                            │
│ 461 }                                                                                                                                                                                                          │
│ 462                                                                                                                                                                                                            │
│ 463 bool DenseMapInfo<SimpleValue>::isEqual(SimpleValue LHS, SimpleValue RHS) {                                                                                                                                │
│ 464   // These comparisons are nontrivial, so assert that equality implies                                                                                                                                     │
│ 465   // hash equality (DenseMap demands this as an invariant).                                                                                                                                                │
│ 466   bool Result = isEqualImpl(LHS, RHS);                                                                                                                                                                     │
│ 467   assert(!Result || (LHS.isSentinel() && LHS.Inst == RHS.Inst) ||                                                                                                                                          │
│ 468          getHashValueImpl(LHS) == getHashValueImpl(RHS));                                                                                                                                                  │
│ 469   return Result;                                                                                                                                                                                           │
│ 470 }                                                                                                                                                                                                          │
