│ 557                                                                                                                                                                                                            │
│ 558 namespace {                                                                                                                                                                                                │
│ 559                                                                                                                                                                                                            │
│ 560 struct GEPValue {                                                                                                                                                                                          │
│ 561   Instruction *Inst;                                                                                                                                                                                       │
│ 562   std::optional<int64_t> ConstantOffset;                                                                                                                                                                   │
│ 563                                                                                                                                                                                                            │
│ 564   GEPValue(Instruction *I) : Inst(I) {                                                                                                                                                                     │
│ 565     assert((isSentinel() || canHandle(I)) && "Inst can't be handled!");                                                                                                                                    │
│ 566   }                                                                                                                                                                                                        │
│ 567                                                                                                                                                                                                            │
│ 568   GEPValue(Instruction *I, std::optional<int64_t> ConstantOffset)                                                                                                                                          │
│ 569       : Inst(I), ConstantOffset(ConstantOffset) {                                                                                                                                                          │
│ 570     assert((isSentinel() || canHandle(I)) && "Inst can't be handled!");                                                                                                                                    │
│ 571   }                                                                                                                                                                                                        │
│ 572                                                                                                                                                                                                            │
│ 573   bool isSentinel() const {                                                                                                                                                                                │
│ 574     return Inst == DenseMapInfo<Instruction *>::getEmptyKey() ||                                                                                                                                           │
│ 575            Inst == DenseMapInfo<Instruction *>::getTombstoneKey();                                                                                                                                         │
│ 576   }                                                                                                                                                                                                        │
│ 577                                                                                                                                                                                                            │
│ 578   static bool canHandle(Instruction *Inst) {                                                                                                                                                               │
│ 579     return isa<GetElementPtrInst>(Inst);                                                                                                                                                                   │
│ 580   }                                                                                                                                                                                                        │
│ 581 };                                                                                                                                                                                                         │
│ 582                                                                                                                                                                                                            │
│ 583 } // namespace                                                                                                                                                                                             │
│ 584                                                                                                                                                                                                            │
│ 585 namespace llvm {                                                                                                                                                                                           │
│ 586                                                                                                                                                                                                            │
│ 587 template <> struct DenseMapInfo<GEPValue> {                                                                                                                                                                │
│ 588   static inline GEPValue getEmptyKey() {                                                                                                                                                                   │
│ 589     return DenseMapInfo<Instruction *>::getEmptyKey();                                                                                                                                                     │
│ 590   }                                                                                                                                                                                                        │
│ 591                                                                                                                                                                                                            │
│ 592   static inline GEPValue getTombstoneKey() {                                                                                                                                                               │
│ 593     return DenseMapInfo<Instruction *>::getTombstoneKey();                                                                                                                                                 │
│ 594   }                                                                                                                                                                                                        │
│ 595                                                                                                                                                                                                            │
│ 596   static unsigned getHashValue(const GEPValue &Val);                                                                                                                                                       │
