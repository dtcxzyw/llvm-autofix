│ 472 //===----------------------------------------------------------------------===//                                                                                                                           │
│ 473 // CallValue                                                                                                                                                                                               │
│ 474 //===----------------------------------------------------------------------===//                                                                                                                           │
│ 475                                                                                                                                                                                                            │
│ 476 namespace {                                                                                                                                                                                                │
│ 477                                                                                                                                                                                                            │
│ 478 /// Struct representing the available call values in the scoped hash                                                                                                                                       │
│ 479 /// table.                                                                                                                                                                                                 │
│ 480 struct CallValue {                                                                                                                                                                                         │
│ 481   Instruction *Inst;                                                                                                                                                                                       │
│ 482                                                                                                                                                                                                            │
│ 483   CallValue(Instruction *I) : Inst(I) {                                                                                                                                                                    │
│ 484     assert((isSentinel() || canHandle(I)) && "Inst can't be handled!");                                                                                                                                    │
│ 485   }                                                                                                                                                                                                        │
│ 486                                                                                                                                                                                                            │
│ 487   bool isSentinel() const {                                                                                                                                                                                │
│ 488     return Inst == DenseMapInfo<Instruction *>::getEmptyKey() ||                                                                                                                                           │
│ 489            Inst == DenseMapInfo<Instruction *>::getTombstoneKey();                                                                                                                                         │
│ 490   }                                                                                                                                                                                                        │
│ 491                                                                                                                                                                                                            │
│ 492   static bool canHandle(Instruction *Inst) {                                                                                                                                                               │
│ 493     // Don't value number anything that returns void.                                                                                                                                                      │
│ 494     if (Inst->getType()->isVoidTy())                                                                                                                                                                       │
│ 495       return false;                                                                                                                                                                                        │
│ 496                                                                                                                                                                                                            │
│ 497     CallInst *CI = dyn_cast<CallInst>(Inst);                                                                                                                                                               │
│ 498     if (!CI || !CI->onlyReadsMemory() ||                                                                                                                                                                   │
│ 499         // FIXME: Currently the calls which may access the thread id may                                                                                                                                   │
│ 500         // be considered as not accessing the memory. But this is                                                                                                                                          │
│ 501         // problematic for coroutines, since coroutines may resume in a                                                                                                                                    │
│ 502         // different thread. So we disable the optimization here for the                                                                                                                                   │
│ 503         // correctness. However, it may block many other correct                                                                                                                                           │
│ 504         // optimizations. Revert this one when we detect the memory                                                                                                                                        │
│ 505         // accessing kind more precisely.                                                                                                                                                                  │
│ 506         CI->getFunction()->isPresplitCoroutine())                                                                                                                                                          │
│ 507       return false;                                                                                                                                                                                        │
│ 508     return true;                                                                                                                                                                                           │
│ 509   }                                                                                                                                                                                                        │
│ 510 };                                                                                                                                                                                                         │
│ 511                                                                                                                                                                                                            │
│ 512 } // end anonymous namespace                                                                                                                                                                               │
│ 513                                                                                                                                                                                                            │
│ 514 namespace llvm {                                                                                                                                                                                           │
│ 515                                                                                                                                                                                                            │
│ 516 template <> struct DenseMapInfo<CallValue> {                                                                                                                                                               │
│ 517   static inline CallValue getEmptyKey() {                                                                                                                                                                  │
│ 518     return DenseMapInfo<Instruction *>::getEmptyKey();                                                                                                                                                     │
│ 519   }                                                                                                                                                                                                        │
│ 520                                                                                                                                                                                                            │
│ 521   static inline CallValue getTombstoneKey() {                                                                                                                                                              │
│ 522     return DenseMapInfo<Instruction *>::getTombstoneKey();                                                                                                                                                 │
│ 523   }                                                                                                                                                                                                        │
│ 524                                                                                                                                                                                                            │
│ 525   static unsigned getHashValue(CallValue Val);                                                                                                                                                             │
│ 526   static bool isEqual(CallValue LHS, CallValue RHS);                                                                                                                                                       │
│ 527 };                                                                                                                                                                                                         │
│ 528                                                                                                                                                                                                            │
│ 529 } // end namespace llvm                                                                                                                                                                                    │
│ 530                                                                                                                                                                                                            │
│ 531 unsigned DenseMapInfo<CallValue>::getHashValue(CallValue Val) {                                                                                                                                            │
│ 532   Instruction *Inst = Val.Inst;                                                                                                                                                                            │
│ 533                                                                                                                                                                                                            │
│ 534   // Hash all of the operands as pointers and mix in the opcode.                                                                                                                                           │
│ 535   return hashCallInst(cast<CallInst>(Inst));                                                                                                                                                               │
│ 536 }                                                                                                                                                                                                          │
│ 537                                                                                                                                                                                                            │
│ 538 bool DenseMapInfo<CallValue>::isEqual(CallValue LHS, CallValue RHS) {                                                                                                                                      │
│ 539   if (LHS.isSentinel() || RHS.isSentinel())                                                                                                                                                                │
│ 540     return LHS.Inst == RHS.Inst;                                                                                                                                                                           │
│ 541                                                                                                                                                                                                            │
│ 542   CallInst *LHSI = cast<CallInst>(LHS.Inst);                                                                                                                                                               │
│ 543   CallInst *RHSI = cast<CallInst>(RHS.Inst);                                                                                                                                                               │
│ 544                                                                                                                                                                                                            │
│ 545   // Convergent calls implicitly depend on the set of threads that is                                                                                                                                      │
│ 546   // currently executing, so conservatively return false if they are in                                                                                                                                    │
│ 547   // different basic blocks.                                                                                                                                                                               │
│ 548   if (LHSI->isConvergent() && LHSI->getParent() != RHSI->getParent())                                                                                                                                      │
│ 549     return false;                                                                                                                                                                                          │
│ 550                                                                                                                                                                                                            │
│ 551   return LHSI->isIdenticalToWhenDefined(RHSI, /*IntersectAttrs=*/true);                                                                                                                                    │
│ 552 }                                                                                                                                                                                                          │
