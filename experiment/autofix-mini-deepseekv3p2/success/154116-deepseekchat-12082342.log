│  823 /// A helper function to check if reassociating through an entry in the user                                                                                                                              │
│  824 /// chain would invalidate the GEP's nuw flag.                                                                                                                                                            │
│  825 static bool allowsPreservingNUW(const User *U) {                                                                                                                                                          │
│  826   if (const BinaryOperator *BO = dyn_cast<BinaryOperator>(U)) {                                                                                                                                           │
│  827     // Binary operations need to be effectively add nuw.                                                                                                                                                  │
│  828     auto Opcode = BO->getOpcode();                                                                                                                                                                        │
│  829     if (Opcode == BinaryOperator::Or) {                                                                                                                                                                   │
│  830       // Ors are only considered here if they are disjoint. The addition that                                                                                                                             │
│  831       // they represent in this case is NUW.                                                                                                                                                              │
│  832       assert(cast<PossiblyDisjointInst>(BO)->isDisjoint());                                                                                                                                               │
│  833       return true;                                                                                                                                                                                        │
│  834     }                                                                                                                                                                                                     │
│  835     return Opcode == BinaryOperator::Add && BO->hasNoUnsignedWrap();                                                                                                                                      │
│  836   }                                                                                                                                                                                                       │
│  837   // UserChain can only contain ConstantInt, CastInst, or BinaryOperator.                                                                                                                                 │
│  838   // Among the possible CastInsts, only trunc without nuw is a problem: If it                                                                                                                             │
│  839   // is distributed through an add nuw, wrapping may occur:                                                                                                                                               │
│  840   // "add nuw trunc(a), trunc(b)" is more poisonous than "trunc(add nuw a, b)"                                                                                                                            │
│  841   if (const TruncInst *TI = dyn_cast<TruncInst>(U))                                                                                                                                                       │
│  842     return TI->hasNoUnsignedWrap();                                                                                                                                                                       │
│  843   return isa<CastInst>(U) || isa<ConstantInt>(U);                                                                                                                                                         │
