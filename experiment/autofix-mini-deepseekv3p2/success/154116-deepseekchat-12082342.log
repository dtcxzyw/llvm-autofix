│ 481                                             bool ZeroExtended,                                                                                                                                             │
│ 482                                             BinaryOperator *BO,                                                                                                                                            │
│ 483                                             bool NonNegative) {                                                                                                                                            │
│ 484   // We only consider ADD, SUB and OR, because a non-zero constant found in                                                                                                                                │
│ 485   // expressions composed of these operations can be easily hoisted as a                                                                                                                                   │
│ 486   // constant offset by reassociation.                                                                                                                                                                     │
│ 487   if (BO->getOpcode() != Instruction::Add &&                                                                                                                                                               │
│ 488       BO->getOpcode() != Instruction::Sub &&                                                                                                                                                               │
│ 489       BO->getOpcode() != Instruction::Or) {                                                                                                                                                                │
│ 490     return false;                                                                                                                                                                                          │
│ 491   }                                                                                                                                                                                                        │
│ 492                                                                                                                                                                                                            │
│ 493   Value *LHS = BO->getOperand(0), *RHS = BO->getOperand(1);                                                                                                                                                │
│ 494   // Do not trace into "or" unless it is equivalent to "add".                                                                                                                                              │
│ 495   // This is the case if the or's disjoint flag is set.                                                                                                                                                    │
│ 496   if (BO->getOpcode() == Instruction::Or &&                                                                                                                                                                │
│ 497       !cast<PossiblyDisjointInst>(BO)->isDisjoint())                                                                                                                                                       │
