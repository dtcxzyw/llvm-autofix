│  36   auto SetResultTyFromOp = [this, R]() {                                                                                                                                                                   │
│  37     Type *ResTy = inferScalarType(R->getOperand(0));                                                                                                                                                       │
│  38     for (unsigned Op = 1; Op != R->getNumOperands(); ++Op) {                                                                                                                                               │
│  39       VPValue *OtherV = R->getOperand(Op);                                                                                                                                                                 │
│  40       assert(inferScalarType(OtherV) == ResTy &&                                                                                                                                                           │
│  41              "different types inferred for different operands");                                                                                                                                           │
│  42       CachedTypes[OtherV] = ResTy;                                                                                                                                                                         │
│  43     }                                                                                                                                                                                                      │
│  44     return ResTy;                                                                                                                                                                                          │
│  45   };                                                                                                                                                                                                       │
│  46                                                                                                                                                                                                            │
│  47   unsigned Opcode = R->getOpcode();                                                                                                                                                                        │
│  48   if (Instruction::isBinaryOp(Opcode) || Instruction::isUnaryOp(Opcode))                                                                                                                                   │
│  49     return SetResultTyFromOp();                                                                                                                                                                            │
│  50                                                                                                                                                                                                            │
│  51   switch (Opcode) {                                                                                                                                                                                        │
│  52   case Instruction::Select: {                                                                                                                                                                              │
│  53     Type *ResTy = inferScalarType(R->getOperand(1));                                                                                                                                                       │
│  54     VPValue *OtherV = R->getOperand(2);                                                                                                                                                                    │
│  55     assert(inferScalarType(OtherV) == ResTy &&                                                                                                                                                             │
│  56            "different types inferred for different operands");                                                                                                                                             │
│  57     CachedTypes[OtherV] = ResTy;                                                                                                                                                                           │
│  58     return ResTy;                                                                                                                                                                                          │
│  59   }                                                                                                                                                                                                        │
│  60   case Instruction::ICmp:                                                                                                                                                                                  │
│  61   case VPInstruction::ActiveLaneMask:                                                                                                                                                                      │
│  62     return inferScalarType(R->getOperand(1));                                                                                                                                                              │
│  63   case VPInstruction::FirstOrderRecurrenceSplice:                                                                                                                                                          │
