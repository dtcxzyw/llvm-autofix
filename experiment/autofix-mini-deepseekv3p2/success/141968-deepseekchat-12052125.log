│ 384       }                                                                                                                                                                                                    │
│ 385   }                                                                                                                                                                                                        │
│ 386                                                                                                                                                                                                            │
│ 387   unsigned BBNum = 0;                                                                                                                                                                                      │
│ 388   for (VPReplicateRecipe *RepR : WorkList) {                                                                                                                                                               │
│ 389     VPBasicBlock *CurrentBlock = RepR->getParent();                                                                                                                                                        │
