│ 218   void restrictToBlocks(const SmallSetVector<BasicBlock *, 4> &NewBlocks) {                                                                                                                                │
│ 219     auto BI = Blocks.begin();                                                                                                                                                                              │
│ 220     auto VI = Values.begin();                                                                                                                                                                              │
