│ 333 class ValueTable {                                                                                                                                                                                         │
│ 334   DenseMap<Value *, uint32_t> ValueNumbering;                                                                                                                                                              │
│ 335   DenseMap<GVNExpression::Expression *, uint32_t> ExpressionNumbering;                                                                                                                                     │
│ 336   DenseMap<size_t, uint32_t> HashNumbering;                                                                                                                                                                │
