│ dependencies can lead to incorrect SCEV analysis\n        // when LCSSA was run without ScalarEvolution, as in   │
│ PR126012.\n        if (PHINode *InstPHI = dyn_cast<PHINode>(Inst)) {\n          bool HasPHIDependency = false;\n │
│ for (unsigned i = 0, e = InstPHI->getNumIncomingValues(); i != e; ++i) {\n            if                         │
│ (isa<PHINode>(InstPHI->getIncomingValue(i))) {\n              HasPHIDependency = true;\n              break;\n   │
│ }\n          }\n          if (HasPHIDependency) {\n            // Skip this PHI to avoid incorrect               │
│ transformations.\n            continue;\n          }\n        }\n        \n        // Okay, this instruction has │
│ a user outside of the current loop\n        // and varies predictably *inside* the loop.  Evaluate the value     │
