│ 413 /// type is irregular if its allocated size doesn't equal the store     │
│ size of an                                                                  │
│ 414 /// element of the corresponding vector type.                           │
│ 415 static bool hasIrregularType(Type *Ty, const DataLayout &DL) {          │
│ 416   // Determine if an array of N elements of type Ty is "bitcast         │
