│ isa<FPMathOperator>(Q.CxtI) && Q.CxtI->hasNoSignedZeros()) {\n    // (T ==  │
│ F) ? T : F --> F\n    if (Pred == FCmpInst::FCMP_OEQ)\n      return F;\n\n  │
│ // (T != F) ? T : F --> T\n    if (Pred == FCmpInst::FCMP_UNE)\n            │
│ return T;\n  }"})                                                           │
