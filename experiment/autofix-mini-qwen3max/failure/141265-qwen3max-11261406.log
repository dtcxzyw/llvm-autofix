│ 401   SmallVector<int> Mask;                                                                                                                                                                                   │
│ 402   unsigned AccumulateLength = 0;                                                                                                                                                                           │
│ 403   for (Value *V : VL) {                                                                                                                                                                                    │
│ 404     auto *SV = cast<ShuffleVectorInst>(V);                                                                                                                                                                 │
