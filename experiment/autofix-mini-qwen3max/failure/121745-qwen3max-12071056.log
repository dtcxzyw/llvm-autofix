│ instructions as their conditions may be\n  // flattened.\n  auto *RepR = dyn_cast<VPReplicateRecipe>(&R);\n  bool IsConditionalAssume =\n      RepR && RepR->isPredicated() &&\n          │
│ match(RepR->getUnderlyingInstr(), m_Intrinsic<Intrinsic::assume>());\n  if (IsConditionalAssume)\n    return true;\n\n  if (R.mayHaveSideEffects())\n    return false;\n\n  // Don't      │
│ remove recipes that correspond to instructions used as branch\n  // conditions in the original loop, even if they appear to have no users\n  // in the VPlan.\n  if (Instruction          │
│ *UnderlyingInst = R.getUnderlyingInstr()) {\n    for (User *U : UnderlyingInst->users()) {\n      if (isa<BranchInst>(U)) {\n        return false;\n      }\n    }\n  }\n\n  // Recipe is │
