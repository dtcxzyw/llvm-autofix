│ 434 void VPBasicBlock::connectToPredecessors(VPTransformState &State) {     │
│ 435   auto &CFG = State.CFG;                                                │
│ 436   BasicBlock *NewBB = CFG.VPBB2IRBB[this];                              │
│ 437   // Hook up the new basic block to its predecessors.                   │
│ 438   for (VPBlockBase *PredVPBlock : getHierarchicalPredecessors()) {      │
│ 439     VPBasicBlock *PredVPBB = PredVPBlock->getExitingBasicBlock();       │
│ 440     auto &PredVPSuccessors = PredVPBB->getHierarchicalSuccessors();     │
│ 441     BasicBlock *PredBB = CFG.VPBB2IRBB[PredVPBB];                       │
│ 442                                                                         │
│ 443     assert(PredBB && "Predecessor basic-block not found building        │
│ successor.");                                                               │
│ 444     auto *PredBBTerminator = PredBB->getTerminator();                   │
│ 445     LLVM_DEBUG(dbgs() << "LV: draw edge from" << PredBB->getName() <<   │
│ '\n');                                                                      │
│ 446                                                                         │
│ 447     auto *TermBr = dyn_cast<BranchInst>(PredBBTerminator);              │
│ 448     if (isa<UnreachableInst>(PredBBTerminator)) {                       │
│ 449       assert(PredVPSuccessors.size() == 1 &&                            │
│ 450              "Predecessor ending w/o branch must have single            │
│ successor.");                                                               │
│ 451       DebugLoc DL = PredBBTerminator->getDebugLoc();                    │
│ 452       PredBBTerminator->eraseFromParent();                              │
│ 453       auto *Br = BranchInst::Create(NewBB, PredBB);                     │
│ 454       Br->setDebugLoc(DL);                                              │
│ 455     } else if (TermBr && !TermBr->isConditional()) {                    │
│ 456       TermBr->setSuccessor(0, NewBB);                                   │
│ 457     } else {                                                            │
│ 458       // Set each forward successor here when it is created, excluding  │
│ 459       // backedges. A backward successor is set when the branch is      │
│ created.                                                                    │
│ 460       unsigned idx = PredVPSuccessors.front() == this ? 0 : 1;          │
│ 461       assert((TermBr && (!TermBr->getSuccessor(idx) ||                  │
│ 462                          (isa<VPIRBasicBlock>(this) &&                  │
│ 463                           TermBr->getSuccessor(idx) == NewBB))) &&      │
│ 464              "Trying to reset an existing successor block.");           │
│ 465       TermBr->setSuccessor(idx, NewBB);                                 │
│ 466     }                                                                   │
│ 467     CFG.DTU.applyUpdates({{DominatorTree::Insert, PredBB, NewBB}});     │
│ 468   }                                                                     │
│ 469 }                                                                       │
