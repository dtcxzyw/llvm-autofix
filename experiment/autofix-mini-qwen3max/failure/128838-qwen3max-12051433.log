│ 500 void VPBasicBlock::execute(VPTransformState *State) {                   │
│ 501   bool Replica = bool(State->Lane);                                     │
│ 502   BasicBlock *NewBB = State->CFG.PrevBB; // Reuse it if possible.       │
│ 503                                                                         │
│ 504   auto IsReplicateRegion = [](VPBlockBase *BB) {                        │
│ 505     auto *R = dyn_cast_or_null<VPRegionBlock>(BB);                      │
│ 506     return R && R->isReplicator();                                      │
│ 507   };                                                                    │
│ 508                                                                         │
│ 509   // 1. Create an IR basic block.                                       │
│ 510   if ((Replica && this == getParent()->getEntry()) ||                   │
│ 511       IsReplicateRegion(getSingleHierarchicalPredecessor())) {          │
│ 512     // Reuse the previous basic block if the current VPBB is either     │
│ 513     //  * the entry to a replicate region, or                           │
│ 514     //  * the exit of a replicate region.                               │
│ 515     State->CFG.VPBB2IRBB[this] = NewBB;                                 │
│ 516   } else {                                                              │
│ 517     NewBB = createEmptyBasicBlock(*State);                              │
│ 518                                                                         │
│ 519     State->Builder.SetInsertPoint(NewBB);                               │
│ 520     // Temporarily terminate with unreachable until CFG is rewired.     │
│ 521     UnreachableInst *Terminator = State->Builder.CreateUnreachable();   │
│ 522     // Register NewBB in its loop. In innermost loops its the same for  │
│ all                                                                         │
│ 523     // BB's.                                                            │
│ 524     Loop *ParentLoop = State->CurrentParentLoop;                        │
│ 525     // If this block has a sole successor that is an exit block then it │
│ needs                                                                       │
│ 526     // adding to the same parent loop as the exit block.                │
│ 527     VPBlockBase *SuccVPBB = getSingleSuccessor();                       │
│ 528     if (SuccVPBB && State->Plan->isExitBlock(SuccVPBB))                 │
│ 529       ParentLoop = State->LI->getLoopFor(                               │
│ 530           cast<VPIRBasicBlock>(SuccVPBB)->getIRBasicBlock());           │
│ 531     if (ParentLoop)                                                     │
│ 532       ParentLoop->addBasicBlockToLoop(NewBB, *State->LI);               │
│ 533     State->Builder.SetInsertPoint(Terminator);                          │
│ 534                                                                         │
│ 535     State->CFG.PrevBB = NewBB;                                          │
│ 536     State->CFG.VPBB2IRBB[this] = NewBB;                                 │
│ 537     connectToPredecessors(*State);                                      │
│ 538   }                                                                     │
│ 539                                                                         │
│ 540   // 2. Fill the IR basic block with IR instructions.                   │
│ 541   executeRecipes(State, NewBB);                                         │
│ 542 }                                                                       │
