│ 409     for (unsigned I = 0, E = StructTy->getNumElements(); I != E; I++) { │
│ 410       Value *ScalarValue = Builder.CreateExtractValue(ScalarInst, I);   │
│ 411       Value *VectorValue = Builder.CreateExtractValue(WideValue, I);    │
│ 412       VectorValue =                                                     │
│ 413           Builder.CreateInsertElement(VectorValue, ScalarValue,         │
│ LaneExpr);                                                                  │
│ 414       WideValue = Builder.CreateInsertValue(WideValue, VectorValue, I); │
│ 415     }                                                                   │
│ 416   } else {                                                              │
│ 417     WideValue = Builder.CreateInsertElement(WideValue, ScalarInst,      │
│ LaneExpr);                                                                  │
│ 418   }                                                                     │
│ 419   set(Def, WideValue);                                                  │
│ 420 }                                                                       │
