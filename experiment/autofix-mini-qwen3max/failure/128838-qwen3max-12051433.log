│ 471 void VPIRBasicBlock::execute(VPTransformState *State) {                 │
│ 472   assert(getHierarchicalSuccessors().size() <= 2 &&                     │
│ 473          "VPIRBasicBlock can have at most two successors at the         │
│ moment!");                                                                  │
│ 474   State->Builder.SetInsertPoint(IRBB->getTerminator());                 │
│ 475   State->CFG.PrevBB = IRBB;                                             │
│ 476   State->CFG.VPBB2IRBB[this] = IRBB;                                    │
│ 477   executeRecipes(State, IRBB);                                          │
│ 478   // Create a branch instruction to terminate IRBB if one was not       │
│ created yet                                                                 │
│ 479   // and is needed.                                                     │
│ 480   if (getSingleSuccessor() &&                                           │
│ isa<UnreachableInst>(IRBB->getTerminator())) {                              │
│ 481     auto *Br = State->Builder.CreateBr(IRBB);                           │
│ 482     Br->setOperand(0, nullptr);                                         │
│ 483     IRBB->getTerminator()->eraseFromParent();                           │
│ 484   } else {                                                              │
│ 485     assert(                                                             │
│ 486         (getNumSuccessors() == 0 ||                                     │
│ isa<BranchInst>(IRBB->getTerminator())) &&                                  │
│ 487         "other blocks must be terminated by a branch");                 │
│ 488   }                                                                     │
│ 489                                                                         │
│ 490   connectToPredecessors(*State);                                        │
│ 491 }                                                                       │
