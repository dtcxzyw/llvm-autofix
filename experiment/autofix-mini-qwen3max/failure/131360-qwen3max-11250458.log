│ 243 /// Returns the type of the given value/instruction \p V. If it is      │
│ store,                                                                      │
│ 244 /// returns the type of its value operand, for Cmp - the types of the   │
│ compare                                                                     │
│ 245 /// operands and for insertelement - the type os the inserted operand.  │
│ 246 /// Otherwise, just the type of the value is returned.                  │
│ 247 static Type *getValueType(Value *V) {                                   │
│ 248   if (auto *SI = dyn_cast<StoreInst>(V))                                │
│ 249     return SI->getValueOperand()->getType();                            │
│ 250   if (auto *CI = dyn_cast<CmpInst>(V))                                  │
│ 251     return CI->getOperand(0)->getType();                                │
│ 252   if (auto *IE = dyn_cast<InsertElementInst>(V))                        │
│ 253     return IE->getOperand(1)->getType();                                │
│ 254   return V->getType();                                                  │
│ 255 }                                                                       │
│ 256                                                                         │
│ 257 /// \returns the number of elements for Ty.                             │
│ 258 static unsigned getNumElements(Type *Ty) {                              │
│ 259   assert(!isa<ScalableVectorType>(Ty) &&                                │
│ 260          "ScalableVectorType is not supported.");                       │
│ 261   if (auto *VecTy = dyn_cast<FixedVectorType>(Ty))                      │
│ 262     return VecTy->getNumElements();                                     │
│ 263   return 1;                                                             │
│ 264 }                                                                       │
