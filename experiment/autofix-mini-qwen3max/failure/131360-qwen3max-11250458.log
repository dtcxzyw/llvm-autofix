│ 292   if (!isValidElementType(Ty))                                          │
│ 293     return bit_floor(Sz);                                               │
│ 294   // Find the number of elements, which forms full vectors.             │
│ 295   unsigned NumParts = TTI.getNumberOfParts(getWidenedType(Ty, Sz));     │
│ 296   if (NumParts == 0 || NumParts >= Sz)                                  │
│ 297     return bit_floor(Sz);                                               │
│ 298   unsigned RegVF = bit_ceil(divideCeil(Sz, NumParts));                  │
│ 299   if (RegVF > Sz)                                                       │
│ 300     return bit_floor(Sz);                                               │
│ 301   return (Sz / RegVF) * RegVF;                                          │
│ 302 }                                                                       │
