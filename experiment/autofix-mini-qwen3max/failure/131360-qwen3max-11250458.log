│ 228 /// Predicate for the element types that the SLP vectorizer supports.   │
│ 229 ///                                                                     │
│ 230 /// The most important thing to filter here are types which are invalid │
│ in LLVM                                                                     │
│ 231 /// vectors. We also filter target specific types which have absolutely │
│ no                                                                          │
│ 232 /// meaningful vectorization path such as x86_fp80 and ppc_f128. This   │
│ just                                                                        │
│ 233 /// avoids spending time checking the cost model and realizing that     │
│ they will                                                                   │
│ 234 /// be inevitably scalarized.                                           │
│ 235 static bool isValidElementType(Type *Ty) {                              │
│ 236   // TODO: Support ScalableVectorType.                                  │
│ 237   if (SLPReVec && isa<FixedVectorType>(Ty))                             │
│ 238     Ty = Ty->getScalarType();                                           │
│ 239   return VectorType::isValidElementType(Ty) && !Ty->isX86_FP80Ty() &&   │
│ 240          !Ty->isPPC_FP128Ty();                                          │
│ 241 }                                                                       │
│ 242                                                                         │
│ 243 /// Returns the type of the given value/instruction \p V. If it is      │
│ store,                                                                      │
│ 244 /// returns the type of its value operand, for Cmp - the types of the   │
│ compare                                                                     │
│ 245 /// operands and for insertelement - the type os the inserted operand.  │
│ 246 /// Otherwise, just the type of the value is returned.                  │
│ 247 static Type *getValueType(Value *V) {                                   │
│ 248   if (auto *SI = dyn_cast<StoreInst>(V))                                │
│ 249     return SI->getValueOperand()->getType();                            │
│ 250   if (auto *CI = dyn_cast<CmpInst>(V))                                  │
