│ 273 /// which forms type, which splits by \p TTI into whole vector types    │
│ during                                                                      │
│ 274 /// legalization.                                                       │
│ 275 static unsigned getFullVectorNumberOfElements(const TargetTransformInfo │
│ &TTI,                                                                       │
│ 276                                               Type *Ty, unsigned Sz) {  │
│ 277   if (!isValidElementType(Ty))                                          │
│ 278     return bit_ceil(Sz);                                                │
