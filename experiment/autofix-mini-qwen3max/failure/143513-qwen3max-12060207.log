│ 282   if (NumParts == 0 || NumParts >= Sz)                                                                                                                                                                     │
│ 283     return bit_ceil(Sz);                                                                                                                                                                                   │
│ 284   return bit_ceil(divideCeil(Sz, NumParts)) * NumParts;                                                                                                                                                    │
│ 285 }                                                                                                                                                                                                          │
