│ 118       auto NSWRange = ConstantRange::makeGuaranteedNoWrapRegion(                                                                                                                                           │
│ 119           Instruction::BinaryOps(Inst.getOpcode()), RangeB,                                                                                                                                                │
│ 120           OverflowingBinaryOperator::NoSignedWrap);                                                                                                                                                        │
