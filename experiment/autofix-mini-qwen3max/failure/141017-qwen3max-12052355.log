│ 395 /// Base class for aggregate constants (with operands).                                                                                                                                                    │
│ 396 ///                                                                                                                                                                                                        │
│ 397 /// These constants are aggregates of other constants, which are stored as                                                                                                                                 │
│ 398 /// operands.                                                                                                                                                                                              │
│ 399 ///                                                                                                                                                                                                        │
│ 400 /// Subclasses are \a ConstantStruct, \a ConstantArray, and \a                                                                                                                                             │
│ 401 /// ConstantVector.                                                                                                                                                                                        │
│ 402 ///                                                                                                                                                                                                        │
│ 403 /// \note Some subclasses of \a ConstantData are semantically aggregates --                                                                                                                                │
│ 404 /// such as \a ConstantDataArray -- but are not subclasses of this because they                                                                                                                            │
│ 405 /// use operands.                                                                                                                                                                                          │
│ 406 class ConstantAggregate : public Constant {                                                                                                                                                                │
│ 407 protected:                                                                                                                                                                                                 │
