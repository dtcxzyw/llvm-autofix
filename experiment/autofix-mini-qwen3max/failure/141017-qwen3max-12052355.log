│ 409                     AllocInfo AllocInfo);                                                                                                                                                                  │
│ 410                                                                                                                                                                                                            │
│ 411 public:                                                                                                                                                                                                    │
│ 412   /// Transparently provide more efficient getOperand methods.                                                                                                                                             │
│ 413   DECLARE_TRANSPARENT_OPERAND_ACCESSORS(Constant);                                                                                                                                                         │
│ 414                                                                                                                                                                                                            │
│ 415   /// Methods for support type inquiry through isa, cast, and dyn_cast:                                                                                                                                    │
│ 416   static bool classof(const Value *V) {                                                                                                                                                                    │
│ 417     return V->getValueID() >= ConstantAggregateFirstVal &&                                                                                                                                                 │
│ 418            V->getValueID() <= ConstantAggregateLastVal;                                                                                                                                                    │
│ 419   }                                                                                                                                                                                                        │
│ 420 };                                                                                                                                                                                                         │
