│ 509   bool isValidSelectInst(SelectInst *SI) {                                                                                              │
│ 510     if (!SI->hasOneUse())                                                                                                               │
│ 511       return false;                                                                                                                     │
│ 512                                                                                                                                         │
│ 513     Instruction *SIUse = dyn_cast<Instruction>(SI->user_back());                                                                        │
│ 514     // The use of the select inst should be either a phi or another select.                                                             │
│ 515     if (!SIUse && !(isa<PHINode>(SIUse) || isa<SelectInst>(SIUse)))                                                                     │
│ 516       return false;                                                                                                                     │
│ 517                                                                                                                                         │
│ 518     BasicBlock *SIBB = SI->getParent();                                                                                                 │
│ 519                                                                                                                                         │
│ 520     // Currently, we can only expand select instructions in basic blocks with                                                           │
│ 521     // one successor.                                                                                                                   │
│ 522     BranchInst *SITerm = dyn_cast<BranchInst>(SIBB->getTerminator());                                                                   │
│ 523     if (!SITerm || !SITerm->isUnconditional())                                                                                          │
│ 524       return false;                                                                                                                     │
│ 525                                                                                                                                         │
│ 526     // Only fold the select coming from directly where it is defined.                                                                   │
│ 527     PHINode *PHIUser = dyn_cast<PHINode>(SIUse);                                                                                        │
│ 528     if (PHIUser && PHIUser->getIncomingBlock(*SI->use_begin()) != SIBB)                                                                 │
│ 529       return false;                                                                                                                     │
│ 530                                                                                                                                         │
│ 531     // If select will not be sunk during unfolding, and it is in the same basic                                                         │
│ 532     // block as another state defining select, then cannot unfold both.                                                                 │
│ 533     for (SelectInstToUnfold SIToUnfold : SelectInsts) {                                                                                 │
│ 534       SelectInst *PrevSI = SIToUnfold.getInst();                                                                                        │
│ 535       if (PrevSI->getTrueValue() != SI && PrevSI->getFalseValue() != SI &&                                                              │
│ 536           PrevSI->getParent() == SI->getParent())                                                                                       │
│ 537         return false;                                                                                                                   │
│ 538     }                                                                                                                                   │
│ 539                                                                                                                                         │
│ 540     return true;                                                                                                                        │
│ 541   }                                                                                                                                     │
