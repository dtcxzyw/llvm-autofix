│ 114                                                FastMathFlags RHS) {                                                                                                                   │
│ 115     const unsigned RewriteMask =                                                                                                                                                      │
│ 116         AllowReassoc | AllowReciprocal | AllowContract | ApproxFunc;                                                                                                                  │
