│ 515     // only.                                                            │
│ 516     if (any_of(WidenOriginalIV->users(),                                │
│ 517                [WidenOriginalIV](VPUser *U) {                           │
│ 518                  return !U->usesScalars(WidenOriginalIV);               │
│ 519                }) ||                                                    │
