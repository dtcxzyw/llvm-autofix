│ 504                                                                         │
│ 505   VPBasicBlock *HeaderVPBB =                                            │
│ Plan.getVectorLoopRegion()->getEntryBasicBlock();                           │
│ 506   for (VPRecipeBase &Phi : HeaderVPBB->phis()) {                        │
│ 507     auto *WidenOriginalIV =                                             │
│ dyn_cast<VPWidenIntOrFpInductionRecipe>(&Phi);                              │
│ 508                                                                         │
