│ 408 static bool mergeBlocksIntoPredecessors(VPlan &Plan) {                  │
│ 409   SmallVector<VPBasicBlock *> WorkList;                                 │
│ 410   for (VPBasicBlock *VPBB : VPBlockUtils::blocksOnly<VPBasicBlock>(     │
