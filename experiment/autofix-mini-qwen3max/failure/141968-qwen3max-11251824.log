│ 416       continue;                                                         │
│ 417     auto *PredVPBB =                                                    │
│ 418         dyn_cast_or_null<VPBasicBlock>(VPBB->getSinglePredecessor());   │
│ 419     if (!PredVPBB || PredVPBB->getNumSuccessors() != 1 ||               │
│ 420         isa<VPIRBasicBlock>(PredVPBB))                                  │
│ 421       continue;                                                         │
│ 422     WorkList.push_back(VPBB);                                           │
│ 423   }                                                                     │
│ 424                                                                         │
│ 425   for (VPBasicBlock *VPBB : WorkList) {                                 │
│ 426     VPBasicBlock *PredVPBB =                                            │
│ cast<VPBasicBlock>(VPBB->getSinglePredecessor());                           │
│ 427     for (VPRecipeBase &R : make_early_inc_range(*VPBB))                 │
│ 428       R.moveBefore(*PredVPBB, PredVPBB->end());                         │
│ 429     VPBlockUtils::disconnectBlocks(PredVPBB, VPBB);                     │
│ 430     auto *ParentRegion = VPBB->getParent();                             │
│ 431     if (ParentRegion && ParentRegion->getExiting() == VPBB)             │
│ 432       ParentRegion->setExiting(PredVPBB);                               │
│ 433     for (auto *Succ : to_vector(VPBB->successors())) {                  │
│ 434       VPBlockUtils::disconnectBlocks(VPBB, Succ);                       │
│ 435       VPBlockUtils::connectBlocks(PredVPBB, Succ);                      │
│ 436     }                                                                   │
│ 437     // VPBB is now dead and will be cleaned up when the plan gets       │
│ destroyed.                                                                  │
│ 438   }                                                                     │
│ 439   return !WorkList.empty();                                             │
