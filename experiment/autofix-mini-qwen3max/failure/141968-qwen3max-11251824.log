│ 535       RepR && RepR->isPredicated() &&                                   │
│ 536       match(RepR->getUnderlyingInstr(),                                 │
│ m_Intrinsic<Intrinsic::assume>());                                          │
│ 537   if (IsConditionalAssume)                                              │
