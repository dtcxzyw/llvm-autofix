│ 539                                                                         │
│ 540   if (R.mayHaveSideEffects())                                           │
│ 541     return false;                                                       │
│ 542                                                                         │
│ 543   // Recipe is dead if no user keeps the recipe alive.                  │
│ 544   return all_of(R.definedValues(),                                      │
│ 545                 [](VPValue *V) { return V->getNumUsers() == 0; });      │
│ 546 }                                                                       │
