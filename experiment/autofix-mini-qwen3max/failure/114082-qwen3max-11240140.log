│ 13579 /// Merges shuffle masks and emits final shuffle instruction, if      │
│ required. It                                                                │
│ 13580 /// supports shuffling of 2 input vectors. It implements lazy         │
│ shuffles emission,                                                          │
│ 13581 /// when the actual shuffle instruction is generated only if this is  │
│ actually                                                                    │
│ 13582 /// required. Otherwise, the shuffle instruction emission is delayed  │
│ till the                                                                    │
│ 13583 /// end of the process, to reduce the number of emitted instructions  │
│ and further                                                                 │
│ 13584 /// analysis/transformations.                                         │
│ 13585 /// The class also will look through the previously emitted shuffle   │
│ instructions                                                                │
│ 13586 /// and properly mark indices in mask as undef.                       │
│ 13587 /// For example, given the code                                       │
│ 13588 /// \code                                                             │
│ 13589 /// %s1 = shufflevector <2 x ty> %0, poison, <1, 0>                   │
│ 13590 /// %s2 = shufflevector <2 x ty> %1, poison, <1, 0>                   │
│ 13591 /// \endcode                                                          │
│ 13592 /// and if need to emit shuffle of %s1 and %s2 with mask <1, 0, 3,    │
│ 2>, it will                                                                 │
│ 13593 /// look through %s1 and %s2 and emit                                 │
│ 13594 /// \code                                                             │
│ 13595 /// %res = shufflevector <2 x ty> %0, %1, <0, 1, 2, 3>                │
│ 13596 /// \endcode                                                          │
│ 13597 /// instead.                                                          │
│ 13598 /// If 2 operands are of different size, the smallest one will be     │
│ resized and                                                                 │
│ 13599 /// the mask recalculated properly.                                   │
│ 13600 /// For example, given the code                                       │
│ 13601 /// \code                                                             │
│ 13602 /// %s1 = shufflevector <2 x ty> %0, poison, <1, 0, 1, 0>             │
│ 13603 /// %s2 = shufflevector <2 x ty> %1, poison, <1, 0, 1, 0>             │
│ 13604 /// \endcode                                                          │
│ 13605 /// and if need to emit shuffle of %s1 and %s2 with mask <1, 0, 5,    │
│ 4>, it will                                                                 │
