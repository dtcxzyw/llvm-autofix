│    }                                                                        │
│                                                                             │
│    // Hash general selects to allow matching commuted true/false operands.  │
│ @@ -391,9 +394,15 @@ static bool isEqualImpl(SimpleValue LHS, SimpleValue   │
│ RHS) {                                                                      │
│             "same opcode, but different instruction type?");                │
│      CmpInst *RHSCmp = cast<CmpInst>(RHSI);                                 │
│      // Commuted equality                                                   │
│ +    bool LHSHasSameSign = false, RHSHasSameSign = false;                   │
│ +    if (const ICmpInst *LHSICI = dyn_cast<ICmpInst>(LHSCmp))               │
│ +      LHSHasSameSign = LHSICI->hasSameSign();                              │
│ +    if (const ICmpInst *RHSICI = dyn_cast<ICmpInst>(RHSCmp))               │
│ +      RHSHasSameSign = RHSICI->hasSameSign();                              │
