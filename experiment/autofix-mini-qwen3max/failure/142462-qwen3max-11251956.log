│ AttributeList OriginalAttrs = ToCB->getAttributes();\n    bool Success =    │
│ ToCB->tryIntersectAttributes(cast<CallBase>(&From));\n    if (!Success) {\n │
│ // Restore the target's original attributes\n                               │
│ ToCB->setAttributes(OriginalAttrs);\n      Success = true;\n    }\n         │
│ assert(Success && \"Failed to intersect attributes in callsites that \"\n   │
│ \"passed identical check\");"})                                             │
