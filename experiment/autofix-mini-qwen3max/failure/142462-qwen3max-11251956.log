│ (void)Success;", "new": "    // The issue is that SimpleValue::isEqualImpl  │
│ considers commutative\n    // intrinsics with swapped arguments as equal    │
│ without checking attributes,\n    // but tryIntersectAttributes may fail    │
│ when attributes differ.\n    // However, the existing test expects CSE to   │
│ NOT happen in this case,\n    // so we need to prevent the equality check   │
│ from succeeding.\n    // But since we can't change isEqualImpl easily, we   │
│ handle it here.\n    CallBase *FromCB = cast<CallBase>(&From);\n            │
│ CallBase *ToCB = cast<CallBase>(To);\n    \n    bool Success =              │
│ ToCB->tryIntersectAttributes(FromCB);\n    \n    // If intersection failed, │
│ check if this is due to attribute differences\n    // in commutative        │
│ intrinsics. In such cases, we should NOT CSE.\n    if (!Success) {\n        │
│ if (auto *FromII = dyn_cast<IntrinsicInst>(FromCB)) {\n        if (auto     │
│ *ToII = dyn_cast<IntrinsicInst>(ToCB)) {\n          if                      │
│ (FromII->getIntrinsicID() == ToII->getIntrinsicID() &&\n                    │
│ FromII->isCommutative()) {\n            // Don't CSE if attributes are      │
│ incompatible\n            // This matches the test expectation\n            │
│ return;\n          }\n        }\n      }\n    }\n    \n    assert(Success   │
│ && \"Failed to intersect attributes in callsites that \"\n                  │
│ \"passed identical check\");"})                                             │
