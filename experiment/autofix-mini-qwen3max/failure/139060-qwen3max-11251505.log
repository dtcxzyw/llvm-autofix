│  95   case HK_FORCE:                                                                                                                                      │
│  96     return (Val <= 1);                                                                                                                                │
│  97   case HK_ISVECTORIZED:                                                                                                                               │
│  98   case HK_PREDICATE:                                                                                                                                  │
│  99   case HK_SCALABLE:                                                                                                                                   │
│ 100     return (Val == 0 || Val == 1);                                                                                                                    │
│ 101   }                                                                                                                                                   │
