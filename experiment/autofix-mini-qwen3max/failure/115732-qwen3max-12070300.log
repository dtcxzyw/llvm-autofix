│ 13604 /// %s2 = shufflevector <2 x ty> %1, poison, <1, 0, 1, 0>                                                                                                                                                │
│ 13605 /// \endcode                                                                                                                                                                                             │
│ 13606 /// and if need to emit shuffle of %s1 and %s2 with mask <1, 0, 5, 4>, it will                                                                                                                           │
│ 13607 /// look through %s1 and %s2 and emit                                                                                                                                                                    │
│ 13608 /// \code                                                                                                                                                                                                │
│ 13609 /// %res = shufflevector <2 x ty> %0, %1, <0, 1, 2, 3>                                                                                                                                                   │
│ 13610 /// \endcode                                                                                                                                                                                             │
