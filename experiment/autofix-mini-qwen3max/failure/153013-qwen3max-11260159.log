│ !Val.getConstantRange().isSingleElement()) {                                │
│ 420     // Do not add range attribute if the value may include undef.       │
│ 421     if (Val.isConstantRangeIncludingUndef())                            │
│ 422       return;                                                           │
│ 423                                                                         │
│ 424     // Take the intersection of the existing attribute and the inferred │
│ range.                                                                      │
│ 425     Attribute OldAttr = F->getAttributeAtIndex(AttrIndex,               │
│ Attribute::Range);                                                          │
