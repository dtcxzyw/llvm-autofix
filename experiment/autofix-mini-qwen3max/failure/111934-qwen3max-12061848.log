│ 170   NewMask = (Mask & (AMask_AllOnes | BMask_AllOnes | Mask_AllZeros |                                                                                                                                       │
│ 171                      AMask_Mixed | BMask_Mixed))                                                                                                                                                           │
│ 172             << 1;                                                                                                                                                                                          │
