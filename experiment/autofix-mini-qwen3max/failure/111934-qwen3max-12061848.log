│ 175                       AMask_NotMixed | BMask_NotMixed))                                                                                                                                                    │
│ 176              >> 1;                                                                                                                                                                                         │
│ 177                                                                                                                                                                                                            │
│ 178   return NewMask;                                                                                                                                                                                          │
