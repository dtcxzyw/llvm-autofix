│ 1199 ///   %iv = phi Ty [%Start, %Entry], [%Inc, %backedge]                                                                                                                                                    │
│ 1200 ///   %inc = binop %step, %iv                                                                                                                                                                             │
│ 1201 ///                                                                                                                                                                                                       │
│ 1202 /// A first order recurrence is a formula with the form: X_n = f(X_(n-1))                                                                                                                                 │
│ 1203 ///                                                                                                                                                                                                       │
│ 1204 /// A couple of notes on subtleties in that definition:                                                                                                                                                   │
│ 1205 /// * The Step does not have to be loop invariant.  In math terms, it can                                                                                                                                 │
│ 1206 ///   be a free variable.  We allow recurrences with both constant and                                                                                                                                    │
│ 1207 ///   variable coefficients. Callers may wish to filter cases where Step                                                                                                                                  │
│ 1208 ///   does not dominate P.                                                                                                                                                                                │
│ 1209 /// * For non-commutative operators, we will match both forms.  This                                                                                                                                      │
│ 1210 ///   results in some odd recurrence structures.  Callers may wish to filter                                                                                                                              │
│ 1211 ///   out recurrences where the phi is not the LHS of the returned operator.                                                                                                                              │
│ 1212 /// * Because of the structure matched, the caller can assume as a post                                                                                                                                   │
│ 1213 ///   condition of the match the presence of a Loop with P's parent as it's                                                                                                                               │
│ 1214 ///   header *except* in unreachable code.  (Dominance decays in unreachable                                                                                                                              │
│ 1215 ///   code.)                                                                                                                                                                                              │
│ 1216 ///                                                                                                                                                                                                       │
│ 1217 /// NOTE: This is intentional simple.  If you want the ability to analyze                                                                                                                                 │
│ 1218 /// non-trivial loop conditons, see ScalarEvolution instead.                                                                                                                                              │
│ 1219 bool matchSimpleRecurrence(const PHINode *P, BinaryOperator *&BO, Value *&Start,                                                                                                                          │
│ 1220                            Value *&Step);                                                                                                                                                                 │
