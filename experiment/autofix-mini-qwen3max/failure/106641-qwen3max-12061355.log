│ LoopVectorizationCostModel &CM) {", "new": "/// Check if a loop contains trunc instructions that truncate to i1 and are\n/// used by branch instructions. This is a common      │
│ pattern that can be optimized\n/// differently by VPlan vs legacy cost models.\nstatic bool hasTruncToI1InControlFlow(Loop *TheLoop) {\n  for (BasicBlock *BB :                 │
│ TheLoop->blocks()) {\n    for (Instruction &I : *BB) {\n      auto *Trunc = dyn_cast<TruncInst>(&I);\n      if (!Trunc || Trunc->getDestTy() !=                                 │
│ Type::getInt1Ty(TheLoop->getContext()))\n        continue;\n      \n      // Check if this trunc is used by a branch instruction\n      for (User *U : Trunc->users()) {\n      │
│ if (auto *Br = dyn_cast<BranchInst>(U)) {\n          if (Br->isConditional() && Br->getCondition() == Trunc)\n            return true;\n        }\n      }\n    }\n  }\n        │
│ return false;\n}\n\n/// Return true if the original loop \\ TheLoop contains any instructions that do\n/// not have corresponding recipes in \\p Plan and are not marked to be  │
│ ignored\n/// in \\p CostCtx. This means the VPlan contains simplification that the legacy\n/// cost-model did not account for.\nstatic                                          │
│ bool\nplanContainsAdditionalSimplifications(VPlan &Plan, ElementCount VF,\n                                       VPCostContext &CostCtx, Loop *TheLoop,\n                      │
│ LoopVectorizationCostModel &CM) {"})                                                                                                                                            │
