│ 161                                                                                                                                                                             │
│ 162   MDNode *IsVectorizedMD = MDNode::get(                                                                                                                                     │
│ 163       Context,                                                                                                                                                              │
│ 164       {MDString::get(Context, "llvm.loop.isvectorized"),                                                                                                                    │
│ 165        ConstantAsMetadata::get(ConstantInt::get(Context, APInt(32, 1)))});                                                                                                  │
│ 166   MDNode *LoopID = TheLoop->getLoopID();                                                                                                                                    │
