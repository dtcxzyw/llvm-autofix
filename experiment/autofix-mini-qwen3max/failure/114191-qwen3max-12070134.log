│ Based on my analysis of the LLVM bug, the root cause is that the negative divisor optimization in InstCombine is incorrectly applied to vector types. The optimization assumes that if the divisor is negative │
│ (large unsigned value), then `Op0 / Op1` equals `zext(Op0 >= Op1)`. However, this reasoning doesn't hold for vectors where different lanes may have different properties.                                      │
│                                                                                                                                                                                                                │
│ The fix is to restrict this optimization to scalar types only, preventing incorrect transformations on vector udiv operations.                                                                                 │
│                                                                                                                                                                                                                │
│ ```diff                                                                                                                                                                                                        │
│ diff --git a/llvm/lib/Transforms/InstCombine/InstCombineMulDivRem.cpp b/llvm/lib/Transforms/InstCombine/InstCombineMulDivRem.cpp                                                                               │
│ index b9c165da906d..b1acba9862b8 100644                                                                                                                                                                        │
│ --- a/llvm/lib/Transforms/InstCombine/InstCombineMulDivRem.cpp                                                                                                                                                 │
│ +++ b/llvm/lib/Transforms/InstCombine/InstCombineMulDivRem.cpp                                                                                                                                                 │
│ @@ -1573,7 +1573,7 @@ Instruction *InstCombinerImpl::visitUDiv(BinaryOperator &I) {                                                                                                                            │
│    // Op0 / C where C is large (negative) --> zext (Op0 >= C)                                                                                                                                                  │
│    // TODO: Could use isKnownNegative() to handle non-constant values.                                                                                                                                         │
│    Type *Ty = I.getType();                                                                                                                                                                                     │
│ -  if (match(Op1, m_Negative())) {                                                                                                                                                                             │
│ +  if (!Ty->isVectorTy() && match(Op1, m_Negative())) {                                                                                                                                                        │
│      Value *Cmp = Builder.CreateICmpUGE(Op0, Op1);                                                                                                                                                             │
│      return CastInst::CreateZExtOrBitCast(Cmp, Ty);                                                                                                                                                            │
│    }                                                                                                                                                                                                           │
│ ```                                                                                                                                                                                                            │
