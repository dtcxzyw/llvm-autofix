│ edit({"file": "llvm/lib/Transforms/InstCombine/InstCombineSelect.cpp", "old": "Instruction *InstCombinerImpl::foldSelectOfBools(SelectInst &SI) {",       │
│ "new": "// Check if folding a select with an ordered floating-point comparison condition\n// is safe. This is unsafe when TrueVal contains operations     │
│ that can produce\n// poison for the same inputs that make CondVal false (e.g., NaN inputs).\nstatic bool isSafeToFoldSelectWithOrderedFPComparison(const  │
│ Value *CondVal,\n                                                      const Value *TrueVal) {\n  // Check if CondVal is an ordered floating-point        │
│ comparison\n  auto *FCmp = dyn_cast<FCmpInst>(CondVal);\n  if (!FCmp || FCmp->getPredicate() != FCmpInst::FCMP_ORD)\n    return true;\n\n  // If TrueVal  │
│ might produce poison when the operands of FCmp are NaN,\n  // then this transformation is unsafe.\n  // We conservatively check if TrueVal contains any   │
│ instructions that\n  // could be affected by fast-math flags or produce poison from floating-point\n  // operations.\n  \n  // For now, we use a simple   │
│ heuristic: if TrueVal is not a constant and\n  // depends on floating-point values, be conservative.\n  // A more precise analysis would require dataflow │
