│ 365 void SimplifyIndvar::simplifyIVRemainder(BinaryOperator *Rem,           │
│ 366                                          Instruction *IVOperand,        │
│ 367                                          bool IsSigned) {               │
│ 368   auto *NValue = Rem->getOperand(0);                                    │
│ 369   auto *DValue = Rem->getOperand(1);                                    │
