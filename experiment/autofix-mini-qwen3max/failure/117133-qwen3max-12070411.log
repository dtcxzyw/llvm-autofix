│ 375     return;                                                             │
│ 376                                                                         │
│ 377   const SCEV *N = SE->getSCEV(NValue);                                  │
│ 378                                                                         │
│ 379   // Simplify unnecessary loops away.                                   │
│ 380   const Loop *ICmpLoop = LI->getLoopFor(Rem->getParent());              │
│ 381   N = SE->getSCEVAtScope(N, ICmpLoop);                                  │
│ 382                                                                         │
