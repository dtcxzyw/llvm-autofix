│ 415 bool SimplifyIndvar::eliminateOverflowIntrinsic(WithOverflowInst *WO) { │
│ 416   const SCEV *LHS = SE->getSCEV(WO->getLHS());                          │
│ 417   const SCEV *RHS = SE->getSCEV(WO->getRHS());                          │
│ 418   if (!SE->willNotOverflow(WO->getBinaryOp(), WO->isSigned(), LHS,      │
│ RHS))                                                                       │
