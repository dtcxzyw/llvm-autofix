│ 397     }                                                                   │
│ 398                                                                         │
│ 399     auto *T = Rem->getType();                                           │
│ 400     const SCEV *NLessOne = SE->getMinusSCEV(N, SE->getOne(T));          │
│ 401     if (SE->isKnownPredicate(LT, NLessOne, D)) {                        │
