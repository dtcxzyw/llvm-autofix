│ 209           Op == Instruction::IntToPtr) &&                               │
│ 210          "InsertNoopCastOfTo cannot perform non-noop casts!");          │
│ 211   assert(SE.getTypeSizeInBits(V->getType()) == SE.getTypeSizeInBits(Ty) │
│ &&                                                                          │
│ 212          "InsertNoopCastOfTo cannot change sizes!");                    │
│ 213                                                                         │
│ 214   // inttoptr only works for integral pointers. For non-integral        │
│ pointers, we                                                                │
│ 215   // can create a GEP on null with the integral value as index. Note    │
│ that                                                                        │
│ 216   // it is safe to use GEP of null instead of inttoptr here, because    │
│ only                                                                        │
│ 217   // expressions already based on a GEP of null should be converted to  │
│ pointers                                                                    │
│ 218   // during expansion.                                                  │
│ 219   if (Op == Instruction::IntToPtr) {                                    │
