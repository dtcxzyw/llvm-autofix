│ flags, then the floating point math\n    // operation in the transformed    │
│ code may produce poison when the original code\n    // would not. For       │
│ example, if the false value is infinity and the ninf flag is\n    // set,   │
│ the transformed fmul would be poison even though the original select\n      │
│ // would have bypassed the poisonous operation entirely.\n    // Avoid the  │
│ folding if the false value might violate any fast-math flags.\n    // We    │
│ use empty fast-math flags for the analysis to get the actual properties\n   │
│ // of the value, not the properties assuming the fast-math flags are        │
│ respected.\n    if (isa<FPMathOperator>(&SI)) {\n      KnownFPClass KFPC =  │
│ computeKnownFPClass(FalseVal, FastMathFlags(), fcAllFlags, &SI);\n      if  │
│ ((FMF.noNaNs() && !KFPC.isKnownNeverNaN()) ||\n          (FMF.noInfs() &&   │
│ !KFPC.isKnownNeverInfinity()) ||\n          (FMF.noSignedZeros() &&         │
│ !KFPC.isKnownNeverZero()))\n        return nullptr;\n    }"})               │
