│ same operand.\n    // In such cases, the original code only evaluates the   │
│ binary operation\n    // when the condition is true (e.g., x == 0), which   │
│ is safe, but the\n    // transformed code always evaluates the binary       │
│ operation, which can be\n    // poisonous if the operand violates the       │
│ fast-math flags.\n    if (isa<FPMathOperator>(TVI)) {\n      // First, keep │
│ the original NaN check using the select's fast-math flags\n      if         │
│ (!computeKnownFPClass(FalseVal, SelectFMF, fcNan, &SI).isKnownNeverNaN())\n │
│ return nullptr;\n      \n      // Check if this is the problematic case:    │
│ binary op with identical operands\n      // and false value equals those    │
│ operands\n      Value *Op0 = TVI->getOperand(0);\n      Value *Op1 =        │
│ TVI->getOperand(1);\n      if (Op0 == Op1 && Op0 == FalseVal) {\n        // │
│ This is the reproducer case: (select cond, (binop x, x), x)\n        //     │
│ Check if the false value could violate the binary operator's flags\n        │
│ KnownFPClass KFPC = computeKnownFPClass(FalseVal, FastMathFlags(),          │
│ fcAllFlags, &SI);\n        if ((BinOpFMF.noInfs() &&                        │
│ !KFPC.isKnownNeverInfinity()) ||\n            (BinOpFMF.noNaNs() &&         │
│ !KFPC.isKnownNeverNaN()))\n          return nullptr;\n      }\n    }",      │
│ "new": "    // The original check only considered NaN issues, but we also   │
│ need to\n    // consider cases where the transformed operation could        │
│ produce poison\n    // due to restrictive fast-math flags on the binary     │
│ operator.\n    // The issue is most critical when the binary operation uses │
│ the same\n    // operand twice (like fmul x, x) and the false value is that │
│ same operand.\n    // In such cases, the original code only evaluates the   │
│ binary operation\n    // when the condition is true (e.g., x == 0), which   │
│ is safe, but the\n    // transformed code always evaluates the binary       │
│ operation, which can be\n    // poisonous if the operand violates the       │
│ fast-math flags.\n    if (isa<FPMathOperator>(TVI)) {\n      // First, keep │
│ the original NaN check using the select's fast-math flags\n      if         │
│ (!computeKnownFPClass(FalseVal, SelectFMF, fcNan, &SI).isKnownNeverNaN())\n │
│ return nullptr;\n      \n      // Check if this is the problematic case:    │
│ binary op with identical operands\n      // and false value equals those    │
│ operands\n      Value *Op0 = TVI->getOperand(0);\n      Value *Op1 =        │
│ TVI->getOperand(1);\n      if (Op0 == Op1 && (Op0 == FalseVal || Op1 ==     │
│ FalseVal)) {\n        // This is the reproducer case: (select cond, (binop  │
│ x, x), x)\n        // Check if the false value could violate the binary     │
│ operator's flags\n        KnownFPClass KFPC = computeKnownFPClass(FalseVal, │
│ FastMathFlags(), fcAllFlags, &SI);\n        if ((BinOpFMF.noInfs() &&       │
│ !KFPC.isKnownNeverInfinity()) ||\n            (BinOpFMF.noNaNs() &&         │
│ !KFPC.isKnownNeverNaN()))\n          return nullptr;\n      }\n    }"})     │
