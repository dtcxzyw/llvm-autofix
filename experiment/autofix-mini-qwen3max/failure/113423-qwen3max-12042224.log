│ "new": "    // The original check only considered NaN issues, but we also   │
│ need to\n    // consider cases where the transformed operation could        │
│ produce poison\n    // due to restrictive fast-math flags on the binary     │
│ operator.\n    // The transformation is unsafe when the false value could   │
│ violate the\n    // binary operator's ninf or nnan flags, because the       │
│ transformed code\n    // always evaluates the binary operation, while the   │
│ original code only\n    // evaluates it when the condition is true.\n    if │
│ (isa<FPMathOperator>(TVI)) {\n      // First, keep the original NaN check   │
│ using the select's fast-math flags\n      if                                │
│ (!computeKnownFPClass(FalseVal, SelectFMF, fcNan, &SI).isKnownNeverNaN())\n │
│ return nullptr;\n      \n      // Check for ninf/nnan violations using      │
│ empty fast-math flags for analysis\n      // We don't check nsz because     │
│ signed zeros are not poison with nsz,\n      // they're just treated as     │
│ equivalent to positive zeros.\n      KnownFPClass KFPC =                    │
│ computeKnownFPClass(FalseVal, FastMathFlags(), fcAllFlags, &SI);\n      if  │
│ ((BinOpFMF.noInfs() && !KFPC.isKnownNeverInfinity()) ||\n                   │
│ (BinOpFMF.noNaNs() && !KFPC.isKnownNeverNaN()))\n        return nullptr;\n  │
│ }"})                                                                        │
