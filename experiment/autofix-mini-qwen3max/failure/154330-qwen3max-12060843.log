│ correctly during transformation. Instead, we use a more direct\n      //    │
│ approach: if the user is a VPReplicateRecipe, we check if the operand\n     │
│ // would be considered single scalar by examining its properties.\n         │
│ RepR->replaceUsesWithIf(LaneDefs[0], [RepR](VPUser &U, unsigned OpIdx) {\n  │
│ assert(U.getOperand(OpIdx) == RepR && \"Operand mismatch\");\n        \n    │
│ // For VPReplicateRecipe users, check if the operand is defined outside\n   │
│ // loop regions (which makes it uniform)\n        if                        │
│ (isa<VPReplicateRecipe>(&U))\n          return                              │
│ RepR->isDefinedOutsideLoopRegions();\n          \n        // For other      │
