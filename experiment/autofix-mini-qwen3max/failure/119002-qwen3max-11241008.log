│ 203                                                                         │
│ 204   unsigned MinVecNumElts = MinVectorSize / ScalarSize;                  │
│ 205   auto *MinVecTy = VectorType::get(ScalarTy, MinVecNumElts, false);     │
│ 206   unsigned OffsetEltIndex = 0;                                          │
