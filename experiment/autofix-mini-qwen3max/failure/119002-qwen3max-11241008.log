│ 168   if (!ScalarSize || !MinVectorSize || MinVectorSize % ScalarSize != 0  │
│ ||                                                                          │
│ 169       ScalarSize % 8 != 0)                                              │
│ 170     return false;                                                       │
│ 171                                                                         │
│ 172   return true;                                                          │
│ 173 }                                                                       │
