│ 165 /// Convert an analysis of a masked ICmp into its equivalent if all     │
│ boolean                                                                     │
│ 166 /// operations had the opposite sense. Since each "NotXXX" flag         │
│ (recording !=)                                                              │
│ 167 /// is adjacent to the corresponding normal flag (recording ==), this   │
│ just                                                                        │
│ 168 /// involves swapping those bits over.                                  │
│ 169 static unsigned conjugateICmpMask(unsigned Mask) {                      │
│ 170   unsigned NewMask;                                                     │
│ 171   NewMask = (Mask & (AMask_AllOnes | BMask_AllOnes | Mask_AllZeros |    │
│ 172                      AMask_Mixed | BMask_Mixed))                        │
│ 173             << 1;                                                       │
│ 174                                                                         │
│ 175   NewMask |= (Mask & (AMask_NotAllOnes | BMask_NotAllOnes |             │
│ Mask_NotAllZeros |                                                          │
│ 176                       AMask_NotMixed | BMask_NotMixed))                 │
│ 177              >> 1;                                                      │
│ 178                                                                         │
│ 179   return NewMask;                                                       │
│ 180 }                                                                       │
