diff --git a/llvm/lib/Transforms/Scalar/GVN.cpp
b/llvm/lib/Transforms/Scalar/GVN.cpp
index 4baa3b3eb824..9fc9039761f2 100644
--- a/llvm/lib/Transforms/Scalar/GVN.cpp
+++ b/llvm/lib/Transforms/Scalar/GVN.cpp
@@ -3002,6 +3002,11 @@ bool GVNPass::performScalarPRE(Instruction *CurInst) {
   if (isa<GetElementPtrInst>(CurInst))
     return false;

+  // Skip PRE if the instruction's type is token-like, as PHI nodes cannot
+  // have token-like types (including DirectX resource handle types).
+  if (CurInst->getType()->isTokenLikeTy())
+    return false;
+
   if (auto *CallB = dyn_cast<CallBase>(CurInst)) {
     // We don't currently value number ANY inline asm calls.
