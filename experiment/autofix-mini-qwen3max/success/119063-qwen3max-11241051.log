Final Patch
-----------
diff --git a/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp
b/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp
index b694fde30927..070914ad2069 100644
--- a/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp
+++ b/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp
@@ -3628,6 +3628,10 @@ Instruction
*InstCombinerImpl::foldICmpBinOpEqualityWithConstant(
       if (Pred == ICmpInst::ICMP_EQ
               ? (match(TV, m_Zero()) && isKnownNonZero(FV, Q))
               : (match(FV, m_Zero()) && isKnownNonZero(TV, Q))) {
+        // Skip this optimization if we have a scalar condition with vector
select operands,
+        // as it requires type conversion that may not be beneficial.
+        if (!Cond->getType()->isVectorTy() && TV->getType()->isVectorTy())
+          return nullptr;
         Value *Cmp = Builder.CreateICmp(
             Pred, Other, Constant::getNullValue(Other->getType()));
         return BinaryOperator::Create(
@@ -3650,6 +3654,10 @@ Instruction
*InstCombinerImpl::foldICmpBinOpEqualityWithConstant(
           (Pred == ICmpInst::ICMP_EQ
                ? (match(FV, m_Zero()) && isKnownNonZero(TV, Q))
                : (match(TV, m_Zero()) && isKnownNonZero(FV, Q)))) {
+        // Skip this optimization if we have a scalar condition with vector
select operands,
+        // as it requires type conversion that may not be beneficial.
+        if (!Cond->getType()->isVectorTy() && TV->getType()->isVectorTy())
+          return nullptr;
         Value *NotCond = Builder.CreateNot(Cond);
         Value *Cmp = Builder.CreateICmp(
             Pred, Other, Constant::getNullValue(Other->getType()));

