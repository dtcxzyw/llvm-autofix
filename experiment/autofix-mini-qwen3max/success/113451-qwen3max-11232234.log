*GatheredLoadsEntriesFirst) || all_of(E->Scalars, [=](Value *V) -> bool { if
(E->getOpcode() == Instruction::GetElementPtr && !isa<GetElementPtrInst>(V))
return true; auto *I = cast<Instruction>(V); return !E->isOpcodeOrAlt(I) ||
I->getParent() == BB || isVectorLikeInstWithConstOps(I); })) && "Expected
gathered loads or GEPs or instructions from same basic " "block."' failed.
