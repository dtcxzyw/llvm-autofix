│ 474   //                                                                    │
│ 475   // The following example shows this:                                  │
│ 476   // for (i = 0; i < 1000; ++i)                                         │
│ 477   //   a[5000 + i * m] = a[i] + a[i + 9000]                             │
│ 478   //                                                                    │
