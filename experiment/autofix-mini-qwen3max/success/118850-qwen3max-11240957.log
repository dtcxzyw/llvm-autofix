│ 358     if (match(&R, m_VPInstruction<VPInstruction::ExtractFromEnd>(       │
│ 359                       m_VPValue(Op0), m_VPValue(Op1)))) {               │
│ 360       addUniformForAllParts(cast<VPSingleDefRecipe>(&R));               │
