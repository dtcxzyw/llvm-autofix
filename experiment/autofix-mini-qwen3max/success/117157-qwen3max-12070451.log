diff --git a/llvm/lib/Analysis/MemorySSAUpdater.cpp
b/llvm/lib/Analysis/MemorySSAUpdater.cpp
index ecfecb03c375..019b3e80da4c 100644
--- a/llvm/lib/Analysis/MemorySSAUpdater.cpp
+++ b/llvm/lib/Analysis/MemorySSAUpdater.cpp
@@ -493,6 +493,11 @@ void MemorySSAUpdater::fixupDefs(const
SmallVectorImpl<WeakVH> &Vars) {
     while (!Worklist.empty()) {
       const BasicBlock *FixupBlock = Worklist.pop_back_val();

+      // Skip blocks that are not dominated by NewDef to maintain
+      // dominance invariants required by MemorySSA.
+      if (!MSSA->DT->dominates(NewDef->getBlock(), FixupBlock))
+        continue;
+
       // Get the first def in the block that isn't a phi node.
       if (auto *Defs = MSSA->getWritableBlockDefs(FixupBlock)) {
         auto *FirstDef = &*Defs->begin();

Reference Patch
