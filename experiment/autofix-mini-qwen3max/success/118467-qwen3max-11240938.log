-804,7 +804,8 @@ static bool foldConsecutiveLoads(Instruction &I, const
DataLayout &DL,\n     Load1Ptr = Load1Ptr->stripAndAccumulateConstantOffsets(\n
DL, Offset1, /* AllowNonInbounds */ true);\n     Load1Ptr =
Builder.CreatePtrAdd(Load1Ptr,\n-
Builder.getInt32(Offset1.getZExtValue()));\n+
Builder.getIntN(DL.getIndexTypeSizeInBits(Load1Ptr->getType()),\n+
