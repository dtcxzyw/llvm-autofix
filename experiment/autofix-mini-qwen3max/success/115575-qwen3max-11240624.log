diff --git a/llvm/lib/Transforms/Vectorize/VectorCombine.cpp
b/llvm/lib/Transforms/Vectorize/VectorCombine.cpp
index 04ea12ef0f12..312d435ae1b1 100644
--- a/llvm/lib/Transforms/Vectorize/VectorCombine.cpp
+++ b/llvm/lib/Transforms/Vectorize/VectorCombine.cpp
@@ -1005,6 +1005,11 @@ bool VectorCombine::scalarizeBinopOrCmp(Instruction &I)
{
     ++NumScalarBO;

   // For constant cases, extract the scalar element, this should constant
fold.
+  // But first check that the index is within bounds to avoid creating poison
+  // that could trigger immediate undefined behavior in the scalar operation.
+  auto *FixedVecTy = dyn_cast<FixedVectorType>(VecTy);
+  if (FixedVecTy && Index >= FixedVecTy->getNumElements())
+    return false;
   if (IsConst0)
     V0 = ConstantExpr::getExtractElement(VecC0, Builder.getInt64(Index));
   if (IsConst1)

