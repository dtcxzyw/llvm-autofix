diff --git a/llvm/include/llvm/CodeGen/BasicTTIImpl.h b/llvm/include/llvm/CodeGen/BasicTTIImpl.h
index 50dc7d5c54c5..ea1bedc9de98 100644
--- a/llvm/include/llvm/CodeGen/BasicTTIImpl.h
+++ b/llvm/include/llvm/CodeGen/BasicTTIImpl.h
@@ -1569,7 +1569,7 @@ public:

     case Intrinsic::powi:
       if (auto *RHSC = dyn_cast<ConstantInt>(Args[1])) {
-        bool ShouldOptForSize = I->getParent()->getParent()->hasOptSize();
+        bool ShouldOptForSize = I ? I->getParent()->getParent()->hasOptSize() : false;
         if (getTLI()->isBeneficialToExpandPowI(RHSC->getSExtValue(),
                                                ShouldOptForSize)) {
           // The cost is modeled on the expansion performed by ExpandPowI in
diff --git a/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp b/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
index e782ac444d02..d961ba2605a5 100644
--- a/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
+++ b/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
@@ -945,7 +945,9 @@ InstructionCost VPWidenCallRecipe::computeCost(ElementCount VF,
   // clear Arguments.
   // TODO: Rework TTI interface to be independent of concrete IR values.
   SmallVector<const Value *> Arguments;
-  for (const auto &[Idx, Op] : enumerate(operands())) {
+  unsigned NumArgs = getNumOperands() - 1; // Exclude the callee function
+  for (unsigned Idx = 0; Idx < NumArgs; ++Idx) {
+    auto *Op = getOperand(Idx);
     auto *V = Op->getUnderlyingValue();
     if (!V) {
       if (auto *UI = dyn_cast_or_null<CallBase>(getUnderlyingValue())) {
@@ -961,7 +963,7 @@ InstructionCost VPWidenCallRecipe::computeCost(ElementCount VF,
   Type *RetTy =
       ToVectorTy(Ctx.Types.inferScalarType(this->getVPSingleValue()), VF);
   SmallVector<Type *> ParamTys;
-  for (unsigned I = 0; I != getNumOperands(); ++I)
+  for (unsigned I = 0; I < getNumOperands() - 1; ++I)
     ParamTys.push_back(
         ToVectorTy(Ctx.Types.inferScalarType(getOperand(I)), VF));


