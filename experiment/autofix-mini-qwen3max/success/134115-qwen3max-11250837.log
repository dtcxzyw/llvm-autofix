Final Patch
-----------
diff --git a/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
b/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
index bbfed2ac2c09..3e2ccce20451 100644
--- a/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
+++ b/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
@@ -57,6 +57,7 @@
 #include "llvm/Support/Compiler.h"
 #include "llvm/Support/Debug.h"
 #include "llvm/Support/ErrorHandling.h"
+#include "llvm/Support/MathExtras.h"
 #include "llvm/Support/raw_ostream.h"
 #include "llvm/Transforms/IPO.h"
 #include "llvm/Transforms/Utils/Local.h"
@@ -661,8 +662,12 @@ ArgumentAccessInfo getArgumentAccessInfo(const Instruction
*I,
     auto TypeSize = DL.getTypeStoreSize(Ty);
     if (!TypeSize.isScalable() && Offset) {
       int64_t Size = TypeSize.getFixedValue();
+      // Check for signed overflow when computing the upper bound.
+      int64_t Upper;
+      if (AddOverflow(*Offset, Size, Upper))
+        return std::nullopt;
       return ConstantRange(APInt(64, *Offset, true),
-                           APInt(64, *Offset + Size, true));
+                           APInt(64, Upper, true));
     }
     return std::nullopt;
   };

Reference Patch
---------------
commit 0547e84181ff10b24d6363bbfc97f168fe245397
Author: Arthur Eubanks <aeubanks@google.com>
Date:   Wed Apr 23 15:56:24 2025 -0700

    [FunctionAttrs] Bail if initializes range overflows 64-bit signed int
(#137053)

    Otherwise the range doesn't make sense since we interpret it as signed.

    Fixes #134115

diff --git a/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
b/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
index bbfed2ac2c09..74e8a849803d 100644
--- a/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
+++ b/llvm/lib/Transforms/IPO/FunctionAttrs.cpp
@@ -661,8 +661,13 @@ ArgumentAccessInfo getArgumentAccessInfo(const Instruction
*I,
     auto TypeSize = DL.getTypeStoreSize(Ty);
     if (!TypeSize.isScalable() && Offset) {
       int64_t Size = TypeSize.getFixedValue();
-      return ConstantRange(APInt(64, *Offset, true),
-                           APInt(64, *Offset + Size, true));
+      APInt Low(64, *Offset, true);
+      bool Overflow;
+      APInt High = Low.sadd_ov(APInt(64, Size, true), Overflow);
+      // Bail if the range overflows signed 64-bit int.
+      if (Overflow)
+        return std::nullopt;
+      return ConstantRange(Low, High);
     }
     return std::nullopt;
   };

