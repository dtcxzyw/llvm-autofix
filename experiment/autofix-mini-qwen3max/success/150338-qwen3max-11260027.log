Final Patch
-----------
diff --git a/llvm/lib/Transforms/Utils/Local.cpp
b/llvm/lib/Transforms/Utils/Local.cpp
index babd7f6b3a05..d6a53a8349f9 100644
--- a/llvm/lib/Transforms/Utils/Local.cpp
+++ b/llvm/lib/Transforms/Utils/Local.cpp
@@ -484,6 +484,10 @@ bool llvm::wouldInstructionBeTriviallyDead(const
Instruction *I,
       auto *Arg = II->getArgOperand(1);
       // If the only uses of the alloca are lifetime intrinsics, then the
       // intrinsics are dead.
+      // For constants like poison/undef that don't have use lists, they
+      // effectively have no non-lifetime-intrinsic uses.
+      if (!Arg->hasUseList())
+        return true;
       return llvm::all_of(Arg->uses(), [](Use &Use) {
         return isa<LifetimeIntrinsic>(Use.getUser());
       });

Reference Patch
