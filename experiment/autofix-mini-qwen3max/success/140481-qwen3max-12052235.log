│ 393 struct OffsetResult {                                                                                                                                                                                      │
│ 394   Value *BasePtr;                                                                                                                                                                                          │
│ 395   APInt ConstantOffset;                                                                                                                                                                                    │
│ 396   SmallMapVector<Value *, APInt, 4> VariableOffsets;                                                                                                                                                       │
│ 397   GEPNoWrapFlags NW;                                                                                                                                                                                       │
