│ 402       : BasePtr(GEP.getPointerOperand()), NW(GEP.getNoWrapFlags()) {                                                                                                                                       │
│ 403     ConstantOffset = APInt(DL.getIndexTypeSizeInBits(BasePtr->getType()), 0);                                                                                                                              │
