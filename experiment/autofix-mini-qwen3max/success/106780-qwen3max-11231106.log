│ (!SeenInstrs.contains(&I) && !CostCtx.skipCostComputation(&I, true)) {\n        // If the instruction is         │
│ loop-invariant, it can be hoisted and doesn't\n        // need to be in the VPlan.\n        if                   │
│ (TheLoop->isLoopInvariant(&I))\n          return false;\n        return true;\n      }\n      return false;\n    │
│ });\n  });"})                                                                                                    │
