diff --git a/llvm/lib/Transforms/Vectorize/VectorCombine.cpp
b/llvm/lib/Transforms/Vectorize/VectorCombine.cpp
index ecbc13d489eb..aca8ae93488b 100644
--- a/llvm/lib/Transforms/Vectorize/VectorCombine.cpp
+++ b/llvm/lib/Transforms/Vectorize/VectorCombine.cpp
@@ -1679,6 +1679,9 @@ bool VectorCombine::foldShuffleOfBinops(Instruction &I) {
     IsCommutative = BinaryOperator::isCommutative(BO->getOpcode());
   } else if (match(LHS, m_Cmp(Pred, m_Value(X), m_Value(Y))) &&
              match(RHS, m_SpecificCmp(Pred, m_Value(Z), m_Value(W)))) {
+    // Verify that both comparisons have identical predicates including
samesign
+    if (cast<CmpInst>(LHS)->getPredicate() !=
cast<CmpInst>(RHS)->getPredicate())
+      return false;
     IsCommutative = cast<CmpInst>(LHS)->isCommutative();
   } else
     return false;

