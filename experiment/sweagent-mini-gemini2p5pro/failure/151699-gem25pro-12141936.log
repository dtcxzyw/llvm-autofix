│ ```bash                                                                                                                      │
│ sed -i '/if (isa<PHINode>(V)) {/a \                                                                                          │
│     if (!all_of(drop_begin(VL), [PN](Value *V) { return isa<PHINode>(V) && cast<PHINode>(V)->getNumIncomingValues() ==       │
│ PN->getNumIncomingValues(); }))\                                                                                             │
│       return InstructionsState();' llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp                                           │
│ ```                                                                                                                          │
