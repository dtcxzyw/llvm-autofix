│     auto *TripCountTy = cast<IntegerType>(TripCount->getType());                                                                                                                         │
│     const SCEV *VFConst =                                                                                                                                                                │
│         VF.isScalable()                                                                                                                                                                  │
│             ? SE.getVScale(TripCountTy)                                                                                                                                                  │
│             : SE.getConstant(TripCountTy, VF.getKnownMinValue());                                                                                                                        │
│     return SE.isKnownMultipleOf(TripCount, VFConst);                                                                                                                                     │
│   }                                                                                                                                                                                      │
│                                                                                                                                                                                          │
│ private:                                                                                                                                                                                 │
│   Loop *L;                                                                                                                                                                               │
