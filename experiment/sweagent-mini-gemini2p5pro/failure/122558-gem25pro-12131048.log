│ /// A helper class for getting a SCEV-based trip count of a loop.                                                                                                                        │
│ ///                                                                                                                                                                                      │
│ /// The SCEV-based trip count is computed using ScalarEvolution, as opposed to                                                                                                           │
│ /// the "syntactic" trip count, which is found by means of a simple analysis                                                                                                             │
│ /// of the loop's exit condition.                                                                                                                                                        │
│ ///                                                                                                                                                                                      │
│ /// TODO: This class is a simplified version of the class with the same name in                                                                                                          │
│ /// LoopDistribute. We should unify them and put the result in a common place.                                                                                                           │
│ class SCEVTripCount {                                                                                                                                                                    │
│ public:                                                                                                                                                                                  │
│   SCEVTripCount(Loop *L, ScalarEvolution &SE) : L(L), SE(SE) {}                                                                                                                          │
│                                                                                                                                                                                          │
│   /// Get the trip count expression for the given loop.                                                                                                                                  │
│   ///                                                                                                                                                                                    │
│   /// The result is not guaranteed to be exact. If the trip count is not                                                                                                                 │
│   // computable, this function will return a SCEVCouldNotCompute object.                                                                                                                 │
│   const SCEV *get() {                                                                                                                                                                    │
│     if (BackedgeTakenCount)                                                                                                                                                              │
│       return BackedgeTakenCount;                                                                                                                                                         │
│                                                                                                                                                                                          │
│     // Check if we have stored the backedge-taken count.                                                                                                                                 │
│     if (const SCEV *BECount = SE.getBackedgeTakenCount(L)) {                                                                                                                             │
│       if (!isa<SCEVCouldNotCompute>(BECount)) {                                                                                                                                          │
│         // Add one to the backedge-taken count to get the trip count.                                                                                                                    │
│         const SCEV *One = SE.getOne(BECount->getType());                                                                                                                                 │
│         BackedgeTakenCount = SE.getAddExpr(BECount, One);                                                                                                                                │
│         return BackedgeTakenCount;                                                                                                                                                       │
│       }                                                                                                                                                                                  │
│     }                                                                                                                                                                                    │
│     return SE.getCouldNotCompute();                                                                                                                                                      │
│   }                                                                                                                                                                                      │
│                                                                                                                                                                                          │
│   /// Get the trip count expression for the given loop.                                                                                                                                  │
│   ///                                                                                                                                                                                    │
│   /// The result is not guaranteed to be exact. If the trip count is not                                                                                                                 │
│   // computable, this function will return a SCEVCouldNotCompute object.                                                                                                                 │
│   ///                                                                                                                                                                                    │
│   /// This is a const version of the above.                                                                                                                                              │
│   const SCEV *get() const {                                                                                                                                                              │
│     if (BackedgeTakenCount)                                                                                                                                                              │
│       return BackedgeTakenCount;                                                                                                                                                         │
│     return const_cast<SCEVTripCount *>(this)->get();                                                                                                                                     │
│   }                                                                                                                                                                                      │
│                                                                                                                                                                                          │
│   /// Returns true if the trip count is known to be a multiple of VF.                                                                                                                    │
│   bool isKnownToHaveTripCount(ElementCount VF) const {                                                                                                                                   │
│     if (VF.isScalar())                                                                                                                                                                   │
│       return true;                                                                                                                                                                       │
│     assert(VF.isVector() && "VF must be a vector");                                                                                                                                      │
│     const SCEV *TripCount = get();                                                                                                                                                       │
│     if (isa<SCEVCouldNotCompute>(TripCount))                                                                                                                                             │
