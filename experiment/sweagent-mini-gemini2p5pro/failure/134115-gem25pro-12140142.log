│ /// A helper for computing the reverse post-order of the call graph.                                                                                                                     │
│ ///                                                                                                                                                                                      │
│ /// This is computed once and shared between the various attribute deduction                                                                                                             │
│ /// logic.                                                                                                                                                                               │
│ class ReversePostOrderTraversal {                                                                                                                                                        │
│   SmallVector<Function *, 8> RPOStack;                                                                                                                                                   │
│   SmallSet<Function *, 8> Visited;                                                                                                                                                       │
│                                                                                                                                                                                          │
│ public:                                                                                                                                                                                  │
│   ReversePostOrderTraversal(LazyCallGraph::SCC &C) {                                                                                                                                     │
│     SmallVector<Function *, 8> VisitStack;                                                                                                                                               │
│     for (Function *F : C)                                                                                                                                                                │
│       if (F && !F->isDeclaration())                                                                                                                                                      │
│         VisitStack.push_back(F);                                                                                                                                                         │
│                                                                                                                                                                                          │
│     while (!VisitStack.empty()) {                                                                                                                                                        │
│       Function *F = VisitStack.pop_back_val();                                                                                                                                           │
│       if (!Visited.insert(F).second)                                                                                                                                                     │
│         continue;                                                                                                                                                                        │
│                                                                                                                                                                                          │
│       RPOStack.push_back(F);                                                                                                                                                             │
│                                                                                                                                                                                          │
│       for (const CallGraphNode::CallRecord &CR : *C.getCallGraph()[F])                                                                                                                   │
│         if (Function *Callee = CR.Callee->getFunction())                                                                                                                                 │
│           if (!Callee->isDeclaration())                                                                                                                                                  │
│             VisitStack.push_back(Callee);                                                                                                                                                │
│     }                                                                                                                                                                                    │
│   }                                                                                                                                                                                      │
│                                                                                                                                                                                          │
│   using iterator = SmallVectorImpl<Function *>::reverse_iterator;                                                                                                                        │
│                                                                                                                                                                                          │
│   iterator begin() { return RPOStack.rbegin(); }                                                                                                                                         │
│   iterator end() { return RPOStack.rend(); }                                                                                                                                             │
│                                                                                                                                                                                          │
│   ArrayRef<Function *> functions() const { return RPOStack; }                                                                                                                            │
│ };                                                                                                                                                                                       │
