│     // If the operand is an instruction, it must dominate the insert point.                                                                                                              │
│     if (!DT.dominates(I, InsertInst))                                                                                                                                                    │
│       InsertBlock = DT.findNearestCommonDominator(InsertBlock, I->getParent());                                                                                                          │
