│   Value *V;                                                                                                                                                                              │
│   VectorSplit VS;                                                                                                                                                                        │
│   bool IsPointer;                                                                                                                                                                        │
│   ValueVector *CachePtr;                                                                                                                                                                 │
│   ValueVector Tmp;                                                                                                                                                                       │
│ };                                                                                                                                                                                       │
