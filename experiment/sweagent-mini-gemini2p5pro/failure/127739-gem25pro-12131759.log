│ // Provides a very limited vector-like interface for lazily accessing one                                                                                                                │
│ // component of a scattered vector or vector pointer.                                                                                                                                    │
│ class Scatterer {                                                                                                                                                                        │
│ public:                                                                                                                                                                                  │
│   Scatterer() = default;                                                                                                                                                                 │
│                                                                                                                                                                                          │
