│   if (EVI.getType()->isVectorTy()) {\                                                                                                                                                    │
│     Scatterer S(&EVI, *this);\                                                                                                                                                           │
│     for (User *U : EVI.users()) {\                                                                                                                                                       │
│       if (auto *EEI = dyn_cast<ExtractElementInst>(U)) {\                                                                                                                                │
