│   void buildRPOT(Function &F);                                                                                                                                                           │
│   void analyzeInitialPHIs(BasicBlock *BB, ModelledPHISet &NeededPHIs,                                                                                                                    │
│                           SmallPtrSetImpl<Value *> &PHIContents);                                                                                                                        │
│   bool shouldAvoidSinkingInstruction(Instruction *I);                                                                                                                                    │
│   std::optional<SinkingInstructionCandidate> analyzeInstructionForSinking(                                                                                                               │
│       LockstepReverseIterator<false> &LRI, unsigned &InstNum,                                                                                                                            │
│       unsigned &MemoryInstNum, ModelledPHISet &NeededPHIs,                                                                                                                               │
│       SmallPtrSetImpl<Value *> &PHIContents);                                                                                                                                            │
│   unsigned sinkBB(BasicBlock *BB);                                                                                                                                                       │
