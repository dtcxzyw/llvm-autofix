│     // Can't sink anything!                                                                                                                                                              │
│     return std::nullopt;                                                                                                                                                                 │
│                                                                                                                                                                                          │
│   // Now restrict the number of incoming blocks down to only those with                                                                                                                  │
│   // VNumToSink.                                                                                                                                                                         │
│   auto &ActivePreds = LRI.getActiveBlocks();                                                                                                                                             │
│   unsigned InitialActivePredSize = ActivePreds.size();                                                                                                                                   │
│   SmallVector<Instruction *, 4> NewInsts;                                                                                                                                                │
│   for (auto *I : Insts) {                                                                                                                                                                │
