│   GVN::ValueTable &VN;                                                                                                                                                                   │
│   DenseMap<const BasicBlock *, unsigned> RPOTOrder;                                                                                                                                      │
│                                                                                                                                                                                          │
│ public:                                                                                                                                                                                  │
│   GVNSink(GVN &G) : G(G), VN(G.getValueTable()) {}                                                                                                                                       │
│   bool run(Function &F);                                                                                                                                                                 │
