│   SmallVector<BasicBlock *, 4> Blocks;                                                                                                                                                   │
│                                                                                                                                                                                          │
│   void calculateCost(unsigned NumOrigPHIs, unsigned NumOrigBlocks) {                                                                                                                     │
│     unsigned NumExtraPHIs = NumPHIs - NumOrigPHIs;                                                                                                                                       │
