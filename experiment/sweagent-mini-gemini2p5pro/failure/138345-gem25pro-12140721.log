│ bool GVNSink::run(Function &F) {                                                                                                                                                         │
│   bool Changed = false;                                                                                                                                                                  │
│   buildRPOT(F);                                                                                                                                                                          │
│                                                                                                                                                                                          │
│   for (auto I = RPOTOrder.begin(), E = RPOTOrder.end(); I != E; ++I) {                                                                                                                   │
│     BasicBlock *BB = const_cast<BasicBlock *>(I->getFirst());                                                                                                                            │
│     Changed |= sinkBB(BB) > 0;                                                                                                                                                           │
│   }                                                                                                                                                                                      │
│                                                                                                                                                                                          │
│   return Changed;                                                                                                                                                                        │
│ }                                                                                                                                                                                        │
