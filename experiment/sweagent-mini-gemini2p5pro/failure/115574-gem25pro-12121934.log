│                                                                                                                                                                                          │
│ ```bash                                                                                                                                                                                  │
│ sed -i -e '1i#include "llvm/Analysis/ValueTracking.h"' -e 's/if (Pred == ICmpInst::ICMP_EQ) {/if (Pred == ICmpInst::ICMP_EQ) {\n    if (CmpLHS->getType()->isPointerTy() \&\&            │
