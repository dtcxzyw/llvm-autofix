│                                       Builder.getInt32(InIdx));                                                              │
│   }                                                                                                                          │
│   // The element is from the second vector operand.                                                                          │
│   return ExtractElementInst::Create(SVI->getOperand(1),                                                                      │
│                                     Builder.getInt32(InIdx - VWidth));                                                       │
