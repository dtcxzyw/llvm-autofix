│ // In translateExtract                                                                                                       │
│ // ...                                                                                                                       │
│   if (auto *Shuffle = dyn_cast<ShuffleVectorInst>(Vec)) {                                                                    │
│     if (auto *Idx = dyn_cast<ConstantInt>(OrigEE->getIndexOperand())) {                                                      │
│       Value *Val = foldExtractFromShuffle(Shuffle, Idx);                                                                     │
