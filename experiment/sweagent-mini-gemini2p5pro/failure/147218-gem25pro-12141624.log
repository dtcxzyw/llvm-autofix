│       // If we created a new extract, recurse.                                                                               │
│       if (auto *EE = dyn_cast<ExtractElementInst>(Val))                                                                      │
│         return translateExtract(EE, 0, Builder);                                                                             │
│       // Otherwise, we have some other instruction. Just return it.                                                          │
│       return Val;                                                                                                            │
│     }                                                                                                                        │
│   }                                                                                                                          │
│ // ...                                                                                                                       │
│ ```                                                                                                                          │
