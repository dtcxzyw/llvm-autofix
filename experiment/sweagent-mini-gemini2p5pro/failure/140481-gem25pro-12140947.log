│   EntryTy Ty;                                                                                                                                                                            │
│                                                                                                                                                                                          │
│   FactOrCheck(EntryTy Ty, DomTreeNode *DTN, Instruction *Inst)                                                                                                                           │
│       : Inst(Inst), NumIn(DTN->getDFSNumIn()), NumOut(DTN->getDFSNumOut()),                                                                                                              │
│         Ty(Ty) {}                                                                                                                                                                        │
│                                                                                                                                                                                          │
│   FactOrCheck(DomTreeNode *DTN, Use *U)                                                                                                                                                  │
│       : U(U), NumIn(DTN->getDFSNumIn()), NumOut(DTN->getDFSNumOut()),                                                                                                                    │
│         Ty(EntryTy::UseCheck) {}                                                                                                                                                         │
│                                                                                                                                                                                          │
