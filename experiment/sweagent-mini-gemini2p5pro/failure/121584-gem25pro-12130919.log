│     return replaceInstUsesWith(I, V);                                                                                                                                                    │
│                                                                                                                                                                                          │
│   if (Value *V = foldVectorBinop(I))                                                                                                                                                     │
│     return replaceInstUsesWith(I, V);                                                                                                                                                    │
│                                                                                                                                                                                          │
│   if (Value *V = foldBinOpIntoSelect(I, Builder))                                                                                                                                        │
│     return replaceInstUsesWith(I, V);                                                                                                                                                    │
│                                                                                                                                                                                          │
│   if (Value *V = foldBinOpIntoPhi(I, Builder))                                                                                                                                           │
│     return replaceInstUsesWith(I, V);                                                                                                                                                    │
│                                                                                                                                                                                          │
│   if (Value *V = foldBinopWithCommonOperands(I))                                                                                                                                         │
│     return replaceInstUsesWith(I, V);                                                                                                                                                    │
│                                                                                                                                                                                          │
│   if (Value *V = foldBinopWithConstAndSelect(I, Builder))                                                                                                                                │
│     return replaceInstUsesWith(I, V);                                                                                                                                                    │
│                                                                                                                                                                                          │
│   if (Value *V = foldExtOp(I, Builder))                                                                                                                                                  │
│     return replaceInstUsesWith(I, V);                                                                                                                                                    │
│                                                                                                                                                                                          │
│   if (Value *V = foldUsingDistributiveLaws(I))                                                                                                                                           │
│     return replaceInstUsesWith(I, V);                                                                                                                                                    │
│                                                                                                                                                                                          │
│   // (X / C1) / C2 -> X / (C1*C2)                                                                                                                                                        │
│   if (auto *BO = dyn_cast<BinaryOperator>(Op0))                                                                                                                                          │
│     if (BO->getOpcode() == I.getOpcode())                                                                                                                                                │
