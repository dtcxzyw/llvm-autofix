│ /// Return true if we can simplify the division or remainder of V by C.                                                                                                                  │
│ /// This is a helper for isDivRemCheap.                                                                                                                                                  │
│ static bool isDivRemCheapForConstant(Value *V, ConstantInt *C) {                                                                                                                         │
│   // Return true if the divisor is a power of 2.                                                                                                                                         │
│   if (C->getValue().isPowerOf2())                                                                                                                                                        │
│     return true;                                                                                                                                                                         │
│                                                                                                                                                                                          │
│   // Return true if the divisor is one.                                                                                                                                                  │
│   if (C->isOne())                                                                                                                                                                        │
│     return true;                                                                                                                                                                         │
│                                                                                                                                                                                          │
│   // Check for udiv by a value of the form 2^k-1.                                                                                                                                        │
│   if (C->getValue().isAllOnes())                                                                                                                                                         │
│     return true;                                                                                                                                                                         │
│                                                                                                                                                                                          │
│   // Check for udiv by a value of the form 2^k+1.                                                                                                                                        │
│   APInt T = C->getValue() - 1;                                                                                                                                                           │
│   if (T.isPowerOf2())                                                                                                                                                                    │
│     return true;                                                                                                                                                                         │
│                                                                                                                                                                                          │
│   return false;                                                                                                                                                                          │
│ }                                                                                                                                                                                        │
