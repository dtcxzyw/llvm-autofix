│ /// Return true if we can simplify a division or remainder by V.                                                                                                                         │
│ /// We do not want to create a new division if we can not simplify it.                                                                                                                   │
│ /// This is a helper for visit[SU]Div.                                                                                                                                                   │
│ static bool isDivRemCheap(Value *V) {                                                                                                                                                    │
│   // A constant divisor is cheap if it is a power of 2.                                                                                                                                  │
│   if (auto *C = dyn_cast<ConstantInt>(V))                                                                                                                                                │
│     return isDivRemCheapForConstant(V, C);                                                                                                                                               │
│                                                                                                                                                                                          │
│   // A non-constant divisor is cheap if it is a power of 2.                                                                                                                              │
│   KnownBits Known(V->getType()->getScalarSizeInBits());                                                                                                                                  │
│   computeKnownBits(V, Known);                                                                                                                                                            │
│   return Known.isPowerOfTwo();                                                                                                                                                           │
│ }                                                                                                                                                                                        │
