│   if (!isKnownNonZeroInCttz(Op1, DL, 0, IC.getAssumptionCache(), I))                                                                                                                     │
│     return nullptr;                                                                                                                                                                      │
│                                                                                                                                                                                          │
│   // The value is non-zero.                                                                                                                                                              │
│   // We can simplify the division or remainder.                                                                                                                                          │
│   Value *V = nullptr;                                                                                                                                                                    │
│   SimplifyQuery Q = IC.getSimplifyQuery();                                                                                                                                               │
│   Q.setAssume(SimplifyQuery::WK_KnownNonZero, {Op1});                                                                                                                                    │
│   if (I->getOpcode() == Instruction::UDiv)                                                                                                                                               │
│     V = simplifyUDiv(I->getOperand(0), Op1, Q);                                                                                                                                          │
