│ /// This is a utility for visitUDiv, visitSDiv, visitURem, and visitSRem.                                                                                                                │
│ /// It is used to simplify a division or remainder by a non-zero value.                                                                                                                  │
│ static Value *simplifyValueKnownNonZero(BinaryOperator *I,                                                                                                                               │
│                                         InstCombinerImpl &IC) {                                                                                                                          │
│   Value *Op1 = I->getOperand(1);                                                                                                                                                         │
│   const DataLayout &DL = I->getModule()->getDataLayout();                                                                                                                                │
│                                                                                                                                                                                          │
│   // Return if we can not determine that the value is non-zero.                                                                                                                          │
│   if (!isKnownNonZeroInCttz(Op1, DL, 0, IC.getAssumptionCache(), I))                                                                                                                     │
│     return nullptr;                                                                                                                                                                      │
│                                                                                                                                                                                          │
│   // The value is non-zero.                                                                                                                                                              │
│   // We can simplify the division or remainder.                                                                                                                                          │
│   Value *V = nullptr;                                                                                                                                                                    │
│   SimplifyQuery Q = IC.getSimplifyQuery();                                                                                                                                               │
│   Q.setAssume(SimplifyQuery::WK_KnownNonZero, {Op1});                                                                                                                                    │
│   if (I->getOpcode() == Instruction::UDiv)                                                                                                                                               │
│     V = simplifyUDiv(I->getOperand(0), Op1, Q);                                                                                                                                          │
│   else if (I->getOpcode() == Instruction::SDiv)                                                                                                                                          │
│     V = simplifySDiv(I->getOperand(0), Op1, Q);                                                                                                                                          │
│   else if (I->getOpcode() == Instruction::URem)                                                                                                                                          │
│     V = simplifyURem(I->getOperand(0), Op1, Q);                                                                                                                                          │
│   else if (I->getOpcode() == Instruction::SRem)                                                                                                                                          │
│     V = simplifySRem(I->getOperand(0), Op1, Q);                                                                                                                                          │
│   return V;                                                                                                                                                                              │
│ }                                                                                                                                                                                        │
