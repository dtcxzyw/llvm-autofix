│                                                                                                                                                                                          │
│ cat <<'EOF' > replacement.txt                                                                                                                                                            │
│     if (isa<ICmpInst>(VL0)) {                                                                                                                                                            │
│       for (Value *V : VL) {                                                                                                                                                              │
│         if (isa<PoisonValue>(V))                                                                                                                                                         │
