│ // Original code in addLocAccess                                                                                                                                                         │
│ 122 static void addLocAccess(IRMemLocation &Loc, const MemoryLocation &MemLoc,                                                                                                           │
│ 123                          ModRefInfo MR, AAResults &AA) {                                                                                                                             │
│ 124   const Value *UnderlyingObject = getUnderlyingObject(MemLoc.Ptr);                                                                                                                   │
│ 125   if (isa<AllocaInst>(UnderlyingObject)) {                                                                                                                                           │
│ ...                                                                                                                                                                                      │
│ ```                                                                                                                                                                                      │
│                                                                                                                                                                                          │
│ I will change it to:                                                                                                                                                                     │
│ ```cpp                                                                                                                                                                                   │
│ // Patched code in addLocAccess                                                                                                                                                          │
│ 122 static void addLocAccess(IRMemLocation &Loc, const MemoryLocation &MemLoc,                                                                                                           │
│ 123                          ModRefInfo MR, AAResults &AA) {                                                                                                                             │
│ 124   const Value *UnderlyingObject = getUnderlyingObject(MemLoc.Ptr);                                                                                                                   │
│ 125   if (!UnderlyingObject) {                                                                                                                                                           │
│ 126     // We don't know what this is, assume it's a global.                                                                                                                             │
