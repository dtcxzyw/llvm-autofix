│ sed -i '12611,12617d' llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp && \                                                                                                               │
│ sed -i '12611i\                                                                                                                                                                          │
│       // The BaseVF is the vector factor of the operand, not the reduction.\                                                                                                             │
│       // The operand may be part of a larger vector than the reduction itself.\                                                                                                          │
│       unsigned BaseVF = TE->getVectorFactor();\                                                                                                                                          │
│       if (TE->isHorReduction()) {\                                                                                                                                                       │
│         if (auto *OpTE = BoUp.getTreeEntry(TE->getOperand(I)))\                                                                                                                          │
│           BaseVF = OpTE->getVectorFactor();\                                                                                                                                             │
│       }\                                                                                                                                                                                 │
│ ' llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp                                                                                                                                        │
│ ```                                                                                                                                                                                      │
