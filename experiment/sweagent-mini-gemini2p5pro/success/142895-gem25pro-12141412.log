│ //                                                                                                                                                                                       │
│ //   %i = phi i32 [ 0, %entry ], [ %inc, %if.end ]                                                                                                                                       │
│ //   %a = phi i32 [ 0, %entry ], [ 5, %if.end ]                                                                                                                                          │
│ //   %y = phi i32 [ 0, %entry ], [ %add, %if.end ]                                                                                                                                       │
