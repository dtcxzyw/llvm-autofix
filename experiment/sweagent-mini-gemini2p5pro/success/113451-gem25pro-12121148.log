│ ```bash                                                                                                                                                                                  │
│ sed -i '18397i\                                                                                                                                                                          │
│       // Do not vectorize if the indices are not in the same basic block.\                                                                                                               │
│       bool AllInBB = true;\                                                                                                                                                              │
│       for (Value *V : VectorizableIndices) {\                                                                                                                                            │
│         if (auto *I = dyn_cast<Instruction>(V)) {\                                                                                                                                       │
│           if (I->getParent() != BB) {\                                                                                                                                                   │
│             AllInBB = false;\                                                                                                                                                            │
│             break;\                                                                                                                                                                      │
│           }\                                                                                                                                                                             │
│         }\                                                                                                                                                                               │
│       }\                                                                                                                                                                                 │
│       if (!AllInBB)\                                                                                                                                                                     │
│         continue;\                                                                                                                                                                       │
│ ' llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp                                                                                                                                        │
