             LocalExternallyUsedValues[RdxVal];
             continue;
           }
-          Value *OrigV = TrackedToOrig.at(RdxVal);
+          auto It = TrackedToOrig.find(RdxVal); if (It == TrackedToOrig.end()) continue; Value *OrigV = It->second;
