│ /// %s2 = shufflevector <2 x ty> %1, poison, <1, 0, 1, 0>                                                                                                                                      │
│ /// \endcode                                                                                                                                                                                   │
│ /// and if need to emit shuffle of %s1 and %s2 with mask <1, 0, 5, 4>, it will                                                                                                                 │
│ /// look through %s1 and %s2 and emit                                                                                                                                                          │
│ /// \code                                                                                                                                                                                      │
