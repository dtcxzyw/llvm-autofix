│     if (!verifyBlock(VPBB, RecipeNumbering, WrappedIRBBs))                                                                                                                                │
│       return false;                                                                                                                                                                       │
│   }                                                                                                                                                                                       │
│                                                                                                                                                                                           │
│   return true;                                                                                                                                                                            │
│ }                                                                                                                                                                                         │
