│ cd /llvm-autofix-deps/llvm/llvm && sed -i '258,265s/Data\.VPV2Scalars\[Def\]\.size() == 1/Data.VPV2Scalars[Def].size() >= 1/' ./llvm/lib/Transforms/Vectorize/VPlan.cpp                   │
│ ```                                                                                                                                                                                       │
