│                                                                                                                                                                                                                │
│ But:                                                                                                                                                                                                           │
│ - i16 0 = 0                                                                                                                                                                                                    │
│ - i16 -1 = -1 (in two's complement)                                                                                                                                                                            │
│ - icmp slt i16 0, -1 = false (0) because 0 is greater than -1                                                                                                                                                  │
│                                                                                                                                                                                                                │
