│                                                                                                                                                                                                                │
│ # Apply the fix                                                                                                                                                                                                │
│ sed -i '15397,15407s/if (BWSz == SrcBWSz) {/if (BWSz == SrcBWSz \&\& VecOpcode != Instruction::ZExt \&\& VecOpcode != Instruction::SExt) {/' "$FILE"                                                           │
