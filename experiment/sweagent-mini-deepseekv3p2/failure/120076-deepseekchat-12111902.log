│ cat <<'EOF' > /tmp/apply_fix.sh                                                                                                                                                                                │
│ #!/bin/bash                                                                                                                                                                                                    │
│ # Apply a fix to prevent converting extensions to BitCast when bitwidths are equal                                                                                                                             │
│ # This preserves signedness/zero-extension semantics                                                                                                                                                           │
│                                                                                                                                                                                                                │
│ FILE="./llvm/lib/Transforms/Vectorize/SLPVectorizer.cpp"                                                                                                                                                       │
│ LINE=15397  # Line where "if (BWSz == SrcBWSz) {" appears                                                                                                                                                      │
│                                                                                                                                                                                                                │
