Final Patch
-----------
diff --git a/llvm/include/llvm/CodeGen/BasicTTIImpl.h b/llvm/include/llvm/CodeGen/BasicTTIImpl.h
index 50dc7d5c54c5..1ec564357eeb 100644
--- a/llvm/include/llvm/CodeGen/BasicTTIImpl.h
+++ b/llvm/include/llvm/CodeGen/BasicTTIImpl.h
@@ -1569,7 +1569,7 @@ public:

     case Intrinsic::powi:
       if (auto *RHSC = dyn_cast<ConstantInt>(Args[1])) {
-        bool ShouldOptForSize = I->getParent()->getParent()->hasOptSize();
+        bool ShouldOptForSize = I ? I->getParent()->getParent()->hasOptSize() : false;
         if (getTLI()->isBeneficialToExpandPowI(RHSC->getSExtValue(),
                                                ShouldOptForSize)) {
           // The cost is modeled on the expansion performed by ExpandPowI in
@@ -1624,8 +1624,7 @@ public:
       const Value *EVL = Args[4];
       bool VarMask = !isa<Constant>(Mask) || !isa<Constant>(EVL);
       Type *EltTy = cast<VectorType>(Data->getType())->getElementType();
-      Align Alignment =
-          I->getParamAlign(1).value_or(thisT()->DL.getABITypeAlign(EltTy));
+      Align Alignment = I ? I->getParamAlign(1).value_or(thisT()->DL.getABITypeAlign(EltTy)) : thisT()->DL.getABITypeAlign(EltTy);
       return thisT()->getStridedMemoryOpCost(Instruction::Store,
                                              Data->getType(), Ptr, VarMask,
                                              Alignment, CostKind, I);
@@ -1636,8 +1635,7 @@ public:
       const Value *EVL = Args[3];
       bool VarMask = !isa<Constant>(Mask) || !isa<Constant>(EVL);
       Type *EltTy = cast<VectorType>(RetTy)->getElementType();
-      Align Alignment =
-          I->getParamAlign(0).value_or(thisT()->DL.getABITypeAlign(EltTy));
+      Align Alignment = I ? I->getParamAlign(0).value_or(thisT()->DL.getABITypeAlign(EltTy)) : thisT()->DL.getABITypeAlign(EltTy);
       return thisT()->getStridedMemoryOpCost(Instruction::Load, RetTy, Ptr,
                                              VarMask, Alignment, CostKind, I);
     }

Reference Patch
---------------
commit 50a02e7c68f964c5d8338369746c849ed8d3bef4
Author: Florian Hahn <flo@fhahn.com>
Date:   Mon Sep 2 20:47:36 2024 +0100

    [VPlan] Pass intrinsic inst to TTI in VPWidenCallRecipe::computeCost.

    Follow-up to 9ccf825, adjust computeCost to also pass IntrinsicInst to
    TTI if available, as there are multiple places in TTI which use the
    IntrinsicInst.

    Fixes https://github.com/llvm/llvm-project/issues/107016.

diff --git a/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp b/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
index e782ac444d02..c91ea2d1663c 100644
--- a/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
+++ b/llvm/lib/Transforms/Vectorize/VPlanRecipes.cpp
@@ -965,8 +965,10 @@ InstructionCost VPWidenCallRecipe::computeCost(ElementCount VF,
     ParamTys.push_back(
         ToVectorTy(Ctx.Types.inferScalarType(getOperand(I)), VF));

-  IntrinsicCostAttributes CostAttrs(VectorIntrinsicID, RetTy, Arguments,
-                                    ParamTys, FMF);
+  // TODO: Rework TTI interface to avoid reliance on underlying IntrinsicInst.
+  IntrinsicCostAttributes CostAttrs(
+      VectorIntrinsicID, RetTy, Arguments, ParamTys, FMF,
+      dyn_cast_or_null<IntrinsicInst>(getUnderlyingValue()));
   return Ctx.TTI.getIntrinsicInstrCost(CostAttrs, CostKind);
 }


