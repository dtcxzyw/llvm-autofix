diff --git a/llvm/lib/Transforms/Scalar/IndVarSimplify.cpp b/llvm/lib/Transforms/Scalar/IndVarSimplify.cpp
index 2b2d516a7079..d6aa961e7201 100644
--- a/llvm/lib/Transforms/Scalar/IndVarSimplify.cpp
+++ b/llvm/lib/Transforms/Scalar/IndVarSimplify.cpp
@@ -1469,6 +1469,9 @@ bool IndVarSimplify::canonicalizeExitCondition(Loop *L) {
     if (FullCR.contains(RHSCR)) {
       // We have now matched icmp signed-cond zext(X), zext(Y'), and can thus
       // replace the signed condition with the unsigned version.
+      // Clear samesign flag because unsigned comparisons don't have sign semantics.
+      if (ICmp->hasSameSign())
+        ICmp->setSameSign(false);
       ICmp->setPredicate(ICmp->getUnsignedPredicate());
       Changed = true;
       // Note: No SCEV invalidation needed.  We've changed the predicate, but
@@ -1524,6 +1527,10 @@ bool IndVarSimplify::canonicalizeExitCondition(Loop *L) {
     // when zext is loop varying and RHS is loop invariant.  This converts
     // loop varying work to loop-invariant work.
     auto doRotateTransform = [&]() {
+      // Clear samesign flag because truncation may change sign relationship
+      // between operands (zext changes sign, trunc may revert it).
+      if (ICmp->hasSameSign())
+        ICmp->setSameSign(false);
       assert(ICmp->isUnsigned() && "must have proven unsigned already");
       auto *NewRHS = CastInst::Create(
           Instruction::Trunc, RHS, LHSOp->getType(), "",

Reference Patch
---------------
commit 40a647fc7dc6048c92e2d580b61f5feca0785980
Author: Yingwei Zheng <dtcxzyw2333@gmail.com>
Date:   Fri Nov 15 09:15:37 2024 +0800

    [IndVarSimplify] Drop samesign flags after narrowing compares (#116263)

    Samesign flag cannot be preserved after narrowing the compare since the
    position of the sign bit is changed.

    Closes https://github.com/llvm/llvm-project/issues/116249.

diff --git a/llvm/lib/Transforms/Scalar/IndVarSimplify.cpp b/llvm/lib/Transforms/Scalar/IndVarSimplify.cpp
index 2b2d516a7079..8a3e0bc3eb97 100644
--- a/llvm/lib/Transforms/Scalar/IndVarSimplify.cpp
+++ b/llvm/lib/Transforms/Scalar/IndVarSimplify.cpp
@@ -1530,6 +1530,8 @@ bool IndVarSimplify::canonicalizeExitCondition(Loop *L) {
           L->getLoopPreheader()->getTerminator()->getIterator());
       ICmp->setOperand(Swapped ? 1 : 0, LHSOp);
       ICmp->setOperand(Swapped ? 0 : 1, NewRHS);
+      // Samesign flag cannot be preserved after narrowing the compare.
+      ICmp->setSameSign(false);
       if (LHS->use_empty())
         DeadInsts.push_back(LHS);
     };

