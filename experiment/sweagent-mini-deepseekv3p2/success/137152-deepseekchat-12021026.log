allUsesOfLoadAndStores(GV, Guses);\n+  for (auto *U : Guses) {\n+    if (auto
*SI = dyn_cast<StoreInst>(U))\n+      if (SI->isAtomic()) return false;\n+
if (auto *LI = dyn_cast<LoadInst>(U))\n+      if (LI->isAtomic()) return
false;\n+  }\n+\n   // We can't optimize this if the malloc itself is used in a
complex way,\n   // for example, being stored into multiple globals.  This
allows the\n   // malloc to be stored into the specified global, loaded, gep,
icmp'd.\n"
