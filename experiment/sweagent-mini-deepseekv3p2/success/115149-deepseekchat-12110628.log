│   }                                                                                                                                                                                                            │
│   GEPNoWrapFlags &operator|=(GEPNoWrapFlags Other) {                                                                                                                                                           │
│     Flags |= Other.Flags;                                                                                                                                                                                      │
│     return *this;                                                                                                                                                                                              │
│   }                                                                                                                                                                                                            │
│ };                                                                                                                                                                                                             │
