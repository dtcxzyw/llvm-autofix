│     return Res;                                                                                                                                                                                                │
│   }                                                                                                                                                                                                            │
│                                                                                                                                                                                                                │
│   bool operator==(GEPNoWrapFlags Other) const { return Flags == Other.Flags; }                                                                                                                                 │
│   bool operator!=(GEPNoWrapFlags Other) const { return !(*this == Other); }                                                                                                                                    │
│                                                                                                                                                                                                                │
│   GEPNoWrapFlags operator&(GEPNoWrapFlags Other) const {                                                                                                                                                       │
