Final Patch
-----------
diff --git a/llvm/lib/Transforms/InstCombine/InstructionCombining.cpp b/llvm/lib/Transforms/InstCombine/InstructionCombining.cpp
index cad17c511b6d..ded699b52b97 100644
--- a/llvm/lib/Transforms/InstCombine/InstructionCombining.cpp
+++ b/llvm/lib/Transforms/InstCombine/InstructionCombining.cpp
@@ -759,10 +759,10 @@ static Value *tryFactorization(BinaryOperator &I, const SimplifyQuery &SQ,
       // iff C+1 isn't INT_MIN
       const APInt *CInt;
       if (match(V, m_APInt(CInt)) && !CInt->isMinSignedValue())
-        cast<Instruction>(RetVal)->setHasNoSignedWrap(HasNSW);
+        if (isa<Instruction>(RetVal)) cast<Instruction>(RetVal)->setHasNoSignedWrap(HasNSW);

       // nuw can be propagated with any constant or nuw value.
-      cast<Instruction>(RetVal)->setHasNoUnsignedWrap(HasNUW);
+      if (isa<Instruction>(RetVal)) cast<Instruction>(RetVal)->setHasNoUnsignedWrap(HasNUW);
     }
   }
   return RetVal;

Reference Patch
---------------
commit 212f344b84b400c0a9dedfa3c1ec6af9d9d30223
Author: Nikita Popov <npopov@redhat.com>
Date:   Mon Jan 27 16:24:15 2025 +0100

    [InstCombine] Handle constant expression result in tryFactorization()

    If IRBuilder folds the result to a constant expression, don't try
    to set nowrap flags on it.

    Fixes https://github.com/llvm/llvm-project/issues/124526.

diff --git a/llvm/lib/Transforms/InstCombine/InstructionCombining.cpp b/llvm/lib/Transforms/InstCombine/InstructionCombining.cpp
index cad17c511b6d..a64c188575e6 100644
--- a/llvm/lib/Transforms/InstCombine/InstructionCombining.cpp
+++ b/llvm/lib/Transforms/InstCombine/InstructionCombining.cpp
@@ -732,7 +732,7 @@ static Value *tryFactorization(BinaryOperator &I, const SimplifyQuery &SQ,
   RetVal->takeName(&I);

   // Try to add no-overflow flags to the final value.
-  if (isa<OverflowingBinaryOperator>(RetVal)) {
+  if (isa<BinaryOperator>(RetVal)) {
     bool HasNSW = false;
     bool HasNUW = false;
     if (isa<OverflowingBinaryOperator>(&I)) {

