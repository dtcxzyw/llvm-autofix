│ ### Create a new file:                                                                                                                                                                                  │
│                                                                                                                                                                                                         │
│ ```bash                                                                                                                                                                                                 │
│ cat <<'EOF' > newfile.py                                                                                                                                                                                │
│ import numpy as np                                                                                                                                                                                      │
│ hello = "world"                                                                                                                                                                                         │
│ print(hello)                                                                                                                                                                                            │
