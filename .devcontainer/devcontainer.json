{
  // See:  https://containers.dev/implementors/json_reference/
  // Also: https://code.visualstudio.com/docs/devcontainers/containers
  "name": "llvm-autofix-devcontainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".." // This is the context option as in the docker build command
  },
  // Set the mount point of our project in the container
  "workspaceMount": "source=${localWorkspaceFolder},target=/llvm-autofix,type=bind,consistency=cached",
  // Set the working directory in the container where the container is up
  "workspaceFolder": "/llvm-autofix",
  // Specify mounting points like [{"source": "/path/to/host/dir", "target": "/path/to/container/dir", "type": "bind"}].
  "mounts": [],
  // Features are scripts to further customize the image after the Dockerfile is executed.
  "features": {
    // More features are available at https://containers.dev/features
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": "true",
      // Create a new user called autofix. Note, it's okay to leave 'userUid' and 'userGid' empty, as they will be adjusted automatically to align with our host machine so as to remove permission issues for accessing/reading/writing files. This is a Dev Containers Specification defined behavior when containerUser or remoteUser is specified with the same username. So UID and GID will be automatically updated by VS Coder (NOT common-utils) if we have specified containerUser or remoteUser with the same username. VS Code does so after the Dockerfile is executed and all the features are applied; this will produce a base image. Particularly, VS Code builds a new image (namely <base-image-name>-uid) from the base image to change the UID/GID of the user by perhaps `usermod -u ...`. Note, usermod only affects files located inside of the user's home directory. For other files, one need to manually update them. So to make the UID/GID updating fast, avoid putting a large number of files in the user's home directory.
      "username": "autofix",
      "upgradePackages": "true"
    },
    // We can also write our own features, see: https://containers.dev/implementors/features/
    "./local-features/llvm-autofix-install-deps": {},
    "./local-features/llvm-autofix-enable-deps-access": {
      "username": "autofix" // This should match the username in common-utils
    }
  },
  // Feature installation order can be overridden.
  "overrideFeatureInstallOrder": [
    "./local-features/llvm-autofix-install-deps",
    "ghcr.io/devcontainers/features/common-utils",
    "./local-features/llvm-autofix-enable-deps-access"
  ],
  // Specify the user to use when the container is started directly for example by `docker run`.
  "containerUser": "autofix", // This should match the username in common-utils
  // Specify the user to use when the container is connected to by VS Code and its relating tools (Dev Containers plugin for example).
  "remoteUser": "autofix", // This should match the username in common-utils
  // Configure tool-specific properties.
  "customizations": {
    // Configure properties specific to VS Code.
    "vscode": {
      // Set *default* container specific settings.json values on container create.
      "settings": {},
      // Add the IDs of extensions we want installed when the container is created.
      "extensions": [
        "charliermarsh.ruff"
      ]
    }
  },
  "hostRequirements": {
    // Enable GPU support for CUDA and other GPU-related tasks.
    "gpu": "optional"
  },
  // Arguments to pass to for example the `docker run` command when starting the container.
  "runArgs": [
    // Enabling PTRACE is required for debugging.
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined"
  ]
}
